                                       name="avisoPrevioAccepted" 
                                       required="required" 
                                       class="form-check-input" 
                                       value="1">
                                <label class="form-check-label" for="avisoPrevioAccepted" style="cursor: pointer;">
                                    <span style="color: #333; font-size: 14px;">He leído y acepto este aviso previo obligatorio *</span>
                                </label>
                            </div>
                            <div class="invalid-feedback d-block" id="avisoError" style="display: none; color: #dc3545; font-size: 13px; margin-top: 5px;">
                                Debes aceptar el aviso para continuar
                            </div>
                        </div>
                    </div>

                    <!-- PASO 1: Datos del Cliente -->
                    <div id="paso1Section" class="paso-section d-none">
                        <div class="paso-title">Paso 1: Datos del Cliente</div>
                        <h6 style="font-size: 13px; color: #666; margin-bottom: 20px;">Cuéntanos tus datos personales</h6>
                        <p style="font-size: 12px; color: #999; margin-bottom: 20px; font-style: italic;">Estos datos servirán para generar el informe resumen de tu solicitud.</p>
                        
                        {% for child in formulario_cliente %}
                            {% if child.vars.name not in ['_token'] %}
                                <div class="form-row">
                                    <div class="form-group col">
                                        {{ form_label(child) }}
                                        {{ form_widget(child) }}
                                        {{ form_errors(child) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <!-- PASO 2: Precio Maximo -->
                    <div id="paso2Section" class="paso-section d-none">
                        <div class="paso-title">Paso 2: Cálculo de Precio Máximo</div>
                        <h6 style="font-size: 13px; color: #666; margin-bottom: 20px;">Información sobre la vivienda y financiación</h6>
                        
                        <!-- Sección de entrada de datos -->
                        <div style="">
                            <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; text-transform: uppercase;">Datos para calcular precio máximo</h6>
                            
                            <!-- Campos de Titular 1 (siempre visibles) -->
                            {% set campos_titular_dos = ['edadTitularDos', 'ingresosMensualesDos', 'numPagasExtraDos', 'importePagaExtraDos', 'prestamosMensualesDos'] %}
                            {% for child in formulario_precio %}
                                {% if child.vars.name not in ['_token', 'precioViviendaObjetivo', 'viviendaDentroPresupuesto'] and child.vars.name not in campos_titular_dos %}
                                    <div class="form-row">
                                        <div class="form-group col">
                                            {{ form_label(child) }}
                                            {{ form_widget(child) }}
                                            {{ form_errors(child) }}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                            
                            <!-- Campos de Titular 2 (visibles solo si numTitulares === 2) -->
                            <div id="titularDosSection" style="display: none; border-top: 2px solid #ddd; padding-top: 20px; margin-top: 20px;">
                                <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; text-transform: uppercase;">Datos del Segundo Titular</h6>
                                {% for child in formulario_precio %}
                                    {% if child.vars.name in campos_titular_dos %}
                                        <div class="form-row">
                                            <div class="form-group col">
                                                {{ form_label(child) }}
                                                {{ form_widget(child) }}
                                                {{ form_errors(child) }}
                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        
                        <!-- Botón de cálculo -->
