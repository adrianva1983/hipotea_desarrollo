                            <tr style="border-bottom: 1px solid #e8e8e8;"><td style="padding: 7px 0; color: #666;">Notaría:</td><td style="font-weight: 600; text-align: right; padding: 7px 0;">${notarioStr}</td></tr>
                            <tr style="border-bottom: 1px solid #e8e8e8;"><td style="padding: 7px 0; color: #666;">Registro:</td><td style="font-weight: 600; text-align: right; padding: 7px 0;">${registroStr}</td></tr>
                            <tr style="border-bottom: 1px solid #e8e8e8;"><td style="padding: 7px 0; color: #666;">Gestoría:</td><td style="font-weight: 600; text-align: right; padding: 7px 0;">${gestoriaStr}</td></tr>
                            <tr style="border-bottom: 1px solid #e8e8e8;"><td style="padding: 7px 0; color: #666;">Tasación:</td><td style="font-weight: 600; text-align: right; padding: 7px 0;">${tasacionStr}</td></tr>
