        function enviarAHipoteaConInforme() {
            confirmarAccion('¿Desea enviar esta solicitud a Hipotea para iniciar el estudio completo?', function() {

            // Renderizar el informe silenciosamente (sin abrir modal)
            descargarPDF(true);
            const informeHtml = document.getElementById('pdfPreviewContent')?.innerHTML || '';

            // Recoger datos del cliente del DOM (Paso 1)
            const nombre   = document.querySelector('#paso1Section input[name*="nombre"]')?.value || '';
            const dni      = document.querySelector('#paso1Section input[name*="dni"]')?.value    || '';
            const telefono = document.querySelector('#paso1Section input[name*="telefono"]')?.value || '';
            const email    = document.querySelector('#paso1Section input[name*="email"]')?.value    || '';

            // Recoger datos económicos y laborales del simulador
            const ingresos_mensuales  = parseFloat($('input[name*="ingresos_mensuales"]:not([name*="Dos"])').val()) || 0;
            const numero_pagas        = parseInt($('input[name*="numero_pagas"]').val()) || 0;
            const importe_pagas       = parseFloat($('input[name*="importe_pagas"]').val()) || 0;
            const aportacion          = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            const situacion_laboral   = document.querySelector('select[name*="situacionLaboral"]')?.value || '';
            const antiguedad_laboral  = document.querySelector('select[name*="antiguedadLaboral"]')?.value || '';
            const tiene_impagados     = document.querySelector('input[name*="tienePrestamosImpagados"]')?.checked || false;
            const prestamos_mensuales = parseFloat($('input[name*="prestamos_mensuales"]').val()) || 0;
            const precio_inmueble     = valorInmueblePaso3 || precioMaximoCalculado || 0;

            fetch('{{ path("simulador_enviar_hipotea") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'include',
                body: JSON.stringify({
                    cliente: { nombre, dni, telefono, email },
                    simulador: {
                        ingresos_mensuales,
                        numero_pagas,
                        importe_pagas,
                        aportacion,
                        prestamos_mensuales,
                        situacion_laboral,
                        antiguedad_laboral,
                        tiene_impagados,
                        precio_inmueble
                    },
                    informe_html: informeHtml
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    mostrarModal(data.mensaje, 'Solicitud enviada');
                } else {
                    mostrarModal(data.mensaje || 'No se pudo crear el expediente', 'Error');
                }
            })
            .catch(err => {
                mostrarModal('Error de conexión: ' + err.message, 'Error');
            });

            }); // fin confirmarAccion
        }

        function enviarAHipotea() {
            enviarAHipoteaConInforme();
        }

