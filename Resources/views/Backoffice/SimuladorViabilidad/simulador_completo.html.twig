            }
            
            pasoActual = paso;
        }
        function mostrarSemaforoViabilidad() 
        {
            // Obtener datos del Paso 4 (valores exactos del formulario SimuladorRiesgoType)
            const tienePrestamosPagados = document.querySelector('input[name*="tienePrestamosImpagados"]')?.checked || false;
            const situacionLaboral = document.querySelector('select[name*="situacionLaboral"]')?.value || '';
            const antiguedadLaboral = document.querySelector('select[name*="antiguedadLaboral"]')?.value || '';
            
            // Obtener datos de Paso 3 (cuota, gastos, aportación y precio)
            // valorInmueblePaso3 = precio del inmueble evaluado; precioMaximoCalculado = precio máximo recomendado desde ingresos
            const precioMaxRec = precioMaximoCalculado || 0;
            const precioVivienda = valorInmueblePaso3 || precioMaximoCalculado || 0;
            const gastosTotalesEl = document.getElementById('resultGastosTotales2');
            const gastosTotales = gastosTotalesEl ? parseFloat(gastosTotalesEl.textContent.replace(/[^\d,]/g, '').replace(',', '.')) || 0 : 0;
            const aportacion = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            const cuotaMensualEl = document.getElementById('resultCuotaMensual2');
            const cuotaMensual = cuotaMensualEl ? parseFloat(cuotaMensualEl.textContent.replace(/[^\d,]/g, '').replace(',', '.')) || 0 : 0;
            
            // Calcular porcentaje de financiación: (precio + gastos - aportacion) / precio * 100
