            });
            
            const activePasoElement = document.getElementById(pasos[paso] + 'Section');
            if (activePasoElement) {
                activePasoElement.classList.remove('d-none');
            }
            
            document.getElementById('btnAnterior').style.display = paso === 0 ? 'none' : 'block';
            
            // PASO 3 (index 3): Cuota y Gastos - Rellenar datos de Paso 2 automáticamente
            if (paso === 3) {
                actualizarResumenPaso2();
                pre_rellenarDatosPaso3();
