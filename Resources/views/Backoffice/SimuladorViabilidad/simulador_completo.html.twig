                            <i class="fa fa-calculator mr-2"></i> Calcular Precio Máximo
                        </button>
                        
                        <!-- Resultado del cálculo -->
                        <div id="resultadoPrecioMaximo" style="background: #e8f4f8; border: 2px solid #0088cc; border-radius: 8px; padding: 15px; margin-bottom: 20px; display: none;">
                            <div style="font-size: 12px; color: #666; text-transform: uppercase; margin-bottom: 8px;">Precio máximo recomendado</div>
                            <div style="font-size: 28px; font-weight: 700; color: #0088cc;" id="precioMaximoValor">0 €</div>
                            <p style="font-size: 12px; color: #666; margin-top: 10px; margin-bottom: 0;">
                                Este es el precio máximo de vivienda que puedes adquirir según los datos introducidos.
                            </p>
                        </div>
                        
                        <!-- Pregunta de coherencia -->
                        <div id="seccionCoherencia" style="display: none; background: #fff9e6; border: 1px solid #ffc107; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                            <h6 style="font-size: 13px; font-weight: 600; color: #333; margin-bottom: 15px;">Validación de coherencia</h6>
                            
                            <label style="font-size: 13px; color: #333; margin-bottom: 15px; display: block;">
                                ¿La vivienda que desea comprar está dentro del precio máximo calculado? *
                            </label>
                            
                            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                                <button type="button" class="btn btn-success btn-sm" onclick="validarCoherenciaSi()" id="btnCoherenciaSi">
                                    <i class="fa fa-check mr-2"></i> Sí
                                </button>
                                <button type="button" class="btn btn-danger btn-sm" onclick="validarCoherenciaNo()" id="btnCoherenciaNo">
                                    <i class="fa fa-times mr-2"></i> No
                                </button>
                            </div>
                            
                            <div id="mensajeCoherencia" style="display: none; padding: 12px; border-radius: 6px; font-size: 13px; margin-bottom: 15px;"></div>
                        </div>
                    </div>

                    <!-- PASO 3: Cuota y Gastos -->
                    <div id="paso3Section" class="paso-section d-none">
                        <div class="paso-title">Paso 3: Cálculo de Cuota y Gastos</div>
                        <h6 style="font-size: 13px; color: #666; margin-bottom: 20px;">Calcula la cuota hipotecaria estimada y los gastos de la operación</h6>
                        
                        <!-- PANEL 1: RESUMEN DATOS PASO 2 (readonly) -->
                        <div style="background: #f8f9fa; border-left: 4px solid #0088cc; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
                            <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 12px; text-transform: uppercase;">📊 Resumen: Paso 2 Precio Máximo</h6>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <div style="font-size: 11px; color: #666; text-transform: uppercase; margin-bottom: 5px;">Precio Máximo Recomendado</div>
                                    <div style="font-size: 18px; font-weight: 700; color: #0088cc;" id="resumenPrecioMaximo">0 €</div>
                                </div>
                                <div>
                                    <div style="font-size: 11px; color: #666; text-transform: uppercase; margin-bottom: 5px;">Aportación Inicial</div>
                                    <div style="font-size: 18px; font-weight: 700; color: #333;" id="resumenAportacion">0 €</div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- PANEL 2: CARACTERÍSTICAS DE LA VIVIENDA -->
                        <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; text-transform: uppercase; border-bottom: 2px solid #ddd; padding-bottom: 10px;">🏠 Características de la Vivienda</h6>
                        
                        {% set campos_cuota_vivienda = ['valorInmueble', 'comunidadAutonoma', 'destinoCompra', 'obraNueva'] %}
                        {% for child in formulario_cuota %}
                            {% if child.vars.name in campos_cuota_vivienda %}
                                <div class="form-row">
                                    <div class="form-group col">
                                        {{ form_label(child) }}
                                        {{ form_widget(child) }}
                                        {{ form_errors(child) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                        
                        <!-- PANEL 3: CONDICIONES DEL PRÉSTAMO -->
                        <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; margin-top: 25px; text-transform: uppercase; border-bottom: 2px solid #ddd; padding-bottom: 10px;">💰 Condiciones del Préstamo</h6>
                        
                        {% set campos_cuota_prestamo = ['plazoAmortizacion', 'tipoInteres'] %}
                        {% for child in formulario_cuota %}
                            {% if child.vars.name in campos_cuota_prestamo %}
                                <div class="form-row">
                                    <div class="form-group col">
                                        {{ form_label(child) }}
                                        {{ form_widget(child) }}
                                        {{ form_errors(child) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                        
                        <!-- PANEL 4: SITUACIÓN ESPECIAL -->
                        <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; margin-top: 25px; text-transform: uppercase; border-bottom: 2px solid #ddd; padding-bottom: 10px;">👨‍👩‍👧 Situación Especial / Ayudas</h6>
                        
                        {% set campos_cuota_especial = ['familiaNumerosa', 'monoparental', 'minusvaliaFamiliaNumerosa', 'vpo'] %}
                        {% for child in formulario_cuota %}
                            {% if child.vars.name in campos_cuota_especial %}
                                <div class="form-check" style="margin-bottom: 12px;">
                                    {{ form_widget(child, { 'attr': {'class': 'form-check-input'} }) }}
                                    {{ form_label(child, null, { 'label_attr': {'class': 'form-check-label', 'style': 'cursor: pointer; margin-bottom: 0;'} }) }}
                                </div>
                            {% endif %}
                        {% endfor %}
                        
                        <!-- PANEL 5: GASTOS ADICIONALES -->
                        <h6 style="font-size: 12px; font-weight: 600; color: #333; margin-bottom: 15px; margin-top: 25px; text-transform: uppercase; border-bottom: 2px solid #ddd; padding-bottom: 10px;">📋 Gastos Adicionales</h6>
                        
                        {% for child in formulario_cuota %}
                            {% if child.vars.name == 'honorariosInmobiliaria' %}
                                <div class="form-row">
                                    <div class="form-group col">
                                        {{ form_label(child) }}
                                        {{ form_widget(child) }}
                                        {{ form_errors(child) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                        
                        <!-- BOTÓN DE CÁLCULO -->
                        <button type="button" class="btn btn-warning btn-sm w-100 mb-3" id="btnCalcularCuotaGastos" onclick="calcularCuotaYGastos()" style="/* background: linear-gradient(135deg, #ff7722, #ff9944); */border: none;color: white;font-weight: 600;margin-top: 25px;display: block;padding: 18px;font-size: 20px;/* width: 200px; */border-radius: 40px;box-shadow: rgb(188, 188, 188) 2px 1px 7px 2px;">
                            <i class="fa fa-calculator mr-2"></i> Calcular Cuota y Gastos
                        </button>
                        
                        <!-- PANEL 6: RESULTADO DEL CÁLCULO - NUEVO FORMATO -->
                        <div id="resultadoCuotaGastos" style="display: none; background: white; border-radius: 8px; padding: 20px; margin-top: 20px;">
                            <style>
                                .result { margin-top: 20px; }
                                .result h2 { font-size: 1.1em; margin-bottom: 40px; }
                                .result h1 { font-size: 2.5em; margin: 20px 0; color: #ff7722; }
                                .costs { margin-top: 40px; }
                                .costs h2 { font-size: 1.3em; color: #ff7722; margin-bottom: 20px; }
                                .costs .row { display: flex; justify-content: flex-start; margin: 10px 0; border-bottom: 1px dashed #ccc; padding-bottom: 10px; }
                                .costs .column { display: flex; align-items: center; width: 50%; }
                                .costs .icon { margin-right: 10px; }
                                .costs .label { font-weight: bold; font-size: 14px; color: #666; }
                                .costs .value { margin-left: auto; font-weight: 600; font-size: 14px; }
                                .costs .column-right { display: flex; align-items: center; width: 50%; flex-direction: row-reverse; }
                                .icono-imagen { height: 30px; width: 30px; object-fit: cover; margin-right: 8px; }
                                .total { color: #333; font-weight: 800; }
                                .costs2 { padding: 15px; margin-top: 20px; }
                                .cost3 { margin-top: 20px; }
                                .fondo_casa {background-image: url(/assets/images/fondo-casa.png);background-repeat: no-repeat;background-size: 250px;background-position-x: center;height: 225px;line-height: 250px;font-size: 25px;margin-bottom: 0px !important;}
                            </style>

                            <div class="result">
                                <div class="mb-4">
                                    <p id="resultTextoPrecio" style="color:grey;font-size:13px;">Con la información que nos has proporcionado, hemos aplicado un algoritmo que estima tu capacidad de pago considerando los gastos y tu aportación inicial. El precio máximo de vivienda que te recomendamos buscar sería:</p>
                                </div>
                                <h1 class="text-center mb-4 fondo_casa"><span id="resultPrecioMaximo" style="font-size: 25px;color: black;font-weight: 500;">0 €</span></h1>
                            </div>

                            <div class="costs">
                                <h2>Gastos asociados a la compraventa</h2>
                                <p style="color:grey;font-size:13px;">Los datos estimados que hemos considerado para el cálculo son los siguientes:</p>
                                
                                <div class="row">
                                    <div class="column">
                                        <span class="label">Impuestos (ITP/IVA/AJD):</span>
                                        <span class="value" id="resultImpuestos">0 €</span>
                                    </div>
                                    <div class="column">
                                        <span class="label">Notaría:</span>
                                        <span class="value" id="resultNotario">0 €</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Registro:</span>
                                        <span class="value" id="resultRegistro">0 €</span>
                                    </div>
                                    <div class="column">
                                        <span class="label">Gestoría:</span>
                                        <span class="value" id="resultGestoria">0 €</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Tasación:</span>
                                        <span class="value" id="resultTasacion">0 €</span>
                                    </div>
                                    <div class="column">
                                        <span class="label">Otros:</span>
                                        <span class="value" id="resultOtros">0 €</span>
                                    </div>
                                </div>
                            </div>

                            <div class="costs costs2">
                                <h2>Importe total de tu Hipoteca</h2>
                            </div>

                            <div class="costs cost3">
                                <div class="row">
                                    <div class="column">
                                        <span class="label">Precio vivienda:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value" id="resultPrecioVivienda2">0 €</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Gastos totales:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value">+ <span id="resultGastosTotales2">0 €</span></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Aportación:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value">- <span id="resultAportacion2">0 €</span></span>
                                    </div>
                                </div>

                                <div class="row" style="border-bottom: 2px solid #ff7722; padding-bottom: 15px; margin-bottom: 15px;">
                                    <div class="column">
                                        <span class="label total">Importe hipoteca:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value total" id="resultImportePrestamo2">0 €</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Plazo:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value" id="resultPlazo">0 años</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Cuota mensual:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value" id="resultCuotaMensual2">0 €</span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="column">
                                        <span class="label">Tipo de interés:</span>
                                    </div>
                                    <div class="column" style="justify-content: flex-end;">
                                        <span class="value" id="resultTipoInteres2">0%</span>
                                    </div>
                                </div>
                            </div>

                            <p style="color:grey;font-size:12px; margin-top:20px;">Este cálculo es orientativo y se basa en valores estandarizados; no garantiza la viabilidad económica del préstamo ni las condiciones definitivas.</p>
                        </div>
                    </div>

                    <!-- PASO 4: Riesgo -->
                    <div id="paso4Section" class="paso-section d-none">
                        <div class="paso-title">Paso 4: Análisis de Riesgo</div>
                        <h6 style="font-size: 13px; color: #666; margin-bottom: 15px;">Evaluación de tu perfil</h6>
                        {% for child in formulario_riesgo %}
                            {% if child.vars.name != '_token' %}
                                <div class="form-row">
                                    <div class="form-group col">
                                        {{ form_label(child) }}
                                        {{ form_widget(child) }}
                                        {{ form_errors(child) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <!-- Botones de navegación -->
                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn btn-success1 mr-auto waves-effect btn-volver flex-grow-12" id="btnAnterior" onclick="anterior()" style="display:none;">
                            ← Anterior
                        </button>
                        
                        <button type="button" class="btn btn-warning waves-effect" id="btnResultado" onclick="mostrarSemaforoViabilidad()" style="display:none;">
                            <i class="fa fa-check-circle mr-2"></i> Resultado
                        </button>
                        
                        <button type="button" class="btn btn-success waves-effect flex-grow-12" id="btnSiguiente" onclick="siguiente()">
                            Siguiente →
                        </button>
                    </div>

                    <!-- Botones finales -->
                    <div class="mt-3 d-none" id="botonesFinales">
                        <!--<button type="button" class="btn btn-success btn-sm w-100 mb-2" onclick="enviarAHipotea()">
                            <i class="fa fa-paper-plane"></i> Enviar a Hipotea
                        </button>
                        <button type="button" class="btn btn-info btn-sm w-100 mb-2" onclick="descargarPDF()">
                            <i class="fa fa-file-pdf"></i> Descargar PDF
                        </button>-->
                        <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="reiniciar()" id="btnReiniciar">
                            <i class="fa fa-redo"></i> Reiniciar
                        </button>
                    </div>
                </form>
            </div>

            <!-- PANEL DERECHO: RESULTADO -->
            <div class="resultado-panel" id="resultadoPanelDesk">
                <div id="resultadoContent">
                    <div class="text-center p-5">
                        <p style="color: #999; font-size: 14px;">Completa el formulario para ver el resultado</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para descarga de PDF (mantener para mobile) -->
    <div class="modal fade" id="modalPDFPreview" tabindex="-1" role="dialog" aria-labelledby="modalPDFLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title" id="modalPDFLabel">Preview - Resultado de Viabilidad</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body" id="pdfPreviewContent" style="max-height: 70vh; overflow-y: auto; background: #f5f5f5;">
                    <div class="text-center p-5">
                        <div class="spinner-border text-info" role="status">
                            <span class="sr-only">Cargando preview...</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="flex-wrap: wrap; gap: 8px;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        <i class="fas fa-times mr-2"></i>Cerrar
                    </button>
                    <button type="button" class="btn btn-info" onclick="generarYDescargarPDF()">
                        <i class="fas fa-print mr-2"></i>Imprimir / Guardar PDF
                    </button>
                    <button type="button" class="btn btn-success" onclick="enviarAHipoteaConInforme()">
                        <i class="fas fa-paper-plane mr-2"></i>Enviar a Hipotea para estudio completo
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ── Modal de avisos del simulador ── #}
    <div class="modal fade" id="modal-simulador-aviso" tabindex="-1" role="dialog" aria-labelledby="modal-simulador-aviso-titulo" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modal-simulador-aviso-titulo">Atención</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <p id="modal-simulador-aviso-msg"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success waves-effect" data-dismiss="modal">Continuar</button>
                </div>
            </div>
        </div>
    </div>

    {# ── Modal de confirmación del simulador ── #}
    <div class="modal fade" id="modal-simulador-confirm" tabindex="-1" role="dialog" aria-labelledby="modal-simulador-confirm-titulo" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modal-simulador-confirm-titulo">Confirmar</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <p id="modal-simulador-confirm-msg"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success waves-effect" id="modal-simulador-confirm-ok">Confirmar</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
