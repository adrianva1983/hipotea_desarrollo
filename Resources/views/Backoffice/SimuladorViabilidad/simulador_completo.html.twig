        function pre_rellenarDatosPaso3() {
            // Copiar valores de Paso 2 a Paso 3 para los campos comunes (versión simplificada)
            try {
                console.log('=== INICIANDO PRE-RELLENADO PASO 3 ===');
                
                const paso2 = document.getElementById('paso2Section');
                const paso3 = document.getElementById('paso3Section');
                
                if (!paso2 || !paso3) {
                    console.error('No se encontraron los pasos 2 o 3');
                    return;
                }
                
                // Comunidad Autónoma
                const selectComunidadPaso2 = paso2.querySelector('select[name*="comunidadAutonoma"]');
                const selectComunidadPaso3 = paso3.querySelector('select[name*="comunidadAutonoma"]');
                if (selectComunidadPaso2 && selectComunidadPaso3) {
                    const valor = selectComunidadPaso2.value;
                    selectComunidadPaso3.value = valor;
                    $(selectComunidadPaso3).trigger('change');
                    console.log('✓ Comunidad copiada: ' + valor);
                }
                
                // Destino Compra
                const selectDestinoPaso2 = paso2.querySelector('select[name*="destinoCompra"]');
                const selectDestinoPaso3 = paso3.querySelector('select[name*="destinoCompra"]');
                if (selectDestinoPaso2 && selectDestinoPaso3) {
                    selectDestinoPaso3.value = selectDestinoPaso2.value;
                    $(selectDestinoPaso3).trigger('change');
                    console.log('✓ Destino copiado: ' + selectDestinoPaso2.value);
                }
                
                // Plazo Amortización
                const selectPlazoPaso2 = paso2.querySelector('select[name*="plazoAmortizacion"], input[name*="plazoAmortizacion"]');
                const selectPlazoPaso3 = paso3.querySelector('select[name*="plazoAmortizacion"], input[name*="plazoAmortizacion"]');
                if (selectPlazoPaso2 && selectPlazoPaso3) {
                    selectPlazoPaso3.value = selectPlazoPaso2.value;
                    $(selectPlazoPaso3).trigger('change');
                    console.log('✓ Plazo amortización copiado: ' + selectPlazoPaso2.value);
                }
                
                console.log('=== PRE-RELLENADO COMPLETADO ===');
            } catch (e) {
                console.error('Error al pre-rellenar datos:', e);
            }
        }

