        function generarYDescargarPDF() {
            const contenido = document.getElementById('pdfPreviewContent')?.innerHTML;
            if (!contenido) return;

            const ventana = window.open('', '_blank');
            ventana.document.write(`<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Estudio Previo de Viabilidad Hipotecaria</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; color: #333; background: white; }
        @page { margin: 12mm; size: A4 portrait; }
        @media print {
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>${contenido}</body>
</html>`);
            ventana.document.close();
            ventana.focus();
            setTimeout(() => {
                ventana.print();
                ventana.close();
            }, 400);
        }

        function reiniciar() {
            confirmarAccion('¿Desea reiniciar el simulador?', function() {
                // Limpiar formulario
                document.getElementById('simuladorForm').reset();
                
                // Volver al paso 0
                pasoActual = 0;
                mostrarPaso(0);
                
                // Limpiar resultado
                document.getElementById('resultadoContent').innerHTML = `
                    <div class="text-center p-5">
                        <p style="color: #999; font-size: 14px;">Completa el formulario para ver el resultado</p>
                    </div>
                `;
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            if (pasoActual === 'resultado') {
                pasoActual = pasos.length - 1;
            } else {
                pasoActual = parseInt(pasoActual) || 0;
            }
            mostrarPaso(pasoActual);
            
            // ===== MOSTRAR/OCULTAR CAMPOS DEL SEGUNDO TITULAR =====
            function toggleTitularDos() {
                const numTitularesField = $('select[name*="numTitulares"], input[name*="numTitulares"]').first();
                const titularDosSection = document.getElementById('titularDosSection');
                
                if (titularDosSection) {
                    const numTitulares = parseInt(numTitularesField.val()) || 1;
                    if (numTitulares === 2) {
                        titularDosSection.style.display = 'block';
                    } else {
                        titularDosSection.style.display = 'none';
                        // Limpiar campos del segundo titular cuando se ocultan
                        $('input[name*="edadTitularDos"], input[name*="ingresosMensualesDos"], input[name*="numPagasExtraDos"], input[name*="importePagaExtraDos"], input[name*="prestamosMensualesDos"]').val('');
                    }
                }
            }
            
            // Ejecutar al cargar la página
            toggleTitularDos();
            
            // Agregar listener para cambios en numTitulares
            $('select[name*="numTitulares"], input[name*="numTitulares"]').on('change', function() {
                toggleTitularDos();
            });
        });

        // ─── Helpers de modales ─────────────────────────────────────────────────
        function mostrarModal(mensaje, titulo) {
            document.getElementById('modal-simulador-aviso-titulo').textContent = titulo || 'Atención';
            document.getElementById('modal-simulador-aviso-msg').textContent = mensaje;
            $('#modal-simulador-aviso').modal('show');
        }

        function confirmarAccion(mensaje, callbackSi, titulo) {
            document.getElementById('modal-simulador-confirm-titulo').textContent = titulo || 'Confirmar';
            document.getElementById('modal-simulador-confirm-msg').textContent = mensaje;
            var btnOk = document.getElementById('modal-simulador-confirm-ok');
            var btnNuevo = btnOk.cloneNode(true);
            btnOk.parentNode.replaceChild(btnNuevo, btnOk);
            btnNuevo.addEventListener('click', function() {
                $('#modal-simulador-confirm').modal('hide');
                callbackSi();
            });
            $('#modal-simulador-confirm').modal('show');
        }
    </script>
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="simulador-container">
