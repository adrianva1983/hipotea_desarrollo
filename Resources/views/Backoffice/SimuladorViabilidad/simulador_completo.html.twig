    <script>    
        let pasoActual = {{ paso_actual ?? 0 }};
        const totalPasos = 5;
        const pasos = ['paso0', 'paso1', 'paso2', 'paso3', 'paso4'];
        const titulosStep = [
            'Paso 0: Aviso Legal',
            'Paso 1: Datos del Cliente',
            'Paso 2: Precio Maximo',
            'Paso 3: Cuota y Gastos',
            'Paso 4: Analisis de Riesgo',
            'Resultado: Evaluacion de Viabilidad'
        ];

        function siguiente() {
            // Validación especial para Paso 0: Aviso Previo
            if (pasoActual === 0) {
                const avisoCheckbox = document.getElementById('avisoPrevioAccepted');
                if (!avisoCheckbox.checked) {
                    document.getElementById('avisoError').style.display = 'block';
                    avisoCheckbox.classList.add('is-invalid');
                    return;
                } else {
                    document.getElementById('avisoError').style.display = 'none';
                    avisoCheckbox.classList.remove('is-invalid');
                }
            }
            
            // Validación especial para Paso 2: Coherencia de precio
            if (pasoActual === 2) {
                // Validar que Paso 2 se haya completado
                if (!precioMaximoCalculado) {
                    mostrarModal('Por favor, calcula el precio máximo antes de continuar');
                    return;
                }
                if (!coherenciaValidada || document.getElementById('btnCoherenciaSi').classList.contains('active') === false) {
                    mostrarModal('Por favor, responde a la pregunta de coherencia');
                    return;
                }
            }
            
            // Validación especial para Paso 3: Cálculo de cuota y gastos
            if (pasoActual === 3) {
                if (!cuotaYGastosCalculado) {
                    mostrarModal('Por favor, calcula la cuota y gastos antes de continuar. Haz clic en "Calcular Cuota y Gastos"');
                    return;
                }
            }
            
            const sectionId = pasos[pasoActual] + 'Section';
            const section = document.getElementById(sectionId);
            
            const inputs = section.querySelectorAll('input, textarea, select');
            let valido = true;
            
            inputs.forEach(input => {
                if (input.hasAttribute('required') && input.id !== 'avisoPrevioAccepted') {
                    if (!input.value) {
                        input.classList.add('is-invalid');
                        valido = false;
                    } else {
                        input.classList.remove('is-invalid');
                    }
                }
            });
            
            if (!valido) {
                mostrarModal('Por favor, complete todos los campos requeridos');
                return;
            }
            
            // Avanzar al siguiente paso sin recargar
            if (pasoActual < pasos.length - 1) {
                mostrarPaso(pasoActual + 1);
            }
        }

        function anterior() {
            if (pasoActual > 0) {
                pasoActual--;
                mostrarPaso(pasoActual);
            }
        }

        // ===== FUNCIONES PARA PASO 2: PRECIO MÁXIMO =====
        let precioMaximoCalculado = null;  // Precio máximo recomendado desde ingresos (Paso 2)
        let valorInmueblePaso3 = 0;         // Precio del inmueble usado en el cálculo de Paso 3
        let coherenciaValidada = false;
        let cuotaYGastosCalculado = false;
        let semaforoResultadoData = null;  // Datos del semáforo para el informe

        function calcularPrecioMaximo() {
            // Recopilar datos del formulario simplificado (PASO 2 - VERSIÓN MINI)
            const seccion = document.getElementById('paso2Section');
            if (!seccion) {
                mostrarModal('No se encontró la sección de Paso 2');
                return;
            }
            
            // Obtener valores de los 6 campos OBLIGATORIOS del formulario Paso 2
            const edad = parseInt($('input[name*="edad"]:not([name*="Dos"])').val()) || 0;
            const aportacion = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            const ingresos_mensuales = parseFloat($('input[name*="ingresos_mensuales"]:not([name*="Dos"])').val()) || 0;
            const numero_pagas = parseInt($('input[name*="numero_pagas"]').val()) || 0;
            const importe_pagas = parseFloat($('input[name*="importe_pagas"]').val()) || 0;
            const prestamos_mensuales = parseFloat($('input[name*="prestamos_mensuales"]').val()) || 0;
            
            // Validación básica
            if (edad <= 0) {
                mostrarModal('La edad es obligatoria y debe ser mayor que 0');
                return;
            }
            if (ingresos_mensuales <= 0) {
                mostrarModal('Los ingresos mensuales deben ser mayores que cero');
                return;
            }
            
            // Construir objeto de datos MINIMALISTA para la API
            const datosAPI = {
                tipo_calculo: 'compra',
                edad: edad,
                aportacion: aportacion,
                ingresos_mensuales: ingresos_mensuales,
                numero_pagas: numero_pagas,
                importe_pagas: importe_pagas,
                prestamos_mensuales: prestamos_mensuales
            };
            
            const payload = {
                datos: datosAPI
            };
            
            // DEBUG: Log de datos enviados
            console.log('=== SIMULADOR PRECIO MÁXIMO (VERSIÓN SIMPLIFICADA) ===');
            console.log('Entrada:');
            console.log('  Edad: ' + edad + ' años');
            console.log('  Aportación: €' + aportacion);
            console.log('  Ingresos Mensuales: €' + ingresos_mensuales);
            console.log('  Número de Pagas: ' + numero_pagas);
            console.log('  Importe de Pagas: €' + importe_pagas);
            console.log('  Préstamos Mensuales: €' + prestamos_mensuales);
            console.log('Enviando payload:', payload);
            console.log('=== FIN DEBUG ===');
            
            // Obtener token de autenticación
            let token = localStorage.getItem('authToken') || 
                       sessionStorage.getItem('authToken') || 
                       window.jwtToken || 
                       window.apiToken || 
                       '';
            
            // Construir headers
            const headers = {
                'Content-Type': 'application/json'
            };
            
            // Si hay token, incluirlo
            if (token) {
                headers['Authorization'] = 'Bearer ' + token;
            }
            
            // Llamar AJAX a la ruta /AJAX/simulador-calcular-precio-maximo
            fetch('/API/CalcularAvanzada', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(payload),
                credentials: 'include'  // Incluir cookies
            })
            .then(response => {
                console.log('Response:', response);
                console.log('Response headers:', response.headers.get('content-type'));
                
                // Si no es JSON válido
                if (!response.headers.get('content-type') || !response.headers.get('content-type').includes('application/json')) {
                    return response.text().then(text => {
                        console.error('Server response (não JSON):', text);
                        throw new Error('El servidor no devolvió JSON. Response: ' + text.substring(0, 200));
                    });
                }
                
                return response.json().then(data => ({
                    status: response.status,
                    data: data
                }));
            })
            .then(({status, data}) => {
                console.log('Response data:', data);
                
                // Manejar error de autenticación
                if (status === 401) {
                    mostrarModal('Error de autenticación. Por favor, inicia sesión nuevamente.', 'Error');
                    return;
                }
                
                if (status && status < 400 && data) {
                    // La API devuelve importe_fijo en caso de cálculo de importe máximo
                    const precioMaximo = data.importe_fijo || 0;
                    if (precioMaximo > 0) {
                        precioMaximoCalculado = precioMaximo;
                        document.getElementById('precioMaximoValor').textContent = 
                            parseFloat(precioMaximo).toLocaleString('es-ES', {
                                minimumFractionDigits: 0,
                                maximumFractionDigits: 0
                            }) + ' €';
                        document.getElementById('resultadoPrecioMaximo').style.display = 'block';
                        document.getElementById('seccionCoherencia').style.display = 'block';
                        coherenciaValidada = false;
                    } else {
                        mostrarModal('No se pudo calcular el precio máximo. Revisa los datos introducidos.');
                    }
                } else {
                    const mensajeError = data.mensaje || data.message || 'No se pudo calcular el precio máximo';
                    mostrarModal('Error: ' + mensajeError, 'Error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                mostrarModal('Error al calcular: ' + error.message, 'Error');
            });
        }

        function validarCoherenciaSi() {
            coherenciaValidada = true;
            document.getElementById('mensajeCoherencia').style.display = 'none';
            document.getElementById('btnCoherenciaSi').classList.add('active');
            document.getElementById('btnCoherenciaNo').classList.remove('active');
        }

        function validarCoherenciaNo() {
            coherenciaValidada = false;
            const mensajeDiv = document.getElementById('mensajeCoherencia');
            mensajeDiv.innerHTML = `
                <div style="background: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px; padding: 12px; color: #721c24;">
                    <strong>⚠️ Alerta de presupuesto:</strong><br>
                    Según los datos introducidos, el precio de la vivienda supera la capacidad económica estimada. 
                    La operación podría requerir un análisis más detallado por parte de nuestros analistas.
                </div>
            `;
            mensajeDiv.style.display = 'block';
            document.getElementById('btnCoherenciaNo').classList.add('active');
            document.getElementById('btnCoherenciaSi').classList.remove('active');
        }

        // ===== FUNCIONES PARA PASO 3: CUOTA Y GASTOS =====
        
        function actualizarResumenPaso2() {
            // Rellenar el resumen con datos del Paso 2
            const precioMaximo = precioMaximoCalculado || 0;
            const aportacion = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            
            document.getElementById('resumenPrecioMaximo').textContent = 
                parseFloat(precioMaximo).toLocaleString('es-ES', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                }) + ' €';
                
            document.getElementById('resumenAportacion').textContent = 
                parseFloat(aportacion).toLocaleString('es-ES', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                }) + ' €';
        }

        function calcularCuotaYGastos() {
            // Validar que Paso 2 esté completado
            if (!precioMaximoCalculado || precioMaximoCalculado <= 0) {
                mostrarModal('Por favor, completa el Paso 2 (Precio Máximo) primero');
                return;
            }
            
            // Validar formulario Paso 3
            const seccion = document.getElementById('paso3Section');
            const inputs = seccion.querySelectorAll('input[required], select[required]');
            let valido = true;
            
            inputs.forEach(input => {
                const fieldName = input.getAttribute('name') || '';
                // Excluir checkboxes que no sean requeridos
                if (input.type === 'checkbox' && !input.hasAttribute('data-required')) {
                    return;
                }
                if (!input.value) {
                    valido = false;
                }
            });
            
            if (!valido) {
                mostrarModal('Por favor, completa todos los campos requeridos del Paso 3');
                return;
            }
            
            // Obtener datos necesarios
            const precioVivienda = precioMaximoCalculado;
            const edad = parseInt($('input[name*="edad"]:not([name*="Dos"])').val()) || 0;
            const aportacion = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            const ingresos_mensuales = parseFloat($('input[name*="ingresos_mensuales"]:not([name*="Dos"])').val()) || 0;
            const numero_pagas = parseInt($('input[name*="numero_pagas"]').val()) || 0;
            const importe_pagas = parseFloat($('input[name*="importe_pagas"]').val()) || 0;
            const prestamos_mensuales = parseFloat($('input[name*="prestamos_mensuales"]').val()) || 0;
            const valorInmueble = parseFloat($('input[name*="valorInmueble"]').val()) || 0;
            const plazoAmortizacion = parseInt($('select[name*="plazoAmortizacion"]').val() || $('input[name*="plazoAmortizacion"]').val() || 25);
            const comunidad = parseInt($('select[name*="comunidadAutonoma"]').val()) || 4;
            const destinoCompra = parseInt($('select[name*="destinoCompra"]').val()) || 1;
            const obraNueva = $('input[name*="obraNueva"]').is(':checked') ? 1 : 0;
            const tipoInteres = $('select[name*="tipoInteres"]').val() || 'variable';

            const familiaNumerosa = $('input[name*="familiaNumerosa"]').is(':checked') ? 1 : 0;
            const monoparental = $('input[name*="monoparental"]').is(':checked') ? 1 : 0;
            const minusvaliaFamiliaNumerosa = $('input[name*="minusvaliaFamiliaNumerosa"]').is(':checked') ? 1 : 0;
            const vpo = $('input[name*="vpo"]').is(':checked') ? 1 : 0;
            
            // Construir payload - tipo 3: cuota+gastos con precio fijo; tipo 2: precio máximo desde ingresos
            const tipoCalculo = valorInmueble > 0 ? 3 : 2;
            const datosAPI = {
                tipo_calculo: tipoCalculo,
                edad: edad,
                valor_inmueble: valorInmueble,
                aportacion: aportacion,
                ingresos_mensuales: ingresos_mensuales,
                numero_pagas: numero_pagas,
                importe_pagas: importe_pagas,
                prestamos_mensuales: prestamos_mensuales,
                plazo: plazoAmortizacion,
                comunidad_autonoma: comunidad,
                destino_compra: destinoCompra,
                obra_nueva: obraNueva,
                familia_numerosa: familiaNumerosa,
                monoparental: monoparental,
                minusvalia_familia_numerosa: minusvaliaFamiliaNumerosa,
                vpo: vpo,
                num_titulares: parseInt($('select[name*="numTitulares"], input[name*="numTitulares"]').val()) || 1
            };
            
            const payload = { datos: datosAPI };
            
            console.log('=== CÁLCULO CUOTA Y GASTOS ===');
            console.log('Entrada:', payload);
            
            // Obtener token
            let token = localStorage.getItem('authToken') || 
                       sessionStorage.getItem('authToken') || 
                       window.jwtToken || '';
            
            const headers = { 'Content-Type': 'application/json' };
            if (token) {
                headers['Authorization'] = 'Bearer ' + token;
            }
            
            // Llamar AJAX a /AJAX/simulador-calcular-cuota-gastos
            fetch('/AJAX/CalculadoraAvanzadaTest', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify(payload),
                credentials: 'include'
            })
            .then(response => {
                if (!response.headers.get('content-type')?.includes('application/json')) {
                    return response.text().then(text => {
                        throw new Error('Servidor no devolvió JSON: ' + text.substring(0, 200));
                    });
                }
                return response.json().then(data => ({
                    status: response.status,
                    data: data
                }));
            })
            .then(({status, data}) => {
                console.log('Respuesta:', data);
                
                if (status === 401) {
                    mostrarModal('Error de autenticación', 'Error');
                    return;
                }
                
                if (status && status < 400 && data && !data.error) {
                    // Mostrar resultado
                    mostrarResultadoCuotaYGastos(data);
                } else {
                    const mensajeError = data?.mensaje || data?.message || 'No se pudo calcular';
                    mostrarModal('Error: ' + mensajeError, 'Error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                mostrarModal('Error al calcular: ' + error.message, 'Error');
            });
        }

        function mostrarResultadoCuotaYGastos(data) {
            // Rellenar datos del resultado
            console.log('mostrarResultadoCuotaYGastos', data);
            
            // Para tipo=3 (precio fijo del inmueble), NO sobreescribir precioMaximoCalculado
            // data.importe_fijo = valorInmueble (tipo=3) ó precio máximo desde ingresos (tipo=2)
            const esCuotaPrecioFijo = (data.tipo_calculo === 'cuota-precio-fijo');
            if (!esCuotaPrecioFijo) {
                precioMaximoCalculado = data.importe_fijo || 0;
            }
            valorInmueblePaso3 = data.importe_fijo || 0;  // precio real usado en este cálculo
            
            const cuotaMensual = data.cuota || data.cuota_fija || 0;
            const aportacion = parseFloat($('input[name*="aportacion"]:not([name*="Dos"])').val()) || 0;
            const importePrestamo = valorInmueblePaso3 - aportacion;
            const porcentajeFinanciacion = importePrestamo > 0
                ? ((importePrestamo / (valorInmueblePaso3 || 1)) * 100).toFixed(1)
                : 0;
            const gastosTotales = data.gastos || 0;
            const aDesembolsar = aportacion + gastosTotales;
