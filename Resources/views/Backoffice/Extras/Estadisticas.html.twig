{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme formulario '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/c3-master/c3.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/node_modules/select2/dist/css/select2.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/node_modules/bootstrap-daterangepicker/daterangepicker.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/node_modules/datatables/media/css/dataTables.bootstrap4.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/c3/0.4.18/c3.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/css/select2.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-daterangepicker/3.0.3/daterangepicker.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/css/dataTables.bootstrap4.min.css" rel="stylesheet">
{% endblock %}
{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/select2.min.css') }}" rel="stylesheet">
	<style>
		.select2-search__field, .select2-search.select2-search--inline {
			width: 100% !important;
		}
	</style>
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/select2/dist/js/select2.full.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/i18n/es.js') }}"></script>
	<script src="{{ asset('assets/node_modules/moment/moment.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/moment/locale/es.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/bootstrap-daterangepicker/daterangepicker.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/bootstrap-daterangepicker/locales/bootstrap-daterangepicker.es.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/d3/d3.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/c3-master/c3.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/datatables/datatables.min.js') }}"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.3.0/chart.min.js" integrity="sha512-yadYcDSJyQExcKhjKSQOkBKy2BLDoW6WnnGXCAkCoRlpHGpYuVuBqGObf3g/TdB86sSbss1AOP4YlGSb6EKQPg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/select2.full.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/i18n/es.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.22.2/moment.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.22.2/locale/es.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-daterangepicker/3.0.3/daterangepicker.min.js"></script>
	<script src="{{ asset('assets/js/custom/bootstrap-daterangepicker/locales/bootstrap-daterangepicker.es.min.js') }}"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/3.5.17/d3.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/c3/0.4.18/c3.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/jquery.dataTables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/dataTables.bootstrap4.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.3.0/chart.min.js" integrity="sha512-yadYcDSJyQExcKhjKSQOkBKy2BLDoW6WnnGXCAkCoRlpHGpYuVuBqGObf3g/TdB86sSbss1AOP4YlGSb6EKQPg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	{% if fases is defined and fases|length>0 and expedientes is defined and expedientes|length>0 %}
		<script src="{{ asset('assets/js/custom/Array.isArray.min.js') }}"></script>
		<script src="{{ asset('assets/js/custom/Array.prototype.filter.min.js') }}"></script>
		<script src="{{ asset('assets/js/custom/isEmpty.min.js') }}"></script>
		<script src="{{ asset('assets/js/custom/getLocaleDateString.min.js') }}"></script>
		<script>
			function obtenerParametros() {
				return {
					usuarios:{{ usuarios|raw }},
					fases:{{ fases|raw }},
					expedientes:{{ expedientes|raw }}
				};
			}

			function obtenerAgentes(){
				let agentes_colaboradores = {{agentes|raw}};
				return agentes_colaboradores;
			}

			function rutaObtenerInformeEstadisticasAJAX(){
				return '{{ path('obtener_informe_estadisticas') }}';
			}
			
		</script>
		<script src="{{ asset('assets/js/custom/estadisticas.min.js') }}"></script>
	{% endif %}
	<script src="{{ asset('assets/js/custom/tabla.min.js') }}"></script>
{% endblock %}
{% block body %}
	<div class="row">
		<div class="col-md">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">Estadísticas Personalizadas</h4>
					<div class="form-row">
						<div class="form-group col-sm-4">
							<label for="informe">Informe</label>
							<select id="informe" name="informe" class="select-informe">
								<option></option>
								<option value="1">Operaciones firmadas</option>
								<option value="2">Importe Hipoteca</option>
								<option value="3">Importe Medio Hipoteca</option>
								<option value="4">Operaciones Activas</option>
								<option value="5">Porcentaje de Transformación</option>
								<option value="6">Calendario</option>
							</select>
						</div>
						<div class="form-group col-sm-4 operaciones-firmadas" style="display:none;">
							<label for="agrupar">Agrupar por</label>
							<select id="agrupar" name="agrupar" class="select-agrupar">
								<option></option>
								<option value="tecnicos">Técnico</option>
								<option value="comerciales">Comercial</option>
								<option value="bancos">Bancos</option>
								<option value="tasadoras">Tasadoras</option>
								<option value="notarias">Notarías</option>
								<option value="inmobiliarias">Inmobiliaria</option>
							</select>
						</div>
						<div class="form-group col-sm-4 hipotecas" style="display:none;">
							<label for="agrupa2r">Agrupar por</label>
							<select id="agrupar2" name="agrupar2" class="select-agrupar">
								<option></option>
								<option value="total">Total</option>
								<option value="tecnicos">Técnico</option>
								<option value="comerciales">Comercial</option>
								<option value="bancos">Bancos</option>
								<option value="tasadoras">Tasadoras</option>
								<option value="notarias">Notarías</option>
								<option value="inmobiliarias">Inmobiliaria</option>
							</select>
						</div>
						<div class="form-group col-sm-4 operaciones-activas" style="display:none;">
							<label for="agrupar4">Agrupar por</label>
							<select id="agrupar4" name="agrupar4" class="select-agrupar">
								<option></option>
								<option value="total">Total</option>
								<option value="fases">Fase</option>
								<option value="tecnicos">Técnico</option>
								<option value="comerciales">Comercial</option>
								<option value="colaboradores">Colaborador</option>
								<option value="bancos">Bancos</option>
								<option value="tasadoras">Tasadoras</option>
								<option value="notarias">Notarías</option>
								<option value="inmobiliarias">Inmobiliaria</option>
							</select>
						</div>
						<div class="form-group col-sm-4 porcentaje-transformacion" style="display:none;">
							<label for="agrupar5">Agrupar por</label>
							<select id="agrupar5" name="agrupar5" class="select-agrupar">
								<option></option>
								<option value="total">Total</option>
								<option value="porcentaje">Porcentaje</option>
							</select>
						</div>
						<div class="form-group col-sm-4 informe-calendario" style="display:none;">
							<label for="agrupar6">Agrupar por</label>
							<select id="agrupar6" name="agrupar6" class="select-agrupar">
