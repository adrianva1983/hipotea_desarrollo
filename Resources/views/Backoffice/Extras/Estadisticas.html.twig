								{% endfor %}
							</select> 
						</div> #}
					</div>

					<div class="form-row informe-calendario" style="display:none;">
						<div class="form-group col-sm-6">
							<label for="tecnicos-comerciales">Técnicos y Comerciales</label>
							<select name="tecnicos-comerciales" id="tecnicos-comerciales" class="select2-tecnicos-comerciales" multiple="multiple">
								<option></option>
								{% for usuario in tecnicos_comerciales %}
									<option value="{{usuario.idUsuario}}">{{usuario.username}} {{usuario.apellidos}}</option>
								{% endfor %}
							</select>
						</div>
						<div class="form-group col-sm-6">
							<label for="inmobiliaria6">Inmobiliaria</label>
							<select name="inmobiliaria6" id="inmobiliaria6" class="select2-inmobiliaria" multiple="multiple">
								<option></option>
								{% for inmobiliaria in inmobiliarias %}
									<option value="{{inmobiliaria.idInmobiliaria}}">{{inmobiliaria.nombre}}</option>
								{% endfor %}
							</select>
						</div>
					</div>
					
					<div class="form-row">
						<div class="form-group col-sm-12">
							<button style="margin-top: 30px;float: right;" class="btn btn-success" id="generar-informe"><i class="fa fa-search" aria-hidden="true"></i> &nbsp; Generar Informe</button>
						</div>
					</div>

					{# <div class="w-100" id="grafico2"></div> #}
					<canvas id="grafico2" width="400" height="100"></canvas>
					<div id="listado-visitas" style="display:none;">
						<table id="tabla-visitas" class="table table-striped table-sm full-color-table full-success-table hover-table"></table>
					</div>
				</div>
			</div>
		</div>


		{# <div class="col-md">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">Estadísticas de uso</h4>
					<div>
