							</select>
						</div>
						<div class="form-group col-sm-4">
							<label for="tipoGrafico">Tipo de Gráfico</label>
							<select id="tipoGrafico" name="tipoGrafico" class="select-tipo-grafico">
								<option></option>
								<option value="bar">Barras</option>
								<option value="doughnut">Donuts</option>
								<option value="pie">Sectores</option>
								<option value="line">Líneas</option>
							</select>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group col-sm-6">
							<label for="rango_fechas2">Desde / Hasta</label>
							<input class="form-control js-daterangepicker" id="rango_fechas2" data-filtro="fecha">
						</div>
					</div>
					
					<div class="form-row operaciones-firmadas operaciones-activas porcentaje-transformacion hipotecas" style="display:none;">
						<div class="form-group col-sm-6">
							<label for="tecnicos">Técnicos</label>
