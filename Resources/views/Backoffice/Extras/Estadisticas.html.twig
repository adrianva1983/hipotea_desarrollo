									<option value="{{entidad_colaboradora.idEntidadColaboradora}}">{{entidad_colaboradora.nombre}}</option>
								{% endfor %}
							</select>
						</div>
						<div class="form-group col-sm-6">
							<label for="inmobiliaria">Inmobiliaria</label>
							<select name="inmobiliaria" id="inmobiliaria" class="select2-inmobiliaria" multiple="multiple">
								<option></option>
								{% for inmobiliaria in inmobiliarias %}
									<option value="{{inmobiliaria.idInmobiliaria}}">{{inmobiliaria.nombre}}</option>
								{% endfor %}
							</select>
						</div>
						{# <div class="form-group col-sm-6">
