{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarEventoCalendario '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% form_theme modificarEventoCalendario '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block devstyles %}
	<link href="{{ asset('assets/node_modules/calendar/dist/fullcalendar.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/node_modules/select2/dist/css/select2.min.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/2.3.2/fullcalendar.min.css" rel="stylesheet">
	<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/css/select2.min.css" rel="stylesheet">
{% endblock %}
{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/select2.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/css/custom/calendario.min.css') }}" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/calendar/jquery-ui.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/moment/moment.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/calendar/dist/fullcalendar.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/calendar/dist/locale/es.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/select2.full.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/i18n/es.js') }}"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.11.4/jquery-ui.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.22.2/moment.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.4.0/fullcalendar.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.4.0/locale/es.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/select2.full.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/i18n/es.js"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script>
		function obtenerIdUsuario() {
			return '{{ app.user.idUsuario }}';
		}

		function seguimientoHorarioJSON() {
			return JSON.parse({{ seguimientoHorarioJSON|json_encode|raw }});
		}

		function rutaActualizarCalendarioAJAX() {
			return '{{ path('actualizar_calendario_ajax') }}';
		}
		{% if is_granted('ROLE_ADMIN') %}
		function rutaSeleccionarUsuarioCalendarioAJAX() {
			return '{{ path('seleccionar_usuario_calendario_ajax') }}';
		}
		{% endif %}
	</script>
	<script src="{{ asset('assets/js/custom/calendario.min.js') }}"></script>
{% endblock %}
{% block body %}
	<div class="card">
		{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
		{% if is_granted('ROLE_ADMIN')and usuarios is defined and usuarios is iterable and usuarios|length>0 %}
			<div class="card-body">
				<form method="post">
					<div class="form-group mb-0">
						<label for="seleccionar-usuario">Seleccione un usuario</label>
						<select class="form-control select2" id="seleccionar-usuario">
							{% for usuario in usuarios %}
								{% if usuario.apellidos|length is same as(0) %}
									{% if usuario.username|length is same as(0) %}
										{% set nombreCompleto = '' %}
									{% else %}
										{% set nombreCompleto = usuario.username %}
									{% endif %}
								{% else %}
									{% if usuario.username|length is same as(0) %}
										{% set nombreCompleto = usuario.apellidos %}
									{% else %}
										{% set nombreCompleto = usuario.apellidos ~ ', ' ~ usuario.username %}
									{% endif %}
								{% endif %}
								<option {% if usuario.idUsuario is same as(app.user.idUsuario) %}selected {% endif %}value="{{ usuario.idUsuario }}">{{ nombreCompleto }}</option>
							{% endfor %}
						</select>
					</div>
				</form>
			</div>
		{% endif %}
		<div class="row">
			<div class="col-lg-3">
				<div class="card-body">
					<h4 class="card-title">{{ titulo }}</h4>
					<div id="calendar-events">
						<div class="calendar-events" data-class="bg-red">
							<i class="fa fa-circle text-color-red"></i>
							<span data-tipo>Apertura de cuenta</span>
						</div>
						<div class="calendar-events" data-class="bg-maroon">
							<i class="fa fa-circle text-color-maroon"></i>
							<span data-tipo>Entrega publicidad</span>
						</div>
						<div class="calendar-events" data-class="bg-lime">
							<i class="fa fa-circle text-color-lime"></i>
							<span data-tipo>Entrevista banco</span>
						</div>
						<div class="calendar-events" data-class="bg-green">
							<i class="fa fa-circle text-color-green"></i>
							<span data-tipo>Pago comisión</span>
						</div>
						<div class="calendar-events" data-class="bg-blue">
							<i class="fa fa-circle text-color-blue"></i>
							<span data-tipo>Recogida documentación</span>
						</div>
						<div class="calendar-events" data-class="bg-navy">
							<i class="fa fa-circle text-color-navy"></i>
							<span data-tipo>Reunión cliente en oficina</span>
						</div>
						<div class="calendar-events" data-class="bg-fuchsia">
							<i class="fa fa-circle text-color-fuchsia"></i>
							<span data-tipo>Reunión cliente fuera oficina</span>
						</div>
						<div class="calendar-events" data-class="bg-purple">
							<i class="fa fa-circle text-color-purple"></i>
							<span data-tipo>Tasación</span>
						</div>
						<div class="calendar-events" data-class="bg-teal">
							<i class="fa fa-circle text-color-teal"></i>
							<span data-tipo>Visita comercial</span>
						</div>
						<div class="calendar-events" data-class="bg-bisque">
							<i class="fa fa-circle text-color-bisque"></i>
							<span data-tipo>Notaría</span>
						</div>
					</div>
					{#<div class="custom-control custom-checkbox m-l-10 m-t-10 m-b-10">
						<input class="custom-control-input" disabled id="drop-remove" type="checkbox">
						<label class="custom-control-label" for="drop-remove">Quitar tras soltar</label>
					</div>
					<button class="btn btn-success btn-block waves-effect waves-light" data-toggle="modal" data-target="#agregar-nueva-categoria" disabled>
						<i class="ti-plus"></i>
						<span> Agregar nuevo evento</span>
					</button>#}
				</div>
			</div>
			<div class="col-lg">
				<div class="card-body">
					<div id="calendar"></div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
{% block modals %}
	{{ parent() }}
	<div class="modal fade" id="agregar-nueva-categoria">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h4 class="modal-title">
						<strong>Agregar</strong>
						<span> nueva categoría</span>
					</h4>
					<button class="close" data-dismiss="modal" type="button">×</button>
				</div>
				<div class="modal-body">
					<form>
						<div class="row">
							<div class="col-md mb-2 mb-md-0">
								<label class="control-label" for="nombre-categoria">Nombre de la categoría</label>
								<input class="form-control form-white" id="nombre-categoria" placeholder="Introduzca un nombre">
							</div>
							<div class="col-md">
								<label class="control-label" for="color-categoria">Color de la categoría</label>
								<select class="form-control form-white" data-placeholder="Escoja un color…" id="color-categoria">
									<option value="success">Verde</option>
									<option value="danger">Rojo</option>
									<option value="info">Azul</option>
									<option value="primary">Naranja</option>
									<option value="warning">Amarillo</option>
									<option value="inverse">Negro</option>
								</select>
							</div>
						</div>
					</form>
				</div>
				<div class="modal-footer">
					<button class="btn btn-danger waves-effect waves-light" data-dismiss="modal" data-evento="guardar" type="button">Guardar</button>
					<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
				</div>
			</div>
		</div>
	</div>
	<div class="modal fade" id="agregar-evento">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h4 class="modal-title">
						<strong>Agregar evento</strong>
					</h4>
					<button class="close" data-dismiss="modal" type="button">×</button>
				</div>
				<div class="modal-body">
					<form>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.idCliente) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.idCliente,{attr:{class:'select2'}}) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.datosCliente) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.datosCliente) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.idInmobiliaria) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.idInmobiliaria,{attr:{class:'select2'}}) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.tipo) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.tipo) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.observaciones) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.observaciones) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(agregarEventoCalendario.estado) }}
							<div class="input-group">
								{{ form_widget(agregarEventoCalendario.estado) }}
							</div>
						</div>
					</form>
				</div>
				<div class="modal-footer">
					<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
					<button class="btn btn-success waves-effect waves-light" data-dismiss="modal" data-evento="guardar" type="button">Crear evento</button>
				</div>
			</div>
		</div>
	</div>
	<div class="modal fade" id="modificar-evento">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h4 class="modal-title">
						<strong>Modificar evento</strong>
					</h4>
					<button class="close" data-dismiss="modal" type="button">×</button>
				</div>
				<div class="modal-body">
					<form>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.idCliente) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.idCliente,{attr:{class:'select2'}}) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.datosCliente) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.datosCliente) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.idInmobiliaria) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.idInmobiliaria,{attr:{class:'select2'}}) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.tipo) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.tipo) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.observaciones) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.observaciones) }}
							</div>
						</div>
						<div class="form-group">
							{{ form_label(modificarEventoCalendario.estado) }}
							<div class="input-group">
								{{ form_widget(modificarEventoCalendario.estado) }}
							</div>
						</div>
					</form>
				</div>
				<div class="modal-footer">
					<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
					<button class="btn btn-success save-event waves-effect waves-light" data-dismiss="modal" data-evento="guardar" type="button">Modificar evento</button>
					<button class="btn btn-danger delete-event waves-effect waves-light" data-dismiss="modal" data-evento="borrar" type="button">Eliminar</button>
				</div>
			</div>
		</div>
	</div>
	<div class="modal fade" id="error-ajax">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header">
					<h4 class="modal-title">
						<strong>Error</strong>
					</h4>
					<button class="close" data-dismiss="modal" type="button">×</button>
				</div>
				<div class="modal-body">Se ha producido un error.</div>
				<div class="modal-footer">
					<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
				</div>
			</div>
		</div>
	</div>
{% endblock %}