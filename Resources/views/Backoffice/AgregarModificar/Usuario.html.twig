		</div>
	</div>
	{% if (is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL')) and app.request.get('_route') is not same as('agregar_modificar_cliente') and app.request.get('_route') is not same as('agregar_modificar_usuario_inmobiliaria')  %}
		<div class="card">
			<div class="card-body">
				<h4 class="card-title">Configuración de envío de Correo</h4>
				<div class="form-row">
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerTransport) }}
						{{ form_widget(agregarModificarUsuario.mailerTransport) }}
						{{ form_errors(agregarModificarUsuario.mailerTransport) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerHost) }}
						{{ form_widget(agregarModificarUsuario.mailerHost) }}
						{{ form_errors(agregarModificarUsuario.mailerHost) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerUser) }}
						{{ form_widget(agregarModificarUsuario.mailerUser) }}
						{{ form_errors(agregarModificarUsuario.mailerUser) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerPassword) }}
						{{ form_widget(agregarModificarUsuario.mailerPassword) }}
						{{ form_errors(agregarModificarUsuario.mailerPassword) }}
					</div>
				</div>
				<div class="form-row">
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerPort) }}
						{{ form_widget(agregarModificarUsuario.mailerPort) }}
						{{ form_errors(agregarModificarUsuario.mailerPort) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerEncryption) }}
						{{ form_widget(agregarModificarUsuario.mailerEncryption) }}
						{{ form_errors(agregarModificarUsuario.mailerEncryption) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.mailerAuthMode) }}
						{{ form_widget(agregarModificarUsuario.mailerAuthMode) }}
						{{ form_errors(agregarModificarUsuario.mailerAuthMode) }}
					</div>
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.firmaCorreo) }}
						{% if fichero_subido is defined %}
							{{ form_widget(agregarModificarUsuario.firmaCorreo,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-default-file':fichero_subido,'data-height':207,'data-max-file-size':max_file_size}}) }}
						{% else %}
							{{ form_widget(agregarModificarUsuario.firmaCorreo,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-height':207,'data-max-file-size':max_file_size}}) }}
						{% endif %}
						{{ form_errors(agregarModificarUsuario.firmaCorreo) }}
					</div>
				</div>
			</div>
		</div>
	{% endif %}
	<div class="card">
		<div class="card-body">
			<div class="d-flex">
				{% if app.request.get('_route') is same as('agregar_modificar_usuario') %}
					<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_usuarios') }}">Volver</a>
				{% elseif app.request.get('_route') is same as('agregar_modificar_cliente') %}
					<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_clientes') }}">Volver</a>
				{% elseif app.request.get('_route') is same as('agregar_modificar_usuario_inmobiliaria') %}
					<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_usuarios_inmobiliarias') }}">Volver</a>
				{% else %}
					<a class="btn btn-success mr-auto waves-effect" href="{{ path('inicio') }}">Volver</a>
				{% endif %}
				{{ form_label(agregarModificarUsuario.reset) }}
				{{ form_widget(agregarModificarUsuario.reset) }}
				{{ form_label(agregarModificarUsuario.submit) }}
				{{ form_widget(agregarModificarUsuario.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
		</div>
	</div>
	{{ form_row(agregarModificarUsuario._token) }}
	{{ form_end(agregarModificarUsuario, {'render_rest': false}) }}
{% endblock %}