						{{ form_label(agregarModificarUsuario.role) }}
						{{ form_widget(agregarModificarUsuario.role) }}
						{{ form_errors(agregarModificarUsuario.role) }}
					</div>
					{% if app.request.get('_route') is not same as('mi_perfil') and is_granted('ROLE_ADMIN') %}
						<div class="form-group col-sm 2222">
						{{ form_label(agregarModificarUsuario.maxOperacionesVivas) }}
						{{ form_widget(agregarModificarUsuario.maxOperacionesVivas) }}
						{{ form_errors(agregarModificarUsuario.maxOperacionesVivas) }}
					</div>
					{% endif %}
				{% endif %}
				{% if app.request.get('_route') is not same as('mi_perfil')and is_granted('ROLE_ADMIN') %}
					<div class="form-group col-sm">
						{{ form_label(agregarModificarUsuario.tag) }}
						{{ form_widget(agregarModificarUsuario.tag) }}
						{{ form_errors(agregarModificarUsuario.tag) }}
					</div>
				{% else %}
					{{ form_widget(agregarModificarUsuario.tag,{attr:{class:'d-none'}}) }}
				{% endif %}
				{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
					<div class="form-group col-sm-2 d-sm-flex align-items-center">
						{{ form_label(agregarModificarUsuario.estado) }}
						{{ form_widget(agregarModificarUsuario.estado) }}
						{{ form_errors(agregarModificarUsuario.estado) }}
					</div>
				{% endif %}
			</div>
		</div>
	</div>
