{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarExpediente '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/select2/dist/css/select2.min.css') }}" rel="stylesheet">
	{% if incluir_dropify is defined and incluir_dropify %}
		<link href="{{ asset('assets/node_modules/dropify/dist/css/dropify.min.css') }}" rel="stylesheet">
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<link href="{{ asset('assets/node_modules/bootstrap-datepicker/bootstrap-datepicker.min.css') }}" rel="stylesheet">
	{% endif %}
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/css/select2.min.css" rel="stylesheet">
	{% if incluir_dropify is defined and incluir_dropify %}
		<link href="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.1/css/dropify.min.css" rel="stylesheet">
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" rel="stylesheet">
	{% endif %}
{% endblock %}
{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/select2.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/css/custom/expediente.min.css') }}" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/select2/dist/js/select2.full.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/i18n/es.js') }}"></script>
	{% if incluir_dropify is defined and incluir_dropify %}
		<script src="{{ asset('assets/node_modules/dropify/dist/js/dropify.min.js') }}"></script>
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<script src="{{ asset('assets/node_modules/bootstrap-datepicker/bootstrap-datepicker.min.js') }}"></script>
		<script src="{{ asset('assets/node_modules/bootstrap-datepicker/locales/bootstrap-datepicker.es.min.js') }}"></script>
	{% endif %}
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/select2.full.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/i18n/es.js"></script>
	{% if incluir_dropify is defined and incluir_dropify %}
		<script src="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.1/js/dropify.min.js"></script>
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/locales/bootstrap-datepicker.es.min.js"></script>
	{% endif %}
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script>
		{% if nombres_fichero is defined %}
		function nombresFicheroFuncion() {
			return JSON.parse({{ nombres_fichero|json_encode|raw }});
		}

		function rutaBorrarFicheroExpedienteAJAX() {
			return '{{ path('borrar_fichero_expediente_ajax') }}';
		}
		{% endif %}
		function rutaObtenerAgentesColaboradoresAJAX() {
			return '{{ path('obtener_agentes_colaboradores_ajax') }}';
		}

		function actualizarSeguimientoExpedienteAJAX() {
			return '{{ path('actualizar_seguimiento_expediente_ajax') }}';
		}

		// Función para sincronizar con Blender (cliente)
		function sincronizarConBlender1() 
		{
			// Obtener el valor del campo 707
			var valorCampo707 = '{{ valor_campo_707 is not null ? valor_campo_707 : "" }}';
			
			console.log('=== DEBUG BLENDER ===');
			console.log('Valor del campo 707 recibido:', valorCampo707);
			console.log('Tipo:', typeof valorCampo707);
			console.log('Longitud:', valorCampo707.length);
			console.log('Es vacío:', valorCampo707 === '');
			console.log('Valor raw Twig: {{ valor_campo_707 }}');
			console.log('Debug array:', '{{ debug_campo_707|join(", ") }}');
			
			if (valorCampo707 && valorCampo707.length > 0) {
				console.log('Valor del campo 707 (Activar Blender): ' + valorCampo707);
				alert('Sincronización con Blender - Valor: ' + valorCampo707);
				// TODO: Implementar lógica de sincronización con Blender
			} else {
				alert('No hay valor configurado en el campo Activar Blender');
			}
		}
		function obtenerDocumentos() 
		{
			const dni = document.getElementById("dniClienteValue").value;
			fetch(`{{ path('document_request') }}?dni=${dni}`)
				.then(response => response.json())
				.then(data => {
					if (data.widget_url_boxed) {
						// Cargar URL en el iframe del modal
						document.getElementById("widgetIframe").src = data.widget_url_boxed;
						// Abrir el modal
						$('#modal-widget-blender').modal('show');
						localStorage.setItem("request_id", data.request_id);
						localStorage.setItem("dni", dni);  // Guardar el DNI en localStorage
						verificarEstadoDocumentos();
					} else {
						alert("Error en la solicitud de documentos.");
					}
				});
		}

		function verificarEstadoDocumentos() 
		{
				const requestId = localStorage.getItem("request_id");
				const dni = localStorage.getItem("dni");

				if (!requestId || !dni) return;

				fetch(`{{ path('document_download') }}?request_id=${requestId}&dni=${dni}`)
					.then(response => response.json())
					.then(data => {
						if (data.success && data.files.length > 0) {
							mostrarBotonDescarga(data.files);
						} else {
							setTimeout(verificarEstadoDocumentos, 5000);
						}
					});
		}

		function mostrarBotonDescarga(files) 
		{
			const container = document.getElementById("botonDescargaContainer");
			const totalArchivos = files.length;
			
			container.innerHTML = `<br><h5>Documentos descargados: ${totalArchivos}</h5>`;

			localStorage.removeItem("request_id");
		}

		// Event listener para cargar documentos cuando se abre la pestaña Belender
		$(document).ready(function() {
			console.log('✅ Document ready - Inicializando eventos Belender');
			
			// Cargar documentos automáticamente al inicializar
			cargarDocumentosPestanaBelender();
			
			// Agregar event listener al elemento del acordeón
			$('[style*="background-color: #ef6c00"]').each(function() {
				if ($(this).find('h5:contains("Documentos Descargados")').length) {
					console.log('✅ Acordeón Belender encontrado');
					$(this).on('click', function() {
						console.log('👆 Click en acordeón detectado');
						toggleDocumentosBelender(this);
					});
				}
			});
		});

		function toggleDocumentosBelender(element) {
			const contenedor = document.getElementById('contenedor-documentos-belender-tab');
			const mostrarIcon = element.querySelector('.mostrar');
			const ocultarIcon = element.querySelector('.ocultar');
			
			console.log('🔄 Toggle - Contenedor encontrado:', !!contenedor);
			console.log('🔄 Toggle - Display actual:', contenedor.style.display);
			
			// Toggle display
			const esVisible = contenedor.style.display !== 'none' && contenedor.style.display !== '';
			console.log('🔄 Toggle - ¿Está visible?', esVisible);
			
			if (esVisible) {
				// Ocultar
				contenedor.style.display = 'none';
				mostrarIcon.classList.remove('d-none');
				ocultarIcon.classList.add('d-none');
				console.log('🔄 Toggle - Ocultando');
			} else {
				// Mostrar
				contenedor.style.display = 'block';
				mostrarIcon.classList.add('d-none');
				ocultarIcon.classList.remove('d-none');
				console.log('🔄 Toggle - Mostrando');
				
				// Cargar documentos
				setTimeout(function() {
					//cargarDocumentosPestanaBelender();
				}, 50);
			}
		}

		function cargarDocumentosPestanaBelender() 
		{
			console.log('🔍 Iniciando carga de documentos en pestaña Belender');
			// Intentar obtener DNI de múltiples formas
			let dni = null;
			
			const dniInput = document.getElementById("dniClienteValue");
			if (dniInput && dniInput.value) {
				dni = dniInput.value;
				console.log('✅ DNI obtenido de dniClienteValue:', dni);
			}
			
			// Si no funciona, buscar en localStorage
			if (!dni) {
				dni = localStorage.getItem("dni");
				console.log('✅ DNI obtenido de localStorage:', dni);
			}
			
			// Si aún no hay DNI, mostrar error
			if (!dni) {
				console.error('❌ No se pudo obtener el DNI');
				document.getElementById('contenedor-documentos-belender-tab').innerHTML = `
					<div class="alert alert-warning">
						<i class="fas fa-exclamation-triangle mr-2"></i>
						No se puede cargar los documentos: DNI no disponible
					</div>
				`;
				return;
			}

			console.log('🔍 Cargando documentos para DNI:', dni);

			// Mostrar estado de cargando
			document.getElementById('contenedor-documentos-belender-tab').innerHTML = `
				<div class="alert alert-info">
					<div class="spinner-border spinner-border-sm mr-2" role="status">
						<span class="sr-only">Cargando...</span>
					</div>
					Cargando documentos...
				</div>
			`;

			fetch(`/cargar-documentos-descargados?dni=${encodeURIComponent(dni)}`)
				.then(response => {
					console.log('📡 Response status:', response.status);
					if (!response.ok) {
						throw new Error(`HTTP error! status: ${response.status}`);
					}
					return response.json();
				})
				.then(data => {
					console.log('✅ Respuesta recibida:', data);
					if (data.success && data.documentos && data.documentos.length > 0) {
						console.log('📋 Mostrando documentos:', data.documentos.length);
						mostrarDocumentosPestanaBelender(data.documentos, dni);
					} else {
						console.log('ℹ️ No hay documentos disponibles');
						document.getElementById('contenedor-documentos-belender-tab').innerHTML = `
							<div class="alert alert-info">
								<i class="fas fa-info-circle mr-2"></i>
								No hay documentos descargados aún. Utiliza la sección "Documentos Descargados de Belender" para descargarlos.
							</div>
						`;
					}
				})
				.catch(error => {
					console.error("❌ Error cargando documentos:", error);
					document.getElementById('contenedor-documentos-belender-tab').innerHTML = `
						<div class="alert alert-danger">
							<i class="fas fa-times-circle mr-2"></i>
							Error al cargar los documentos: ${error.message}
						</div>
					`;
				});
		}

		function obtenerBadgeEstado(estado) {
			const estadoMap = {
				'disponible': '<span class="badge badge-success">Disponible</span>',
				'procesando': '<span class="badge badge-warning">Procesando</span>',
				'error': '<span class="badge badge-danger">Error</span>',
				'descargado': '<span class="badge badge-info">Descargado</span>'
			};
			return estadoMap[estado] || `<span class="badge badge-secondary">${estado}</span>`;
		}

		function formatearBytes(bytes) {
			if (bytes === 0) return '0 Bytes';
			const k = 1024;
			const sizes = ['Bytes', 'KB', 'MB', 'GB'];
			const i = Math.floor(Math.log(bytes) / Math.log(k));
			return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
		}

		function generarAcciones(doc, dni) {
			let html = '<div class="btn-group" role="group">';
			
			if (doc.tipo === 'json') {
				html += `<button type="button" class="btn btn-sm btn-primary" onclick="verDocumentoJSON('${dni}', '${doc.nombre}')">
					<i class="fas fa-eye"></i> Ver
				</button>`;
			} else if (doc.tipo === 'pdf') {
				const url = new URL('{{ path('obtener_documento') }}', window.location.origin);
				url.searchParams.append('dni', dni);
				url.searchParams.append('archivo', doc.nombre);
				html += `<a href="${url.toString()}" class="btn btn-sm btn-success" download>
					<i class="fas fa-download"></i> Descargar
				</a>`;
			}
			
			html += '</div>';
			return html;
		}

		function consolidarDocumentosBelender() {
			const dni = document.getElementById("dniClienteValue").value;
			
			if (!dni) {
				alert('No se ha encontrado el DNI del cliente');
				return;
			}

			// Mostrar loading
			const btnConsolidar = document.getElementById('btn-consolidar-belender');
			const textoOriginal = btnConsolidar.innerHTML;
			btnConsolidar.disabled = true;
			btnConsolidar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando con IA del cliente...';

			console.log('📨 Iniciando fetch a procesar_documentos_belender...');
			fetch(`{{ path('procesar_documentos_belender') }}?dni=${encodeURIComponent(dni)}`)
				.then(response => {
					console.log('📥 Respuesta recibida, status:', response.status);
					return response.json();
				})
				.then(async data => {
					console.log('📦 Datos JSON parseados:', data);
					console.log('Estado:', data.estado || 'no definido');
					console.log('¿Tiene documentos_originales?', !!data.documentos_originales);
					
					if (data.success || data.estado === 'consolidacion_basica') {
						console.log('✅ Condición cumplida');
						let datosFinales = data.datos_consolidados || data;
						
						// Si es consolidación básica (sin IA), intentar procesar con IA en cliente
						if (data.estado === 'consolidacion_basica' && data.documentos_originales) {
							console.log('🤖 *** INTENTANDO CONSOLIDAR CON IA EN EL CLIENTE ***');
							btnConsolidar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Consolidando con IA (cliente)...';
							
							const datosConIA = await procesarConGeminiJS(data.documentos_originales, dni);
							console.log('Resultado de procesarConGeminiJS:', datosConIA);
							
							if (datosConIA) {
								console.log('✅ IA del cliente funcionó');
								datosFinales = datosConIA;
								datosFinales.procesado_por = 'gemini-js-client';
							} else {
								console.log('⚠️ IA del cliente falló, usando datos sin procesar');
								datosFinales.procesado_por = 'fallback-sin-ia';
							}
						} else {
							console.log('❌ Condición de IA fallida. Estado:', data.estado, 'Tiene docs:', !!data.documentos_originales);
						}
						
						btnConsolidar.disabled = false;
						btnConsolidar.innerHTML = textoOriginal;
						console.log('✅ Datos finales:', datosFinales);
						mostrarDatosConsolidados(datosFinales);
					} else {
						console.log('❌ Condición inicial fallida');
						alert('Error al consolidar documentos: ' + (data.error || 'Error desconocido'));
						btnConsolidar.disabled = false;
						btnConsolidar.innerHTML = textoOriginal;
					}
				})
				.catch(error => {
					console.error('❌ Error en fetch:', error);
					btnConsolidar.disabled = false;
					btnConsolidar.innerHTML = textoOriginal;
					alert('Error al procesar documentos: ' + error.message);
				});
		}

		function mostrarDatosConsolidados(datos) {
			const modalHtml = `
				<div class="modal fade" id="modalDatosConsolidados" tabindex="-1" role="dialog">
					<div class="modal-dialog modal-xl" role="document">
						<div class="modal-content">
							<div class="modal-header bg-success text-white">
								<h5 class="modal-title"><i class="fas fa-robot mr-2"></i>Datos Consolidados por IA</h5>
								<button type="button" class="close text-white" data-dismiss="modal">
									<span>&times;</span>
								</button>
							</div>
							<div class="modal-body">
								<div class="alert alert-info">
									<i class="fas fa-info-circle mr-2"></i>
									Estos datos han sido extraídos y consolidados automáticamente de todos los documentos de Belender usando IA.
								</div>
								<pre style="max-height: 600px; overflow-y: auto; background-color: #f8f9fa; padding: 15px; border-radius: 5px; border: 1px solid #dee2e6; font-size: 13px;">${JSON.stringify(datos, null, 2)}</pre>
							</div>
							<div class="modal-footer">
								<button type="button" class="btn btn-warning" onclick="compararConExpediente()">
									<i class="fas fa-balance-scale mr-2"></i>Comparar con Expediente
								</button>
								<button type="button" class="btn btn-secondary" data-dismiss="modal">
									<i class="fas fa-times mr-2"></i>Cerrar
								</button>
							</div>
						</div>
					</div>
				</div>
			`;
			
			$('#modalDatosConsolidados').remove();
			$('body').append(modalHtml);
			$('#modalDatosConsolidados').modal('show');
		}

		function compararConExpediente() {
			console.log('🔎 Iniciando comparación con los datos del expediente...');
			const dni = document.getElementById("dniClienteValue").value;
			if (!dni) {
				alert('No se ha encontrado el DNI del cliente');
				return;
			}

			// Recoger todos los campos del formulario en un objeto plano
			const form = document.querySelector('form');
			if (!form) {
				alert('Formulario no encontrado en la página');
				return;
			}

			const fd = new FormData(form);
			const datosObj = {};
			for (const [k, v] of fd.entries()) {
				if (datosObj.hasOwnProperty(k)) {
					if (!Array.isArray(datosObj[k])) datosObj[k] = [datosObj[k]];
					datosObj[k].push(v);
				} else {
					datosObj[k] = v;
				}
			}

			// Enviar al servidor para comparar
			const payload = new FormData();
			payload.append('datos_expediente', JSON.stringify(datosObj));

			const compararUrl = `{{ path('comparar_datos_expediente') }}?dni=${encodeURIComponent(dni)}`;
			console.log('📨 Enviando datos al servidor para comparar:', compararUrl);

			fetch(compararUrl, {
				method: 'POST',
				body: payload
			})
			.then(resp => resp.json())
			.then(result => {
				console.log('📦 Resultado comparación:', result);
				if (result.error) {
					alert('Error al comparar: ' + result.error);
					return;
				}
				// Construir modal con discrepancias y coincidencias
				const discrepancias = result.discrepancias || result.discrepancies || [];
				const coincidencias = result.coincidencias || result.matches || [];
				const resumen = result.resumen || {};

				let html = `
					<div class="modal fade" id="modalComparacion" tabindex="-1" role="dialog">
						<div class="modal-dialog modal-xl" role="document">
							<div class="modal-content">
								<div class="modal-header bg-info text-white">
									<h5 class="modal-title"><i class="fas fa-balance-scale mr-2"></i>Resultado de la Comparación</h5>
									<button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
								</div>
								<div class="modal-body">
									<div class="mb-3">
										<strong>Resumen:</strong>
										<ul>
											<li>Total discrepancias: ${resumen.total_discrepancias || (discrepancias.length)}</li>
											<li>Discrepancias graves: ${resumen.discrepancias_graves || 0}</li>
											<li>Porcentaje coincidencia: ${resumen.porcentaje_coincidencia || 0}%</li>
										</ul>
									</div>
									<div class="row">
										<div class="col-md-6">
											<h6>Discrepancias</h6>
											<div style="max-height:400px; overflow:auto;">
												${discrepancias.map(d => `
													<div class="border p-2 mb-2">
														<strong>${d.campo}</strong> — <span class="badge badge-${d.gravedad === 'alta' ? 'danger' : d.gravedad === 'media' ? 'warning' : 'secondary'}">${d.gravedad}</span>
														<div><em>Declarado:</em> ${d.valor_declarado}</div>
														<div><em>Oficial:</em> ${d.valor_oficial}</div>
														<div class="text-muted small">${d.descripcion || ''}</div>
													</div>
												`).join('')}
											</div>
										</div>
										<div class="col-md-6">
											<h6>Coincidencias</h6>
											<div style="max-height:400px; overflow:auto;">
												${coincidencias.map(c => `
													<div class="border p-2 mb-2">
														<strong>${c.campo}</strong>
														<div>${c.valor}</div>
													</div>
												`).join('')}
											</div>
										</div>
									</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
								</div>
								</div>
							</div>
						</div>`;

				$('#modalComparacion').remove();
				$('body').append(html);
				$('#modalComparacion').modal('show');
			})
			.catch(err => {
				console.error('❌ Error en compararConExpediente:', err);
				alert('Error al comparar: ' + err.message);
			});
		}

		async function procesarConGeminiJS(documentosOriginales, dni) {
			console.log('🤖 Iniciando procesamiento con Gemini en JavaScript...');
			
			try {
				const apiKey = 'AIzaSyB2QjeyKlwcZ2aYdwFJ5wvLpFqErbURkVc';
				const modeloUrl = `https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash-lite:generateContent?key=${apiKey}`;
				
				const systemPrompt = `Eres un asistente especializado en procesar documentos oficiales españoles (IRPF, catastro, vida laboral, etc.) provenientes de la API de Belender.

TAREA: Consolida múltiples documentos JSON en UN SOLO JSON estructurado con los siguientes campos:

{
