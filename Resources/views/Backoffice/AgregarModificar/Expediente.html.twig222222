        "nombre_completo": "",
        "dni": "",
        "fecha_nacimiento": ""
    },
    "domicilio": {
        "calle": "",
        "numero": "",
        "piso": "",
        "codigo_postal": "",
        "municipio": "",
        "provincia": ""
    },
    "situacion_laboral": {
        "situacion": "",
        "empresa": "",
        "puesto": ""
    },
    "ingresos": {
        "total_bruto": 0,
        "total_neto": 0,
        "fuentes": []
    },
    "patrimonio": {
        "inmuebles": [],
        "vehiculos": [],
        "cuentas_bancarias": []
    },
    "cargas_financieras": {
        "hipotecas": [],
        "prestamos": [],
        "obligaciones": []
    },
    "informacion_fiscal": {
        "base_imponible": 0,
        "impuesto_a_pagar": 0,
        "porcentaje_retencion": 0
    },
    "metadatos": {
        "fecha_procesamiento": "",
        "documentos_origen": []
    }
}

IMPORTANTE: 
- Extrae SOLO los datos que existan en los documentos
- Si un campo no tiene información, déjalo vacío o como null
- Deduplica información repetida
- Detecta inconsistencias entre documentos
- Devuelve SOLO JSON válido, sin markdown ni explicaciones`;
				
				const mensaje = `DOCUMENTOS A CONSOLIDAR:\n\n${JSON.stringify(documentosOriginales, null, 2)}`;
				
				const body = {
					contents: [
						{
							parts: [
								{
									text: `${systemPrompt}\n\nMENSAJE:\n${mensaje}`
								}
							]
						}
					],
					generationConfig: {
						temperature: 0.7,
						topK: 40,
						topP: 0.95,
						maxOutputTokens: 8000
					}
				};
				
				console.log('📤 Enviando petición a Gemini...');
				const response = await fetch(modeloUrl, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify(body)
				});
				
				if (!response.ok) {
					const error = await response.text();
					console.error('❌ Error HTTP:', response.status, error);
					return null;
				}
				
				const data = await response.json();
				console.log('📥 Respuesta recibida de Gemini');
				
				if (data.candidates && data.candidates[0]?.content?.parts[0]?.text) {
					let texto = data.candidates[0].content.parts[0].text;
					
					// Limpiar markdown si existe
					texto = texto.replace(/^```json\n?/i, '').replace(/\n?```$/i, '').trim();
					
					try {
						const jsonConsolidado = JSON.parse(texto);
						console.log('✅ Datos consolidados exitosamente con IA');
						return jsonConsolidado;
					} catch (e) {
						console.error('❌ Error al parsear JSON de Gemini:', e);
						console.log('Texto recibido:', texto.substring(0, 200));
						return null;
					}
				}
				
				console.error('⚠️ Respuesta inesperada de Gemini:', JSON.stringify(data).substring(0, 300));
				return null;
				
			} catch (error) {
				console.error('❌ Error en procesarConGeminiJS:', error);
				return null;
			}
		}

		function verDocumentoJSON(dni, nombreArchivo) 
		{
			console.log('🔍 Iniciando verDocumentoJSON');
			console.log('🔍 DNI recibido:', dni);
			console.log('🔍 Tipo DNI:', typeof dni);
			console.log('🔍 Nombre archivo recibido:', nombreArchivo);
			console.log('🔍 Tipo nombre:', typeof nombreArchivo);
			
			// Verificar que los parámetros no estén vacíos
			if (!dni || !nombreArchivo) {
				alert('Error: DNI o nombre de archivo no están definidos.\nDNI: ' + dni + '\nArchivo: ' + nombreArchivo);
				return;
			}
			
			// Construir URL base
			const baseUrl = '{{ path('obtener_documento') }}';
			console.log('🔍 URL base:', baseUrl);
			
			// Crear URLSearchParams para asegurar encoding correcto
			const params = new URLSearchParams();
			params.append('dni', dni);
			params.append('archivo', nombreArchivo); // ⚠️ Cambio: 'nombre' → 'archivo'
			
			const fullUrl = baseUrl + '?' + params.toString();
			console.log('🔍 URL completa:', fullUrl);
			console.log('🔍 Parámetros:', params.toString());
			
			fetch(fullUrl, {
				method: 'GET',
				headers: {
					'Accept': 'application/json',
					'X-Requested-With': 'XMLHttpRequest'
				}
			})
				.then(response => {
					console.log('📡 Response status:', response.status);
					console.log('📡 Response statusText:', response.statusText);
					console.log('📡 Response headers:', [...response.headers.entries()]);
					
					if (!response.ok) {
						return response.text().then(text => {
							console.error('❌ Response body:', text);
							let errorMsg = text;
							try {
								const errorJson = JSON.parse(text);
								errorMsg = errorJson.error || text;
							} catch (e) {
								// Si no es JSON, usar el texto tal cual
							}
							throw new Error('HTTP ' + response.status + ': ' + errorMsg);
						});
					}
					return response.json();
				})
				.then(data => {
					console.log('✅ Contenido JSON recibido:', data);
					
					// Mostrar en modal
					const contenidoFormateado = JSON.stringify(data, null, 2);
					const modalHtml = `
						<div class="modal fade" id="modalDocumentoJSON" tabindex="-1" role="dialog">
							<div class="modal-dialog modal-lg" role="document">
								<div class="modal-content">
									<div class="modal-header bg-primary text-white">
										<h5 class="modal-title"><i class="fas fa-file-code mr-2"></i>Documento JSON: ${nombreArchivo}</h5>
										<button type="button" class="close text-white" data-dismiss="modal">
											<span>&times;</span>
										</button>
									</div>
									<div class="modal-body">
										<pre style="max-height: 500px; overflow-y: auto; background-color: #f8f9fa; padding: 15px; border-radius: 5px; border: 1px solid #dee2e6; font-size: 13px;">${contenidoFormateado}</pre>
									</div>
									<div class="modal-footer">
										<button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fas fa-times mr-2"></i>Cerrar</button>
									</div>
								</div>
							</div>
						</div>
					`;
					
					// Eliminar modal anterior si existe
					$('#modalDocumentoJSON').remove();
					
					// Agregar y mostrar nuevo modal
					$('body').append(modalHtml);
					$('#modalDocumentoJSON').modal('show');
				})
				.catch(error => {
					console.error('❌ Error completo:', error);
					alert('Error al cargar el documento JSON:\n\n' + error.message + '\n\nDNI: ' + dni + '\nArchivo: ' + nombreArchivo + '\n\nRevisa la consola del navegador (F12) para más detalles.');
				});
		}

		function mostrarDocumentosPestanaBelender(documentos, dni) 
		{
			const contenedor = document.getElementById('contenedor-documentos-belender-tab');
			const acordeon = document.getElementById('acordeon-documentos-belender');
			
			// Mostrar el acordeón si hay documentos
			if (documentos && documentos.length > 0) 
			{
				acordeon.style.display = 'block';
				console.log('📂 Mostrando acordeón de documentos Belender');
			} 
			else 
			{
				console.log('ℹ️ No hay documentos para mostrar el acordeón de documentos Belender');
				acordeon.style.display = 'none';
				return;
			}
			
			let html = `
				<!-- Botón para consolidar documentos con IA -->
				<div class="mb-3">
					<button type="button" id="btn-consolidar-belender" class="btn btn-warning btn-block" onclick="consolidarDocumentosBelender()">
						<i class="fas fa-robot mr-2"></i>Consolidar Documentos con IA
					</button>
					<small class="form-text text-muted">
						La IA analizará todos los documentos JSON y extraerá la información relevante en un formato unificado.
					</small>
				</div>
				<hr>
				<div class="table-responsive">
					<table class="table table-hover table-striped table-sm">
						<thead style="background-color: #f5f5f5;">
							<tr>
								<th><i class="fas fa-file mr-2"></i>Nombre</th>
								<th><i class="fas fa-tag mr-2"></i>Tipo</th>
								<th><i class="fas fa-info-circle mr-2"></i>Estado</th>
								<th><i class="fas fa-weight mr-2"></i>Tamaño</th>
								<th><i class="fas fa-cog mr-2"></i>Acciones</th>
							</tr>
						</thead>
						<tbody>
			`;

			documentos.forEach((doc) => {
				const estadoBadge = obtenerBadgeEstado(doc.estado);
				const tamaño = doc.tipo === 'json' ? 'N/A' : formatearBytes(doc.tamaño);
				const acciones = generarAcciones(doc, dni);

				html += `
					<tr style="vertical-align: middle;">
						<td><strong>${doc.nombre}</strong></td>
						<td><span class="badge" style="background-color: #0056b3; color: white;">${doc.tipo.toUpperCase()}</span></td>
						<td>${estadoBadge}</td>
						<td>${tamaño}</td>
						<td>${acciones}</td>
					</tr>
				`;
			});

			html += `
				</tbody>
					</table>
				</div>
			`;

			contenedor.innerHTML = html;
			// Mantener el contenedor contraído (con d-none)
			contenedor.classList.add('d-none');
			
			// Consolidar automáticamente al cargar los documentos
			console.log('🤖 Iniciando consolidación automática...');
			setTimeout(() => {
				consolidarDocumentosBelender();
			}, 1000);
		}
	</script>
	<script src="{{ asset('assets/js/custom/Element.hasAttribute.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/expediente.min.js') }}"></script>
{% endblock %}
