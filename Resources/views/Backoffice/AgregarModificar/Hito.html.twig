{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarHito '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarHito) }}
			<div class="form-row">
				<div class="form-group col-sm">
					{{ form_label(agregarModificarHito.nombre) }}
					{{ form_widget(agregarModificarHito.nombre) }}
					{{ form_errors(agregarModificarHito.nombre) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col-sm">
					{{ form_label(agregarModificarHito.orden) }}
					{{ form_widget(agregarModificarHito.orden) }}
					{{ form_errors(agregarModificarHito.orden) }}
				</div>
				<div class="form-group col-sm">
					{{ form_label(agregarModificarHito.repetible) }}
					{{ form_widget(agregarModificarHito.repetible) }}
					{{ form_errors(agregarModificarHito.repetible) }}
				</div>
				<div class="form-group col-sm">
					{{ form_label(agregarModificarHito.hitoCondicional) }}
					{{ form_widget(agregarModificarHito.hitoCondicional) }}
					{{ form_errors(agregarModificarHito.hitoCondicional) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success waves-effect mr-auto" href="{{ path('lista_fases_hitos_campos_opciones') }}">Volver</a>
				{{ form_label(agregarModificarHito.reset) }}
				{{ form_widget(agregarModificarHito.reset) }}
				{{ form_label(agregarModificarHito.submit) }}
				{{ form_widget(agregarModificarHito.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_widget(agregarModificarHito.idFase) }}
			{{ form_end(agregarModificarHito) }}
		</div>
	</div>
{% endblock %}