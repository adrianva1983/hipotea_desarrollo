{% extends '@App/Backoffice/base.html.twig' %}
{% block body %}
    <div class="card">
        <div class="card-body">
            {% include '@App/Backoffice/MensajeAlerta.html.twig' %}
            <h4 class="card-title">{{ titulo }}</h4>

            {% if error is defined and error %}
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-triangle mr-1"></i>
                    {{ error }}
                </div>
            {% endif %}

            {# ---------------------------------------------------------------- #}
            {# Modo CREAR: formulario para generar una nueva vista               #}
            {# ---------------------------------------------------------------- #}
            {% if modo == 'crear' %}
                <form method="post" id="formulario-agente-vistas">
                    <div class="form-row">
                        <div class="form-group col-sm-8">
                            <label for="ruta">Ruta relativa del nuevo fichero</label>
                            <input type="text"
                                   class="form-control"
                                   id="ruta"
                                   name="ruta"
                                   placeholder="Backoffice/Lista/MiNuevaVista.html.twig"
                                   value="{{ ruta }}"
                                   required>
                            <small class="form-text text-muted">
                                Ruta relativa dentro del directorio <code>Resources/views/</code>.
                            </small>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="descripcion">Descripción de la vista a generar</label>
                        <textarea class="form-control"
                                  id="descripcion"
                                  name="descripcion"
                                  rows="5"
                                  placeholder="Describe en detalle el contenido y la estructura de la vista que quieres crear…"
                                  required>{{ descripcion }}</textarea>
                        <small class="form-text text-muted">
                            Cuanto más detallada sea la descripción, mejor será el resultado generado por la IA.
                        </small>
                    </div>

                    {% if codigo is defined and codigo %}
                        {# Mostrar el código generado para revisión antes de guardar #}
                        <div class="form-group">
                            <label for="codigo_generado">
                                Código generado por la IA
                                <small class="text-muted">(puedes editarlo antes de guardar)</small>
                            </label>
                            <textarea class="form-control font-monospace"
                                      id="codigo_generado"
                                      name="codigo_generado"
                                      rows="20"
                                      style="font-family: monospace; font-size: 0.85rem;">{{ codigo }}</textarea>
                        </div>
                        <div class="d-flex">
                            <a class="btn btn-secondary mr-auto" href="{{ path('agente_vistas_index') }}">Cancelar</a>
                            <button type="submit" name="accion" value="generar" class="btn btn-outline-primary mr-2">
                                <i class="fas fa-sync-alt mr-1"></i>Regenerar con IA
                            </button>
                            <button type="submit" name="accion" value="guardar" class="btn btn-success">
                                <i class="fas fa-save mr-1"></i>Guardar vista
                            </button>
                        </div>
                    {% else %}
                        <div class="d-flex">
                            <a class="btn btn-secondary mr-auto" href="{{ path('agente_vistas_index') }}">Cancelar</a>
                            <button type="submit" name="accion" value="generar" class="btn btn-primary">
                                <i class="fas fa-magic mr-1"></i>Generar vista con IA
                            </button>
                        </div>
                    {% endif %}
                </form>

            {# ---------------------------------------------------------------- #}
            {# Modo MODIFICAR: formulario para modificar una vista existente     #}
            {# ---------------------------------------------------------------- #}
            {% elseif modo == 'modificar' %}
                <form method="post" id="formulario-agente-vistas">
                    <div class="form-row">
                        <div class="form-group col-sm-8">
                            <label for="ruta">Vista seleccionada</label>
                            <input type="text"
                                   class="form-control"
                                   id="ruta"
                                   name="ruta"
                                   value="{{ ruta }}"
                                   readonly>
                        </div>
                    </div>

                    {% if codigoActual is defined and codigoActual %}
                        <div class="form-group">
                            <label for="codigo_actual">
                                Código actual de la vista
                                <small class="text-muted">(solo lectura)</small>
                            </label>
                            <textarea class="form-control font-monospace"
                                      id="codigo_actual"
                                      rows="12"
                                      readonly
                                      style="font-family: monospace; font-size: 0.85rem; background-color: #f8f9fa;">{{ codigoActual }}</textarea>
                        </div>
                    {% endif %}

                    <div class="form-group">
                        <label for="instrucciones">Instrucciones de modificación</label>
                        <textarea class="form-control"
                                  id="instrucciones"
                                  name="instrucciones"
                                  rows="4"
                                  placeholder="Describe los cambios que quieres aplicar a la vista…"
                                  required>{{ instrucciones }}</textarea>
                        <small class="form-text text-muted">
                            Por ejemplo: «Añade una columna "Fecha de creación" a la tabla» o
                            «Cambia el título de la tarjeta a "Lista de Clientes"».
                        </small>
                    </div>

                    {% if codigo is defined and codigo %}
                        <div class="form-group">
                            <label for="codigo_generado">
                                Código modificado por la IA
                                <small class="text-muted">(puedes editarlo antes de guardar)</small>
                            </label>
                            <textarea class="form-control font-monospace"
                                      id="codigo_generado"
                                      name="codigo_generado"
                                      rows="20"
                                      style="font-family: monospace; font-size: 0.85rem;">{{ codigo }}</textarea>
                        </div>
                        <div class="d-flex">
                            <a class="btn btn-secondary mr-auto" href="{{ path('agente_vistas_index') }}">Cancelar</a>
                            <button type="submit" name="accion" value="generar" class="btn btn-outline-primary mr-2">
                                <i class="fas fa-sync-alt mr-1"></i>Regenerar con IA
                            </button>
                            <button type="submit" name="accion" value="guardar" class="btn btn-success">
                                <i class="fas fa-save mr-1"></i>Guardar cambios
                            </button>
                        </div>
                    {% else %}
                        <div class="d-flex">
                            <a class="btn btn-secondary mr-auto" href="{{ path('agente_vistas_index') }}">Cancelar</a>
                            <button type="submit" name="accion" value="generar" class="btn btn-primary">
                                <i class="fas fa-magic mr-1"></i>Modificar vista con IA
                            </button>
                        </div>
                    {% endif %}
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
{% block customscripts %}
    {{ parent() }}
    <script>
        (function () {
            var formulario = document.getElementById('formulario-agente-vistas');
            if (!formulario) { return; }

            // Capturar el botón pulsado antes del envío del formulario
            var botonPulsado = null;
            formulario.addEventListener('click', function (e) {
                if (e.target && e.target.type === 'submit') {
                    botonPulsado = e.target;
                }
            });

            // Mostrar indicador de carga mientras la IA procesa la petición
            formulario.addEventListener('submit', function () {
                if (botonPulsado && botonPulsado.value === 'generar') {
                    botonPulsado.disabled = true;
                    botonPulsado.innerHTML = '<span class="spinner-border spinner-border-sm mr-1" role="status" aria-hidden="true"></span>Procesando…';
                }
            });
        }());
    </script>
{% endblock %}
