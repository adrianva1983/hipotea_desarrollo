{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarExpediente '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/select2/dist/css/select2.min.css') }}" rel="stylesheet">
	{% if incluir_dropify is defined and incluir_dropify %}
		<link href="{{ asset('assets/node_modules/dropify/dist/css/dropify.min.css') }}" rel="stylesheet">
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<link href="{{ asset('assets/node_modules/bootstrap-datepicker/bootstrap-datepicker.min.css') }}" rel="stylesheet">
	{% endif %}
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/css/select2.min.css" rel="stylesheet">
	{% if incluir_dropify is defined and incluir_dropify %}
		<link href="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.1/css/dropify.min.css" rel="stylesheet">
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" rel="stylesheet">
	{% endif %}
{% endblock %}
{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/select2.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/css/custom/expediente.min.css') }}" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/select2/dist/js/select2.full.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/i18n/es.js') }}"></script>
	{% if incluir_dropify is defined and incluir_dropify %}
		<script src="{{ asset('assets/node_modules/dropify/dist/js/dropify.min.js') }}"></script>
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<script src="{{ asset('assets/node_modules/bootstrap-datepicker/bootstrap-datepicker.min.js') }}"></script>
		<script src="{{ asset('assets/node_modules/bootstrap-datepicker/locales/bootstrap-datepicker.es.min.js') }}"></script>
	{% endif %}
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/select2.full.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/i18n/es.js"></script>
	{% if incluir_dropify is defined and incluir_dropify %}
		<script src="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.1/js/dropify.min.js"></script>
	{% endif %}
	{% if incluir_datepicker is defined and incluir_datepicker %}
		<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/locales/bootstrap-datepicker.es.min.js"></script>
	{% endif %}
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script>
		{% if nombres_fichero is defined %}
		function nombresFicheroFuncion() {
			return JSON.parse({{ nombres_fichero|json_encode|raw }});
		}

		function rutaBorrarFicheroExpedienteAJAX() {
			return '{{ path('borrar_fichero_expediente_ajax') }}';
		}
		{% endif %}
		function rutaObtenerAgentesColaboradoresAJAX() {
			return '{{ path('obtener_agentes_colaboradores_ajax') }}';
		}

		function actualizarSeguimientoExpedienteAJAX() {
			return '{{ path('actualizar_seguimiento_expediente_ajax') }}';
		}

		function obtenerDocumentosAdmin(idHitoExpediente) 
		{
			try {
				const input = document.getElementById("belenderNif_" + idHitoExpediente);
				const dni = input ? String(input.value).trim() : '';
				if (!dni) {
					alert('No se ha encontrado el DNI del cliente');
					return;
				} 
				console.log('Iniciando solicitud de documentos para DNI:', dni);
				// Mostrar overlay mientras se hace la petición
				showBelenderSyncOverlay('Solicitando documentos a Belender...');

				fetch(`{{ path('document_request') }}?dni=${encodeURIComponent(dni)}`)
					.then(response => response.json())
					.then(data => {
						if (data && data.widget_url_boxed) 
						{
							console.log('✅ Respuesta recibida:', data);
							// Cargar widget en iframe y mostrar modal
							const iframe = document.getElementById('widgetIframe');
							if (iframe) iframe.src = data.widget_url_boxed;
							try { $('#modal-widget-blender').modal('show'); } catch(e) {}
							// Guardar referencia para el polling y comprobar estado
							if (data.request_id) localStorage.setItem('request_id', data.request_id);
							localStorage.setItem('dni', dni);
							localStorage.setItem('belender_last_hito', idHitoExpediente);
							verificarEstadoDocumentos();
							// ocultar overlay cuando el modal esté visible
							hideBelenderSyncOverlay();
						} else {
			
							hideBelenderSyncOverlay();
							alert('Error en la solicitud de documentos: ' + (data && data.error ? data.error : 'respuesta inesperada'));
						}
					})
					.catch(err => {
						console.error('❌ Error en request a Belender:', err);
						hideBelenderSyncOverlay();
						alert('Error al solicitar documentos: ' + (err.message || err));
					});
			} catch (err) {
				console.error('Error en obtenerDocumentosAdmin:', err);
				alert('Error inesperado al iniciar la solicitud de documentos');
			}
		} 
		
		// ====== FUNCIONES PARA CIRBE ======
		function solicitarCirbeDocumentos(idHitoExpediente) {
			try {
				const input = document.getElementById("belenderNif_" + idHitoExpediente);
				const dni = input ? String(input.value).trim() : '';
				
				if (!dni) {
					alert('No se ha encontrado el DNI del cliente');
					return;
				}
				
				console.log('🚀 Iniciando solicitud CIRBE para:', dni);
				showBelenderSyncOverlay('Solicitando informe CIRBE...');
				
				// Obtener nombre y apellidos desde inputs ocultos del formulario
				const nombreInput = document.querySelector('input[name*="nombre"]');
				const apellido1Input = document.querySelector('input[name*="apellido1"]');
				const apellido2Input = document.querySelector('input[name*="apellido2"]');
				
				const nombre = nombreInput?.value || '';
				const apellido1 = apellido1Input?.value || '';
				const apellido2 = apellido2Input?.value || '';
				
				if (!nombre || !apellido1) {
					hideBelenderSyncOverlay();
					alert('⚠️ Por favor asegúrate que la solicitud tiene nombre y al menos un apellido en el sistema');
					return;
				}
				
				const params = new URLSearchParams({
					dni: dni,
					nombre: nombre,
					apellido1: apellido1,
					apellido2: apellido2 || ''
				});
				
				fetch(`{{ path('solicitar_cirbe') }}?${params}`)
					.then(response => response.json())
					.then(data => {
						if (data.status === 'success') {
							console.log('✅ CIRBE solicitado:', data);
							// Guardar IDs para descarga posterior
							localStorage.setItem('cirbe_request_id', data.request_id);
							localStorage.setItem('cirbe_funder_id', data.funder_id);
							localStorage.setItem('cirbe_dni', dni);
							localStorage.setItem('cirbe_last_hito', idHitoExpediente);
							
							hideBelenderSyncOverlay();
							alert('✅ Solicitud CIRBE realizada correctamente.\n\n📧 Espera a recibir las credenciales de acceso (usuario/contraseña) en tu email.\n\nUna vez recibidas, usa el botón "Enviar Credenciales CIRBE" para continuar con el proceso.');
						} else {
							hideBelenderSyncOverlay();
							console.error('❌ Error CIRBE:', data.error);
							alert('❌ Error: ' + (data.error || 'Error desconocido'));
						}
					})
					.catch(err => {
						console.error('❌ Error solicitud CIRBE:', err);
						hideBelenderSyncOverlay();
						alert('❌ Error al solicitar CIRBE: ' + err.message);
					});
			} catch (err) {
				console.error('Error en solicitarCirbeDocumentos:', err);
				hideBelenderSyncOverlay();
				alert('Error inesperado');
			}
		}

		function enviarCredencialesCirbeForm(idHitoExpediente) {
			const requestId = localStorage.getItem('cirbe_request_id');
			const funderId = localStorage.getItem('cirbe_funder_id');
			
			if (!requestId || !funderId) {
				alert('⚠️ Primero debes solicitar el informe CIRBE');
				return;
			}
			
			const password = prompt('🔐 Introduce la contraseña CIRBE que recibiste por email:');
			if (!password || password.trim() === '') {
				alert('Cancelado: No se proporcionó contraseña');
				return;
			}
			
			showBelenderSyncOverlay('Enviando credenciales CIRBE...');
			
			const payload = {
				funder_id: funderId,
				request_id: requestId,
				credential_password: password.trim()
			};
			
			fetch(`{{ path('enviar_credenciales_cirbe') }}`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload)
			})
			.then(response => response.json())
			.then(data => {
				hideBelenderSyncOverlay();
				if (data.status === 'success') {
					console.log('✅ Credenciales CIRBE enviadas');
					alert('✅ Credenciales enviadas correctamente.\n\n⏳ CIRBE procesará la solicitud (puede tardar minutos u horas).\n\nUna vez procesado, recibirás una notificación para descargar el informe.');
				} else {
					console.error('❌ Error:', data.error);
					alert('❌ Error: ' + (data.error || 'Error desconocido'));
				}
			})
			.catch(err => {
				hideBelenderSyncOverlay();
				console.error('Error:', err);
				alert('❌ Error: ' + err.message);
			});
		}

		function descargarYAdjuntarCirbe(idHitoExpediente) {
			const requestId = localStorage.getItem('cirbe_request_id');
			const funderId = localStorage.getItem('cirbe_funder_id');
			const dni = localStorage.getItem('cirbe_dni');
			
			if (!requestId || !funderId || !dni) {
				alert('⚠️ Falta información CIRBE. Solicita primero el informe.');
				return;
			}
			
			showBelenderSyncOverlay('Descargando informe CIRBE...');
			
			const params = new URLSearchParams({
				funder_id: funderId,
				request_id: requestId,
				dni: dni
			});
			
			fetch(`{{ path('descargar_cirbe') }}?${params}`)
				.then(response => response.json())
				.then(data => {
					hideBelenderSyncOverlay();
					if (data.success) {
						console.log('✅ CIRBE descargado:', data);
						alert('✅ Informe descargado correctamente.\n\nAdjuntando documentos al expediente...');
						adjuntarArchivosCirbeAlExpediente(idHitoExpediente);
					} else {
						console.error('❌ Error:', data.error);
						alert('❌ Error: ' + (data.error || 'Error desconocido'));
					}
				})
				.catch(err => {
					hideBelenderSyncOverlay();
					console.error('Error:', err);
					alert('❌ Error al descargar: ' + err.message);
				});
		}

		function adjuntarArchivosCirbeAlExpediente(idHitoExpediente) {
			const dni = localStorage.getItem('cirbe_dni');
			
			// Buscar id_expediente desde el formulario
			let idExpediente = document.querySelector('input[name*="idExpediente"][type="hidden"]')?.value;
			if (!idExpediente) {
				const anyInput = document.querySelector('input[name*="idExpediente"]');
				if (anyInput) idExpediente = anyInput.value;
			}
			
			if (!dni || !idExpediente) {
				alert('❌ Falta DNI o ID Expediente');
				console.error('dni:', dni, 'idExpediente:', idExpediente);
				return;
			}
			
			showBelenderSyncOverlay('Adjuntando documentos CIRBE...');
			
			const payload = {
				dni: dni,
				id_expediente: idExpediente,
				files: ['CIRBE.pdf', 'ICI.pdf', 'DEUDA.pdf', 'PRÉSTAMOS.pdf']
			};
			
			console.log('📤 Enviando payload CIRBE:', payload);
			
			fetch(`{{ path('adjuntar_archivos_cirbe') }}`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload)
			})
			.then(response => response.json())
			.then(data => {
				hideBelenderSyncOverlay();
				if (data.success) {
					console.log('✅ CIRBE adjuntados:', data);
					const mensaje = '✅ Documentos CIRBE adjuntados exitosamente\n\n' 
						+ '📄 ' + data.created.length + ' archivo(s) procesado(s)';
					if (data.errors && data.errors.length > 0) {
						alert(mensaje + '\n\n⚠️ Advertencias: ' + data.errors.join(', '));
					} else {
						alert(mensaje);
					}
					// Recargar página para ver cambios
					setTimeout(() => location.reload(), 1500);
				} else {
					console.error('❌ Errores:', data.errors);
					alert('❌ Error: ' + (data.errors ? data.errors.join(', ') : 'Error desconocido'));
				}
			})
			.catch(err => {
				hideBelenderSyncOverlay();
				console.error('Error adjuntar CIRBE:', err);
				alert('❌ Error: ' + err.message);
			});
		}
		
