					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf', 'trimestres',
					'certificado estado civil', 'estado civil',
					'otros', 'documentación adicional',
					'100', '111', '130', '131', '347', '390',
					'situación aeat', 'situaciónaeat', 'aeat',
					'situación ss', 'situacións', 'ss', 'cotizacion'
				],
				funcionario: [
					// SIEMPRE: DNI, Renta, Certificado Retenciones, Vida Laboral, Movimientos Bancarios,
					// Contrato Alquiler, Recibos Préstamos, Cuadro Amortización, Convenio, IVA-IRPF, Estado Civil, Otros
					// ADICIONAL: Nóminas (como empleado público)
					'dni', 'nie', 'tarjeta residencia', 'residencia',
					'nóminas', 'nomina', '3 últimas nóminas',
					'renta', 'certificado retenciones', 'retenciones',
					'vida laboral', 'laboral', 'laboral_v2',
					'movimientos bancarios', 'movimientos', 'bancarios',
					'contrato alquiler', 'alquiler',
					'recibos préstamos', 'recibos',
					'cuadro amortización', 'amortización',
					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf',
					'certificado estado civil', 'estado civil',
					'otros', 'documentación adicional',
					'100', '111', '130', '131', '347', '390',
					'cotizacion', 'censo'
				],
				parado: [
					// SIEMPRE: DNI, Renta, Certificado Retenciones, Vida Laboral, Movimientos Bancarios,
					// Contrato Alquiler, Recibos Préstamos, Cuadro Amortización, Convenio, IVA-IRPF, Estado Civil, Otros
					'dni', 'nie', 'tarjeta residencia', 'residencia',
					'renta', 'certificado retenciones', 'retenciones',
					'vida laboral', 'laboral', 'laboral_v2',
					'movimientos bancarios', 'movimientos', 'bancarios',
					'contrato alquiler', 'alquiler',
					'recibos préstamos', 'recibos',
					'cuadro amortización', 'amortización',
					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf',
					'certificado estado civil', 'estado civil',
					'otros', 'documentación adicional',
					'100', '111', '130', '131', '347', '390', 'censo'
				],
				estudiante: [
					// SIEMPRE: DNI, Renta, Certificado Retenciones, Vida Laboral, Movimientos Bancarios,
					// Contrato Alquiler, Recibos Préstamos, Cuadro Amortización, Convenio, IVA-IRPF, Estado Civil, Otros
					'dni', 'nie', 'tarjeta residencia', 'residencia',
					'renta', 'certificado retenciones', 'retenciones',
					'vida laboral', 'laboral', 'laboral_v2',
					'movimientos bancarios', 'movimientos', 'bancarios',
					'contrato alquiler', 'alquiler',
					'recibos préstamos', 'recibos',
					'cuadro amortización', 'amortización',
					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf',
					'certificado estado civil', 'estado civil',
					'otros', 'documentación adicional',
					'100', '111', '130', '131', '347', '390', 'censo'
				]
			};

			// Si no hay perfil, mostrar todos los campos (comportamiento seguro)
			if (!perfil) {
				console.log('ℹ️  Sin perfil definido, mostrando todos los campos del hito 31');
				mostrarTodosCampos();
				return;
			}

			// Obtener palabras clave para este perfil
			const palabrasclave = palabrasclavePorPerfil[perfil] || [];
			console.log('📋 Palabras clave para', perfil + ':', palabrasclave);

			// Identificar IDs de campos requeridos
			const idsRequeridos = [];
			for (const [idCampo, nombreCampo] of Object.entries(mapaCampos)) {
				const nombreNorm = nombreCampo.toLowerCase();
				for (const palabra of palabrasclave) {
					if (nombreNorm.includes(palabra.toLowerCase())) {
						idsRequeridos.push(parseInt(idCampo));
						console.log('✅ Campo requerido:', idCampo, '-', nombreCampo);
						break;
					}
				}
			}

			console.log('📊 IDs de campos requeridos:', idsRequeridos);

			// Ocultar/mostrar campos según si están en la lista de requeridos
			// Solo dentro del hito 31
			const todosCampos = hitoDiv.querySelectorAll('[data-id-campo-hito]');
			console.log('📊 Total de campos encontrados en hito 31:', todosCampos.length);

			todosCampos.forEach(campo => {
				const idCampo = parseInt(campo.getAttribute('data-id-campo-hito'));
				const debesMostrarse = idsRequeridos.includes(idCampo);
				
				if (debesMostrarse) {
					campo.classList.remove('d-none');
					console.log('✅ Campo', idCampo, 'mostrado para', perfil);
				} else {
					campo.classList.add('d-none');
					console.log('❌ Campo', idCampo, 'ocultado para', perfil);
				}
			});
		}

		function mostrarTodosCampos() {
			const hitoDiv = document.querySelector('[data-hito-expediente="31"]');
			if (!hitoDiv) return;
			
			const todosCampos = hitoDiv.querySelectorAll('[data-id-campo-hito]');
			todosCampos.forEach(campo => {
				// Solo mostrar si no está oculto por permisos de rol
				if (!campo.classList.contains('d-none-rol')) {
					campo.classList.remove('d-none');
				}
			});
			console.log('📊 Todos los campos del hito 31 visibles');
		}

		// Ejecutar filtrado al cargar la página (solo si estamos en hito 31)
		document.addEventListener('DOMContentLoaded', function() {
			// Verificar si el hito 31 está presente en la página
			const hitoDiv = document.querySelector('[data-hito-expediente="31"]');
			if (hitoDiv) {
				filtrarCamposSegunPerfil();
				
				// Re-ejecutar filtrado cuando cambie el campo de "Estado Laboral"
				const estadoLaboralInput = document.getElementById('campo_hito_expediente_0_690_0_valor');
				if (estadoLaboralInput) {
					estadoLaboralInput.addEventListener('change', filtrarCamposSegunPerfil);
				}
			}
		});

		
		function updateBelenderInfoModal(mensaje = '', status = null) 
		{
			const modal = document.getElementById('belender-info-modal');
			if (!modal) return;
			const msgEl = modal.querySelector('#belender-info-message');
			const spinner = modal.querySelector('#belender-info-spinner');
			if (msgEl) msgEl.innerHTML = mensaje;
			if (status === 'success') {
				if (spinner) spinner.classList.remove('spinner-border');
				if (spinner) spinner.classList.add('d-none');
				if (msgEl) msgEl.insertAdjacentHTML('afterbegin', '<i class="fas fa-check-circle" style="color:green;margin-right:8px"></i>');
				// No auto-hide: dejar modal abierto para mostrar resultado final
			} else if (status === 'error') {
				if (spinner) spinner.classList.remove('spinner-border');
				if (spinner) spinner.classList.add('d-none');
				if (msgEl) msgEl.insertAdjacentHTML('afterbegin', '<i class="fas fa-times-circle" style="color:red;margin-right:8px"></i>');
				// No auto-hide: permitir al usuario ver el error
			}
		}

		// Auto adjuntar e insertar una lista de PDFs: adjunta en backend y luego descarga blob->File->asigna input
		async function autoAdjuntarYInsertarLista(pdfs) {
			if (!Array.isArray(pdfs) || pdfs.length === 0) return;
			const dni = localStorage.getItem('dni') || '';
			if (!dni) console.warn('autoAdjuntar: no hay dni en localStorage');
			// Mostrar modal de progreso si no existe
			showBelenderInfoModal('Procesando documentos...');
			// Inicializar lista y barra
			const progressList = document.getElementById('belender-progress-list');
			const progressBar = document.getElementById('belender-info-progressbar');
			if (progressList) progressList.innerHTML = '';
			let index = 0;
			for (const p of pdfs) {
				index++;
				const progressPercent = Math.round((index - 1) / pdfs.length * 100);
				if (progressBar) progressBar.style.width = progressPercent + '%';
				// Añadir item en la lista
				let li = null;
				if (progressList) {
					li = document.createElement('li');
					li.textContent = (p.name || (typeof p === 'string' ? p.split('/').pop() : 'archivo')) + ' — Pendiente';
					li.style.marginBottom = '6px';
					progressList.appendChild(li);
				}
				try {
					const name = p.name || (typeof p === 'string' ? p.split('/').pop() : null);
					const url = p.url || (typeof p === 'string' ? p : null);
					if (!name) {
						if (li) li.textContent = (li.textContent || '') + ' — Nombre no disponible';
						continue;
					}

					// Determinar id de fila correspondiente y helper para actualizar estado en la tabla
					const rowIndex = index - 1;
					const rowStatusId = 'belender-status-row-' + rowIndex;
					function setRowStatus(text) {
						try { const el = document.getElementById(rowStatusId); if (el) el.textContent = text; } catch(e){}
					}

					// Detectar ids y selectores desde DOM
					const detected = (typeof detectarIdsDesdeDOM === 'function') ? detectarIdsDesdeDOM() : {};
					const idFromView = (typeof obtenerIdExpedienteDesdeVista === 'function') ? obtenerIdExpedienteDesdeVista() : null;
					const idHitoExpediente = localStorage.getItem('belender_last_hito') || detected.id_campo_hito_expediente || null;
					const payload = {
						id_campo_hito: detected.id_campo_hito || 313,
						id_expediente: idFromView || detected.id_expediente || null,
						id_campo_hito_expediente: detected.id_campo_hito_expediente || null,
						id_hito_expediente: idHitoExpediente,
						dni: dni,
						files: [ name ],
						source_url: url || null
					};
					if (li) li.textContent = name + ' — Adjuntando...';
					console.log('AUTO Payload adjuntar-archivos:', payload);
					console.log('🔍 DEBUG: idFromView=', idFromView, 'detected.id_expediente=', detected.id_expediente, 'idHitoExpediente=', idHitoExpediente);
					console.log('🔍 DEBUG: detected=', detected);
					// Llamar al endpoint para adjuntar y esperar respuesta
					let adjResp = null;
					try {
						const res = await fetch('{{ path('belender_adjuntar_archivos') }}', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
							credentials: 'same-origin',
							body: JSON.stringify(payload)
						});
						adjResp = await (res.ok ? res.json() : (await res.text()));
						console.log('AUTO adjuntar response:', adjResp);
							if (li) li.textContent = name + ' — Adjuntado';
							try { setRowStatus('Adjuntado'); } catch(e){}
					} catch(e) {
						console.error('AUTO adjuntar fetch error', e);
							if (li) li.textContent = name + ' — Error al adjuntar';
							try { setRowStatus('Error al adjuntar'); } catch(e){}
					}

					// Intentar insertar en Dropify sin pulsar botón guardar
					try {
						let inputEl = null;
						if (detected.dropifySelector && detected.dropifySelector instanceof Element) inputEl = detected.dropifySelector;
						if (!inputEl) inputEl = document.querySelector('.dropify');
						if (url && inputEl) {
							if (li) li.textContent = name + ' — Insertando en preview...';
							try { setRowStatus('Insertando en preview...'); } catch(e){}
							const blob = await descargarBlobDesdeUrl(url);
							const file = crearFileDesdeBlob(blob, name);
							asignarFileAInput(inputEl, file);
							if (li) li.textContent = name + ' — Insertado (preview)';
							try { setRowStatus('Insertado (preview)'); } catch(e){}
						} else if (adjResp && adjResp.success && adjResp.saved_path && inputEl) {
							if (li) li.textContent = name + ' — Insertando desde saved_path...';
							try { setRowStatus('Insertando desde saved_path...'); } catch(e){}
							const blob2 = await descargarBlobDesdeUrl(adjResp.saved_path);
							const file2 = crearFileDesdeBlob(blob2, adjResp.saved_name || name);
							asignarFileAInput(inputEl, file2);
							if (li) li.textContent = name + ' — Insertado (preview)';
							try { setRowStatus('Insertado (preview)'); } catch(e){}
						} else {
							// No se pudo insertar en preview
							if (li) li.textContent = name + ' — Adjuntado (no preview)';
							try { setRowStatus('Adjuntado (no preview)'); } catch(e){}
						}
					} catch(e) {
						console.warn('AUTO no se pudo insertar en preview', e);
						if (li) li.textContent = name + ' — Error insertando preview';
					}

					// Actualizar barra progreso
					const donePercent = Math.round(index / pdfs.length * 100);
					if (progressBar) progressBar.style.width = donePercent + '%';

					// Pequeña espera entre archivos para evitar saturar el UI/backend
					await new Promise(r => setTimeout(r, 350));
				} catch (e) {
					console.error('Error procesando archivo auto adjuntar', p, e);
					if (li) li.textContent = (p.name||p) + ' — Error inesperado';
				}
			}
			// Finalizar progreso
			if (progressBar) progressBar.style.width = '100%';
			console.log('✅ Procesamiento completado, actualizando modal...');
			updateBelenderInfoModal('Procesamiento finalizado', 'success');
			console.log('⏳ Recargando página en 2 segundos...');
			// Recargar la página después de 2 segundos
			setTimeout(function() {
				console.log('🔄 Ejecutando window.location.reload()');
				window.location.reload();
			}, 2000);
		}
	</script>
	<script src="{{ asset('assets/js/custom/Element.hasAttribute.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/expediente.min.js') }}"></script>
{% endblock %}
{% block body %}

{# <input type="text" id="dniInput" placeholder="Introduce DNI">
<button onclick="obtenerDocumentos()"> &nbsp;&nbsp; Obtener Documentos Cl@ve</button>
<div id="botonDescargaContainer"></div>

<script>
	function obtenerDocumentos() {
		const dni = document.getElementById("dniInput").value;
		fetch(`{{ path('document_request') }}?dni=${dni}`)
			.then(response => response.json())
			.then(data => {
				if (data.widget_url_boxed) {
					window.open(data.widget_url_boxed, '_blank');
					localStorage.setItem("request_id", data.request_id);
					localStorage.setItem("dni", dni);  // Guardar el DNI en localStorage
					verificarEstadoDocumentos();
				} else {
					alert("Error en la solicitud de documentos.");
				}
			});
	}

	function verificarEstadoDocumentos() {
			const requestId = localStorage.getItem("request_id");
			const dni = localStorage.getItem("dni");

			if (!requestId || !dni) return;

			fetch(`{{ path('document_download') }}?request_id=${requestId}&dni=${dni}`)
				.then(response => response.json())
				.then(data => {
					if (data.success && data.files.length > 0) {
						mostrarBotonDescarga(data.files);
					} else {
						setTimeout(verificarEstadoDocumentos, 5000);
					}
				});
	}

	function mostrarBotonDescarga(files) {
		const container = document.getElementById("botonDescargaContainer");
		const totalArchivos = files.length;
		
		container.innerHTML = `<br><h5>Documentos descargados: ${totalArchivos}</h5>`;

		localStorage.removeItem("request_id");
	}
</script> #}


	<form enctype="multipart/form-data" method="post">
		<div class="card">
			<div class="card-body">
				{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			{% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}
				<h4 class="card-title">{{ fases[0].nombre }}</h4>
					<div class="form-row">
						<div class="form-group col-xl {% if is_granted('ROLE_CLIENTE') %}oculto{% endif %}">
							{{ form_label(agregarModificarExpediente.idCliente) }}
							{{ form_widget(agregarModificarExpediente.idCliente,{attr:{class:'select2'}}) }}
							{{ form_errors(agregarModificarExpediente.idCliente) }}
						</div>
						<div class="form-group col-xl {% if is_granted('ROLE_CLIENTE') %}oculto{% endif %}">
							{{ form_label(agregarModificarExpediente.vivienda) }}
							{{ form_widget(agregarModificarExpediente.vivienda) }}
							{{ form_errors(agregarModificarExpediente.vivienda) }}
						</div>
						{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined %}
							<div class="form-group col-md oculto">
								{{ form_label(agregarModificarExpediente.idFaseActual) }}
								{{ form_widget(agregarModificarExpediente.idFaseActual) }}
								{{ form_errors(agregarModificarExpediente.idFaseActual) }}
							</div>
							<div class="form-group col-md oculto">
								{{ form_label(agregarModificarExpediente.estado) }}
								{{ form_widget(agregarModificarExpediente.estado) }}
								{{ form_errors(agregarModificarExpediente.estado) }}
							</div>
						{% endif %}
					</div>
				{% else %}
					<h4 class="card-title">{{ titulo }}</h4>
					{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
						<div class="form-row">
							<div class="form-group col-lg">
								{{ form_label(agregarModificarExpediente.idColaborador) }}
								{{ form_widget(agregarModificarExpediente.idColaborador,{attr:{class:'select2'}}) }}
								{{ form_errors(agregarModificarExpediente.idColaborador) }}
							</div>
							<div class="form-group col-lg">
								{{ form_label(agregarModificarExpediente.idComercial) }}
								{{ form_widget(agregarModificarExpediente.idComercial,{attr:{class:'select2'}}) }}
								{{ form_errors(agregarModificarExpediente.idComercial) }}
							</div>
							<div class="form-group col-lg">
								{{ form_label(agregarModificarExpediente.idTecnico) }}
								{{ form_widget(agregarModificarExpediente.idTecnico,{attr:{class:'select2'}}) }}
								{{ form_errors(agregarModificarExpediente.idTecnico) }}
							</div>
						</div>
					{% endif %}
					<div class="form-row">
						<div class="form-group col-xl">
							{{ form_label(agregarModificarExpediente.idCliente) }}
							{{ form_widget(agregarModificarExpediente.idCliente,{attr:{class:'select2'}}) }}
							{{ form_errors(agregarModificarExpediente.idCliente) }}
						</div>
						<div class="form-group col-xl">
							{{ form_label(agregarModificarExpediente.vivienda) }}
							{{ form_widget(agregarModificarExpediente.vivienda) }}
							{{ form_errors(agregarModificarExpediente.vivienda) }}
						</div>
					</div>
					{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined %}
						<div class="form-row">
							<div class="form-group col-md">
								{{ form_label(agregarModificarExpediente.idFaseActual) }}
								{{ form_widget(agregarModificarExpediente.idFaseActual) }}
								{{ form_errors(agregarModificarExpediente.idFaseActual) }}
							</div>
							<div class="form-group col-md">
								{{ form_label(agregarModificarExpediente.estado) }}
								{{ form_widget(agregarModificarExpediente.estado) }}
								{{ form_errors(agregarModificarExpediente.estado) }}
							</div>
						</div>
					{% endif %}
				{% endif %}
			</div>
		</div>
		{{ form_widget(agregarModificarExpediente._token) }}
		<div class="card">
			<div class="card-body">
				{% if fases is defined and fases is iterable and fases|length>0 %}
					{% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
						{# LEYENDAS DE COLORES #}
							<div class="leyenda-fases">
								<div class="fase fase-negra">Fase 1</div>
								<div class="fase fase-verde">Fase 2</div>
								<div class="fase fase-amarilla">Fase 3</div>
								<div class="fase fase-naranja">Fase 4</div>
								<div class="fase fase-roja">Fase 5</div>
							</div>

						{# FIN LEYENDAS DE COLORES #}
						<div role="tablist">
							<nav class="nav nav-tabs">
								{% for fase in fases %}
									<a aria-controls="nav-fase-{{ fase.idFase }}" aria-selected="true" class="nav-item nav-link{% if (fase.idFase is same as(faseActual.idFase) and not irADocumentos) or ((not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA')) and irADocumentos and fase.tipo is same as(1)) %} active{% endif %}" data-toggle="tab" id="nav-fase-{{ fase.idFase }}-tab" href="#nav-fase-{{ fase.idFase }}" role="tab">
										<b>{% if (fase.idFase is same as(faseActual.idFase) and not irADocumentos) or (not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') and fase.tipo is same as(1)) %}<u>{% endif %}{{ fase.nombre }}{% if (fase.idFase is same as(faseActual.idFase) and not irADocumentos) or (not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') and fase.tipo is same as(1)) %}</u>{% endif %}</b>
									</a>
								{% endfor %}
							</nav>
						</div>
					{% endif %}
					<div class="tab-content">
						{% for fase in fases %}
							{% if (not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA')) or (fase.tipo is same as(0) and not irADocumentos) or (fase.tipo is same as(1) and irADocumentos) %}
						{% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
						<div aria-labelledby="nav-fase-{{ fase.idFase }}-tab" class="tab-pane fade{% if (fase.idFase is same as(faseActual.idFase) and not irADocumentos) or (not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') and fase.tipo is same as(1) and irADocumentos) %} show active{% endif %} border border-top-0 p-3" id="nav-fase-{{ fase.idFase }}" role="tabpanel">
							{% endif %}
								{% if hitos[fase.idFase] is iterable and hitos[fase.idFase]|length>0 %}
									{% for hito in hitos[fase.idFase] %}
										{% if hitos_expediente[hito.idHito] is iterable and hitos_expediente[hito.idHito]|length>0 %}
											{% set iteracion_hito_expediente = 0 %}
											{% for hito_expediente in hitos_expediente[hito.idHito] %}
												{% form_theme agregarModificarHitoExpediente[hito.idHito][loop.index-1] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
												<div{% if not loop.parent.loop.last or hito.repetible %} class="mb-3"{% endif %} data-hito-condicional="{{ hito.hitoCondicional }}" data-hito-expediente="{{ hito.idHito }}"{% if loop.index is same as(1) %} data-repetible="{{ hito.repetible?1:0 }}"{% endif %} {% if iteracion_hito_expediente > 0 %} data-agregado="{{ iteracion_hito_expediente }}"{% endif %} {% if hito_expediente.idHitoExpediente %} data-id-hito-expediente={{ hito_expediente.idHitoExpediente }}{% endif %}>
													<h4 class="card-title bg-success text-light mb-0 p-3 {{ hito.idHito }} 555 {{valores_campo_707[iteracion_hito_expediente]}}" data-hito-titulo>{{ hito.nombre }} {% if loop.index>1 %} ({{ loop.index }}){% endif %} <i class="fas fa-angle-down mostrar"></i><i class="fas fa-angle-up d-none ocultar"></i></h4>
													<div class="border p-3 d-none">
														{% if hito.idHito == 31 %} 
															{% if not (is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA')) %}
																<div class="form-row align-items-center mb-2 ">
																<div class="form-group col-md">
																	<h6 class="card-title">NIF / NIE  <span style="color:red;">* Sólo GN</span></h6>
																	<input type="text" id="belenderNif_{{ hito_expediente.idHitoExpediente }}" name="belenderNif_{{ hito_expediente.idHitoExpediente }}" class="form-control" placeholder="Introduzca NIF/NIE" value="{{ hito_expediente.nif|default('') }}">
																</div>
																<div class="form-group col-md-auto mb-0">
																	<button class="btn btn-success waves-effect mr-2" type="button" onclick="obtenerDocumentosAdmin({{hito_expediente.idHitoExpediente}})">
																		<i class="fas fa-file-pdf mr-1"></i> Descargar documentos Belender
																	</button>
																	{#<button class="btn btn-info waves-effect mr-2" type="button" onclick="solicitarCirbeDocumentos({{hito_expediente.idHitoExpediente}})" title="Solicitar informe CIRBE de riesgos de crédito">
																		<i class="fas fa-credit-card mr-1"></i> CIRBE
																	</button>
																	<button class="btn btn-warning waves-effect mr-2" type="button" onclick="enviarCredencialesCirbeForm({{hito_expediente.idHitoExpediente}})" title="Enviar credenciales después de recibirlas por email">
																		<i class="fas fa-key mr-1"></i> Credenciales
																	</button>
																	<button class="btn btn-primary waves-effect" type="button" onclick="descargarYAdjuntarCirbe({{hito_expediente.idHitoExpediente}})" title="Descargar y adjuntar documentos CIRBE al expediente">
																		<i class="fas fa-download mr-1"></i> Descargar CIRBE
																	</button>#}
																</div>																
															</div>

															{% elseif is_granted('ROLE_CLIENTE') and valores_campo_707[iteracion_hito_expediente] == 'SI' %}
																<div class="form-row align-items-center mb-2 ">
																<div class="form-group col-md">
																	<h6 class="card-title">NIF / NIE  </h6>
																	<input type="text" id="belenderNif_{{ hito_expediente.idHitoExpediente }}" name="belenderNif_{{ hito_expediente.idHitoExpediente }}" class="form-control" placeholder="Introduzca NIF/NIE" value="{{ hito_expediente.nif|default('') }}">
																</div>
																<div class="form-group col-md-auto mb-0">
																	<button class="btn btn-success waves-effect mr-2" type="button" onclick="obtenerDocumentosAdmin({{hito_expediente.idHitoExpediente}})">
																		<i class="fas fa-file-pdf mr-1"></i> Descargar documentos Belender
																	</button>
																	{#<button class="btn btn-info waves-effect mr-2" type="button" onclick="solicitarCirbeDocumentos({{hito_expediente.idHitoExpediente}})" title="Solicitar informe CIRBE de riesgos de crédito">
																		<i class="fas fa-credit-card mr-1"></i> CIRBE
																	</button>
																	<button class="btn btn-warning waves-effect mr-2" type="button" onclick="enviarCredencialesCirbeForm({{hito_expediente.idHitoExpediente}})" title="Enviar credenciales después de recibirlas por email">
																		<i class="fas fa-key mr-1"></i> Credenciales
																	</button>
																	<button class="btn btn-primary waves-effect" type="button" onclick="descargarYAdjuntarCirbe({{hito_expediente.idHitoExpediente}})" title="Descargar y adjuntar documentos CIRBE al expediente">
																		<i class="fas fa-download mr-1"></i> Descargar CIRBE
																	</button>#}
																</div>																
															</div>
															{% endif %}
															
														{% endif %}
														<div class="form-row d-none">
															<div class="form-group col-md">
																{{ form_label(agregarModificarHitoExpediente[hito.idHito][loop.index-1].estado) }}
																{{ form_widget(agregarModificarHitoExpediente[hito.idHito][loop.index-1].estado,{attr:{hidden:''}}) }}
																{{ form_errors(agregarModificarHitoExpediente[hito.idHito][loop.index-1].estado) }}
															</div>
														</div>
														<hr class="d-none mt-0">
														{% if grupos_campos_hito[hito.idHito] is iterable and grupos_campos_hito[hito.idHito]|length>0 %}
															{% for grupo_campos_hito in grupos_campos_hito[hito.idHito] %}
																{% for grupo_hito_expediente in grupos_hito_expediente[hito_expediente.idHitoExpediente][grupo_campos_hito.idGrupoCamposHito] %}
																	<div{% if grupo_campos_hito.nombre is not empty %} class="border{% if loop.length>1 %} mb-3{% endif %} p-3"{% endif %} data-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" data-id-grupo-expediente="{{ grupo_hito_expediente }}" data-grupo-repetible="{{ grupo_campos_hito.repetible?1:0 }}">
																		{% if grupo_campos_hito.nombre is not empty %}
																			<h5 class="card-title titulo-grupo" data-grupo-titulo>{{ grupo_campos_hito.nombre }}</h5>
																			<hr>
																		{% endif %}
																		{% if campos_hito[grupo_campos_hito.idGrupoCamposHito] is iterable and campos_hito[grupo_campos_hito.idGrupoCamposHito]|length>0 %}
																			<div class="row">
																				{% for campo_hito in campos_hito[grupo_campos_hito.idGrupoCamposHito] %}
																					{% if agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente] is defined %}
																						{% form_theme agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																					{% endif %}
																					<div data-id-campo-hito="{{ campo_hito.idCampoHito }}" class="col-lg {% if loop.length>1 and not loop.last and loop.index is odd %} border-lg-right{% endif %}{% if (is_granted('ROLE_CLIENTE') and not campo_hito.mostrarCliente) or (is_granted('ROLE_COLABORADOR') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_JEFE_INMOBILIARIA') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_JEFE_OFICINA') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_RESPONSABLE_ZONA') and not campo_hito.mostrarColaborador) %} d-none{% endif %}" data-campo-condicional="{{ campo_hito.campoCondicional }}">
																						{% if campo_hito.tipo is not same as(10) %}
																							<h6 class="card-title">{{ campo_hito.nombre }} {% if not campo_hito.mostrarCliente and not campo_hito.mostrarColaborador  %} <span style="color:red;">* Sólo GN</span> {% endif %}</h6>
																						{% endif %}
																						{% if campo_hito.tipo is same as(4) %}
																							<div data-contenedor-campo-hito-expediente-colaboradores>
																								<div class="row">
																									<div class="col-md {% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}d-none{% endif %}">
																										<div class="form-row d-none">
																											<div class="form-group col">
																												{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor) }}
																												{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor,{attr:{readonly:'',value:campo_hito.nombre}}) }}
																												{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor) }}
																											</div>
																										</div>
																										<div class="form-row">
																											<div class="col">
																												{% if fase.tipo is same as(1) %}
																													<div class="form-group">
																														{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].obligatorio) }}
																														{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].obligatorio) }}
																														{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].obligatorio) }}
																													</div>
																													<div class="form-group">
																														{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].solicitarAlColaborador) }}
																														{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].solicitarAlColaborador) }}
																														{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].solicitarAlColaborador) }}
																													</div>
																												{% endif %}
																												<div class="form-group">
																													{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].avisarColaborador) }}
																													{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].avisarColaborador) }}
																													{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].avisarColaborador) }}
																												</div>
																												<div class="form-group">
																													{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].paraFirmar) }}
																													{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].paraFirmar) }}
																													{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].paraFirmar) }}
																												</div>
																												<div class="form-group">
																													{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlCliente) }}
																													{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlCliente) }}
																													{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlCliente) }}
																												</div>
																												<div class="form-group">
																													{{ form_label(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlColaborador) }}
																													{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlColaborador) }}
																													{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].enviarAlColaborador) }}
																												</div>
																											</div>
																										</div>
																									</div>
																									<div class="col-md" data-fichero-campo="{{ agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].vars.value.idFicheroCampo }}">
																										{% form_theme agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																										<div class="form-row">
																											<div class="form-group col">
																												{{ form_label(agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].fichero) }}
																												{% if fichero_subido[campo_hito.idCampoHito][hito_expediente.idHitoExpediente] is defined %}
																													{{ form_widget(agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].fichero,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-default-file':fichero_subido[campo_hito.idCampoHito][hito_expediente.idHitoExpediente],'data-max-file-size':maxFileSize}}) }}
																												{% else %}
																													{{ form_widget(agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].fichero,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-max-file-size':maxFileSize}}) }}
																												{% endif %}
																												{{ form_errors(agregarModificarFicheroCampo[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].fichero) }}
																											</div>
																										</div>
																										{% if fichero_subido_ruta[campo_hito.idCampoHito][hito_expediente.idHitoExpediente] is defined %}
																											<a class="btn btn-success waves-effect mb-3" data-boton-descargar href="{{ fichero_subido_ruta[campo_hito.idCampoHito][hito_expediente.idHitoExpediente] }}" target="_blank">Ver</a>
																										{% endif %}
																									</div>
																								</div>
																								{% form_theme agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																							<div class="form-row {% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}d-none{% endif %}">
																									<div class="form-group col-md">
																										{{ form_label(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idEntidadColaboradora) }}
																										{{ form_widget(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idEntidadColaboradora,{attr:{class:'select2'}}) }}
																										{{ form_errors(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idEntidadColaboradora) }}
																									</div>
																									<div class="form-group col-md">
																										{{ form_label(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idAgenteColaborador) }}
																										{{ form_widget(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idAgenteColaborador,{attr:{class:'select2'}}) }}
																										{{ form_errors(agregarModificarCampoHitoExpedienteColaboradores[campo_hito.idCampoHito][hito_expediente.idHitoExpediente].idAgenteColaborador) }}
																									</div>
																								</div>
																							</div>
																						{% else %}
																							<div class="form-row">
																								<div class="form-group col">
																									{% if campo_hito.tipo is same as(2) or campo_hito.tipo is same as(3) %}
																										{# {{ form_label(agregarModificarCampoHitoExpediente[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1].idOpcionesCampo) }} #}
																										{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].idOpcionesCampo) }}
																										{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].idOpcionesCampo) }}
																									{% elseif campo_hito.tipo is same as(6) %}
																										{# {{ form_label(agregarModificarCampoHitoExpediente[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1].valor) }} #}
																										{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor,{attr:{class:'js-datepicker'}}) }}
																										{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor) }}
																									{% elseif campo_hito.tipo is same as(7) or campo_hito.tipo is same as(8) or campo_hito.tipo is same as(9) %}
																										{# {{ form_label(agregarModificarCampoHitoExpediente[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1].idAgenteColaborador) }} #}
																										{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].idAgenteColaborador,{attr:{class:'select2'}}) }}
																										{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].idAgenteColaborador) }}
																									{% elseif campo_hito.tipo is same as(10) %}
																									{% else %}
																										{# {{ form_label(agregarModificarCampoHitoExpediente[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1].valor) }} #}
																										{{ form_widget(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor) }}
																										{{ form_errors(agregarModificarCampoHitoExpediente[grupo_campos_hito.idGrupoCamposHito][campo_hito.idCampoHito][grupo_hito_expediente].valor) }}
																									{% endif %}
																								</div>
																							</div>
																						{% endif %}
																					</div>
																					{% if loop.index is even and not loop.last %}
																						<div class="col-12 d-none d-lg-block">
																							<hr>
																						</div>
																					{% endif %}
																				{% endfor %}
																			</div>
																		{% else %}
																			<div class="alert alert-info" role="alert">
																				<span>No hay campos hito.</span>
																			</div>
																		{% endif %}
																		{% if grupo_campos_hito.repetible and grupos_campos_hito[hito.idHito]|length>1 %}
																			<div class="d-flex justify-content-end border-top pt-3">
																				<button class="btn btn-danger waves-effect {% if not loop.last or loop.index <= 1 %}oculto{% endif %}" data-borrar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
																					<i class="far fa-trash-alt"></i> Eliminar {{ grupo_campos_hito.nombre }}
																				</button>
																			</div>
																		{% endif %}
																	</div>
																	{% if grupo_campos_hito.repetible and loop.last %}
																		<div class="d-flex justify-content-end{% if not loop.parent.loop.last %} mb-3{% endif %} mr-3" data-agregar-grupo-expediente-contenedor>
																			<button class="btn btn-success waves-effect" data-agregar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
																				<i class="fas fa-plus"></i> Añadir {{ grupo_campos_hito.nombre }}
																			</button>
																		</div>
																	{% endif %}
																{% endfor %}
															{% endfor %}
														{% else %}
															<div class="alert alert-info" role="alert">
																<span>No hay grupos de campos hito.</span>
															</div>
														{% endif %}
														{% if hito.repetible and hitos_expediente[hito.idHito]|length>1 %}
															<div class="d-flex justify-content-end border-top pt-3">
																<button class="btn btn-danger waves-effect btn-hito-rojo {% if not loop.last or loop.index <= 1 %}oculto{% endif %}" data-borrar-hito-expediente="{{ hito.idHito }}" type="button">
																	<i class="far fa-trash-alt"></i> Eliminar {{ hito.nombre }}
																</button>
															</div>
														{% endif %}
													</div>
												</div>
												{% if hito.repetible and loop.last %}
													<div class="d-flex justify-content-end{% if not loop.parent.loop.last %} mb-3{% endif %} mr-3" data-agregar-hito-expediente-contenedor>
														<button class="btn btn-success waves-effect btn-hito" data-agregar-hito-expediente="{{ hito.idHito }}" type="button">
															<i class="fas fa-plus"></i> Añadir {{ hito.nombre }}
														</button>
													</div>
												{% endif %}
												{% set iteracion_hito_expediente = iteracion_hito_expediente + 1 %}
											{% endfor %}
										{% endif %}
									{% endfor %}
								{% else %}
									<div class="alert alert-info" role="alert">
										<span>No hay hitos.</span>
									</div>
								{% endif %}
							{% endif %}
						{% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
						</div>
						{% endif %}
						{% endfor %}
					</div>
				{% else %}
					<div class="alert alert-info" role="alert">
						<span>No hay fases.</span>
					</div>
				{% endif %}
			</div>
		</div>
		<div class="card">
			<div class="card-body">
				<div class="d-flex">
					<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_expedientes') }}">Volver</a>
					{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined and (is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO')) %}
						<button class="btn btn-info waves-effect ml-3 btn_seguimiento btn_seguimiento-fijo" data-boton-seguimiento>Seguimiento</button>
					{% endif %}
					{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined and (is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO')) %}
						<button class="btn btn-warning waves-effect ml-3 btn_seguimiento-fijo" data-boton-tecnico type="button">Auto-asignar Técnico</button>
						<button class="btn btn-warning waves-effect ml-3 btn_seguimiento-fijo fase-amarilla" data-boton-comercial type="button">Auto-asignar Comercial</button>
					{% endif %}
					{% if attribute(agregarModificarExpediente, 'idFaseActual') is not defined %}
						<button class="btn btn-secondary waves-effect" type="reset">Reiniciar</button>
					{% endif %}
					{#{% if is_granted('ROLE_CLIENTE') and valor_campo_707 == 'SI' %}
						<button class="btn btn-info waves-effect ml-3" id="boton-sincronizar-blender" onclick="obtenerDocumentosCliente()" type="button">Descargar documentos Belender</button>
					{% endif %}
					<input type="hidden" id="dniClienteValue" value="{{ agregarModificarExpediente.vars.data.idCliente.nif }}">
					<input type="hidden" id="campo707Value" value="{{ valor_campo_707 }}">#}
					<button class="btn btn-success waves-effect ml-3" data-boton-enviar>Aceptar</button>
				</div>
			</div>
		</div>
		{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined and (is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO')) %}
			<button class="btn btn-info waves-effect shadow-sm position-fixed d-none boton-flotante btn_seguimiento boton-flotante-izq" data-boton-flotante data-boton-seguimiento>
				<i class="far fa-check-square"></i>
				<span> Seguimiento</span>
			</button>
			<button class="btn btn-warning waves-effect shadow-sm position-fixed d-none boton-flotante boton-flotante-centro" data-boton-flotante data-boton-tecnico type="button">
				<i class="far fa-user"></i>
				<span> Auto-asignar Técnico</span>
			</button>
			<button class="btn btn-warning waves-effect shadow-sm position-fixed d-none boton-flotante boton-flotante-dcha fase-amarilla" data-boton-flotante data-boton-comercial type="button">
				<i class="far fa-user"></i>
				<span> Auto-asignar Comercial</span>
			</button>
		{% endif %}
		<button class="btn btn-success waves-effect shadow-sm position-fixed d-none boton-flotante" data-boton-flotante>
			<i class="fas fa-save"></i>
			<span> Guardar</span>
		</button>
		{% if numero_hitos_expediente_duplicados is defined %}
			{% if fases is defined and fases is iterable and fases|length>0 %}
				{% for fase in fases %}
					{% if hitos[fase.idFase] is iterable and hitos[fase.idFase]|length>0 %}
						{% for hito in hitos[fase.idFase] %}
							{% if hito.repetible and numero_hitos_expediente_duplicados[hito.idHito] is defined and numero_hitos_expediente_duplicados[hito.idHito] > 0 %}
								<input name="numero-hitos-expediente-duplicados[{{ hito.idHito }}]" type="hidden" value="{{ numero_hitos_expediente_duplicados[hito.idHito] }}">
							{% endif %}
						{% endfor %}
					{% endif %}
				{% endfor %}
			{% endif %}
		{% endif %}
		{# {% if numero_grupos_hito_expediente_duplicados is defined %}
			{% if fases is defined and fases is iterable and fases|length>0 %}
				{% for fase in fases %}
					{% if hitos[fase.idFase] is iterable and hitos[fase.idFase]|length>0 %}
						{% for hito in hitos[fase.idFase] %}
							{% for hito_expediente in hitos_expediente[hito.idHito] %}
								{% for grupo_campos_hito in grupos_campos_hito[hito.idHito] %}
									{% if grupo_campos_hito.repetible and numero_grupos_hito_expediente_duplicados[hito_expediente.idHitoExpediente][grupo_campos_hito.idGrupoCamposHito] is defined and numero_grupos_hito_expediente_duplicados[hito_expediente.idHitoExpediente][grupo_campos_hito.idGrupoCamposHito] > 0 %}
										{% for grupo_hito_exp in grupos_hito_expediente[hito_expediente.idHitoExpediente][grupo_campos_hito.idGrupoCamposHito] %}
											<input name="numero-grupos-hito-expediente-duplicados[{{ grupo_hito_exp }}]" type="hidden" value=1">
										{% endfor %}
									{% endif %}
								{% endfor %}
							{% endfor %}
						{% endfor %}
					{% endif %}
				{% endfor %}
			{% endif %}
		{% endif %} #}
		{% if numero_grupos_hito_expediente_duplicados is defined %}
			{% if fases is defined and fases is iterable and fases|length>0 %}
				{% for fase in fases %}
					{% if hitos[fase.idFase] is iterable and hitos[fase.idFase]|length>0 %}
						{% for hito in hitos[fase.idFase] %}
							{% for hito_expediente in hitos_expediente[hito.idHito] %}
								{% for grupo_campos_hito in grupos_campos_hito[hito.idHito] %}
									{% if grupo_campos_hito.repetible %}
										{# KKK: {{ hito.idHito }} - {{ loop.parent.loop.index - 1 }} - {{ grupo_campos_hito.idGrupoCamposHito }} #}
										{% set miIndex = loop.parent.loop.index -1 %}
										{% set miClave =  hito.idHito ~ '_' ~ miIndex ~ '_' ~ grupo_campos_hito.idGrupoCamposHito %}
										{# {% set full_name = content.field_firstname.value ~ ' ' ~ content.field_lastname.value %} #}
										{# {% set miClave =  {hito.idHito}"_"{loop.parent.loop.index - 1}"_"{grupo_campos_hito.idGrupoCamposHito} %} #}
										{# KKK: {{ miClave }} #}
										{% if numero_grupos_hito_expediente_duplicados[miClave] is defined %}
											{% if numero_grupos_hito_expediente_duplicados[miClave] > 0 %}
											{# {% for grupo_hito_exp in grupos_hito_expediente[hito_expediente.idHitoExpediente][grupo_campos_hito.idGrupoCamposHito] %} #}
												<input name="numero-grupos-hito-expediente-duplicados[{{ miClave }}]" type="hidden" value="{{ numero_grupos_hito_expediente_duplicados[miClave]-1 }}">
											{# {% endfor %} #}
											{% endif %}
										{% endif %}
									{% endif %}
								{% endfor %}
							{% endfor %}
						{% endfor %}
					{% endif %}
				{% endfor %}
			{% endif %}
		{% endif %}
		<input name="ids-hitos-expedientes-borrar" type="hidden">
		<input type="hidden" id="idExpediente_belender" name="idExpediente_belender" value="">
		<input type="hidden" name="autoAsignarTecnico" value="0" id="auto-asignar-tecnico-hidden">
		<input type="hidden" name="autoAsignarComercial" value="0" id="auto-asignar-comercial-hidden">
	</form>
	{% if fases is defined and fases is iterable and fases|length>0 %}
		{% for fase in fases %}
			{% if hitos[fase.idFase] is iterable and hitos[fase.idFase]|length>0 %}
				{% set hitoActual = '' %}
				{% set hitoAnterior = '' %}
				{% for hito in hitos[fase.idFase] %}
					{% set hitoActual = hito.idHito %}
					{% if hito.repetible %}
						{% form_theme agregarModificarHitoExpedienteModelo[hito.idHito] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
						<div class="d-none">
							<div{% if not loop.parent.loop.last or hito.repetible %} class="mb-3"{% endif %} data-modelo-hito-condicional="{{ hito.hitoCondicional }}" data-modelo-hito-expediente="{{ hito.idHito }}">
								<h4 class="card-title bg-success text-light mb-0 p-3" data-hito-titulo>{{ hito.nombre }}{% if hitoActual == hitoAnterior and loop.index>1 %} ({{ loop.index }}){% endif %}</h4>
								<div class="border p-3">
									<div class="form-row d-none">
										<div class="form-group col-md">
											{{ form_label(agregarModificarHitoExpedienteModelo[hito.idHito].estado) }}
											{{ form_widget(agregarModificarHitoExpedienteModelo[hito.idHito].estado,{attr:{hidden:''}}) }}
											{{ form_errors(agregarModificarHitoExpedienteModelo[hito.idHito].estado) }}
										</div>
									</div>
									<hr class="d-none mt-0">
									{% if grupos_campos_hito[hito.idHito] is iterable and grupos_campos_hito[hito.idHito]|length>0 %}
										{% for grupo_campos_hito in grupos_campos_hito[hito.idHito] %}
											<div{% if grupo_campos_hito.nombre is not empty %} class="border{% if loop.length>1 %} mb-3{% endif %} p-3"{% endif %} data-modelo-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" data-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" data-grupo-repetible="{{ grupo_campos_hito.repetible?1:0 }}">
												{% if grupo_campos_hito.nombre is not empty %}
													<h5 class="card-title titulo-grupo">{{ grupo_campos_hito.nombre }}</h5>
													<hr>
												{% endif %}
												{% if campos_hito[grupo_campos_hito.idGrupoCamposHito] is iterable and campos_hito[grupo_campos_hito.idGrupoCamposHito]|length>0 %}
													<div class="row">
														{% for campo_hito in campos_hito[grupo_campos_hito.idGrupoCamposHito] %}
															{% if agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito] is defined %}
																{% form_theme agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
															{% endif %}
															<div data-id-campo-hito="{{ campo_hito.idCampoHito }}" class="col-lg {% if loop.length>1 and not loop.last and loop.index is odd %} border-lg-right{% endif %}{% if (is_granted('ROLE_CLIENTE') and not campo_hito.mostrarCliente) or (is_granted('ROLE_COLABORADOR') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_JEFE_INMOBILIARIA') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_JEFE_OFICINA') and not campo_hito.mostrarColaborador) or (is_granted('ROLE_RESPONSABLE_ZONA') and not campo_hito.mostrarColaborador) %} d-none{% endif %}" data-campo-condicional="{{ campo_hito.campoCondicional }}">
																{% if campo_hito.tipo is not same as(10) %}
																	<h6 class="card-title">{{ campo_hito.nombre }}</h6>
																{% endif %}
																{% if campo_hito.tipo is same as(4) %}
																	<div data-contenedor-campo-hito-expediente-colaboradores>
																		<div class="row">
																			<div class="col-md {% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}d-none{% endif %}">
																				<div class="form-row d-none">
																					<div class="form-group col">
																						{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																						{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor,{attr:{readonly:'',value:campo_hito.nombre}}) }}
																						{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																					</div>
																				</div>
																				<div class="form-row">
																					<div class="col">
																						{% if fase.tipo is same as(1) %}
																							<div class="form-group">
																								{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].obligatorio) }}
																								{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].obligatorio,{attr:{checked:'checked'}}) }}
																								{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].obligatorio) }}
																							</div>
																							<div class="form-group">
																								{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].solicitarAlColaborador) }}
																								{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].solicitarAlColaborador,{attr:{checked:'checked'}}) }}
																								{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].solicitarAlColaborador) }}
																							</div>
																						{% endif %}
																						<div class="form-group">
																							{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].avisarColaborador) }}
																							{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].avisarColaborador) }}
																							{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].avisarColaborador) }}
																						</div>
																						<div class="form-group">
																							{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].paraFirmar) }}
																							{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].paraFirmar) }}
																							{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].paraFirmar) }}
																						</div>
																						<div class="form-group">
																							{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlCliente) }}
																							{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlCliente) }}
																							{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlCliente) }}
																						</div>
																						<div class="form-group">
																							{{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlColaborador) }}
																							{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlColaborador) }}
																							{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].enviarAlColaborador) }}
																						</div>
																					</div>
																				</div>
																			</div>
																			<div class="col-md">
																				{% form_theme agregarModificarFicheroCampoModelo[campo_hito.idCampoHito] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																				<div class="form-row">
																					<div class="form-group col">
																						{{ form_label(agregarModificarFicheroCampoModelo[campo_hito.idCampoHito].fichero) }}
																						{% if fichero_subido[campo_hito.idCampoHito] is defined %}
																							{# {{ form_widget(agregarModificarFicheroCampoModelo[campo_hito.idCampoHito].fichero,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-default-file':fichero_subido[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1],'data-max-file-size':maxFileSize}}) }} #}
																							{{ form_widget(agregarModificarFicheroCampoModelo[campo_hito.idCampoHito].fichero,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-default-file':fichero_subido[campo_hito.idCampoHito]|first,'data-max-file-size':maxFileSize}}) }}
																						{% else %}
																							{{ form_widget(agregarModificarFicheroCampoModelo[campo_hito.idCampoHito].fichero,{attr:{class:'dropify','data-allowed-file-extensions':extensiones_permitidas,'data-max-file-size':maxFileSize}}) }}
																						{% endif %}
																						{{ form_errors(agregarModificarFicheroCampoModelo[campo_hito.idCampoHito].fichero) }}
																					</div>
																				</div>
																				{# {% if fichero_subido_ruta[campo_hito.idCampoHito] is defined %} #}
																					{# <a class="btn btn-success waves-effect mb-3" data-boton-descargar href="{{ fichero_subido_ruta[campo_hito.idCampoHito][loop.parent.loop.parent.loop.index-1] }}" target="_blank">Descargar</a> #}
																					{# <a class="btn btn-success waves-effect mb-3" data-boton-descargar href="{{ fichero_subido_ruta[campo_hito.idCampoHito]|first }}" target="_blank">Ver</a>
																				{% endif %} #}
																			</div>
																		</div>
																		{% form_theme agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																		<div class="form-row {% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}d-none{% endif %}"">
																			<div class="form-group col-md">
																				{{ form_label(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora) }}
																				{{ form_widget(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora) }}
																			</div>
																			<div class="form-group col-md">
																				{{ form_label(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																				{{ form_widget(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																			</div>
																		</div>
																	</div>
																{% else %}
																	<div class="form-row">
																		<div class="form-group col">
																			{% if campo_hito.tipo is same as(2) or campo_hito.tipo is same as(3) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }}
																			{% elseif campo_hito.tipo is same as(6) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor,{attr:{class:'js-datepicker'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																			{% elseif campo_hito.tipo is same as(7) or campo_hito.tipo is same as(8) or campo_hito.tipo is same as(9) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																			{% elseif campo_hito.tipo is same as(10) %}
																			{% else %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																			{% endif %}
																		</div>
																	</div>
																{% endif %}
															</div>
															{% if loop.index is even and not loop.last %}
																<div class="col-12 d-none d-lg-block">
																	<hr>
																</div>
															{% endif %}
														{% endfor %}
													</div>
												{% else %}
													<div class="alert alert-info" role="alert">
														<span>No hay campos hito.</span>
													</div>
												{% endif %}
												{% if grupo_campos_hito.repetible and grupos_campos_hito[hito.idHito]|length>1 %}
													<div class="d-flex justify-content-end border-top pt-3">
														{# <button class="btn btn-danger waves-effect {%if not loop.last%}oculto{% endif %}" data-borrar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button"> #}
														<button class="btn btn-danger waves-effect oculto" data-borrar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
															<i class="far fa-trash-alt"></i> Eliminar {{ grupo_campos_hito.nombre }}
														</button>
													</div>
												{% endif %}
											</div>
											{% if grupo_campos_hito.repetible %}
												<div class="d-flex justify-content-end{% if not loop.parent.loop.last %} mb-3{% endif %} mr-3" data-agregar-grupo-expediente-contenedor>
													<button class="btn btn-success waves-effect" data-agregar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
														<i class="fas fa-plus"></i> Añadir {{ grupo_campos_hito.nombre }}
													</button>
												</div>
											{% endif %}
										{% endfor %}
									{% else %}
										<div class="alert alert-info" role="alert">
											<span>No hay grupos de campos hito.</span>
										</div>
									{% endif %}
									<div class="d-flex justify-content-end border-top pt-3">
										<button class="btn btn-danger waves-effect btn-hito-rojo" data-borrar-hito-expediente type="button">
											<i class="far fa-trash-alt"></i> Eliminar {{ hito.nombre }}
										</button>
									</div>
								</div>
							</div>
						</div>
					{% endif %}
					{% set hitoAnterior = hito.idHito %}
				{% endfor %}
			{% endif %}
		{% endfor %}
	{% endif %}
{% endblock %}
{% block modals %}
	{{ parent() }}
	{% if nombres_fichero is defined %}
		<div class="modal fade" id="mensaje-ajax">
			<div class="modal-dialog">
				<div class="modal-content">
					<div class="modal-header">
						<h4 class="modal-title">
							<strong>Error</strong>
						</h4>
						<button class="close" data-dismiss="modal" type="button">×</button>
					</div>
					<div class="modal-body" id="mensaje-ajax-body">Error al borrar el archivo</div>
					<div class="modal-footer">
						<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
					</div>
				</div>
			</div>
		</div>
	{% endif %}
	{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined and (is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO')) %}
		{% include '@App/Backoffice/Modal/SeguimientoExpediente.html.twig' %}
	{% endif %}


	<!-- Modal Widget Belender -->
	<div class="modal fade" id="modal-widget-blender" tabindex="-1" role="dialog">
		<div class="modal-dialog modal-xl" role="document" style="max-width: 1024px; margin: auto; top: 50px;">
			<div class="modal-content">
				<div class="modal-header bg-primary text-white">
					<h5 class="modal-title"><i class="fas fa-file-upload mr-2"></i>Solicitar Documentos - Belender</h5>
					<button type="button" class="close text-white" data-dismiss="modal">
						<span>&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<iframe id="widgetIframe" src="" style="width: 100%; height: 600px; border: none;"></iframe>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
				</div>
			</div>
		</div>
	</div>
	<!-- Contenedores Belender -->
	<div id="botonDescargaContainer" style="display: none;"></div>
{% endblock %}