		// Inserta un archivo dado (URL + nombre) en el input Dropify correspondiente
		// Helpers para descargar y convertir a File y asignarlo al input
		async function descargarBlobDesdeUrl(url) {
			if (!url) throw new Error('URL vacía');
			const opts = { method: 'GET', credentials: 'same-origin' };
			try {
				const resp = await fetch(url, opts);
				if (!resp.ok) throw new Error('HTTP ' + resp.status + ' al descargar ' + url);
				return await resp.blob();
			} catch (e) {
				console.error('Error descargando blob desde URL:', url, e);
				throw e;
			}
		}

		function crearFileDesdeBlob(blob, nombre) {
			try {
				return new File([blob], nombre, { type: blob.type || 'application/pdf' });
			} catch (e) {
				// Entornos antiguos no soportan constructor File — usar Blob y añadir propiedades mínimas
				const fallback = new Blob([blob], { type: blob.type || 'application/pdf' });
				fallback.name = nombre;
				fallback.lastModified = Date.now();
				return fallback;
			}
		}

		function asignarFileAInput(inputEl, fileObj) {
			try {
				const dt = new DataTransfer();
				dt.items.add(fileObj);
				inputEl.files = dt.files;
				// Disparar eventos para que Dropify/otros detecten el cambio
				try {
					const evt = new Event('change', { bubbles: true });
					inputEl.dispatchEvent(evt);
					if (typeof $ !== 'undefined') $(inputEl).trigger('change');
				} catch (e) { /* no crítico */ }
				return true;
			} catch (e) {
				console.error('Error asignando file al input:', e);
				return false;
			}
		}

		async function insertarArchivoDesdeUrl(url, filename, dropifySelector = '.dropify', saveSelector = '[data-boton-enviar]') 
		{
			if (!url) { alert('URL de archivo no disponible'); return false; }
			try {
				const blob = await descargarBlobDesdeUrl(url);
				const file = crearFileDesdeBlob(blob, filename || (url.split('/').pop() || 'archivo'));
				const inputEl = document.querySelector(dropifySelector);
				if (!inputEl) { alert('No se encontró el input Dropify. Selector: ' + dropifySelector); return false; }
				const ok = asignarFileAInput(inputEl, file);
				if (!ok) { alert('No se pudo asignar el archivo al input'); return false; }
				if (saveSelector) {
					const saveBtn = document.querySelector(saveSelector);
					if (saveBtn) saveBtn.click();
				}
				return true;
			} catch (e) {
				console.error('Error insertando archivo desde URL:', e);
				alert('Error descargando/insertrando archivo. Revisa la consola.');
				return false;
			}
		}

		function insertarArchivoDesdeButton(btn) 
		{
			try {
				const tr = btn.closest('tr');
				if (!tr) return alert('fila no encontrada');
				const url = tr.getAttribute('data-file-url');
				const name = tr.getAttribute('data-file-name') || (url ? url.split('/').pop() : 'archivo.pdf');

				// helpers para detectar elementos/ids en el DOM
				function detectarIdsDesdeDOM() {
					const result = { id_campo_hito: null, id_expediente: null, id_campo_hito_expediente: null, dropifySelector: null, saveSelector: null };
					try {
						const lastHito = localStorage.getItem('belender_last_hito');
						let container = null;
						if (lastHito) container = document.querySelector('[data-id-hito-expediente="' + lastHito + '"]');
						if (!container) {
							// intentar localizar por input nif asociado
							if (lastHito) {
								const nifInput = document.getElementById('belenderNif_' + lastHito);
								if (nifInput) container = nifInput.closest('[data-id-hito-expediente]');
							}
						}
						// Si no hay contenedor aún, intentar buscar por título exacto 'RENTA ÚLTIMO AÑO'
						if (!container) {
							const titles = Array.from(document.querySelectorAll('h6.card-title'));
							for (const t of titles) {
								try {
									const text = (t.textContent || '').trim().replace(/\s+/g,' ');
									if (/^RENTA ÚLTIMO AÑO$/i.test(text)) {
										// buscar el contenedor de hito más cercano
										const possible = t.closest('[data-id-hito-expediente]') || t.closest('[data-hito-expediente]') || t.closest('.border');
										if (possible) { container = possible; break; }
									}
								} catch(e) {}
							}
						}
						// si hay contenedor del hito, buscar dentro el fichero y campo hito
						if (container) {
							// buscar elemento con data-fichero-campo
							const ficheroEl = container.querySelector('[data-fichero-campo]') || container.querySelector('[data-id-campo-hito]');
							if (ficheroEl) {
								const attr = ficheroEl.getAttribute('data-fichero-campo') || ficheroEl.getAttribute('data-id-campo-hito');
								if (attr && /\d+/.test(attr)) result.id_campo_hito_expediente = attr;
								// el campo hito estará en un ancestro con data-id-campo-hito
								const campoAncestor = ficheroEl.closest('[data-id-campo-hito]');
								if (campoAncestor) result.id_campo_hito = campoAncestor.getAttribute('data-id-campo-hito');
							}
							// intentar encontrar input.file.dropify concreto dentro del hito
							const inputFile = container.querySelector('input[type="file"].dropify');
							if (inputFile) result.dropifySelector = inputFile;
						}
						// intentar detectar id_expediente buscando inputs con nombre o id relacionados
						let expedienteInput = document.querySelector('input[name$="[idExpediente]"]') || document.querySelector('input[name*="idExpediente"]') || document.querySelector('input[id*="idExpediente"]') || document.querySelector('input[name="idExpediente"]');
						if (expedienteInput && expedienteInput.value) result.id_expediente = expedienteInput.value;
						// fallback: buscar un input oculto que contenga "idExpediente" en su name
						if (!result.id_expediente) {
							const anyHidden = Array.from(document.querySelectorAll('input[type="hidden"]')).find(i => /idExpediente/i.test(i.name) || /idExpediente/i.test(i.id));
							if (anyHidden) result.id_expediente = anyHidden.value;
						}
						// boton de guardar del formulario (saveSelector)
						const saveBtn = document.querySelector('[data-boton-enviar]');
						if (saveBtn) result.saveSelector = saveBtn;
					} catch(e) { console.warn('detectarIdsDesdeDOM error', e); }
					return result;
				}

				// Determinar DNI: preferir input belenderNif_{idHitoExpediente} guardado en localStorage
				let dni = '';
				try {
					const lastHito = localStorage.getItem('belender_last_hito');
					if (lastHito) {
						const nifInput = document.getElementById('belenderNif_' + lastHito);
						if (nifInput) dni = String(nifInput.value || '').trim();
					}
				} catch(e) { console.warn('No se pudo leer belender_last_hito', e); }
				if (!dni && url) {
					try { const u = new URL(url, window.location.origin); if (u.searchParams.has('dni')) dni = u.searchParams.get('dni'); } catch(e) {}
				}

				const detected = detectarIdsDesdeDOM();

				

				const idFromView = obtenerIdExpedienteDesdeVista();
				if (idFromView) console.log('Detected id_expediente from view:', idFromView);
				const defaultIdCampoHito = 313;
				const defaultIdExpediente = 15642;
				const defaultIdCampoHitoExpediente = 7086910;

				// Obtener id_hito_expediente de la vista: preferir localStorage (establecido en obtenerDocumentosAdmin)
				const idHitoExpedienteFromView = (function(){
					try { return localStorage.getItem('belender_last_hito') || null; } catch(e) { return null; }
				})();

				const payload = {
					id_campo_hito: detected.id_campo_hito || defaultIdCampoHito,
					id_expediente: idFromView || detected.id_expediente || defaultIdExpediente,
					id_campo_hito_expediente: detected.id_campo_hito_expediente || defaultIdCampoHitoExpediente,
					// Nuevo: enviar id_hito_expediente explícito si lo tenemos (viene de obtenerDocumentosAdmin(...))
					id_hito_expediente: idHitoExpedienteFromView || null,
					dni: dni,
					files: [ name ],
					source_url: url
				};

				console.log('Payload adjuntar-archivos:', payload);

				fetch('{{ path('belender_adjuntar_archivos') }}', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'X-Requested-With': 'XMLHttpRequest'
					},
					body: JSON.stringify(payload),
					credentials: 'same-origin'
				})
				.then(async res => {
					const status = res.status;
					let text = '';
					try { text = await res.text(); } catch(e) { text = ''; }
					let data = null;
					try { data = text ? JSON.parse(text) : null; } catch(e) { data = { raw: text }; }
					if (!res.ok) {
						console.error('HTTP error adjuntar-archivos:', status, res.statusText, data);
						const missing = data && data.missing ? '\nFaltan: ' + data.missing.join(', ') : '';
						alert('Error adjuntando archivo en el servidor. ' + (data && data.error ? data.error : '') + missing + '\nRevisa la consola para más detalles.');
						throw new Error('adjuntar-archivos HTTP ' + status);
					}
					return data;
				})
				.then(data => {
					if (data && data.success && data.saved_path) {
						// intentar obtener selector dropify detectado, si no usar el selector genérico
						let targetInput = null;
						if (detected.dropifySelector && detected.dropifySelector instanceof Element) targetInput = detected.dropifySelector;
						if (!targetInput) targetInput = document.querySelector('.dropify');
						let saveBtn = detected.saveSelector || document.querySelector('[data-boton-enviar]');
						insertarArchivoDesdeUrl(data.saved_path, data.saved_name || name, targetInput || '.dropify', saveBtn || '[data-boton-enviar]');
					} else {
						console.error('Respuesta inválida al adjuntar archivo:', data);
						alert('Error adjuntando archivo en el servidor: ' + (data && data.error ? data.error : JSON.stringify(data)));
					}
				})
				.catch(err => {
					console.error('Error en fetch adjuntar-archivos:', err);
				});
			} catch (e) { console.error(e); alert('Error al insertar archivo'); }
		}
		// Obtener id_expediente de la vista de forma fiable
		function obtenerIdExpedienteDesdeVista() 
		{
			// 0) Preferir input explícito preparado para Belender (determinista)
			try {
				const explicit = document.getElementById('idExpediente_belender');
				if (explicit && explicit.value) return explicit.value;
			} catch(e) {}

			// 1) Intentar extraer de la URL: /Expediente/{id} o /Documentos/{id} (PRIORIDAD ALTA)
			try {
				const path = window.location.pathname || '';
				let m = path.match(/Expediente\/(\d+)/i);
				if (m && m[1]) return m[1];
				// Para ruta cliente: /Documentos/15642
				m = path.match(/Documentos\/(\d+)/i);
				if (m && m[1]) return m[1];
				// Fallback: último segmento numérico en la ruta
				const parts = path.split('/').filter(p => p);
				for (let i = parts.length - 1; i >= 0; i--) {
					if (/^\d+$/.test(parts[i])) return parts[i];
				}
			} catch (e) {}

			// 2) inputs comunes generados por Symfony
			let el = document.querySelector('input[name$="[idExpediente]"], input[name*="idExpediente"], input[id*="idExpediente"], input[name="idExpediente"]');
			if (el && el.value) return el.value;
			
			// 3) any hidden input containing idExpediente in name or id
			const anyHidden = Array.from(document.querySelectorAll('input[type="hidden"]')).find(i => /idExpediente/i.test(i.name) || /idExpediente/i.test(i.id));
			if (anyHidden && anyHidden.value) return anyHidden.value;
			
			// 4) buscar en query string parámetros 'id_expediente' o 'expediente'
			try {
				const sp = new URLSearchParams(window.location.search);
				if (sp.get('id_expediente')) return sp.get('id_expediente');
				if (sp.get('expediente')) return sp.get('expediente');
			} catch (e) {}
			return null;
		}

		// Inicializar y fijar el hidden input al cargar la página para garantizar determinismo
		document.addEventListener('DOMContentLoaded', function() {
			try {
				const v = (function(){ try { return obtenerIdExpedienteDesdeVista(); } catch(e) { return null; } })();
				let el = document.getElementById('idExpediente_belender');
				if (!el) return;
				if (v) {
					el.value = v;
					console.log('idExpediente_belender set to', v);
				} else {
					console.log('idExpediente_belender present but no value extracted yet');
				}
			} catch(e){}
		});

		function verificarEstadoDocumentos() 
		{
			const requestId = localStorage.getItem("request_id");
			const dni = localStorage.getItem("dni");

			if (!requestId || !dni) {
				console.log('⏸️ Polling detenido - no hay request_id o dni');
				return;
			}

			fetch(`{{ path('document_download') }}?request_id=${requestId}&dni=${dni}`)
				.then(response => response.json())
				.then(data => {
					if (data.success && data.files && data.files.length > 0) {
							console.log('✅ Documentos descargados, deteniendo polling');
							// Esperar a que el modal cierre y luego mostrar overlay + continuar
							showOverlayAfterModalClosed('Descargando documentos...', null, function() {
								mostrarBotonDescarga(data.files);
								// Indicar éxito breve
								updateBelenderSyncOverlay('Documentos descargados correctamente', 'success');
							});
						} else {
						console.log('⏳ Esperando documentos, reintentando en 5 segundos...');
						updateBelenderSyncOverlay('Esperando documentos en Belender...', null);
						setTimeout(verificarEstadoDocumentos, 5000);
					}
				})
				.catch(error => {
					console.error('❌ Error en polling:', error);
					updateBelenderSyncOverlay('Error verificando documentos', 'error');
					// No reintentar si hay error 
				});
		}

		// Overlay visual para indicar sincronización con Belender
		function showBelenderSyncOverlay(mensaje = 'Sincronizando con Belender...') 
		{
			// No mostrar overlay si el modal de Belender está abierto
			try {
				if (typeof $ !== 'undefined' && $('#modal-widget-blender').length && $('#modal-widget-blender').hasClass('show')) return;
				const modalEl = document.getElementById('modal-widget-blender');
				if (modalEl && window.getComputedStyle(modalEl).display !== 'none') return;
			} catch (e) {}

			if (document.getElementById('belender-sync-overlay')) return;
			const html = `
				<div id="belender-sync-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:999999;display:flex;align-items:center;justify-content:center;">
					<div style="background:#fff;border-radius:8px;padding:18px 22px;display:flex;align-items:center;gap:12px;box-shadow:0 6px 20px rgba(0,0,0,0.2);min-width:280px;max-width:90%;">
						<div class="spinner-border text-primary" role="status" style="width:2rem;height:2rem;"></div>
						<div style="font-weight:600;color:#222;">${mensaje}</div>
					</div>
				</div>`;
			document.body.insertAdjacentHTML('beforeend', html);
		}

		function hideBelenderSyncOverlay() 
		{
			const el = document.getElementById('belender-sync-overlay');
			if (el) el.remove();
			// También ocultar el modal de información si está presente
			try { hideBelenderInfoModal(); } catch (e) {}
		}

		function hideBelenderInfoModal() 
		{
			try {
				const $modal = $('#belender-info-modal');
				if ($modal.length) {
					$modal.one('hidden.bs.modal', function() {
						$modal.remove();
						$('.modal-backdrop').remove();
						document.body.classList.remove('modal-open');
					});
					$modal.modal('hide');
					console.log('✅ Belender info modal hide triggered');
					return;
				}
				const el = document.getElementById('belender-info-modal'); if (el) el.remove();
				const backs = document.querySelectorAll('.modal-backdrop'); backs.forEach(function(b){ b.remove(); });
				document.body.classList.remove('modal-open');
			} catch(e) {
				const el = document.getElementById('belender-info-modal'); if (el) el.remove();
				const backs = document.querySelectorAll('.modal-backdrop'); backs.forEach(function(b){ b.remove(); });
				document.body.classList.remove('modal-open');
			}
		}

		function hideBelenderInfoModalCerrar() 
		{
			// Reuse the generic hide logic to ensure backdrop is removed correctly
			hideBelenderInfoModal();
		}

		function showOverlayAfterModalClosed(mensaje = 'Procesando...', status = null, callback = null) 
		{
			// Si el modal está abierto, esperar a que termine la animación 'hidden.bs.modal'
			try {
				if (typeof $ !== 'undefined' && $('#modal-widget-blender').length && $('#modal-widget-blender').hasClass('show')) {
					$('#modal-widget-blender').one('hidden.bs.modal', function() {
						// Mostrar modal de información y ejecutar callback
						showBelenderInfoModal(mensaje);
						if (status) updateBelenderInfoModal(mensaje, status);
						if (typeof callback === 'function') callback();
					});
					// Si el modal está visible, cerrar (triggerará el evento)
					try { $('#modal-widget-blender').modal('hide'); } catch(e){}
					return;
				}
			} catch (e) {}

			// Si el modal no está abierto, mostrar inmediatamente
			showBelenderInfoModal(mensaje);
			if (status) updateBelenderInfoModal(mensaje, status);
			if (typeof callback === 'function') callback();
		}

		function updateBelenderSyncOverlay(mensaje = '', status = null) 
		{
			// status: null | 'success' | 'error'
			// Si el modal de Belender está abierto, no mostrar/actualizar overlay
			try {
				if (typeof $ !== 'undefined' && $('#modal-widget-blender').length && $('#modal-widget-blender').hasClass('show')) return;
				const modalEl = document.getElementById('modal-widget-blender');
				if (modalEl && window.getComputedStyle(modalEl).display !== 'none') return;
			} catch (e) {}

			// Si hay un modal de información activo, actualizarlo en su lugar
			if (document.getElementById('belender-info-modal')) {
				updateBelenderInfoModal(mensaje, status);
				return;
			}

			const el = document.getElementById('belender-sync-overlay');
			if (!el) {
				showBelenderSyncOverlay(mensaje || 'Procesando...');
				return;
			}
			const inner = el.querySelector('div > div');
			if (!inner) return;
			let iconHtml = '';
			if (status === 'success') iconHtml = '<i class="fas fa-check-circle" style="color:green;font-size:1.5rem;margin-right:8px"></i>';
			if (status === 'error') iconHtml = '<i class="fas fa-times-circle" style="color:red;font-size:1.5rem;margin-right:8px"></i>';
			const msgEl = inner.querySelector('div[role="belender-message"]');
			if (msgEl) {
				msgEl.innerHTML = `${iconHtml}${mensaje}`;
			} else {
				const div = document.createElement('div');
				div.setAttribute('role', 'belender-message');
				div.style.fontWeight = '600';
				div.style.color = '#222';
				div.innerHTML = `${iconHtml}${mensaje}`;
				inner.appendChild(div);
			}

			// Auto-hide on success/error after short delay
			if (status === 'success') {
				setTimeout(() => hideBelenderSyncOverlay(), 1400);
			} else if (status === 'error') {
				setTimeout(() => hideBelenderSyncOverlay(), 3600);
			}
		}

		/* ===== Modal de información persistente (usado tras cerrar modal Belender) ===== */
		function showBelenderInfoModal(mensaje = 'Procesando...', status = null) 
		{
			// Evitar duplicados
			if (document.getElementById('belender-info-modal')) return;
			const modalHtml = `
						<div class="modal fade" id="belender-info-modal" tabindex="-1" role="dialog" aria-hidden="true">
							<div class="modal-dialog modal-dialog-centered" role="document" style="max-width:1080px;">
				    <div class="modal-content">
				      <div class="modal-header bg-primary text-white">
				        <h5 class="modal-title">Procesamiento</h5>
				      </div>
				      <div class="modal-body  align-items-start" style="gap:12px;">
				        <div class="spinner-border text-primary" role="status" id="belender-info-spinner" style="width:2rem;height:2rem;"></div>
				        <div id="belender-info-message" style="font-weight:600;color:#222;">${mensaje}</div>
				        <div style="width:100%;margin-top:12px;">
							<div class="progress mb-2" style="height:12px;"><div id="belender-info-progressbar" class="progress-bar" role="progressbar" style="width:0%"></div></div>
							<ul id="belender-progress-list" style="max-height:240px;overflow:auto;padding-left:18px;margin:0;"> </ul>
						</div>
				      </div>
				    </div>
				  </div>
				</div>`;
			document.body.insertAdjacentHTML('beforeend', modalHtml);
			try { $('#belender-info-modal').modal({backdrop: 'static', keyboard: false}); $('#belender-info-modal').modal('show'); } catch(e) {}
		}

		function mostrarBotonDescarga(files) 
		{
			console.log('mostrarBotonDescarga3333333', files);
			const totalArchivos = files.length;
			localStorage.removeItem("request_id");
			
			// Cerrar modal de widget (si está abierto)
			// Mostrar overlay después de que se cierre el modal (si estaba abierto)
			showOverlayAfterModalClosed(`Procesando ${totalArchivos} documento(s)...`, null, function() {
				// Lanzar función/evento cuando se descargan los documentos
				//onDocumentosDescargados(files, totalArchivos);
				// Mostrar mensaje final en overlay
				//updateBelenderSyncOverlay(`Se han descargado ${totalArchivos} documento(s)`, 'success');
				// Asegurar que el modal de información existe y está visible
			let infoModal = document.getElementById('belender-info-modal');
			if (!infoModal) {
				// Crear y mostrar el modal de información si no existe
				showBelenderInfoModal('Resultados listos');
				infoModal = document.getElementById('belender-info-modal');
			}
			if (infoModal) {
				// Actualizar header
				try {
					const header = infoModal.querySelector('.modal-header');
					if (header) header.innerHTML = `<h5 class="modal-title"><i class="fas fa-compress-alt mr-2"></i>JSON Consolidado (${totalDocumentos} documentos)</h5>`;
				} catch(e){}

				// Actualizar body: mostrar una tabla con los ficheros (nombre, tipo, acciones)
				const body = infoModal.querySelector('.modal-body');
				if (body) {
					// Filtrar solo PDFs y construir la tabla
					const pdfs = [];
					for (const f of files) {
						let url = null;
						let name = 'archivo';
						if (typeof f === 'string') { url = f; name = f.split('/').pop(); }
						else if (typeof f === 'object') {
							url = f.url || f.archivo || f.path || f.download_url || f.file || null;
							name = f.filename || f.nombre || f.name || (url ? String(url).split('/').pop() : 'archivo');
						}
						const ext = (name && name.split('.').length>1) ? name.split('.').pop().toLowerCase() : '';
						if (ext === 'pdf') pdfs.push({ url: url, name: name });
					}

					// Sin filtrado: usar todos los PDFs descargados
					const documentosFiltrados = pdfs;

					if (documentosFiltrados.length === 0) {
						body.innerHTML = `<div class="alert alert-info">No se han encontrado documentos PDF necesarios para este DNI.</div>`;
					} else {
						let tableHtml = `
							<div class="alert alert-success mb-3"> 
								<i class="fas fa-check-circle mr-2"></i>
								Se han procesado correctamente ${documentosFiltrados.length} documento(s) PDF requerido(s). El estado se actualizará automáticamente mientras se adjuntan.
							</div>
							<div style="max-height:360px;overflow:auto;">
							<table class="table table-striped table-sm" id="belender-files-table">
							<thead><tr><th>Archivo</th><th>Tipo</th><th style="width:180px">Estado</th></tr></thead>
							<tbody>
							`;

							let rowIndex = 0;
							for (const p of documentosFiltrados) {
								const safeUrl = p.url ? String(p.url).replace(/"/g, '%22') : '';
								const rowId = 'belender-status-row-' + (rowIndex);
								tableHtml += `<tr id="belender-row-${rowIndex}" data-file-url="${safeUrl}" data-file-name="${p.name}"><td title="${p.name}">${p.name}</td><td>PDF</td><td id="${rowId}">Pendiente</td></tr>`;
								rowIndex++;
							}

							// Auto-attach: procesar automáticamente una vez descargados
							try {
								const autoAttach = true; // activar auto-attach
								if (autoAttach) {
									// Ejecutar en background (se procesan secuencialmente)
									setTimeout(function(){
										autoAdjuntarYInsertarLista(documentosFiltrados).catch(e => console.error('autoAdjuntarYInsertarLista error', e));
									}, 200);
								}
							} catch(e) { console.warn('Auto attach error init', e); }

							tableHtml += `
							</tbody></table></div>`;
							body.innerHTML = tableHtml;
						}
					}

				// Actualizar footer con solo botón de cerrar (mostrar solo mensaje de éxito)
				let footer = infoModal.querySelector('.modal-footer');
				if (!footer) {
					footer = document.createElement('div');
					footer.className = 'modal-footer';
					infoModal.querySelector('.modal-content').appendChild(footer);
				}
				footer.innerHTML = ``;

				// Ensure modal remains visible (it should already be shown)
				try { 
					$('#belender-info-modal').modal('show'); 
				} 
				catch(e){}
				return;
			}
			});
		}

		// Obtener perfil del cliente desde el formulario
		function obtenerPerfilCliente() {
			// Opción 1: Buscar por ID específico del campo "Trabajo o Estado Laboral"
			const estadoLaboralInput = document.getElementById('campo_hito_expediente_0_690_0_valor');
			if (estadoLaboralInput) {
				const valor = estadoLaboralInput.value ? estadoLaboralInput.value.trim().toLowerCase() : '';
				
				if (valor) {
					console.log('📊 Estado Laboral encontrado:', valor);
					return valor;
				} else {
					console.log('ℹ️  Campo "Estado Laboral" vacío - mostrando todos los documentos');
					return null;
				}
			}

			// Opción 2: Buscar cualquier input que contenga información del estado laboral
			let perfilInputs = document.querySelectorAll('input[name*="690_0"][name*="valor"]');
			if (perfilInputs.length > 0) {
				for (let input of perfilInputs) {
					if (input.value && input.value.trim()) {
						return input.value.trim().toLowerCase();
					}
				}
			}

			// Opción 3: Buscar desde localStorage (si se guarda en sesión)
			const perfilLocalStorage = localStorage.getItem('perfil_cliente');
			if (perfilLocalStorage) {
				return perfilLocalStorage.toLowerCase();
			}

			console.log('⚠️  No se pudo determinar el perfil del cliente - mostrando todos los documentos');
			return null;
		}

		// ====== FILTRADO DE CAMPOS POR PERFIL ======
		function obtenerMapoAutomaticoCampos() {
			// Extraer automáticamente todos los campos disponibles en el hito 31
			const mapaCampos = {};
			const hitoDiv = document.querySelector('[data-hito-expediente="31"]');
			if (!hitoDiv) return mapaCampos;
			
			const todosCampos = hitoDiv.querySelectorAll('[data-id-campo-hito]');
			
			todosCampos.forEach(campo => {
				const idCampo = parseInt(campo.getAttribute('data-id-campo-hito'));
				// Buscar el nombre del campo en el h6 anterior
				const h6 = campo.querySelector('h6.card-title');
				const nombreCampo = h6 ? h6.textContent.trim().replace(/\s*\*\s*Sólo GN\s*$/, '').trim() : 'Campo ' + idCampo;
				mapaCampos[idCampo] = nombreCampo;
			});
			
			console.log('🔍 Mapa de campos encontrados en hito 31:', mapaCampos);
			return mapaCampos;
		}

		function filtrarCamposSegunPerfil() {
			const perfil = obtenerPerfilCliente();
			console.log('📋 Filtrando campos del hito 31 según perfil:', perfil);

			// Obtener el contenedor del hito 31
			const hitoDiv = document.querySelector('[data-hito-expediente="31"]');
			if (!hitoDiv) {
				console.log('⚠️  Hito 31 no encontrado en la página');
				return;
			}

			// Obtener todos los campos disponibles en el hito 31
			const mapaCampos = obtenerMapoAutomaticoCampos();
			
			// Mapeo: Perfil → Palabras clave para identificar campos requeridos
			// Basado en los documentos que cada perfil debe ver
			const palabrasclavePorPerfil = {
				jubilado: [
					// SIEMPRE: DNI, Renta, Certificado Retenciones, Vida Laboral, Movimientos Bancarios, 
					// Contrato Alquiler, Recibos Préstamos, Cuadro Amortización, Convenio, IVA-IRPF, Estado Civil, Otros
					'dni', 'nie', 'tarjeta residencia', 'residencia',
					'renta', 'certificado retenciones', 'retenciones',
					'vida laboral', 'laboral',
					'movimientos bancarios', 'movimientos', 'bancarios',
					'contrato alquiler', 'alquiler',
					'recibos préstamos', 'recibos',
					'cuadro amortización', 'amortización',
					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf',
					'certificado estado civil', 'estado civil',
					'certificado pensión', 'pensión', 'pension',
					'otros', 'documentación adicional',
					'100', '111', '130', '131', '347', '390',
					'censo', 'cotizacion', 'revalorización', 'situación aeat', 'situación ss'
				],
				empleado: [
					// SIEMPRE: DNI, Renta, Certificado Retenciones, Vida Laboral, Movimientos Bancarios,
					// Contrato Alquiler, Recibos Préstamos, Cuadro Amortización, Convenio, IVA-IRPF, Estado Civil, Otros
					// ADICIONAL: Contrato Trabajo, Nóminas, Cotización, Laboral_V2
					'dni', 'nie', 'tarjeta residencia', 'residencia',
					'contrato de trabajo', 'contrato trabajo',
					'nóminas', 'nomina', '3 últimas nóminas',
					'renta', 'certificado retenciones', 'retenciones',
					'vida laboral', 'laboral', 'laboral_v2',
					'movimientos bancarios', 'movimientos', 'bancarios',
					'contrato alquiler', 'alquiler',
					'recibos préstamos', 'recibos',
					'cuadro amortización', 'amortización',
					'convenio', 'sentencia',
					'trimestres iva', 'iva', 'irpf',
					'certificado estado civil', 'estado civil',
					'otros', 'documentación adicional',
					'cotizacion', '100', '111', '130', '131', '347', '390'
				],
