		// ===== 3.5. FUNCIÓN PARA CONTAR PRÉSTAMOS EN HITO 46 =====
		function contarPrestamosEnHito46() 
		{
			// Contar todos los bloques de hito 46 (incluyendo el primero + los agregados)
			// Selector: [data-hito-expediente="46"] que NO tengan data-modelo-hito-expediente (estos son templates)
			const prestamosBloques = document.querySelectorAll('[data-hito-expediente="46"]:not([data-modelo-hito-expediente])');
