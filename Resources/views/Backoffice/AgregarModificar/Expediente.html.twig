		/* ===== Estilos para PDF (html2canvas) ===== */
		@page {
			margin: 10mm;
			size: A4 portrait;
		}

		@media print {
			.no-print {
				display: none !important;
			}

			/* Evitar cortes en tablas y secciones */
			.informe-pdf div[data-documento-id] {
				page-break-inside: avoid;
			}

			.informe-pdf table {
				page-break-inside: avoid;
			}

			.informe-pdf tr {
				page-break-inside: avoid;
			}

			.informe-pdf > div:first-child {
				page-break-inside: avoid;
			}

			/* Encabezados de interviniente siempre juntos con contenido */
