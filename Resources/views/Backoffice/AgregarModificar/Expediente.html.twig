		function solicitarCirbeDocumentos(idHitoExpediente) 
		{
			try {
				const input = document.getElementById("belenderNif_" + idHitoExpediente);
				const dni = input ? String(input.value).trim() : '';
				
				if (!dni) {
					//alert('No se ha encontrado el DNI del cliente');
					const input = document.getElementById("belenderNif_" + idHitoExpediente);
					$('#belenderNif_' + idHitoExpediente).focus();
					mostrarToast('No se ha encontrado el DNI del cliente.', 'error', 3000);					
					return;
				}
				
				// Guardar datos para usar en el modal
				window.cirbeData = {
					idHitoExpediente: idHitoExpediente,
					dni: dni
				};
				
				// Limpiar campos del modal
				document.getElementById('cirbeNombre').value = '';
				document.getElementById('cirbeApellido1').value = '';
				document.getElementById('cirbeApellido2').value = '';
				document.getElementById('cirbeDniDisplay').textContent = dni;
				
				// Abrir modal
				try { 
					$('#modal-cirbe-request').modal({backdrop: 'static', keyboard: false}); 
					$('#modal-cirbe-request').modal('show'); 
				} catch(e) {
					//console.error('Error abriendo modal:', e);
				}
			} catch (err) {
				//console.error('Error en solicitarCirbeDocumentos:', err);
				alert('Error inesperado');
			}
		}

		function enviarSolicitudCirbe() 
		{
			try {
				const nombre = document.getElementById('cirbeNombre').value.trim();
				const apellido1 = document.getElementById('cirbeApellido1').value.trim();
				const apellido2 = document.getElementById('cirbeApellido2').value.trim();
				const dni = window.cirbeData?.dni || '';
				const idHitoExpediente = window.cirbeData?.idHitoExpediente || '';

				// Validaciones
				if (!nombre) 
				{
					mostrarToast('El campo "Nombre" es obligatorio', 'error', 3000);
					document.getElementById('cirbeNombre').focus();
					return;
				}
				if (!apellido1) 
				{
					mostrarToast('El campo "Primer Apellido" es obligatorio', 'error', 3000);
					document.getElementById('cirbeApellido1').focus();
					return;
				}
				if (!dni) 
				{
					mostrarToast('No se encontró el DNI', 'error', 3000);
					return;
				}

				// Construir payload
				const payload = {
					dni: dni,
					nombre: nombre,
					apellido1: apellido1,
					apellido2: apellido2 || '',
					idHitoExpediente: idHitoExpediente
				};

				//console.log('📤 Enviando solicitud CIRBE:', JSON.stringify(payload));
				
				// Mostrar overlay
				showBelenderSyncOverlay('Solicitando informe CIRBE...');

				// Hacer petición
				fetch(`{{ path('solicitar_cirbe') }}`, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'X-Requested-With': 'XMLHttpRequest'
					},
					body: JSON.stringify(payload)
				})
				.then(response => response.json())
				.then(data => {
					hideBelenderSyncOverlay();
					
					if (data.status === 'success' || data.request_id) {
						//console.log('✅ CIRBE solicitado:', data);
						
						// Guardar IDs para usos posteriores si lo necesitas
						localStorage.setItem('cirbe_request_id', data.request_id);
						localStorage.setItem('cirbe_funder_id', data.funder_id || '');
						localStorage.setItem('cirbe_dni', dni);
