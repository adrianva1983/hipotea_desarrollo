		// Función para monitorear cambios en Hito 46 (cuando se agregan préstamos)
		function monitorearPrestamosBotonesAgregar() {
			// Buscar todos los botones "+ Agregar" en Hito 46
			const hito46 = document.querySelector('[data-hito-expediente="46"]');
			if (!hito46) return;
			
			// Observar MutationObserver para detectar cuando se agrega un nuevo préstamo
			const observer = new MutationObserver(() => {
				//console.log('Cambio detectado en Hito 46 - Actualizando filtrado de Hito 31');
				filtrarCamposHito31();
			});
			
			observer.observe(hito46, {
				childList: true,      // Detectar nuevos elementos agregados
				subtree: true,        // Monitorear profundidad
				attributes: false
			});
			
			//console.log('✓ Monitor de Hito 46 iniciado');
		}
		
		// Listeners para botones de agregar/eliminar préstamos
		function configurarListenersPrestamosBotones() {
			// Botones para AGREGAR préstamos (data-agregar-hito-expediente="46")
			const botonesAgregar = document.querySelectorAll('[data-agregar-hito-expediente="46"]');
			botonesAgregar.forEach(btn => {
				btn.addEventListener('click', () => {
					//console.log('Botón agregar préstamo presionado');
					// Esperar a que el DOM se actualice antes de filtrar
					setTimeout(() => {
						//console.log('Ejecutando filtrado después de agregar préstamo');
						filtrarCamposHito31();
					}, 300);
				});
			});
			
			// Botones para ELIMINAR préstamos (data-borrar-hito-expediente="46")
			const botonesEliminar = document.querySelectorAll('[data-borrar-hito-expediente="46"]');
			botonesEliminar.forEach(btn => {
				btn.addEventListener('click', () => {
					//console.log('Botón eliminar préstamo presionado');
					// Esperar a que el DOM se actualice antes de filtrar
					setTimeout(() => {
						//console.log('Ejecutando filtrado después de eliminar préstamo');
						filtrarCamposHito31();
					}, 300);
				});
			});
			
			//console.log('✓ Listeners de botones de préstamos configurados');
		}

