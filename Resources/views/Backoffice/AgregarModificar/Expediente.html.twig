		function mostrarBotonDescarga(files) 
		{
			//console.log('mostrarBotonDescarga4444444', files);
			const totalArchivos = files.length;
			localStorage.removeItem("request_id");
			
			// Cerrar modal de widget (si está abierto)
			// Mostrar overlay después de que se cierre el modal (si estaba abierto)
			showOverlayAfterModalClosed(`Procesando ${totalArchivos} documento(s)...`, null, function() {
				// Lanzar función/evento cuando se descargan los documentos
				//onDocumentosDescargados(files, totalArchivos);
				// Mostrar mensaje final en overlay
				//updateBelenderSyncOverlay(`Se han descargado ${totalArchivos} documento(s)`, 'success');
				// Asegurar que el modal de información existe y está visible
			let infoModal = document.getElementById('belender-info-modal');
			if (!infoModal) {
				// Crear y mostrar el modal de información si no existe
				showBelenderInfoModal('Resultados listos');
				infoModal = document.getElementById('belender-info-modal');
			}
			if (infoModal) {
				// Actualizar header
				try {
					const header = infoModal.querySelector('.modal-header');
					if (header) header.innerHTML = `<h5 class="modal-title"><i class="fas fa-compress-alt mr-2"></i>JSON Consolidado (${totalDocumentos} documentos)</h5>`;
				} catch(e){}

				// Actualizar body: mostrar una tabla con los ficheros (nombre, tipo, acciones)
				const body = infoModal.querySelector('.modal-body');
				if (body) {
					// Filtrar solo PDFs y construir la tabla
					const pdfs = [];
					for (const f of files) {
						let url = null;
						let name = 'archivo';
						if (typeof f === 'string') { url = f; name = f.split('/').pop(); }
						else if (typeof f === 'object') {
							url = f.url || f.archivo || f.path || f.download_url || f.file || null;
							name = f.filename || f.nombre || f.name || (url ? String(url).split('/').pop() : 'archivo');
						}
						const ext = (name && name.split('.').length>1) ? name.split('.').pop().toLowerCase() : '';
						if (ext === 'pdf') pdfs.push({ url: url, name: name });
					}

					if (pdfs.length === 0) {
						body.innerHTML = `<div class="alert alert-info">No se han encontrado documentos PDF para este DNI.</div>`;
					} else {
						let tableHtml = `
							<div class="alert alert-success mb-3"> 
								<i class="fas fa-check-circle mr-2"></i>
								Se han procesado correctamente ${pdfs.length} documento(s) PDF. El estado se actualizará automáticamente mientras se adjuntan.
							</div>
							<div style="max-height:360px;overflow:auto;">
							<table class="table table-striped table-sm" id="belender-files-table">
							<thead><tr><th>Archivo</th><th>Tipo</th><th style="width:180px">Estado</th></tr></thead>
							<tbody>
							`;

							let rowIndex = 0;
							for (const p of pdfs) {
								const safeUrl = p.url ? String(p.url).replace(/"/g, '%22') : '';
								const rowId = 'belender-status-row-' + (rowIndex);
								tableHtml += `<tr id="belender-row-${rowIndex}" data-file-url="${safeUrl}" data-file-name="${p.name}"><td title="${p.name}">${p.name}</td><td>PDF</td><td id="${rowId}">Pendiente</td></tr>`;
								rowIndex++;
							}

							// Auto-attach: procesar automáticamente una vez descargados
							try {
								const autoAttach = true; // activar auto-attach
								if (autoAttach) {
									// Ejecutar en background (se procesan secuencialmente)
									setTimeout(function(){
										autoAdjuntarYInsertarLista(pdfs).catch(e => console.error('autoAdjuntarYInsertarLista error', e));
									}, 200);
								}
							} catch(e) { 
								//console.warn('Auto attach error init', e); 
							}

							tableHtml += `
							</tbody></table></div>`;
							body.innerHTML = tableHtml;
						}
					}

				// Actualizar footer con solo botón de cerrar (mostrar solo mensaje de éxito)
				let footer = infoModal.querySelector('.modal-footer');
				if (!footer) {
					footer = document.createElement('div');
					footer.className = 'modal-footer';
					infoModal.querySelector('.modal-content').appendChild(footer);
				}
				footer.innerHTML = ``;

				// Ensure modal remains visible (it should already be shown)
				try { 
					$('#belender-info-modal').modal('show'); 
				} 
				catch(e){}
				return;
			}
			});
		}
		
		function updateBelenderInfoModal(mensaje = '', status = null) 
		{
			const modal = document.getElementById('belender-info-modal');
			if (!modal) return;
			const msgEl = modal.querySelector('#belender-info-message');
			const spinner = modal.querySelector('#belender-info-spinner');
			if (msgEl) msgEl.innerHTML = mensaje;
			if (status === 'success') {
				if (spinner) spinner.classList.remove('spinner-border');
				if (spinner) spinner.classList.add('d-none');
				if (msgEl) msgEl.insertAdjacentHTML('afterbegin', '<i class="fas fa-check-circle" style="color:green;margin-right:8px"></i>');
				// No auto-hide: dejar modal abierto para mostrar resultado final
			} else if (status === 'error') {
				if (spinner) spinner.classList.remove('spinner-border');
				if (spinner) spinner.classList.add('d-none');
				if (msgEl) msgEl.insertAdjacentHTML('afterbegin', '<i class="fas fa-times-circle" style="color:red;margin-right:8px"></i>');
				// No auto-hide: permitir al usuario ver el error
			}
		}

		// Auto adjuntar e insertar una lista de PDFs: adjunta en backend y luego descarga blob->File->asigna input
		async function autoAdjuntarYInsertarLista(pdfs) {
			if (!Array.isArray(pdfs) || pdfs.length === 0) return;
			const dni = localStorage.getItem('dni') || '';
			//const dni = '95328187H';
			if (!dni) console.warn('autoAdjuntar: no hay dni en localStorage');
			// Mostrar modal de progreso si no existe
			showBelenderInfoModal('Procesando documentos...');
			// Inicializar lista y barra
			const progressList = document.getElementById('belender-progress-list');
			const progressBar = document.getElementById('belender-info-progressbar');
			if (progressList) progressList.innerHTML = '';
			let index = 0;
			for (const p of pdfs) {
				index++;
				const progressPercent = Math.round((index - 1) / pdfs.length * 100);
				if (progressBar) progressBar.style.width = progressPercent + '%';
				// Añadir item en la lista
				let li = null;
				if (progressList) {
					li = document.createElement('li');
					li.textContent = (p.name || (typeof p === 'string' ? p.split('/').pop() : 'archivo')) + ' — Pendiente';
					li.style.marginBottom = '6px';
					progressList.appendChild(li);
				}
				try {
					const name = p.name || (typeof p === 'string' ? p.split('/').pop() : null);
					const url = p.url || (typeof p === 'string' ? p : null);
					if (!name) {
						if (li) li.textContent = (li.textContent || '') + ' — Nombre no disponible';
						continue;
					}

					// Determinar id de fila correspondiente y helper para actualizar estado en la tabla
					const rowIndex = index - 1;
					const rowStatusId = 'belender-status-row-' + rowIndex;
					function setRowStatus(text) {
						try { const el = document.getElementById(rowStatusId); if (el) el.textContent = text; } catch(e){}
					}

					// Detectar ids y selectores desde DOM
					const detected = (typeof detectarIdsDesdeDOM === 'function') ? detectarIdsDesdeDOM() : {};
					const idFromView = (typeof obtenerIdExpedienteDesdeVista === 'function') ? obtenerIdExpedienteDesdeVista() : null;
					const idHitoExpediente = localStorage.getItem('belender_last_hito') || detected.id_campo_hito_expediente || null;
					const payload = {
						id_campo_hito: detected.id_campo_hito || 313,
						id_expediente: idFromView || detected.id_expediente || null,
						id_campo_hito_expediente: detected.id_campo_hito_expediente || null,
						id_hito_expediente: idHitoExpediente,
						dni: dni,
						files: [ name ],
						source_url: url || null
					};
					if (li) li.textContent = name + ' — Adjuntando...';
					//console.log('AUTO Payload adjuntar-archivos:', payload);
					//console.log('🔍 DEBUG: idFromView=', idFromView, 'detected.id_expediente=', detected.id_expediente, 'idHitoExpediente=', idHitoExpediente);
					//console.log('🔍 DEBUG: detected=', detected);
					// Llamar al endpoint para adjuntar y esperar respuesta
					let adjResp = null;
					try {
						const res = await fetch('{{ path('belender_adjuntar_archivos') }}', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
							credentials: 'same-origin',
							body: JSON.stringify(payload)
						});
						adjResp = await (res.ok ? res.json() : (await res.text()));
						//console.log('AUTO adjuntar response1:', adjResp);
							if (li) li.textContent = name + ' — Adjuntado';
							try { setRowStatus('Adjuntado'); } catch(e){}
					} catch(e) {
						//console.error('AUTO adjuntar fetch error', e);
							if (li) li.textContent = name + ' — Error al adjuntar';
							try { setRowStatus('Error al adjuntar'); } catch(e){}
					}

					// Intentar insertar en Dropify sin pulsar botón guardar
					try {
						let inputEl = null;
						if (detected.dropifySelector && detected.dropifySelector instanceof Element) inputEl = detected.dropifySelector;
						if (!inputEl) inputEl = document.querySelector('.dropify');
						if (url && inputEl) {
							if (li) li.textContent = name + ' — Insertando en preview...';
							try { setRowStatus('Insertando en preview...'); } catch(e){}
							const blob = await descargarBlobDesdeUrl(url);
							const file = crearFileDesdeBlob(blob, name);
							asignarFileAInput(inputEl, file);
							if (li) li.textContent = name + ' — Insertado (preview)';
							try { setRowStatus('Insertado (preview)'); } catch(e){}
						} else if (adjResp && adjResp.success && adjResp.saved_path && inputEl) {
							if (li) li.textContent = name + ' — Insertando desde saved_path...';
							try { setRowStatus('Insertando desde saved_path...'); } catch(e){}
							const blob2 = await descargarBlobDesdeUrl(adjResp.saved_path);
							const file2 = crearFileDesdeBlob(blob2, adjResp.saved_name || name);
							asignarFileAInput(inputEl, file2);
							if (li) li.textContent = name + ' — Insertado (preview)';
							try { setRowStatus('Insertado (preview)'); } catch(e){}
						} else {
							// No se pudo insertar en preview
							if (li) li.textContent = name + ' — Adjuntado (no preview)';
							try { setRowStatus('Adjuntado (no preview)'); } catch(e){}
						}
					} catch(e) {
						//console.warn('AUTO no se pudo insertar en preview', e);
						if (li) li.textContent = name + ' — Error insertando preview';
					}

					// Actualizar barra progreso
					const donePercent = Math.round(index / pdfs.length * 100);
					if (progressBar) progressBar.style.width = donePercent + '%';

					// Pequeña espera entre archivos para evitar saturar el UI/backend
					await new Promise(r => setTimeout(r, 350));
				} catch (e) {
					//console.error('Error procesando archivo auto adjuntar', p, e);
					if (li) li.textContent = (p.name||p) + ' — Error inesperado';
				}
			}
			// Finalizar progreso
			if (progressBar) progressBar.style.width = '100%';
			//console.log('✅ Procesamiento completado, actualizando modal...');
			updateBelenderInfoModal('Procesamiento finalizado', 'success');
			//console.log('⏳ Recargando página en 2 segundos...');
			// Recargar la página después de 2 segundos
			setTimeout(function() {
				//console.log('🔄 Ejecutando window.location.reload()');
				window.location.reload(); 
			}, 2000);
		}

		

		// Mapeo de status_code a mensajes descriptivos
		const belenderStatusMessages = {
			'all_documents_downloaded': '✅ Todos los documentos disponibles para ser adjuntados',
			'partial_documents_downloaded': '⚠️ Documentos parcialmente disponibles, puede intentarlo más tarde',
		};

		function getStatusMessage(statusCode) {
			if (belenderStatusMessages[statusCode]) {
				return belenderStatusMessages[statusCode];
			}
			return '⏳ Descarga aún no disponible - Intentar más tarde';
		}

		function miFuncionHover(idHitoExpediente) 
		{
			//console.log('Hover en botón', idHitoExpediente);
			
			// Obtener el botón por su ID
			const buttonElement = document.getElementById(`verificar_${idHitoExpediente}`);
			
			// Mostrar tooltip de carga de forma simple
			if (buttonElement) {
				//buttonElement.setAttribute('title', '⏳ Buscando datos...');
				buttonElement.setAttribute('data-toggle', 'tooltip');
				buttonElement.setAttribute('data-placement', 'top');
			}
			
			fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=BELENDER`)
				.then(response => response.json())
				.then(data => {
					if (data.found) {
						//console.log('✅ Datos encontrados en BD', data);
						requestId = data.request_id;
						dni = data.dni;
						
						// Obtener mensaje basado en el status_code
						const statusCode = data.status_code || data.tipo_peticion;
						const statusMessage = getStatusMessage(statusCode);
						const tooltipMessage = `${statusMessage} | DNI: ${dni}`;
						
						// Determinar si la descarga está disponible
						const downloadAvailable = statusCode === 'all_documents_downloaded' || statusCode === 'partial_documents_downloaded';
						
						// Actualizar tooltip y estado del botón
						if (buttonElement) {
							buttonElement.setAttribute('title', tooltipMessage);
							
							if (downloadAvailable) {
								// Habilitar botón
								buttonElement.disabled = false;
								buttonElement.style.opacity = '1';
								buttonElement.style.cursor = 'pointer';
							} else {
								// Deshabilitar botón
								buttonElement.disabled = true;
								buttonElement.style.opacity = '0.5';
								buttonElement.style.cursor = 'not-allowed';
							}
							
							// Reinitializar tooltip en Bootstrap 4/5
							if (typeof $().tooltip === 'function') {
								$(buttonElement).tooltip('dispose');
								$(buttonElement).tooltip('show');
							} else if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
								try {
									new bootstrap.Tooltip(buttonElement, {trigger: 'manual'}).show();
								} catch(e) {
									//console.log('Tooltip no disponible');
								}
							}
						}
						return;
					} else {
						//console.log('❌ No se encontraron datos en BD', data);
						
						// Actualizar tooltip de no encontrado y deshabilitar botón
						if (buttonElement) {
							buttonElement.setAttribute('title', '❌ No se encontró registro - Ejecutar primero Belender');
							buttonElement.disabled = true;
							buttonElement.style.opacity = '0.5';
							buttonElement.style.cursor = 'not-allowed';
							
							if (typeof $().tooltip === 'function') {
								$(buttonElement).tooltip('dispose');
								$(buttonElement).tooltip('show');
							}
						}
						return;
					}
				})
				.catch(error => {
					//console.error('⚠️ Error buscando en BD:', error);
					
					// Actualizar tooltip de error y deshabilitar botón
					if (buttonElement) {
						buttonElement.setAttribute('title', '⚠️ Error: ' + error.message);
						buttonElement.disabled = true;
						buttonElement.style.opacity = '0.5';
						buttonElement.style.cursor = 'not-allowed';
						
						if (typeof $().tooltip === 'function') {
							$(buttonElement).tooltip('dispose');
							$(buttonElement).tooltip('show');
						}
					}
				});
			return;
		}


