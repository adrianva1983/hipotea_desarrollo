		// Inserta un archivo dado (URL + nombre) en el input Dropify correspondiente
		// Helpers para descargar y convertir a File y asignarlo al input
		async function descargarBlobDesdeUrl(url) {
			if (!url) throw new Error('URL vacía');
			const opts = { method: 'GET', credentials: 'same-origin' };
			try {
				const resp = await fetch(url, opts);
				if (!resp.ok) throw new Error('HTTP ' + resp.status + ' al descargar ' + url);
				return await resp.blob();
			} catch (e) {
				//console.error('Error descargando blob desde URL:', url, e);
				throw e;
			}
		}

		function crearFileDesdeBlob(blob, nombre) {
			try {
				return new File([blob], nombre, { type: blob.type || 'application/pdf' });
			} catch (e) {
				// Entornos antiguos no soportan constructor File — usar Blob y añadir propiedades mínimas
				const fallback = new Blob([blob], { type: blob.type || 'application/pdf' });
				fallback.name = nombre;
				fallback.lastModified = Date.now();
				return fallback;
			}
		}

		function asignarFileAInput(inputEl, fileObj) {
			try {
				const dt = new DataTransfer();
				dt.items.add(fileObj);
				inputEl.files = dt.files;
				// Disparar eventos para que Dropify/otros detecten el cambio
				try {
					const evt = new Event('change', { bubbles: true });
					inputEl.dispatchEvent(evt);
					if (typeof $ !== 'undefined') $(inputEl).trigger('change');
				} catch (e) { /* no crítico */ }
				return true;
			} catch (e) {
				//console.error('Error asignando file al input:', e);
				return false;
			}
		}

		async function insertarArchivoDesdeUrl(url, filename, dropifySelector = '.dropify', saveSelector = '[data-boton-enviar]') 
		{
			if (!url) { alert('URL de archivo no disponible'); return false; }
			try {
				const blob = await descargarBlobDesdeUrl(url);
				const file = crearFileDesdeBlob(blob, filename || (url.split('/').pop() || 'archivo'));
				const inputEl = document.querySelector(dropifySelector);
				if (!inputEl) { alert('No se encontró el input Dropify. Selector: ' + dropifySelector); return false; }
				const ok = asignarFileAInput(inputEl, file);
				if (!ok) { alert('No se pudo asignar el archivo al input'); return false; }
				if (saveSelector) {
					const saveBtn = document.querySelector(saveSelector);
					if (saveBtn) saveBtn.click();
				}
				return true;
			} catch (e) {
				//console.error('Error insertando archivo desde URL:', e);
				alert('Error descargando/insertrando archivo. Revisa la consola.');
				return false;
			}
		}

		function insertarArchivoDesdeButton(btn) 
		{
			try {
				const tr = btn.closest('tr');
				if (!tr) return alert('fila no encontrada');
				const url = tr.getAttribute('data-file-url');
				const name = tr.getAttribute('data-file-name') || (url ? url.split('/').pop() : 'archivo.pdf');

				// helpers para detectar elementos/ids en el DOM
				function detectarIdsDesdeDOM() {
					const result = { id_campo_hito: null, id_expediente: null, id_campo_hito_expediente: null, dropifySelector: null, saveSelector: null };
					try {
						const lastHito = localStorage.getItem('belender_last_hito');
						let container = null;
						if (lastHito) container = document.querySelector('[data-id-hito-expediente="' + lastHito + '"]');
						if (!container) {
							// intentar localizar por input nif asociado
							if (lastHito) {
								const nifInput = document.getElementById('belenderNif_' + lastHito);
								if (nifInput) container = nifInput.closest('[data-id-hito-expediente]');
							}
						}
						// Si no hay contenedor aún, intentar buscar por título exacto 'RENTA ÚLTIMO AÑO'
						if (!container) {
							const titles = Array.from(document.querySelectorAll('h6.card-title'));
							for (const t of titles) {
								try {
									const text = (t.textContent || '').trim().replace(/\s+/g,' ');
									if (/^RENTA ÚLTIMO AÑO$/i.test(text)) {
										// buscar el contenedor de hito más cercano
										const possible = t.closest('[data-id-hito-expediente]') || t.closest('[data-hito-expediente]') || t.closest('.border');
										if (possible) { container = possible; break; }
									}
								} catch(e) {}
							}
						}
						// si hay contenedor del hito, buscar dentro el fichero y campo hito
						if (container) {
							// buscar elemento con data-fichero-campo
							const ficheroEl = container.querySelector('[data-fichero-campo]') || container.querySelector('[data-id-campo-hito]');
							if (ficheroEl) {
								const attr = ficheroEl.getAttribute('data-fichero-campo') || ficheroEl.getAttribute('data-id-campo-hito');
								if (attr && /\d+/.test(attr)) result.id_campo_hito_expediente = attr;
								// el campo hito estará en un ancestro con data-id-campo-hito
								const campoAncestor = ficheroEl.closest('[data-id-campo-hito]');
								if (campoAncestor) result.id_campo_hito = campoAncestor.getAttribute('data-id-campo-hito');
							}
							// intentar encontrar input.file.dropify concreto dentro del hito
							const inputFile = container.querySelector('input[type="file"].dropify');
							if (inputFile) result.dropifySelector = inputFile;
						}
						// intentar detectar id_expediente buscando inputs con nombre o id relacionados
						let expedienteInput = document.querySelector('input[name$="[idExpediente]"]') || document.querySelector('input[name*="idExpediente"]') || document.querySelector('input[id*="idExpediente"]') || document.querySelector('input[name="idExpediente"]');
						if (expedienteInput && expedienteInput.value) result.id_expediente = expedienteInput.value;
						// fallback: buscar un input oculto que contenga "idExpediente" en su name
						if (!result.id_expediente) {
							const anyHidden = Array.from(document.querySelectorAll('input[type="hidden"]')).find(i => /idExpediente/i.test(i.name) || /idExpediente/i.test(i.id));
							if (anyHidden) result.id_expediente = anyHidden.value;
						}
						// boton de guardar del formulario (saveSelector)
						const saveBtn = document.querySelector('[data-boton-enviar]');
						if (saveBtn) result.saveSelector = saveBtn;
					} catch(e) { 
						//console.warn('detectarIdsDesdeDOM error', e); 
						}
					return result;
				}

				// Determinar DNI: preferir input belenderNif_{idHitoExpediente} guardado en localStorage
				let dni = '';
				try {
					const lastHito = localStorage.getItem('belender_last_hito');
					if (lastHito) {
						const nifInput = document.getElementById('belenderNif_' + lastHito);
						if (nifInput) dni = String(nifInput.value || '').trim();
					}
				} catch(e) { 
					//console.warn('No se pudo leer belender_last_hito', e); 
					}
				if (!dni && url) {
					try { const u = new URL(url, window.location.origin); if (u.searchParams.has('dni')) dni = u.searchParams.get('dni'); } catch(e) {}
				}

				const detected = detectarIdsDesdeDOM();

				

				const idFromView = obtenerIdExpedienteDesdeVista();
				//if (idFromView) console.log('Detected id_expediente from view:', idFromView);
				const defaultIdCampoHito = 313;
				const defaultIdExpediente = 15642;
				const defaultIdCampoHitoExpediente = 7086910;

				// Obtener id_hito_expediente de la vista: preferir localStorage (establecido en obtenerDocumentosAdmin)
				const idHitoExpedienteFromView = (function(){
					try { return localStorage.getItem('belender_last_hito') || null; } catch(e) { return null; }
				})();

				const payload = {
					id_campo_hito: detected.id_campo_hito || defaultIdCampoHito,
					id_expediente: idFromView || detected.id_expediente || defaultIdExpediente,
					id_campo_hito_expediente: detected.id_campo_hito_expediente || defaultIdCampoHitoExpediente,
					// Nuevo: enviar id_hito_expediente explícito si lo tenemos (viene de obtenerDocumentosAdmin(...))
					id_hito_expediente: idHitoExpedienteFromView || null,
					dni: dni,
					files: [ name ],
					source_url: url
				};

				//console.log('Payload adjuntar-archivos:', payload);

				fetch('{{ path('belender_adjuntar_archivos') }}', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'X-Requested-With': 'XMLHttpRequest'
					},
					body: JSON.stringify(payload),
					credentials: 'same-origin'
				})
				.then(async res => {
					const status = res.status;
					let text = '';
					try { text = await res.text(); } catch(e) { text = ''; }
					let data = null;
					try { data = text ? JSON.parse(text) : null; } catch(e) { data = { raw: text }; }
					if (!res.ok) {
						//console.error('HTTP error adjuntar-archivos:', status, res.statusText, data);
						const missing = data && data.missing ? '\nFaltan: ' + data.missing.join(', ') : '';
						alert('Error adjuntando archivo en el servidor. ' + (data && data.error ? data.error : '') + missing + '\nRevisa la consola para más detalles.');
						throw new Error('adjuntar-archivos HTTP ' + status);
					}
					return data;
				})
				.then(data => {
					if (data && data.success && data.saved_path) {
						// intentar obtener selector dropify detectado, si no usar el selector genérico
						let targetInput = null;
						if (detected.dropifySelector && detected.dropifySelector instanceof Element) targetInput = detected.dropifySelector;
						if (!targetInput) targetInput = document.querySelector('.dropify');
						let saveBtn = detected.saveSelector || document.querySelector('[data-boton-enviar]');
						insertarArchivoDesdeUrl(data.saved_path, data.saved_name || name, targetInput || '.dropify', saveBtn || '[data-boton-enviar]');
					} else {
						//console.error('Respuesta inválida al adjuntar archivo:', data);
						alert('Error adjuntando archivo en el servidor: ' + (data && data.error ? data.error : JSON.stringify(data)));
					}
				})
				.catch(err => {
					//console.error('Error en fetch adjuntar-archivos:', err);
				});
			} catch (e) { 
				//console.error(e); 
				alert('Error al insertar archivo'); 
			}
		}
		// Obtener id_expediente de la vista de forma fiable
		function obtenerIdExpedienteDesdeVista() 
		{
			// 0) Preferir input explícito preparado para Belender (determinista)
			try {
				const explicit = document.getElementById('idExpediente_belender');
				if (explicit && explicit.value) return explicit.value;
			} catch(e) {}

			// 1) Intentar extraer de la URL: /Expediente/{id} o /Documentos/{id} (PRIORIDAD ALTA)
			try {
				const path = window.location.pathname || '';
				let m = path.match(/Expediente\/(\d+)/i);
				if (m && m[1]) return m[1];
				// Para ruta cliente: /Documentos/15642
				m = path.match(/Documentos\/(\d+)/i);
				if (m && m[1]) return m[1];
				// Fallback: último segmento numérico en la ruta
				const parts = path.split('/').filter(p => p);
				for (let i = parts.length - 1; i >= 0; i--) {
					if (/^\d+$/.test(parts[i])) return parts[i];
				}
			} catch (e) {}

			// 2) inputs comunes generados por Symfony
			let el = document.querySelector('input[name$="[idExpediente]"], input[name*="idExpediente"], input[id*="idExpediente"], input[name="idExpediente"]');
			if (el && el.value) return el.value;
			
			// 3) any hidden input containing idExpediente in name or id
			const anyHidden = Array.from(document.querySelectorAll('input[type="hidden"]')).find(i => /idExpediente/i.test(i.name) || /idExpediente/i.test(i.id));
			if (anyHidden && anyHidden.value) return anyHidden.value;
			
			// 4) buscar en query string parámetros 'id_expediente' o 'expediente'
			try {
				const sp = new URLSearchParams(window.location.search);
				if (sp.get('id_expediente')) return sp.get('id_expediente');
				if (sp.get('expediente')) return sp.get('expediente');
			} catch (e) {}
			return null;
		}

		// Inicializar y fijar el hidden input al cargar la página para garantizar determinismo
		document.addEventListener('DOMContentLoaded', function() {
			try {
				const v = (function(){ try { return obtenerIdExpedienteDesdeVista(); } catch(e) { return null; } })();
				let el = document.getElementById('idExpediente_belender');
				if (!el) return;
				if (v) {
					el.value = v;
					//console.log('idExpediente_belender set to', v);
				} else {
					//console.log('idExpediente_belender present but no value extracted yet');
				}
			} catch(e){}
			
			// Rellenar campos belenderNif si ya existen registros en la BD
			rellenarCamposBelenderDesdeDB();
		});

		/**
		 * Rellenar campos belenderNif_{idHitoExpediente} desde la BD
		 * si ya existen registros en belender_hito_expediente
		 */
		async function rellenarCamposBelenderDesdeDB() 
		{
			// Buscar todos los inputs belenderNif presentes
			const inputs = document.querySelectorAll('input[id^="belenderNif_"]');
			
			for (const input of inputs) {
				// Extraer idHitoExpediente del id: belenderNif_480133 -> 480133
				const idHitoExpediente = input.id.replace('belenderNif_', '');
				
				// Si ya tiene valor, saltar
				if (input.value) continue;
				//console.log('kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk');
				try {
					const response = await fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=BELENDER_PIN`)
					const data = await response.json();
					
					if (data.found && data.dni) 
					{
						//console.log('ppppppppppppppppppppppppppppppppppppppppppppppppp', data);
						input.value = data.dni;
						if (data.tipo_peticion == 'BELENDER_PIN') $('#verificar_' + idHitoExpediente).show();
						//console.log(`✅ Campo belenderNif_${idHitoExpediente} rellenado con DNI: ${data.dni}`);
						$('#solicitarDocumentos_' + idHitoExpediente).show();
						//$('#solicitarDocumentosICI_' + idHitoExpediente).hide();
						$('#solicitarDocumentosSMS_' + idHitoExpediente).hide();
					}
					else
					{
						const response1 = await fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=BELENDER_SMS`)
						const data1 = await response1.json();
						if (data1.found && data1.dni) 
						{
							input.value = data1.dni;
							$('#solicitarDocumentos_' + idHitoExpediente).hide();
							//$('#solicitarDocumentosICI_' + idHitoExpediente).show();
							$('#solicitarDocumentosSMS_' + idHitoExpediente).show();
							if (data1.tipo_peticion == 'BELENDER_SMS') $('#verificar_' + idHitoExpediente).show();
						}
						else
						{
							const response2 = await fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=CLAVE_PIN`)
							const data2 = await response2.json();
							if (data2.found && data2.dni) 
							{
								input.value = data2.dni;
								//console.log(`✅ Campo belenderNif rellenado con DNI (CLAVE_PIN):`, data2);
								if (data2.request_id == 'AVAILABLE') 
								{
									$('#solicitarDocumentos_' + idHitoExpediente).show();
									//$('#solicitarDocumentosICI_' + idHitoExpediente).hide();
									$('#solicitarDocumentosSMS_' + idHitoExpediente).hide();
								} 
								else if (data2.request_id == 'NOT_AVAILABLE')
								{
									//$('#solicitarDocumentosICI_' + idHitoExpediente).show();
									$('#solicitarDocumentosSMS_' + idHitoExpediente).show();
									$('#solicitarDocumentos_' + idHitoExpediente).hide();
								}
							}
							
						}
					}
					const response3 = await fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=CIRBE`)
					const data3 = await response3.json();
					if (data3.found && data3.dni) 
