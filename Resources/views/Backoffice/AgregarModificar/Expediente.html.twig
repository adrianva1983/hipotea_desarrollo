		function verificarEstadoDocumentosNewTab(idHitoExpediente) 
		{
			localStorage.setItem('belender_last_hito', idHitoExpediente);
			let requestId = localStorage.getItem("request_id");
			let dni = localStorage.getItem("dni");
			/*const requestId = '11f6e570-65b4-449f-9546-a42e1bf5d81a';
			const dni = '95328187H';*/

			// Si no existen en localStorage, buscar en la BD
			if (!requestId || !dni) 
			{
				if (!idHitoExpediente) {
					//console.log('⏸️ Verificación detenida - no hay request_id, dni ni idHitoExpediente');
					alert('No se encontró información de la solicitud. Por favor, realiza la solicitud nuevamente.');
					return;
				}
				
				//console.log('🔍 Buscando request_id y dni en BD para hito:', idHitoExpediente);
				showBelenderSyncOverlay('Buscando información en la base de datos...');
				
				fetch(`{{ path('obtener_belender_registro') }}?id_hito_expediente=${idHitoExpediente}&tipo_peticion=BELENDER`)
					.then(response => response.json())
					.then(data => {
						if (data.found) {
							//console.log('✅ Datos encontrados en BD');
							requestId = data.request_id;
							dni = data.dni;
							localStorage.setItem("request_id", requestId);
							localStorage.setItem("dni", dni);
							// Continuar con la verificación recursivamente
							verificarEstadoDocumentosNewTab(idHitoExpediente);
							return;
						} else {
							//console.log('❌ No se encontraron datos en BD', data);
							hideBelenderSyncOverlay();
							mostrarToast('No se encontró información de la solicitud. Por favor, realiza la solicitud nuevamente.', 'error');
							return;
						}
					})
					.catch(error => {
						//console.error('⚠️ Error buscando en BD:', error);
						hideBelenderSyncOverlay();
						mostrarToast('Error al buscar información: ' + (error.message || error), 'error');
					});
				return;
			}

			//console.log('Verificando estado de documentos...');
			showBelenderSyncOverlay('Verificando documentos en Belender...');

			fetch(`{{ path('document_download') }}?request_id=${requestId}&dni=${dni}`)
				.then(response => response.json())
				.then(data => {
					if (data.success && data.files && data.files.length > 0) {
						//console.log('✅ Documentos disponibles', data);
						hideBelenderSyncOverlay();
						//ocultarBotonVerificarDocumentos();
						mostrarBotonDescarga(data.files);
						updateBelenderSyncOverlay('Documentos descargados correctamente', 'success');
					} else {
						//console.log('⏳ Los documentos aún no están disponibles', data);
						hideBelenderSyncOverlay();
						mostrarToast('Los documentos aún no están disponibles. Intenta de nuevo en unos momentos.', 'warning');
					}
				})
				.catch(error => {
					//console.error('❌ Error verificando documentos:', error);
					hideBelenderSyncOverlay();
					mostrarToast('Error al verificar documentos: ' + (error.message || error), 'error');
				});
		}

		// Overlay visual para indicar sincronización con Belender
		function showBelenderSyncOverlay(mensaje = 'Sincronizando con Belender...') 
		{
			// No mostrar overlay si el modal de Belender está abierto
			try {
				if (typeof $ !== 'undefined' && $('#modal-widget-blender').length && $('#modal-widget-blender').hasClass('show')) return;
				const modalEl = document.getElementById('modal-widget-blender');
				if (modalEl && window.getComputedStyle(modalEl).display !== 'none') return;
			} catch (e) {}

			if (document.getElementById('belender-sync-overlay')) return;
			const html = `
				<div id="belender-sync-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:999999;display:flex;align-items:center;justify-content:center;">
					<div style="background:#fff;border-radius:8px;padding:18px 22px;display:flex;align-items:center;gap:12px;box-shadow:0 6px 20px rgba(0,0,0,0.2);min-width:280px;max-width:90%;">
						<div class="spinner-border text-primary" role="status" style="width:2rem;height:2rem;"></div>
						<div style="font-weight:600;color:#222;">${mensaje}</div>
					</div>
				</div>`;
			document.body.insertAdjacentHTML('beforeend', html);
		}

		function hideBelenderSyncOverlay() 
		{
			const el = document.getElementById('belender-sync-overlay');
			if (el) el.remove();
			// También ocultar el modal de información si está presente
			try { hideBelenderInfoModal(); } catch (e) {}
		}

		function hideBelenderInfoModal() 
		{
			try {
				const $modal = $('#belender-info-modal');
				if ($modal.length) {
					$modal.one('hidden.bs.modal', function() {
						$modal.remove();
						$('.modal-backdrop').remove();
						document.body.classList.remove('modal-open');
					});
					$modal.modal('hide');
					//console.log('✅ Belender info modal hide triggered');
					return;
