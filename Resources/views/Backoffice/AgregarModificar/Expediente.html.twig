		// ===== 4. FUNCIÓN PRINCIPAL DE FILTRADO (SOLO INTERVINIENTE 1) =====
		function filtrarCamposHito31() {
			const respuestas = obtenerRespuestasFormulario();
			//console.log('Valores actuales:', respuestas);
			
			// Obtener solo el contenedor del Interviniente 1
			const interviniente1 = obtenerContenedorInterviniente1();
			if (!interviniente1) {
				//console.log('  ⚠️ No hay Interviniente 1 en el DOM');
				return;
			}
			
			// Campos SIEMPRE VISIBLES: 707=Belender, 385=Solicitar doc, 207=DNI, 314=Renta, 316=Mov.Banc, 318=Recibos, 320=Convenio, 322=Trimestres, 324=Pensión, 326=Doc.Adicional
			const camposSiempreVisibles = [707, 385, 207, 313, 316, 326,708,709,710,711,712,713,716,717,718,719,722,723,724,726,739, 315];
			
			// Obtener SOLO los campos en Interviniente 1
			const todosLoscampos = interviniente1.querySelectorAll('[data-id-campo-hito]');
			//console.log('Total de campos encontrados en Interviniente 1:', todosLoscampos.length);
			
			// VERIFICAR SI HAY RESPUESTAS DEL CUESTIONARIO
			// Si no hay valores rellenados, mostrar TODO sin filtrar
			const tieneRespuestas = Object.values(respuestas).some(valor => 
				valor !== null && valor !== undefined && valor !== '' && valor !== 'false'
			);
			
			if (!tieneRespuestas) {
				//console.log('ℹ️ No hay respuestas en cuestionario → Mostrando TODOS los documentos sin filtro');
				// Mostrar TODOS los campos
				todosLoscampos.forEach(campo => {
					campo.classList.remove('campo-oculto-sin-espacio');
				});
				return;
			}
			
			// PASO 1: Ocultar todos los campos condicionales por defecto
			todosLoscampos.forEach(campo => {
				const idCampo = parseInt(campo.getAttribute('data-id-campo-hito'));
				
				// Si NO es siempre visible → ocultarlo
				if (!camposSiempreVisibles.includes(idCampo)) {
					campo.classList.add('campo-oculto-sin-espacio');
					//console.log(`  [Oculto] Campo ${idCampo} (condicional)`);
				}
			});
			
			// PASO 2: Mostrar campos siempre visibles (por si acaso estaban ocultos)
			camposSiempreVisibles.forEach(idCampo => {
				const campo = interviniente1.querySelector(`[data-id-campo-hito="${idCampo}"]`);
				if (campo) {
					campo.classList.remove('campo-oculto-sin-espacio');
					//console.log(`✓ Campo ${idCampo} siempre visible (genérico)`);
				}
			});
			
			// PASO 3: Aplicar cada regla para mostrar campos condicionales que cumplen condiciones
			for (const [nombreRegla, regla] of Object.entries(REGLAS_FILTRADO)) {
				if (regla.condicion(respuestas)) {
					//console.log(`✓ Regla ACTIVA: ${nombreRegla}`);
					regla.campos.forEach(idCampo => {
						const campo = interviniente1.querySelector(`[data-id-campo-hito="${idCampo}"]`);
						if (campo) {
							campo.classList.remove('campo-oculto-sin-espacio');
							//console.log(`    → Mostrando campo ${idCampo}`);
						} else {
							//console.warn(`    ⚠️ Campo ${idCampo} no encontrado en DOM`);
						}
					});
				}
			}
			
			//console.log('✓ Filtrado completado');
		}
		
		// ===== 4.5. FUNCIÓN AUXILIAR: OBTENER CONTENEDOR DEL INTERVINIENTE 1 =====
		function obtenerContenedorInterviniente1() {
