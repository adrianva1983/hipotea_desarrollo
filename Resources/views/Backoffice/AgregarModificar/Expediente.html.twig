		function checkClavePinService(idHitoExpediente) 
		{
			try {
				//console.log('🔍 Verificando disponibilidad del servicio Clave PIN...', idHitoExpediente);
				showBelenderSyncOverlay('Verificando disponibilidad del servicio Clave PIN...');
				const input = document.getElementById("belenderNif_" + idHitoExpediente);
				const dni = input ? String(input.value).trim() : '';
				const inputFecha = document.getElementById("belenderFechaValidez_" + idHitoExpediente);
				const fechaValidez = inputFecha ? String(inputFecha.value).trim() : '';
				//console.log('dni', dni);
				//console.log('fechaValidez', fechaValidez);

				if (!dni) 
				{
					//alert('No se ha encontrado el DNI del cliente');
					hideBelenderSyncOverlay();
					mostrarToast('No se ha encontrado el DNI del cliente.', 'error',3000);
					return;
				} 
				if (!fechaValidez) 
				{
					//alert('No se ha encontrado la fecha de validez del DNI del cliente');
					hideBelenderSyncOverlay();
					mostrarToast('No se ha encontrado la fecha de validez del DNI del cliente.', 'error',3000);
					return;
				} 
				const payload = {
					document_number: dni,
					document_expiration_date: fechaValidez,
					id_hito_expediente: idHitoExpediente
				};
				
				return fetch('{{ path('check_clave_pin_service') }}', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'X-Requested-With': 'XMLHttpRequest'
					},
					body: JSON.stringify(payload)
				})
				.then(response => response.json())
				.then(data => {
					hideBelenderSyncOverlay();
					if (data.available) 
					{
						//console.log('✅ Servicio Clave PIN disponible', data);
						mostrarToast('Servicio Clave PIN disponible. Puede solicitar los documentos.', 'success',3000);
						// Activar el botón de "Solicitar documentos descargables"
						const botonSolicitar = document.getElementById(`solicitarDocumentos_${idHitoExpediente}`);
						if (botonSolicitar) 
						{
							botonSolicitar.style.display = 'inline-block';
						}
						const botonSolicitarSMS = document.getElementById(`solicitarDocumentosSMS_${idHitoExpediente}`);
						if (botonSolicitarSMS) 
						{
							botonSolicitarSMS.style.display = 'none';
						}
						/*const botonSolicitarICI = document.getElementById(`solicitarDocumentosICI_${idHitoExpediente}`);
						if (botonSolicitarICI) 
						{
							botonSolicitarICI.style.display = 'none';
						}*/
					} 
					else 
					{
						//console.log('⚠️ Servicio Clave PIN NO disponible', data);
						$('#modal-clave-pin-no-disponible').modal('show');
						const botonSolicitar = document.getElementById(`solicitarDocumentos_${idHitoExpediente}`);
						if (botonSolicitar) 
						{
							botonSolicitar.style.display = 'none';
						}
						const botonSolicitarSMS = document.getElementById(`solicitarDocumentosSMS_${idHitoExpediente}`);
						if (botonSolicitarSMS) 
						{
							botonSolicitarSMS.style.display = 'inline-block';
						}
						/*const botonSolicitarICI = document.getElementById(`solicitarDocumentosICI_${idHitoExpediente}`);
						if (botonSolicitarICI) 
						{
							botonSolicitarICI.style.display = 'inline-block';
						}*/
					}
				})
				.catch(err => {
					hideBelenderSyncOverlay();
					//console.error('❌ Error verificando Clave PIN:', err);
					return {
						available: false,
						error: err.message
					};
				});
			} catch (err) {
				//console.error('❌ Error inesperado en checkClavePinService:', err);
				return Promise.reject(err);
			}
		}
		
