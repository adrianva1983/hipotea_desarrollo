		function obtenerDocumentosAdmin(idHitoExpediente) 
		{
			try {
				const input = document.getElementById("belenderNif_" + idHitoExpediente);
				const inputFecha = document.getElementById("belenderFechaValidez_" + idHitoExpediente);
				const dni = input ? String(input.value).trim() : '';
				const docExpirationDate = inputFecha ? String(inputFecha.value).trim() : '';
				
				if (!dni) {
					alert('No se ha encontrado el DNI del cliente');
					return;
				}
				
				if (!docExpirationDate) {
					alert('Debe ingresar la fecha de vencimiento del documento');
					return;
				}
				//console.log('Iniciando solicitud de documentos para DNI:', dni);
				// Mostrar overlay mientras se hace la petición
				showBelenderSyncOverlay('Solicitando documentos a Belender...');

				fetch(`{{ path('document_request') }}?dni=${encodeURIComponent(dni)}&doc_expiration_date=${encodeURIComponent(docExpirationDate)}`)
					.then(response => response.json())
					.then(data => {
						if (data && data.widget_url_boxed) 
						{
							//console.log('✅ Respuesta recibida:', data);
							// Cargar widget en iframe y mostrar modal
							const iframe = document.getElementById('widgetIframe');
							if (iframe) iframe.src = data.widget_url_boxed;
							try { $('#modal-widget-blender').modal('show'); } catch(e) {}
							// Guardar referencia para el polling y comprobar estado
							if (data.request_id) localStorage.setItem('request_id', data.request_id);
							localStorage.setItem('dni', dni);
							localStorage.setItem('belender_last_hito', idHitoExpediente);
							verificarEstadoDocumentos();
							// ocultar overlay cuando el modal esté visible
							hideBelenderSyncOverlay();
						} else {
			
							hideBelenderSyncOverlay();
							alert('Error en la solicitud de documentos: ' + (data && data.error ? data.error : 'respuesta inesperada'));
						}
					})
					.catch(err => {
						//console.error('❌ Error en request a Belender:', err);
						hideBelenderSyncOverlay();
						alert('Error al solicitar documentos: ' + (err.message || err));
					});
			} catch (err) {
				//console.error('Error en obtenerDocumentosAdmin:', err);
				alert('Error inesperado al iniciar la solicitud de documentos');
			}
		}

