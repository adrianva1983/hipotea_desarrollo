																		</div>
																		{% form_theme agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito] '@App/Backoffice/bootstrap_4_layout.html.twig' %}
																		<div class="form-row {% if is_granted('ROLE_CLIENTE') or is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_INMOBILIARIA') or is_granted('ROLE_JEFE_OFICINA') or is_granted('ROLE_RESPONSABLE_ZONA') %}d-none{% endif %}"">
																			<div class="form-group col-md">
																				{{ form_label(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora) }}
																				{{ form_widget(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idEntidadColaboradora) }}
																			</div>
																			<div class="form-group col-md">
																				{{ form_label(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																				{{ form_widget(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteColaboradoresModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																			</div>
																		</div>
																	</div>
																{% else %}
																	<div class="form-row">
																		<div class="form-group col">
																			{% if campo_hito.tipo is same as(2) or campo_hito.tipo is same as(3) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idOpcionesCampo) }}
																			{% elseif campo_hito.tipo is same as(6) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor,{attr:{class:'js-datepicker'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																			{% elseif campo_hito.tipo is same as(7) or campo_hito.tipo is same as(8) or campo_hito.tipo is same as(9) %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador,{attr:{class:'select2'}}) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].idAgenteColaborador) }}
																			{% elseif campo_hito.tipo is same as(10) %}
																			{% else %}
																				{# {{ form_label(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }} #}
																				{{ form_widget(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																				{{ form_errors(agregarModificarCampoHitoExpedienteModelo[campo_hito.idCampoHito].valor) }}
																			{% endif %}
																		</div>
																	</div>
																{% endif %}
															</div>
															{% if loop.index is even and not loop.last %}
																<div class="col-12 d-none d-lg-block">
																	<hr>
																</div>
															{% endif %}
														{% endfor %}
													</div>
												{% else %}
													<div class="alert alert-info" role="alert">
														<span>No hay campos hito.</span>
													</div>
												{% endif %}
												{% if grupo_campos_hito.repetible and grupos_campos_hito[hito.idHito]|length>1 %}
													<div class="d-flex justify-content-end border-top pt-3">
														{# <button class="btn btn-danger waves-effect {%if not loop.last%}oculto{% endif %}" data-borrar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button"> #}
														<button class="btn btn-danger waves-effect oculto" data-borrar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
															<i class="far fa-trash-alt"></i> Eliminar {{ grupo_campos_hito.nombre }}
														</button>
													</div>
												{% endif %}
											</div>
											{% if grupo_campos_hito.repetible %}
												<div class="d-flex justify-content-end{% if not loop.parent.loop.last %} mb-3{% endif %} mr-3" data-agregar-grupo-expediente-contenedor>
													<button class="btn btn-success waves-effect" data-agregar-grupo-expediente="{{ grupo_campos_hito.idGrupoCamposHito }}" type="button">
														<i class="fas fa-plus"></i> Añadir {{ grupo_campos_hito.nombre }}
													</button>
												</div>
											{% endif %}
										{% endfor %}
									{% else %}
										<div class="alert alert-info" role="alert">
											<span>No hay grupos de campos hito.</span>
										</div>
									{% endif %}
									<div class="d-flex justify-content-end border-top pt-3">
										<button class="btn btn-danger waves-effect btn-hito-rojo" data-borrar-hito-expediente type="button">
											<i class="far fa-trash-alt"></i> Eliminar {{ hito.nombre }}
										</button>
									</div>
								</div>
							</div>
						</div>
					{% endif %}
					{% set hitoAnterior = hito.idHito %}
				{% endfor %}
			{% endif %}
		{% endfor %}
	{% endif %}
{% endblock %}
{% block modals %}
	{{ parent() }}
	{% if nombres_fichero is defined %}
		<div class="modal fade" id="mensaje-ajax">
			<div class="modal-dialog">
				<div class="modal-content">
					<div class="modal-header">
						<h4 class="modal-title">
							<strong>Error</strong>
						</h4>
						<button class="close" data-dismiss="modal" type="button">×</button>
					</div>
					<div class="modal-body" id="mensaje-ajax-body">Error al borrar el archivo</div>
					<div class="modal-footer">
						<button class="btn btn-secondary waves-effect" data-dismiss="modal" type="button">Cerrar</button>
					</div>
				</div>
			</div>
		</div>
	{% endif %}
	{% if attribute(agregarModificarExpediente, 'idFaseActual') is defined and (is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO')) %}
		{% include '@App/Backoffice/Modal/SeguimientoExpediente.html.twig' %}
	{% endif %}

	<!-- Modal CIRBE ICI Request -->
	<div class="modal fade" id="modal-cirbe-request" tabindex="-1" role="dialog" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<div class="modal-content">
				<div class="modal-header bg-info text-white">
					<h5 class="modal-title">
						<i class="fas fa-credit-card mr-2"></i>Solicitar Informe CIRBE ICI
					</h5>
					<button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<form id="formSolicitudCirbe" onsubmit="event.preventDefault(); enviarSolicitudCirbe();">
						
						<!-- DNI (solo lectura) -->
						<div class="form-group">
							<label for="cirbeDniDisplay" class="font-weight-bold">
								<i class="fas fa-id-card mr-2"></i>DNI
							</label>
							<div class="alert alert-light border" id="cirbeDniDisplay" style="padding: 0.75rem; background-color: #f8f9fa;">
								-
							</div>
						</div>

						<!-- Nombre -->
						<div class="form-group">
							<label for="cirbeNombre" class="font-weight-bold">
								<span class="text-danger">*</span> Nombre
							</label>
							<input 
								type="text" 
								class="form-control" 
								id="cirbeNombre" 
								placeholder="Ej: Juan"
								required
							>
							<small class="form-text text-muted">Campo obligatorio</small>
						</div>

						<!-- Primer Apellido -->
						<div class="form-group">
							<label for="cirbeApellido1" class="font-weight-bold">
								<span class="text-danger">*</span> Primer Apellido
							</label>
							<input 
								type="text" 
								class="form-control" 
								id="cirbeApellido1" 
								placeholder="Ej: García"
								required
							>
							<small class="form-text text-muted">Campo obligatorio</small>
						</div>

						<!-- Segundo Apellido -->
						<div class="form-group">
							<label for="cirbeApellido2" class="font-weight-bold">
								Segundo Apellido
							</label>
							<input 
								type="text" 
								class="form-control" 
								id="cirbeApellido2" 
								placeholder="Ej: López (opcional)"
							>
							<small class="form-text text-muted">Campo opcional</small>
						</div>

					</form>
				</div>
				<div class="modal-footer bg-light">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						<i class="fas fa-times mr-2"></i>Cancelar
					</button>
					<button type="button" class="btn btn-info" onclick="enviarSolicitudCirbe()">
						<i class="fas fa-paper-plane mr-2"></i>Solicitar CIRBE
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Widget Belender -->
	<div class="modal fade" id="modal-widget-blender" tabindex="-1" role="dialog">
		<div class="modal-dialog modal-xl" role="document" style="max-width: 1024px; margin: auto; top: 50px;">
			<div class="modal-content">
				<div class="modal-header bg-primary text-white">
					<h5 class="modal-title"><i class="fas fa-file-upload mr-2"></i>Solicitar Documentos - Belender</h5>
					<button type="button" class="close text-white" data-dismiss="modal">
						<span>&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<iframe id="widgetIframe" src="" style="width: 100%; height: 600px; border: none;"></iframe>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
				</div>
			</div>
		</div>
	</div>
	<!-- Modal Clave PIN No Disponible -->
	<div class="modal fade" id="modal-clave-pin-no-disponible" tabindex="-1" role="dialog" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<div class="modal-content">
				<div class="modal-header bg-warning text-dark">
					<h5 class="modal-title">
						<i class="fas fa-key mr-2"></i>No dispones de Cl@ve PIN
					</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<p><strong>Los documentos de Hacienda solo pueden descargarse con Cl@ve PIN.</strong></p>
					<p>Hemos detectado que actualmente no la tienes.</p>
					<hr>
					<p class="mb-2"><strong>👉 Puedes darte de alta online y en pocos minutos en este enlace oficial:</strong></p>
					<p>
						<a href="https://clave.gob.es/registro/como-puedo-registrarme" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-warning">
							<i class="fas fa-external-link-alt mr-1"></i>Registrarse en Cl@ve PIN
						</a>
					</p>
					<hr>
					<p><strong>Mientras tanto:</strong></p>
					<p>Podemos avanzar con los documentos de Seguridad Social usando el número de móvil que tengas vinculado en Hacienda.</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						<i class="fas fa-times mr-2"></i>Cerrar
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- Modal Especificaciones de Documentos -->
	<div class="modal fade" id="modalEspecificaciones" tabindex="-1" role="dialog" aria-labelledby="modalEspecificacionesLabel" aria-hidden="true" data-expediente-id="{{ idExpediente }}">
		<div class="modal-dialog modal-lg" role="document">
			<div class="modal-content" style="max-width: 1600px;margin-left: auto;margin-right: auto;">
				<div class="modal-header bg-info text-white">
					<h5 class="modal-title" id="modalEspecificacionesLabel">
						<i class="fas fa-file-alt mr-2"></i>Datos Extraídos de Documentos
					</h5>
					<button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body" id="contenidoEspecificaciones" style="max-height: 70vh; overflow-y: auto;">
					<div class="text-center">
						<div class="spinner-border text-info" role="status">
							<span class="sr-only">Cargando...</span>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						<i class="fas fa-times mr-2"></i>Cerrar
					</button>
					<button type="button" class="btn btn-primary" onclick="procesarDocumentos()"  id="btnProcesarDocumentos">
						<i class="fas fa-cog mr-2"></i>Procesar Documentos
					</button>
					<button type="button" class="btn btn-info" onclick="descargarEspecificaciones()" style="display: none;" id="btnDescargarEspecificaciones">
						<i class="fas fa-download mr-2"></i>Descargar
					</button>
				</div>
			</div>
		</div>
	</div>

	<!-- MODAL CONSOLIDADO (SEPARADO) -->
	<div class="modal fade" id="modalConsolidado" tabindex="-1" role="dialog" aria-labelledby="modalConsolidadoLabel" aria-hidden="true" data-expediente-id="{{ idExpediente }}">
		<div class="modal-dialog modal-lg" role="document">
			<div class="modal-content" style="max-width: 1600px;margin-left: auto;margin-right: auto;">
				<div class="modal-header bg-success text-white">
					<h5 class="modal-title" id="modalConsolidadoLabel">
						<i class="fas fa-file-contract mr-2"></i>Consolidado de Datos Extraídos
					</h5>
					<button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body" id="contenidoConsolidado" style="max-height: 70vh; overflow-y: auto;">
					<div class="text-center">
						<div class="spinner-border text-success" role="status">
							<span class="sr-only">Cargando consolidado...</span>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						<i class="fas fa-times mr-2"></i>Cerrar
					</button>
					<button type="button" class="btn btn-success" id="btnGenerarConsolidado" onclick="generarConsolidadoDesdeModal({{ idExpediente }})">
						<i class="fas fa-plus mr-2"></i>Generar Consolidado
					</button>
					<button type="button" class="btn btn-info" onclick="descargarConsolidado()" style="display: none;" id="btnDescargarConsolidado">
						<i class="fas fa-download mr-2"></i>Descargar
					</button>					
				</div>
			</div>
		</div>
	</div>

	<!-- Contenedores Belender -->
	<div id="botonDescargaContainer" style="display: none;"></div>

	
{% endblock %}