		/**
		 * Mostrar notificación Toast elegante en el centro de la pantalla
		 * @param {string} mensaje 
		 * @param {string} tipo - 'info', 'warning', 'error', 'success'
		 * @param {number} duracion - milisegundos (default 6000)
		 */
		function mostrarToast(mensaje, tipo = 'info', duracion = 6000) 
		{
			const colores = {
				info: '#03a9f3',
				warning: '#fec107',
				error: '#ff0000',
				success: 'rgb(40, 167, 69)'
			};

			const iconos = {
				info: 'ℹ️',
				warning: '⚠️',
				error: '❌',
				success: '✅'
			};

			const toast = document.createElement('div');
			toast.style.cssText = `
				position: fixed;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				background: ${colores[tipo]};
				color: white;
				padding: 20px 32px;
				border-radius: 12px;
				box-shadow: 0 8px 24px rgba(0,0,0,0.4);
				z-index: 9999;
				font-weight: 600;
				font-size: 25px;
				animation: zoomIn 0.3s ease-out;
				max-width: 500px;
				word-wrap: break-word;
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				text-align: center;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				padding-right: 16px;
			`;
			
			const closeBtn = document.createElement('button');
			closeBtn.innerHTML = '✕';
			closeBtn.style.cssText = `
				background: rgba(255,255,255,0.2);
				border: none;
				color: white;
				font-size: 24px;
				cursor: pointer;
				border-radius: 50%;
				width: 36px;
				height: 36px;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: background 0.2s;
				flex-shrink: 0;
			`;
			
			closeBtn.onmouseover = () => closeBtn.style.background = 'rgba(255,255,255,0.3)';
			closeBtn.onmouseout = () => closeBtn.style.background = 'rgba(255,255,255,0.2)';
			
			const cerrarToast = () => {
				toast.style.animation = 'zoomOut 0.3s ease-out';
				setTimeout(() => toast.remove(), 300);
			};
			
			closeBtn.onclick = cerrarToast;
			
			const contenido = document.createElement('span');
			contenido.innerHTML = `<span style="margin-right: 12px; font-size: 20px;">${iconos[tipo]}</span>${mensaje}`;
			
			toast.appendChild(contenido);
			toast.appendChild(closeBtn);
			document.body.appendChild(toast);
			
			setTimeout(() => {
				if (document.body.contains(toast)) {
					cerrarToast();
				}
			}, duracion);
		}

		// Agregar animaciones CSS si no existen
		if (!document.querySelector('style[data-toast-animations]')) {
			const style = document.createElement('style');
			style.setAttribute('data-toast-animations', 'true');
			style.textContent = `
				@keyframes zoomIn {
					from { transform: translate(-50%, -50%) scale(0.8); opacity: 0; }
					to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
				}
				@keyframes zoomOut {
					from { transform: translate(-50%, -50%) scale(1); opacity: 1; }
					to { transform: translate(-50%, -50%) scale(0.8); opacity: 0; }
				}
			`;
			document.head.appendChild(style);
		}

		function verificarEstadoDocumentos() 
		{
			const requestId = localStorage.getItem("request_id");
			const dni = localStorage.getItem("dni");

			if (!requestId || !dni) {
				//console.log('⏸️ Polling detenido - no hay request_id o dni');
				return;
			}

			fetch(`{{ path('document_download') }}?request_id=${requestId}&dni=${dni}`)
				.then(response => response.json())
				.then(data => {
					if (data.success && data.files && data.files.length > 0) {
							//console.log('✅ Documentos descargados, deteniendo polling');
							// Esperar a que el modal cierre y luego mostrar overlay + continuar
							showOverlayAfterModalClosed('Descargando documentos...', null, function() {
								mostrarBotonDescarga(data.files);
								// Indicar éxito breve
								updateBelenderSyncOverlay('Documentos descargados correctamente', 'success');
							});
						} else {
						//console.log('⏳ Esperando documentos, reintentando en 5 segundos...');
						updateBelenderSyncOverlay('Esperando documentos en Belender...', null);
						setTimeout(verificarEstadoDocumentos, 5000);
					}
				})
				.catch(error => {
					//console.error('❌ Error en polling:', error);
					updateBelenderSyncOverlay('Error verificando documentos', 'error');
					// No reintentar si hay error 
				});
		}

