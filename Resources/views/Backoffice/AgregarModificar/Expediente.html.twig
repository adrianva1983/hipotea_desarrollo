				        <div class="spinner-border text-primary" role="status" id="belender-info-spinner" style="width:2rem;height:2rem;"></div>
				        <div id="belender-info-message" style="font-weight:600;color:#222;">${mensaje}</div>
				        <div style="width:100%;margin-top:12px;">
