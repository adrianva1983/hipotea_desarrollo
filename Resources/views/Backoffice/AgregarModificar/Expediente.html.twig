		function agregarOtraEntidadBancaria() 
		{
			const campo316 = document.querySelector('[data-hito-expediente="31"] [data-id-campo-hito="316"]');
			if (!campo316) return;
			
			const contenedor = campo316.querySelector('[data-contenedor-campo-hito-expediente-colaboradores]');
			if (!contenedor) return;
			
			// Obtener el index de entidades existentes (excluyendo el botón)
			const entidadesExistentes = contenedor.querySelectorAll('.row').length;
			const nuevoIndex = entidadesExistentes;
			
			// Crear nuevo bloque para la entidad
			const nuevoBloque = document.createElement('div');
			nuevoBloque.className = 'row mt-3 border-top pt-3';
			nuevoBloque.innerHTML = `
				<div class="col-md">
					<div class="form-row">
						<div class="form-group col">
							<label for="fichero_campo_0_316_${nuevoIndex}_fichero">Banco ${nuevoIndex + 1} - Fichero</label>
							<div class="dropify-wrapper">
								<div class="dropify-message"><span class="file-icon"></span>
									<p>Arrastre y suelte un archivo aquí o haga clic</p>
									<p class="dropify-error">¡Uy! algo salió mal</p>
								</div>
								<div class="dropify-loader"></div>
								<div class="dropify-errors-container"><ul></ul></div>
								<input type="file" id="fichero_campo_0_316_${nuevoIndex}_fichero"
									name="fichero_campo_0_316_${nuevoIndex}[fichero][]" multiple="multiple"
									class="dropify form-control-file"
									data-allowed-file-extensions="doc docx pdf xls xlsx jpeg png webp jpg"
									data-max-file-size="128M">
								<button type="button" class="dropify-clear">Eliminar</button>
								<div class="dropify-preview"><span class="dropify-render"></span></div>
							</div>
						</div>
					</div>
				</div>
			`;
			
			// Insertar antes del botón
			const btnAgregar = contenedor.querySelector('.btn-agregar-banco');
			if (btnAgregar) {
				btnAgregar.parentNode.insertBefore(nuevoBloque, btnAgregar);
			} else {
				contenedor.appendChild(nuevoBloque);
			}
			
			// Re-inicializar dropify para el nuevo elemento
			if (typeof jQuery !== 'undefined' && jQuery.fn.dropify) {
				jQuery(nuevoBloque).find('.dropify').dropify();
			}
			
			//console.log(`✓ Nueva entidad bancaria (${nuevoIndex + 1}) agregada`);
		}
		
