{% extends '@App/Backoffice/base.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/select2/dist/css/select2.min.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/css/select2.min.css" rel="stylesheet">
{% endblock %}
{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/select2.min.css') }}" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/select2/dist/js/select2.full.min.js') }}"></script>
	<script src="{{ asset('assets/node_modules/select2/dist/js/i18n/es.js') }}"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/select2.full.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.1/js/i18n/es.js"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/custom/opciones-campo.min.js') }}"></script>
{% endblock %}
{% form_theme agregarModificarOpcionesCampo '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarOpcionesCampo) }}
			<div class="form-row">
				<div class="form-group col-sm">
					{{ form_label(agregarModificarOpcionesCampo.valor) }}
					{{ form_widget(agregarModificarOpcionesCampo.valor) }}
					{{ form_errors(agregarModificarOpcionesCampo.valor) }}
				</div>
				<div class="form-group col-sm-2">
					{{ form_label(agregarModificarOpcionesCampo.orden) }}
					{{ form_widget(agregarModificarOpcionesCampo.orden) }}
					{{ form_errors(agregarModificarOpcionesCampo.orden) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(agregarModificarOpcionesCampo.idHitoCondicional) }}
					{{ form_widget(agregarModificarOpcionesCampo.idHitoCondicional,{attr:{class:'select2'}}) }}
					{{ form_errors(agregarModificarOpcionesCampo.idHitoCondicional) }}
				</div>
				<div class="form-group col">
					{{ form_label(agregarModificarOpcionesCampo.idCampoCondicional) }}
					{{ form_widget(agregarModificarOpcionesCampo.idCampoCondicional,{attr:{class:'select2'}}) }}
					{{ form_errors(agregarModificarOpcionesCampo.idCampoCondicional) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success waves-effect mr-auto" href="{{ path('lista_fases_hitos_campos_opciones') }}">Volver</a>
				{{ form_label(agregarModificarOpcionesCampo.reset) }}
				{{ form_widget(agregarModificarOpcionesCampo.reset) }}
				{{ form_label(agregarModificarOpcionesCampo.submit) }}
				{{ form_widget(agregarModificarOpcionesCampo.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_widget(agregarModificarOpcionesCampo.idCampoHito) }}
			{{ form_end(agregarModificarOpcionesCampo) }}
		</div>
	</div>
{% endblock %}