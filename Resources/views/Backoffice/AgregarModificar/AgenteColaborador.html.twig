{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarAgenteColaborador '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarAgenteColaborador) }}
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.nombre) }}
					{{ form_widget(agregarModificarAgenteColaborador.nombre) }}
					{{ form_errors(agregarModificarAgenteColaborador.nombre) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.apellidos) }}
					{{ form_widget(agregarModificarAgenteColaborador.apellidos) }}
					{{ form_errors(agregarModificarAgenteColaborador.apellidos) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.telefono) }}
					{{ form_widget(agregarModificarAgenteColaborador.telefono) }}
					{{ form_errors(agregarModificarAgenteColaborador.telefono) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.email) }}
					{{ form_widget(agregarModificarAgenteColaborador.email) }}
					{{ form_errors(agregarModificarAgenteColaborador.email) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.idEntidadColaboradora) }}
					{{ form_widget(agregarModificarAgenteColaborador.idEntidadColaboradora) }}
					{{ form_errors(agregarModificarAgenteColaborador.idEntidadColaboradora) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregarModificarAgenteColaborador.direccion) }}
					{{ form_widget(agregarModificarAgenteColaborador.direccion) }}
					{{ form_errors(agregarModificarAgenteColaborador.direccion) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_agentes_colaboradores') }}">Volver</a>
				{{ form_label(agregarModificarAgenteColaborador.reset) }}
				{{ form_widget(agregarModificarAgenteColaborador.reset) }}
				{{ form_label(agregarModificarAgenteColaborador.submit) }}
				{{ form_widget(agregarModificarAgenteColaborador.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_end(agregarModificarAgenteColaborador) }}
		</div>
	</div>
{% endblock %}