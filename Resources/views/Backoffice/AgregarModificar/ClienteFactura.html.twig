{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregar_modificar_cliente_facturas '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregar_modificar_cliente_facturas) }}
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.cif) }}
					{{ form_widget(agregar_modificar_cliente_facturas.cif) }}
					{{ form_errors(agregar_modificar_cliente_facturas.cif) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.telefono) }}
					{{ form_widget(agregar_modificar_cliente_facturas.telefono) }}
					{{ form_errors(agregar_modificar_cliente_facturas.telefono) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.razonSocial) }}
					{{ form_widget(agregar_modificar_cliente_facturas.razonSocial) }}
					{{ form_errors(agregar_modificar_cliente_facturas.razonSocial) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.direccion) }}
					{{ form_widget(agregar_modificar_cliente_facturas.direccion) }}
					{{ form_errors(agregar_modificar_cliente_facturas.direccion) }}
				</div>
				<div class="form-group col-md-3">
					{{ form_label(agregar_modificar_cliente_facturas.cp) }}
					{{ form_widget(agregar_modificar_cliente_facturas.cp) }}
					{{ form_errors(agregar_modificar_cliente_facturas.cp) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.municipio) }}
					{{ form_widget(agregar_modificar_cliente_facturas.municipio) }}
					{{ form_errors(agregar_modificar_cliente_facturas.municipio) }}
				</div>
				<div class="form-group col-md">
					{{ form_label(agregar_modificar_cliente_facturas.provincia) }}
					{{ form_widget(agregar_modificar_cliente_facturas.provincia) }}
					{{ form_errors(agregar_modificar_cliente_facturas.provincia) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_clientes_facturas') }}">Volver</a>
				{{ form_label(agregar_modificar_cliente_facturas.reset) }}
				{{ form_widget(agregar_modificar_cliente_facturas.reset) }}
				{{ form_label(agregar_modificar_cliente_facturas.submit) }}
				{{ form_widget(agregar_modificar_cliente_facturas.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_end(agregar_modificar_cliente_facturas) }}
		</div>
	</div>
{% endblock %}