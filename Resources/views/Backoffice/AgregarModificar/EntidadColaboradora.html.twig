{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarEntidadColaboradora '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarEntidadColaboradora) }}
			<div class="form-row">
				<div class="form-group col-md-6">
					{{ form_label(agregarModificarEntidadColaboradora.nombre) }}
					{{ form_widget(agregarModificarEntidadColaboradora.nombre) }}
					{{ form_errors(agregarModificarEntidadColaboradora.nombre) }}
				</div>
				<div class="form-group col-md col-sm">
					{{ form_label(agregarModificarEntidadColaboradora.tipoEntidad) }}
					{{ form_widget(agregarModificarEntidadColaboradora.tipoEntidad) }}
					{{ form_errors(agregarModificarEntidadColaboradora.tipoEntidad) }}
				</div>
				<div class="form-group col-md col-sm">
					{{ form_label(agregarModificarEntidadColaboradora.estado) }}
					{{ form_widget(agregarModificarEntidadColaboradora.estado) }}
					{{ form_errors(agregarModificarEntidadColaboradora.estado) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_entidades_colaboradoras') }}">Volver</a>
				{{ form_label(agregarModificarEntidadColaboradora.reset) }}
				{{ form_widget(agregarModificarEntidadColaboradora.reset) }}
				{{ form_label(agregarModificarEntidadColaboradora.submit) }}
				{{ form_widget(agregarModificarEntidadColaboradora.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_end(agregarModificarEntidadColaboradora) }}
		</div>
	</div>
{% endblock %}