{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarFase '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarFase) }}
			<div class="form-row">
				<div class="form-group col-lg">
					{{ form_label(agregarModificarFase.nombre) }}
					{{ form_widget(agregarModificarFase.nombre) }}
					{{ form_errors(agregarModificarFase.nombre) }}
				</div>
				<div class="form-group col-lg-3 col-sm">
					{{ form_label(agregarModificarFase.tipo) }}
					{{ form_widget(agregarModificarFase.tipo) }}
					{{ form_errors(agregarModificarFase.tipo) }}
				</div>
				<div class="form-group col-lg-1 col-sm-2">
					{{ form_label(agregarModificarFase.color) }}
					{{ form_widget(agregarModificarFase.color) }}
					{{ form_errors(agregarModificarFase.color) }}
				</div>
				<div class="form-group col-lg-1 col-sm-2">
					{{ form_label(agregarModificarFase.orden) }}
					{{ form_widget(agregarModificarFase.orden) }}
					{{ form_errors(agregarModificarFase.orden) }}
				</div>
				<div class="form-group col-lg-2 col-md-3 col-sm-4 d-sm-flex align-items-center">
					{{ form_label(agregarModificarFase.final) }}
					{{ form_widget(agregarModificarFase.final) }}
					{{ form_errors(agregarModificarFase.final) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_fases_hitos_campos_opciones') }}">Volver</a>
				{{ form_label(agregarModificarFase.reset) }}
				{{ form_widget(agregarModificarFase.reset) }}
				{{ form_label(agregarModificarFase.submit) }}
				{{ form_widget(agregarModificarFase.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_end(agregarModificarFase) }}
		</div>
	</div>
{% endblock %}