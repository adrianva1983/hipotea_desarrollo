{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme agregarModificarCampoHitoExpediente '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{{ form_start(agregarModificarCampoHitoExpediente) }}
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(agregarModificarCampoHitoExpediente.valor) }}
					{{ form_widget(agregarModificarCampoHitoExpediente.valor) }}
					{{ form_errors(agregarModificarCampoHitoExpediente.valor) }}
				</div>
				<div class="form-group col">
					{{ form_widget(agregarModificarCampoHitoExpediente.obligatorio) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success waves-effect mr-auto" href="{{ path('agregar_modificar_hito_expediente',{'idExpediente':idExpediente,'idHito':idHito,'idHitoExpediente':idHitoExpediente}) }}">Volver</a>
				{{ form_label(agregarModificarCampoHitoExpediente.reset) }}
				{{ form_widget(agregarModificarCampoHitoExpediente.reset) }}
				{{ form_label(agregarModificarCampoHitoExpediente.submit) }}
				{{ form_widget(agregarModificarCampoHitoExpediente.submit,{attr:{class:'btn-success ml-3'}}) }}
			</div>
			{{ form_widget(agregarModificarCampoHitoExpediente.idExpediente) }}
			{{ form_widget(agregarModificarCampoHitoExpediente.idCampoHito) }}
			{{ form_end(agregarModificarCampoHitoExpediente) }}
		</div>
	</div>
{% endblock %}