{% set crearnuevo = path('agregar_modificar_conexion') %}
{% set crearnuevo_texto = 'Crear nueva conexion' %}
{% extends '@App/Backoffice/base.html.twig' %}

{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/datatables/media/css/dataTables.bootstrap4.css') }}" rel="stylesheet">
{% endblock %}

{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/css/dataTables.bootstrap4.min.css" rel="stylesheet">
{% endblock %}

{% block customstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/css/custom/lista-expedientes.min.css') }}" rel="stylesheet">
	<style>
		#tabla-conexiones {
			max-width: 100% !important;
		}

		#tabla-conexiones thead th,
		#tabla-conexiones tbody tr td {
			max-width: max-content !important;
			width: max-content !important;
		}

		a.editar {
			border: 2px solid green;
			padding: 2px;
			border-radius: 5px;
			color: green;
			background: white;
			font-size: 18px;
		}

		a.eliminar {
			border: 2px solid red;
			padding: 2px 5px;
			border-radius: 5px;
			color: red;
			background: white;
			font-size: 18px;
		}

		a.editar span,
		a.eliminar span {
			display: none;
		}

		@media(max-width: 576px) {
			#tabla-conexiones thead th,
			#tabla-conexiones tbody tr td {
				max-width: max-content !important;
				width: max-content !important;
			}

			#tabla-conexiones td:nth-child(1) {
				padding-right: 20px !important;
			}
		}
	</style>
{% endblock %}

{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/datatables/datatables.min.js') }}"></script>
{% endblock %}

{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/jquery.dataTables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/dataTables.bootstrap4.min.js"></script>
{% endblock %}

{% block customscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/custom/borrar-entidades.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/tabla-boton-borrar.min.js') }}"></script>
	<script>
		$(document).ready(function() {
			$('#tabla-conexiones').DataTable({
				"language": {
					"url": "//cdn.datatables.net/plug-ins/1.10.19/i18n/Spanish.json"
				},
				"pageLength": 25,
				"order": [[4, "desc"]],
				"columnDefs": [
					{"orderable": false, "targets": [6]}
				]
			});

			$('[data-toggle="popover"]').popover();
		});

		function abrirConexion(idSender) {
			window.location.href = '{{ path('editar_conexion', {'id': '___ID___'}) }}'.replace('___ID___', idSender);
		}

		function borrarConexion(idSender) {
			if (confirm('¿Está seguro de que desea actualizar el QR de esta conexión?')) {
				$.ajax({
					url: '{{ path('eliminar_conexion', {'id': '___ID___'}) }}'.replace('___ID___', idSender),
					type: 'POST',
					dataType: 'json',
					success: function(response) {
						if (response.success) {
							alert(response.message);
							location.reload();
						} else {
							alert('Error: ' + response.message);
						}
					},
					error: function() {
						alert('Error al actualizar la conexión');
					}
				});
			}
		}
	</script>
{% endblock %}

{% block body %}
	<div class="card">
        <div class="card-body">
            {% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>

			<!-- Botón para crear nueva conexión -->
			<div class="mb-3">
				<a href="{{ crearnuevo }}" class="btn btn-success btn-sm">
					<i class="fas fa-plus"></i> {{ crearnuevo_texto }}
				</a>
			</div>

			{% if conexiones is defined and conexiones is iterable and conexiones|length > 0 %}
				<!-- Selector de cantidad de registros y búsqueda -->
				<div class="row mb-3 align-items-center">
					<div class="col-auto">
						<label class="col-form-label">Total: <strong>{{ conexiones|length }}</strong> conexiones</label>
					</div>
					<div class="col text-right">
						<label for="buscar-tabla" class="col-form-label mr-2">Buscar:</label>
						<input type="search" class="form-control d-inline-block" id="buscar-tabla" placeholder="Teléfono, servidor..." style="width: 200px;">
					</div>
				</div>

				<!-- Tabla de conexiones -->
				<div style="overflow-x: auto;">
					<table class="table table-striped table-sm full-color-table full-success-table hover-table" id="tabla-conexiones">
						<thead class="table-dark">
							<tr>
								<th>ID</th>
								<th>Teléfono</th>
								<th>ID Agencia</th>
								<th>ID Usuario</th>
								<th>Última Interacción</th>
								<th>Servidor</th>
								<th>Acciones</th>
								<th>Piloto Automático</th>
								<th>Sync Conversaciones</th>
								<th>Cruces Automáticos</th>
							</tr>
						</thead>
						<tbody>
							{% for conexion in conexiones %}
								<tr>
									<td><strong>#{{ conexion.id }}</strong></td>
									<td>
										<i class="fas fa-phone"></i> {{ conexion.telefono }}
									</td>
									<td>{{ conexion.idAgencia }}</td>
									<td>{{ conexion.idUsuario }}</td>
									<td>
										{% if conexion.fechaUltimaInteraccion %}
											{{ conexion.fechaUltimaInteraccion|date('d/m/Y H:i') }}
										{% else %}
											<small class="text-muted">-</small>
										{% endif %}
									</td>
									<td>
										{% if conexion.servidor %}
											<span class="badge badge-success">{{ conexion.servidor }}</span>
										{% else %}
											<span class="badge badge-warning">Sin asignar</span>
										{% endif %}
									</td>
									<td>
										<a class="mr-2 editar" href="javascript:void(0)" onclick="abrirConexion({{ conexion.id }})" data-toggle="popover" data-content="Editar" data-trigger="hover">
											<i class="far fa-edit"></i>
											<span>Editar</span>
										</a>
										<a class="eliminar" href="javascript:void(0)" onclick="borrarConexion({{ conexion.id }})" data-toggle="popover" data-content="Actualizar QR" data-trigger="hover">
											<i class="fas fa-trash"></i>
											<span>Eliminar</span>
										</a>
									</td>
									<td>
										{% if conexion.pilotoAutomatico %}
											<span class="badge badge-primary">Sí</span>
										{% else %}
											<span class="badge badge-secondary">No</span>
										{% endif %}
									</td>
									<td>
										{% if conexion.syncConversaciones %}
											<span class="badge badge-primary">Sí</span>
										{% else %}
											<span class="badge badge-secondary">No</span>
										{% endif %}
									</td>
									<td>
										{% if conexion.crucesAutomaticos %}
											<span class="badge badge-primary">Sí</span>
										{% else %}
											<span class="badge badge-secondary">No</span>
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>

				<!-- Estadísticas -->
				<div class="row mt-4">
					<div class="col-md-3">
						<div class="card bg-light">
							<div class="card-body text-center">
								<h3>{{ conexiones|length }}</h3>
								<p class="text-muted">Conexiones Totales</p>
							</div>
						</div>
					</div>
					<div class="col-md-3">
						<div class="card bg-light">
							<div class="card-body text-center">
								<h3>{{ conexiones|filter(c => c.pilotoAutomatico)|length }}</h3>
								<p class="text-muted">Con Piloto Automático</p>
							</div>
						</div>
					</div>
					<div class="col-md-3">
						<div class="card bg-light">
							<div class="card-body text-center">
								<h3>{{ conexiones|filter(c => c.servidor)|length }}</h3>
								<p class="text-muted">Con Servidor Asignado</p>
							</div>
						</div>
					</div>
					<div class="col-md-3">
						<div class="card bg-light">
							<div class="card-body text-center">
								<h3>{{ conexiones|filter(c => not c.servidor)|length }}</h3>
								<p class="text-muted">Sin Servidor</p>
							</div>
						</div>
					</div>
				</div>
			{% else %}
				<div class="alert alert-info" role="alert">
					<i class="fas fa-inbox"></i> No hay conexiones disponibles.
				</div>
			{% endif %}
        </div>
    </div>
{% endblock %}

{% block modals %}
	{{ parent() }}
	{% include '@App/Backoffice/Modal/ConfirmarBorrar.html' %}
{% endblock %}