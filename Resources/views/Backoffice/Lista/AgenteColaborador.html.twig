{% set crearnuevo = path('agregar_modificar_agente_colaborador') %}
{% set crearnuevo_texto = 'Crear nuevo' %}
{% extends '@App/Backoffice/base.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/datatables/media/css/dataTables.bootstrap4.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/css/dataTables.bootstrap4.min.css" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/datatables/datatables.min.js') }}"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/jquery.dataTables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/dataTables.bootstrap4.min.js"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/custom/borrar-entidades.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/tabla-usuarios-boton-borrar.min.js') }}"></script>
{% endblock %}
{% block body %}
	<div class="card">
		<div class="card-body">
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>
			{% if agentes_colaboradores is defined %}
				{% if agentes_colaboradores is empty %}
					<div class="alert alert-info" role="alert">
						<span>No hay agentes colaboradores.</span>
					</div>
				{% else %}
					<form class="text-truncate mb-3" id="formulario-borrar-entidades" method="post">
						<table class="table table-striped table-sm full-color-table full-success-table hover-table" id="tabla-entidades">
							<thead>
							<tr>
								<th scope="col">
									<div class="custom-control custom-checkbox">
										<input class="custom-control-input" id="seleccionar-todas-entidades" type="checkbox">
										<label class="custom-control-label" for="seleccionar-todas-entidades"></label>
									</div>
								</th>
								<th scope="col">Nombre</th>
								<th scope="col">Apellidos</th>
								<th scope="col">Entidad colaboradora</th>
								<th scope="col">Teléfono</th>
								<th scope="col">E-Mail</th>
								<th scope="col">Dirección</th>
								<th scope="col">Acciones</th>
							</tr>
							</thead>
							<tbody>
							{% for agente_colaborador in agentes_colaboradores %}
								<tr>
									<td>
										<div class="custom-control custom-checkbox">
											<input class="custom-control-input" id="entidad[{{ agente_colaborador.idAgenteColaborador }}]" name="agente-colaborador[]" type="checkbox" value="{{ agente_colaborador.idAgenteColaborador }}">
											<label class="custom-control-label" for="entidad[{{ agente_colaborador.idAgenteColaborador }}]"></label>
										</div>
									</td>
									<td>{{ agente_colaborador.nombre }}</td>
									<td>{{ agente_colaborador.apellidos }}</td>
									<td>{{ agente_colaborador.idEntidadColaboradora }}</td>
									<td>{{ agente_colaborador.telefono }}</td>
									<td>{{ agente_colaborador.email }}</td>
									<td>{{ agente_colaborador.direccion }}</td>
									<td>
										<a href="{{ path('agregar_modificar_agente_colaborador',{'id':agente_colaborador.idAgenteColaborador}) }}">
											<i class="far fa-edit"></i>
											<span> Editar</span>
										</a>
									</td>
								</tr>
							{% endfor %}
							</tbody>
						</table>
						<div>
							<button class="btn btn-success waves-effect" id="boton-borrar-entidades">Borrar marcados</button>
						</div>
					</form>
				{% endif %}
			{% endif %}
			<a class="btn btn-success" href="{{ path('inicio') }}">Volver</a>
		</div>
	</div>
{% endblock %}
{% block modals %}
	{{ parent() }}
	{% include '@App/Backoffice/Modal/ConfirmarBorrar.html' %}
{% endblock %}