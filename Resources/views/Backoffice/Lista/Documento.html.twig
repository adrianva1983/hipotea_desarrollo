{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
	{% set crearnuevo = path('agregar_modificar_documento') %}
	{% set crearnuevo_texto = 'Crear nuevo' %}
{% endif %}
{% extends '@App/Backoffice/base.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/datatables/media/css/dataTables.bootstrap4.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/css/dataTables.bootstrap4.min.css" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/datatables/datatables.min.js') }}"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/jquery.dataTables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/dataTables.bootstrap4.min.js"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/custom/RegExp.escape.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/borrar-entidades.min.js') }}"></script>
	{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
		{#<script src="{{ asset('assets/js/custom/tabla-usuarios-boton-borrar.min.js') }}"></script>#}
		<script src="{{ asset('assets/js/custom/lista-documentos-datatable.min.js') }}"></script>
		<script src="{{ asset('assets/js/custom/lista-clientes.min.js') }}"></script>
	{% else %}
		<script src="{{ asset('assets/js/custom/tabla.min.js') }}"></script>
	{% endif %}
{% endblock %}
{% block body %}
	<div class="card">
		<div class="card-body">
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>
			{% if documentos is defined %}
				{% if documentos is empty %}
					<div class="alert alert-info" role="alert">
						<span>No hay documentos.</span>
					</div>
				{% else %}
					<div class="form-row" data-buscar>
						<div class="form-group col-md text-right">
							<div class="d-none">
								<label for="estado">Buscar estado</label>
								<select class="form-control" id="estado" multiple>
									<option value="0">Desactivado</option>
									<option selected value="1">Publicado</option>
								</select>
							</div>
							<div class="btn-group btn-group-toggle align-items-center h-100" data-id="estado" data-toggle="buttons">
								<label class="btn btn-success">
									<input name="estado" type="radio" value="0">
									<span>Desactivado</span>
								</label>
								<label class="btn btn-success active">
									<input checked name="estado" type="radio" value="1">
									<span>Publicados</span>
								</label>
							</div>
						</div>
					</div>
					<form class="text-truncate mb-3" id="formulario-borrar-entidades" method="post">
						<table class="table table-striped table-sm full-color-table full-success-table hover-table" id="tabla-entidades">
							<thead>
							<tr>
								{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
									<th scope="col">
										<div class="custom-control custom-checkbox">
											<input class="custom-control-input" id="seleccionar-todas-entidades" type="checkbox">
											<label class="custom-control-label" for="seleccionar-todas-entidades"></label>
										</div>
									</th>
									<th scope="col">Usuario</th>
								{% endif %}
								<th scope="col">Nombre</th>
								<th scope="col">Descripción</th>
								{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
									<th scope="col">Fecha de subida</th>
									<th data-nombre-columna="estado" scope="col">Estado</th>
									<th scope="col">Visible para</th>
								{% endif %}
								<th scope="col">Acciones</th>
							</tr>
							</thead>
							<tbody>
							{% for documento in documentos %}
								<tr>
									{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
										<td>
											<div class="custom-control custom-checkbox">
												<input class="custom-control-input" id="entidad[{{ documento.idDocumento }}]" name="documento[]" type="checkbox" value="{{ documento.idDocumento }}">
												<label class="custom-control-label" for="entidad[{{ documento.idDocumento }}]"></label>
											</div>
										</td>
									{% endif %}
									{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
										{% set usuario = documento.idUsuario %}
										{% if usuario.apellidos|length is same as(0) %}
											{% if usuario.username|length is same as(0) %}
												{% set nombreCompleto = '' %}
											{% else %}
												{% set nombreCompleto = usuario.username %}
											{% endif %}
										{% else %}
											{% if usuario.username|length is same as(0) %}
												{% set nombreCompleto = usuario.apellidos %}
											{% else %}
												{% set nombreCompleto = usuario.apellidos ~ ', ' ~ usuario.username %}
											{% endif %}
										{% endif %}
										<td>{{ nombreCompleto }}</td>
									{% endif %}
									<td>{{ documento.nombre }}</td>
									<td>{{ documento.descripcion }}</td>
									{# <td>{{ documento.nombre|length>16?documento.nombre|slice(0,16)~'…':documento.nombre }}</td>
									<td>{{ documento.descripcion|length>32?documento.descripcion|slice(0,32)~'…':documento.descripcion }}</td> #}
									{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
										<td data-order="{{ documento.fechaSubida|date('U') }}">{{ documento.fechaSubida|date('d/m/Y H:i:s') }}</td>
										{% if documento.estado is same as(false) %}
											<td>Desactivado</td>
										{% elseif documento.estado is same as(true) %}
											<td>Publicado</td>
										{% else %}
											<td></td>
										{% endif %}
									{% endif %}
									{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
										{% if documento.visiblePara is same as(0) %}
											<td>Clientes</td>
										{% elseif documento.visiblePara is same as(1) %}
											<td>Colaboradores</td>
										{% elseif documento.visiblePara is same as(2) %}
											<td>Clientes y colaboradores</td>
										{% elseif documento.visiblePara is same as(3) %}
											<td>Administradores, comerciales y técnicos</td>
										{% else %}
											<td></td>
										{% endif %}
									{% endif %}
									<td>
										{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
											<a class="mr-2 " href="{{ path('agregar_modificar_documento',{'id':documento.idDocumento}) }}">
												<i class="far fa-edit"></i>
												<span> Editar</span>
											</a>
										{% endif %}
										<a href="{% if documento.nombreFichero is null %}javascript:void(0){% else %}{{ path('descargar_fichero_documento',{'id':documento.idDocumento}) }}{% endif %}"{% if documento.nombreFichero is not null %} target="_blank"{% endif %}>
											<i class="fas fa-eye"></i>
											<span> Ver</span>
										</a>
									</td>
								</tr>
							{% endfor %}
							</tbody>
						</table>
						{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_TECNICO') or is_granted('ROLE_COMERCIAL') %}
							<div>
								<button class="btn btn-success waves-effect" id="boton-borrar-entidades">Borrar marcados</button>
							</div>
						{% endif %}
					</form>
				{% endif %}
			{% endif %}
			<a class="btn btn-success waves-effect" href="{{ path('inicio') }}">Volver</a>
		</div>
	</div>
	{% include '@App/Backoffice/Modal/ConfirmarBorrar.html' %}
{% endblock %}