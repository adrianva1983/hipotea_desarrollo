{% set crearnuevo = path('agregar_modificar_noticia') %}
{% set crearnuevo_texto = 'Crear nueva' %}
{% extends '@App/Backoffice/base.html.twig' %}
{% block devstyles %}
	{{ parent() }}
	<link href="{{ asset('assets/node_modules/datatables/media/css/dataTables.bootstrap4.css') }}" rel="stylesheet">
{% endblock %}
{% block cloudstyles %}
	{{ parent() }}
	<link href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/css/dataTables.bootstrap4.min.css" rel="stylesheet">
{% endblock %}
{% block devscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/node_modules/datatables/datatables.min.js') }}"></script>
{% endblock %}
{% block cloudscripts %}
	{{ parent() }}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/jquery.dataTables.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.19/js/dataTables.bootstrap4.min.js"></script>
{% endblock %}
{% block customscripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/custom/RegExp.escape.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/borrar-entidades.min.js') }}"></script>
	{# <script src="{{ asset('assets/js/custom/tabla-boton-borrar.min.js') }}"></script> #}
	<script src="{{ asset('assets/js/custom/lista-documentos-datatable.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/lista-clientes.min.js') }}"></script>
{% endblock %}
{% block body %}
	<div class="card">
		<div class="card-body">
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>
			{% if noticias is defined %}
				{% if noticias is empty %}
					<div class="alert alert-info" role="alert">
						<span>No hay noticias.</span>
					</div>
				{% else %}
				<div class="form-row" data-buscar>
						<div class="form-group col-md text-right">
							<div class="d-none">
								<label for="estado">Buscar estado</label>
								<select class="form-control" id="estado" multiple>
									<option value="0">Inactiva</option>
									<option selected value="1">Activa</option>
								</select>
							</div>
							<div class="btn-group btn-group-toggle align-items-center h-100" data-id="estado" data-toggle="buttons">
								<label class="btn btn-success">
									<input name="estado" type="radio" value="0">
									<span>Inactivas</span>
								</label>
								<label class="btn btn-success active">
									<input checked name="estado" type="radio" value="1">
									<span>Activas</span>
								</label>
							</div>
						</div>
					</div>
					<form class="text-truncate mb-3" id="formulario-borrar-entidades" method="post">
						<table class="table table-striped table-sm full-color-table full-success-table hover-table" id="tabla-entidades">
							<thead>
							<tr>
								<th scope="col">
									<div class="custom-control custom-checkbox">
										<input class="custom-control-input" id="seleccionar-todas-entidades" type="checkbox">
										<label class="custom-control-label" for="seleccionar-todas-entidades"></label>
									</div>
								</th>
								<th scope="col">Fecha</th>
								<th scope="col">Título</th>
								<th scope="col">Descripción</th>
								<th data-nombre-columna="estado" scope="col">Estado</th>
								<th scope="col">Acciones</th>
							</tr>
							</thead>
							<tbody>
							{% for noticia in noticias %}
								<tr>
									<td>
										<div class="custom-control custom-checkbox">
											<input class="custom-control-input" id="entidad[{{ noticia.idNoticia }}]" name="noticia[]" type="checkbox" value="{{ noticia.idNoticia }}">
											<label class="custom-control-label" for="entidad[{{ noticia.idNoticia }}]"></label>
										</div>
									</td>
									{% if noticia.fecha %}
										<td data-order="{{ noticia.fecha|date('U') }}">{{ noticia.fecha|date('d/m/Y') }}</td>
									{% else %}
										<td></td>
									{% endif %}
									<td{% if noticia.titulo|length>16 %} title="{{ noticia.titulo }}"{% endif %}>{{ noticia.titulo|length>16?noticia.titulo|slice(0,16)~'…':noticia.titulo }}</td>
									<td{% if noticia.descripcion|length>32 %} title="{{ noticia.descripcion }}"{% endif %}>{{ noticia.descripcion|length>32?noticia.descripcion|slice(0,32)~'…':noticia.descripcion }}</td>
									{% if noticia.estado is same as(false) %}
										<td>Inactiva</td>
									{% elseif noticia.estado is same as(true) %}
										<td>Activa</td>
									{% else %}
										<td></td>
									{% endif %}
									<td>
										<a href="{{ path('agregar_modificar_noticia',{'id':noticia.idNoticia}) }}">
											<i class="far fa-edit"></i>
											<span> Editar</span>
										</a>
									</td>
								</tr>
							{% endfor %}
							</tbody>
						</table>
						<div>
							<button class="btn btn-success waves-effect" id="boton-borrar-entidades">Borrar marcadas</button>
						</div>
					</form>
				{% endif %}
			{% endif %}
			<a class="btn btn-success waves-effect" href="{{ path('inicio') }}">Volver</a>
		</div>
	</div>
	{% include '@App/Backoffice/Modal/ConfirmarBorrar.html' %}
{% endblock %}