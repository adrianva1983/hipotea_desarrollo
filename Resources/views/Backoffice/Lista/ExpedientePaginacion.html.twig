												{% set oficinas_nombres = oficinas_nombres|merge([expediente.idCliente.idOficina.nombre]) %}
											{% endif %}
											{% if expediente.idComercial is not null and expediente.idComercial.idOficina is not null %}
												{% set oficinas_nombres = oficinas_nombres|merge([expediente.idComercial.idOficina.nombre]) %}
											{% endif %}
											{% if expediente.idTecnico is not null and expediente.idTecnico.idOficina is not null %}
												{% set oficinas_nombres = oficinas_nombres|merge([expediente.idTecnico.idOficina.nombre]) %}
											{% endif %}
											{% if expediente.idColaborador is not null and expediente.idColaborador.idOficina is not null %}
												{% set oficinas_nombres = oficinas_nombres|merge([expediente.idColaborador.idOficina.nombre]) %}
											{% endif %}
											{% set oficinas_unicas = [] %}
											{% for nombre in oficinas_nombres %}
												{% if nombre not in oficinas_unicas %}
													{% set oficinas_unicas = oficinas_unicas|merge([nombre]) %}
												{% endif %}
