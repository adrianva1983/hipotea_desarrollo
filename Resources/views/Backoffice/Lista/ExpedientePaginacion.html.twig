														{% if not loop.last %},
														{% endif %}
													{% endfor %}
													]</span>
											{% endif %}

										</td>
									{% endif %}
									{% if not is_granted('ROLE_CLIENTE')and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
										<td>{{ camposPersonalizados[expediente.idExpediente]['origen'] is defined ? camposPersonalizados[expediente.idExpediente]['origen'] : '' }}</td>
									{% endif %}
									{% if not is_granted('ROLE_CLIENTE') %}
										{% if expediente.idCliente is null %}
											<td></td>
