													<span>Documentos</span>
												</a>
												<a class="mr-2 firmas" href="{{ path('lista_documentos_expediente',{'id':expediente.idExpediente,'paraFirmar':'ParaFirmar'}) }}" data-toggle="popover" data-content="Firmas" data-trigger="hover">
													<i class="fas fa-edit"></i>
													<span>Firmas</span>
												</a>
											{% endif %}
										{% else %}
											<a class="mr-2 editar" target="_blank" href="{{ path('agregar_modificar_expediente',{'id':expediente.idExpediente}) }}" data-toggle="popover" data-content="Editar" data-trigger="hover">
												<i class="far fa-edit"></i>
												<span>Editar</span>
											</a>
											<a class="mr-2 documentos" href="{{ path('agregar_modificar_documentos',{'id':expediente.idExpediente}) }}" data-toggle="popover" data-content="Documentos" data-trigger="hover">
												<i class="far fa-file-alt"></i>
												<span>Documentos</span>
											</a>
											<a class="mr-2 notificar" data-notificacion-expediente="{{ expediente.idExpediente }}" {% if expediente.idCliente is null %} data-sin-cliente {% endif %} href="javascript:void(0)" data-toggle="popover" data-content="Notificar" data-trigger="hover">
												<i class="fab fa-telegram-plane"></i>
												<span>Notificar</span>
