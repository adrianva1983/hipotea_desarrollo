												{% set inmuebles_nombres = inmuebles_nombres|merge([expediente.idCliente.idInmobiliaria.nombre]) %}
											{% endif %}
											{% if expediente.idComercial is not null and expediente.idComercial.idInmobiliaria is not null %}
												{% set inmuebles_nombres = inmuebles_nombres|merge([expediente.idComercial.idInmobiliaria.nombre]) %}
											{% endif %}
											{% if expediente.idTecnico is not null and expediente.idTecnico.idInmobiliaria is not null %}
												{% set inmuebles_nombres = inmuebles_nombres|merge([expediente.idTecnico.idInmobiliaria.nombre]) %}
											{% endif %}
											{% if expediente.idColaborador is not null and expediente.idColaborador.idInmobiliaria is not null %}
												{% set inmuebles_nombres = inmuebles_nombres|merge([expediente.idColaborador.idInmobiliaria.nombre]) %}
											{% endif %}
											{% set inmobiliarias_unicas = [] %}
											{% for nombre in inmuebles_nombres %}
												{% if nombre not in inmobiliarias_unicas %}
													{% set inmobiliarias_unicas = inmobiliarias_unicas|merge([nombre]) %}
												{% endif %}
											{% endfor %}
											{% if inmobiliarias_unicas|length > 0 %}
												{{ inmobiliarias_unicas|join(', ') }}
											{% endif %}
										</td>
										<td>
											{% set oficinas_nombres = [] %}
