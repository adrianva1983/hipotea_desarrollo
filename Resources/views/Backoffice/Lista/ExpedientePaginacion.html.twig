												{% set nombreCompleto = nombreCompleto  %}
											{% endif %}
											<td>{{ nombreCompleto }}</td>
										{% endif %}
									{% endif %}
									{% if not is_granted('ROLE_CLIENTE')and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
