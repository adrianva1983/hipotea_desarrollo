												(id == 5 ? 3 :
												(id in [6,9] ? 4 :
													(id in [7,10] ? 5 : 'N/A')
												)
												)
											)
										%}
										<div class="fase-popover" data-toggle="popover" data-trigger="hover" data-content="Fase {{ numeroFase }}: {{ expediente.idFaseActual.nombre }}">
											<span class="expediente-color" style="background:{{ expediente.idFaseActual.color }}"></span>
											<span>Fase {{ numeroFase }}</span>
										</div>
									</td>
									{% if not is_granted('ROLE_CLIENTE')and not is_granted('ROLE_COLABORADOR')  %}
										{% if expediente.estado is same as(0) %}
											<td>
												Cancelado
												{% if expediente.motivoCancelacion is same as(1) %}
													por: Honorarios
												{% elseif expediente.motivoCancelacion is same as(2) %}
													por: No le mejoramos la oferta
												{% elseif expediente.motivoCancelacion is same as(3) %}
													por: Operación no viable por perfil del cliente
												{% elseif expediente.motivoCancelacion is same as(4) %}
													por: Operación no viable por tasación
												{% elseif expediente.motivoCancelacion is same as(5) %}
													por: No tienen vivienda
												{% elseif expediente.motivoCancelacion is same as(6) %}
													por: Compran después de 3 meses
												{% elseif expediente.motivoCancelacion is same as(7) %}
													por: Importe hipoteca inferior a 100.000 €
												{% elseif expediente.motivoCancelacion is same as(8) %}
													por: Lo hacen con su banco
												{% elseif expediente.motivoCancelacion is same as(9) %}
													por: Lo hacen con otra empresa intermediaria
												{% elseif expediente.motivoCancelacion is same as(10) %}
													por: Duplicado
												{% elseif expediente.motivoCancelacion is same as(11) %}
													por:
												{% endif %}
												{{ expediente.texto }}
											</td>
										{% elseif expediente.estado is same as(1) %}
											<td>Activo</td>
										{% elseif expediente.estado is same as(2) %}
											<td>Firmado</td>
										{% else %}
											<td></td>
										{% endif %}
									{% endif %}
								</tr>
							{% endfor %}
						</tbody>
					</table>
					</div>
					
					<!-- Mensaje y botón en la misma línea -->
					<div class="row align-items-center mt-3 mb-3">
						<div class="col-md-6">
							<p class="text-muted mb-0">
								Mostrando registros del {{ ((currentPage - 1) * limit) + 1 }} al {{ min(currentPage * limit, totalExpedientes) }} de un total de {{ totalExpedientes }} registros (filtrado de un total de {{ totalExpedientes }} registros)
							</p>
						</div>
						<div class="col-md-6 text-right">
                            <!-- Paginación -->
                            {% if totalPages > 1 %}
                            <nav aria-label="Paginación de expedientes" class="mt-3">
                                <ul class="pagination justify-content-end">
                                    <li class="page-item {% if currentPage == 1 %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('lista_expedientes_paginacion', app.request.query.all|merge({'page': 1})) }}">
                                            <i class="fas fa-angle-double-left"></i>
                                        </a>
                                    </li>
                                    <li class="page-item {% if currentPage == 1 %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('lista_expedientes_paginacion', app.request.query.all|merge({'page': currentPage - 1})) }}">
                                            Anterior
                                        </a>
                                    </li>
                                    
                                    {% set startPage = max(1, currentPage - 2) %}
                                    {% set endPage = min(totalPages, currentPage + 2) %}
                                    
                                    {% if startPage > 1 %}
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    {% endif %}
                                    
                                    {% for page in startPage..endPage %}
                                        <li class="page-item {% if page == currentPage %}active{% endif %}">
                                            <a class="page-link" href="{{ path('lista_expedientes_paginacion', app.request.query.all|merge({'page': page})) }}">
                                                {{ page }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                    
                                    {% if endPage < totalPages %}
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    {% endif %}
                                    
                                    <li class="page-item {% if currentPage == totalPages %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('lista_expedientes_paginacion', app.request.query.all|merge({'page': currentPage + 1})) }}">
                                            Siguiente
                                        </a>
                                    </li>
                                    <li class="page-item {% if currentPage == totalPages %}disabled{% endif %}">
                                        <a class="page-link" href="{{ path('lista_expedientes_paginacion', app.request.query.all|merge({'page': totalPages})) }}">
                                            <i class="fas fa-angle-double-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                            {% endif %}
							
						</div>
                        <div class="col-md-22">
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') and not is_granted('ROLE_JEFE_INMOBILIARIA') and not is_granted('ROLE_JEFE_OFICINA') and not is_granted('ROLE_RESPONSABLE_ZONA') %}
								<button class="btn btn-success waves-effect" id="boton-borrar-entidades">Borrar marcados</button>
							{% endif %}
                        </div>
					</div>
				</form>
				
				
				
			{% else %}
				<div class="alert alert-info" role="alert">
					<span>No hay expedientes pendientes.</span>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
{% block modals %}
	{{ parent() }}
	{% include '@App/Backoffice/Modal/ConfirmarBorrar.html' %}
	{% include '@App/Backoffice/Modal/ConfirmarDuplicar.html' %}
	{% include '@App/Backoffice/Modal/NotificacionExpediente.html.twig' %}
	{% include '@App/Backoffice/Modal/CancelarExpediente.html.twig' %}

	<!-- Modal para ver conversaciones de WhatsApp -->
	<div class="modal fade" id="whatsappChatModal" tabindex="-1" role="dialog" aria-labelledby="whatsappChatModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-lg" role="document">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="whatsappChatModalLabel">
						<i class="fab fa-whatsapp" style="color: #25D366;"></i>
						Conversaciones de WhatsApp
					</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<div id="whatsappMessagesContent">
						<div class="text-center">
							<div class="spinner-border" role="status">
								<span class="sr-only">Cargando...</span>
							</div>
						</div>
					</div>
				</div>
				<div class="modal-body border-top" id="whatsappInputArea" style="display:none; padding-top: 15px;">
					<div class="form-group">
						<textarea id="whatsappMessageInput" class="form-control" placeholder="Escribe tu mensaje..." rows="3"></textarea>
					</div>
					<button type="button" class="btn btn-success btn-sm" id="enviarMensajeWhatsapp">
						<i class="fas fa-paper-plane"></i> Enviar
					</button>
					<button type="button" class="btn btn-secondary btn-sm" id="limpiarMensajeWhatsapp">
						Limpiar
					</button>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
				</div>
			</div>
		</div>
	</div>
{% endblock %}