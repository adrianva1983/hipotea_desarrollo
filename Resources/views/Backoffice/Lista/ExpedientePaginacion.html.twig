											</a>
											<a class="mr-2 whatsapp-chat disabled" data-expediente-id="{{ expediente.idExpediente }}" href="javascript:void(0)" data-toggle="popover" data-content="Ver WhatsApp" data-trigger="hover">
												<i class="fab fa-whatsapp"></i>
											</a>
											<a class="mr-2 cancelar" data-cancelar-expediente="{{ expediente.idExpediente }}" {% if expediente.idCliente is null %} data-sin-cliente {% endif %} href="javascript:void(0)" data-toggle="popover" data-content="Cancelar" data-trigger="hover">
												<i class="far fa-trash-alt"></i>
												<span>Cancelar</span>
											</a>
										{% endif %}
									</td>
