{% block customscripts %}
	{{ parent() }}
	<script>
		$(function () {
			'use strict';
			
			// DEBUG: Contar opciones antes de inicializar Select2
			var countClientes = $('#clientes option').length;
			//console.log('Opciones de clientes en HTML:', countClientes);
			$('#count-clientes').text(countClientes);
			
			// DEBUG: Director de Expansión - Mostrar responsables y inmobiliarias filtradas
			//console.log('=== DIRECTOR DE EXPANSIÓN ===');
			//console.log('ID Usuario Mod:', {{ app.user.idUsuario }});
			
			// Responsables asignados
			const responsables = {{ responsablesDelDirector|json_encode|raw }};
			const responsables1 = {{ responsablesDelDirector1|json_encode|raw }};
			//console.log('Responsables asignados:', responsables);
			//console.log('Responsables asignados1:', responsables1);
			
			
			// Inmobiliarias filtradas
			const inmobiliariaIds = [{% for id in inmobiliariasFiltradas %}'{{ id }}'{% if not loop.last %}, {% endif %}{% endfor %}];
			//console.log('Inmobiliarias filtradas:', inmobiliariaIds);
			
			// IMPORTANTE: Destruir TODAS las instancias de Select2 antes de inicializar
			$('select').each(function() {
				if ($(this).data('select2')) {
					$(this).select2('destroy');
				}
			});
			
			// Esperar un momento antes de reinicializar
			setTimeout(function() {
				// Inicializar todos los select2
				$('.select2').each(function() {
					var placeholderText = $(this).data('placeholder') || '';
					var isMultiple = $(this).attr('multiple') !== undefined;
					
					//console.log('Inicializando select:', $(this).attr('id'), 'con', $(this).find('option').length, 'opciones, multiple:', isMultiple);
					
					$(this).select2({
						language: 'es',
						placeholder: placeholderText,
						allowClear: true,
						width: '100%',
						closeOnSelect: !isMultiple
					});
				});
				
				//console.log('Select2 inicializado correctamente');
				
				// Aplicar filtro de inmobiliarias si es Director de Expansión
				if ({{ app.user.idUsuario }} === 1656 && inmobiliariaIds.length > 0) {
					//console.log('Aplicando filtro de inmobiliarias para Director de Expansión');
					$('#inmobiliarias').val(inmobiliariaIds).change();
					//console.log('Filtro de inmobiliarias aplicado');
				}
			}, 100);
			
			$('[data-toggle="popover"]').popover();
			
			// Manejar selección de todos los checkboxes
			$('#seleccionar-todas-entidades').on('change', function() {
				$('input[name="expediente[]"]').prop('checked', $(this).prop('checked'));
			});
			
			// Si se desmarca alguno individualmente, desmarcar el "seleccionar todos"
			$(document).on('change', 'input[name="expediente[]"]', function() {
				if (!$(this).prop('checked')) {
					$('#seleccionar-todas-entidades').prop('checked', false);
				} else {
					// Si todos están marcados, marcar el "seleccionar todos"
					if ($('input[name="expediente[]"]:checked').length === $('input[name="expediente[]"]').length) {
						$('#seleccionar-todas-entidades').prop('checked', true);
					}
				}
			});
			
			// Funcionalidad de búsqueda global con debounce
			var searchTimeout;
			$('#buscar-tabla').on('keyup', function() {
				clearTimeout(searchTimeout);
				var valor = $(this).val();
				
				// Si el campo está vacío, no hacer búsqueda
				if (valor.length === 0) {
					return;
				}
				
				// Esperar 500ms después de que el usuario deje de escribir
				searchTimeout = setTimeout(function() {
					// Obtener la URL actual y agregar el parámetro de búsqueda
					var url = new URL(window.location.href);
					url.searchParams.set('buscar', valor);
					url.searchParams.set('page', '1'); // Resetear a la página 1
					
					// Redirigir a la URL con el parámetro de búsqueda
					window.location.href = url.toString();
				}, 500);
			});
			
			// Limpiar búsqueda si se borra el campo
			$('#buscar-tabla').on('search', function() {
				if ($(this).val() === '') {
					var url = new URL(window.location.href);
					url.searchParams.delete('buscar');
					window.location.href = url.toString();
				}
			});
		});

		function rutaDuplicarExpediente() {
			return '{{ path('duplicar_expediente',{'id':' '}) }}';
		}

		function rutaNotificacionExpediente() {
			return '{{ path('notificacion_expediente',{'id':' '}) }}';
		}

		function rutaCancelarExpediente() {
			return '{{ path('cancelar_expediente',{'id':' '}) }}';
		}
		
		function cambiarLimit(nuevoLimit) {
			// Obtener la URL actual con todos sus parámetros
			var url = new URL(window.location.href);
			
			// Actualizar el parámetro limit
			url.searchParams.set('limit', nuevoLimit);
			
			// Resetear a la página 1 al cambiar el límite
			url.searchParams.set('page', '1');
			
			// Redirigir a la nueva URL
			window.location.href = url.toString();
		}
		
		// Manejo de botones de estado (Cancelados, Activos, Firmados)
		$(function() {
			// Función para aplicar estilos al botón según el estado
			function aplicarEstiloBotón(estado) {
				//console.log('Aplicando estilo al estado:', estado);
				// Remover estilos de todos los botones
				$('.estado-btn').removeAttr('style').removeClass('active');
				
				// Buscar el botón con el estado y aplicar estilo
				var botón = $('.estado-btn[data-estado="' + estado + '"]');
				if (botón.length) {
					//console.log('Botón encontrado para estado:', estado);
					if (estado == '0') {
						botón.css({'background-color': '#dc3545', 'color': 'white'});
					} else if (estado == '1') {
						botón.css({'background-color': '#28a745', 'color': 'white'});
					} else if (estado == '2') {
						botón.css({'background-color': '#007bff', 'color': 'white'});
					} 
				}
			}
			
			// Al cargar la página, activar el botón correspondiente al valor del input oculto
			var estadoActual = $('#estado-filtro').val();
			//console.log('Estado actual del input oculto:', estadoActual);
			
			// Si no hay estado o está vacío, usar '1' (Activos) por defecto
			if (!estadoActual || estadoActual === '') {
				estadoActual = '1';
				$('#estado-filtro').val('1');
			}
			
			aplicarEstiloBotón(estadoActual);
			
			// Evento click en los botones
			$('.estado-btn').on('click', function() {
				var estado = $(this).data('estado');
				//console.log('Click en botón con estado:', estado);
				
				// Aplicar estilos al botón clickeado
				aplicarEstiloBotón(estado);
				
				// Actualizar el valor del input oculto
				$('#estado-filtro').val(estado);
			});
		});
	</script>
	<script src="{{ asset('assets/js/custom/lista-expedientes.min.js') }}"></script>
	<script src="{{ asset('assets/js/custom/notificacion-expediente.js') }}"></script>
	<script src="{{ asset('assets/js/custom/cancelar-expediente.js') }}"></script>
	<script>
		// Variable global para almacenar expedientes con mensajes
		var expedientesConMensajes = [];
		
		// Datos del usuario logueado
		var usuarioLogueado = {
			id: {{ usuarioLogueado.idUsuario }},
			role: '{{ rolUsuario }}',
			phone: '{{ telefonoUsuario }}'
		};
		
		// Variable para guardar el ID del expediente actual
		var expedienteActual = null;
		
		// Variable para rastrear el número de mensajes y controlar el botón
		var numeroMensajesActual = 0;
		var mensajeEnviadoAstPendiente = false;
		// Variable para polling automático de mensajes
		var pollingIntervalId = null;
		
		console.log('Usuario logueado:', usuarioLogueado);

		// Cargar expedientes con mensajes al cargar la página
		$(document).ready(function() {
			cargarExpedientesConMensajes();
			
			// Eventos del formulario de WhatsApp
			$('#enviarMensajeWhatsapp').on('click', function() {
				enviarMensajeWhatsApp();
			});
			
			$('#limpiarMensajeWhatsapp').on('click', function() {
				$('#whatsappMessageInput').val('');
			});
			
			// Enviar con Enter (Shift+Enter para nueva línea)
			$('#whatsappMessageInput').on('keypress', function(e) {
				if (e.which === 13 && !e.shiftKey) {
					e.preventDefault();
					enviarMensajeWhatsApp();
				}
			});
			// Detector de cierre del modal para detener polling
			$('#whatsappChatModal').on('hidden.bs.modal', function() {
				console.log('Modal cerrado, deteniendo polling...');
				if (pollingIntervalId) {
					clearInterval(pollingIntervalId);
					pollingIntervalId = null;
				}
			});
		});

		function cargarExpedientesConMensajes() {
			$.ajax({
				url: '{{ path('api_get_expedientes_con_mensajes') }}?api_key=123456',
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(response) {
					console.log('Expedientes con mensajes:', response.expedientes_con_mensajes);
					expedientesConMensajes = response.expedientes_con_mensajes;
					
					// Habilitar/deshabilitar botones de WhatsApp según acceso
					actualizarBotonesWhatsApp();
				},
				error: function(xhr, status, error) {
					console.error('Error al cargar expedientes con mensajes:', error);
				}
			});
		}

		function actualizarBotonesWhatsApp() {
			// Recorrer todos los botones de WhatsApp
			$('a.whatsapp-chat').each(function() {
				var expedienteId = String($(this).data('expediente-id'));
				
				// Si es ADMIN, habilitar solo si hay mensajes
				if (usuarioLogueado.role === 'ROLE_ADMIN') {
					var idsConMensajesString = expedientesConMensajes.map(String);
					if (idsConMensajesString.includes(expedienteId)) {
						console.log('✓ Habilitando botón para ADMIN en expediente:', expedienteId, '(Tiene mensajes)');
						$(this).removeClass('disabled');
					} else {
						console.log('Deshabilitando botón para ADMIN en expediente:', expedienteId, '(Sin mensajes)');
						$(this).addClass('disabled');
					}
					return;
				}
				
				// Para TECNICO/COMERCIAL, SIEMPRE verificar si es asignado (con o sin mensajes previos)
				verificarAccesoWhatsApp(expedienteId, $(this));
			});
		}
		
		function verificarAccesoWhatsApp(expedienteId, boton) {
			// Si es ADMIN, habilitar siempre
			if (usuarioLogueado.role === 'ROLE_ADMIN') {
				console.log('Habilitando botón para ADMIN en expediente:', expedienteId);
				boton.removeClass('disabled');
				return;
			}
			console.log('Verificando acceso WhatsApp para expediente:', expedienteId);
			// Verificar si es TÉCNICO o COMERCIAL del expediente
			$.ajax({
				url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteId,
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(expedienteData) {
					var idUsuario = parseInt(usuarioLogueado.id);
					var idTecnico = expedienteData.id_tecnico ? parseInt(expedienteData.id_tecnico) : null;
					var idComercial = expedienteData.id_comercial ? parseInt(expedienteData.id_comercial) : null;
					
					// Si es técnico o comercial del expediente, habilitar
					if (idTecnico === idUsuario || idComercial === idUsuario) {
						console.log('✓ Habilitando botón para expediente:', expedienteId, '(Eres Técnico/Comercial)');
						boton.removeClass('disabled');
						return;
					}
					
					// Si no es técnico/comercial, continuar con la verificación normal
					verificarAccesoWhatsAppPorMensajes(expedienteId, boton);
				},
				error: function(xhr, status, error) {
					console.error('Error al verificar técnico/comercial:', error);
					verificarAccesoWhatsAppPorMensajes(expedienteId, boton);
				}
			});
		}
		
		function verificarAccesoWhatsAppPorMensajes(expedienteId, boton) {
			// Verificar si tiene mensajes de su teléfono
			$.ajax({
				url: '{{ path('api_get_whatsapp_messages', {'id': 'EXPEDIENTE_ID'}) }}'.replace('EXPEDIENTE_ID', expedienteId),
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(response) {
					var tieneAcceso = false;
					
					if (response && response.length > 0) {
						for (var i = 0; i < response.length; i++) {
							if (response[i].phone_number === usuarioLogueado.phone) {
								tieneAcceso = true;
								break;
							}
						}
					}
					
					if (tieneAcceso) {
						console.log('Habilitando botón para expediente:', expedienteId, '(Tiene mensajes)');
						boton.removeClass('disabled');
					} else {
						console.log('Deshabilitando botón para expediente:', expedienteId, '(Sin acceso)');
						boton.addClass('disabled');
					}
				},
				error: function(xhr, status, error) {
					console.error('Error al verificar acceso:', error);
					boton.addClass('disabled');
				}
			});
		}
		
		// Manejar click en botón de WhatsApp para ver conversaciones
		$(document).on('click', 'a.whatsapp-chat', function(e) {
			e.preventDefault();
			
			// Si el botón está deshabilitado, no hacer nada
			if ($(this).hasClass('disabled')) {
				return;
			}
			
			var expedienteId = $(this).data('expediente-id');
			expedienteActual = expedienteId;
			
			
			
			// Obtener datos del expediente para mostrar teléfono del cliente
			$.ajax({
				url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteId,
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(response) {
					// Mostrar el modal
					$('#whatsappChatModal').modal('show');
					var telefonoCliente = response.telefono_cliente || 'N/A';
					
					// Actualizar título del modal con la información completa
					$('#whatsappChatModalLabel').html(
						'<i class="fab fa-whatsapp" style="color: #25D366;"></i> ' +
						'Expediente #' + expedienteId + 
						' | Mi teléfono: ' + usuarioLogueado.phone +
						' | Cliente: ' + telefonoCliente
					);
				},
				error: function() {
					// Si falla, mostrar solo la información que tenemos
					$('#whatsappChatModalLabel').html(
						'<i class="fab fa-whatsapp" style="color: #25D366;"></i> ' +
						'Expediente #' + expedienteId + 
						' | Mi teléfono: ' + usuarioLogueado.phone +
						' | Cliente: N/A'
					);
				}
			});
			
			// Limpiar input
			$('#whatsappMessageInput').val('');
			$('#whatsappInputArea').hide();
			
			// Cargar los mensajes del expediente
			console.log('Cargando mensajes de WhatsApp para expediente ID:', expedienteId);
			cargarMensajesWhatsApp(expedienteId);
			// Iniciar polling automático de mensajes cada 3 segundos
			if (pollingIntervalId) {
				clearInterval(pollingIntervalId);
			}
			pollingIntervalId = setInterval(function() {
				cargarMensajesWhatsApp(expedienteId);
			}, 10000);
			console.log('✓ Polling iniciado para expediente:', expedienteId);
		});
		
		function cargarMensajesWhatsApp(expedienteId) {
			var url = '{{ path('api_get_whatsapp_messages', {'id': 'EXPEDIENTE_ID'}) }}'.replace('EXPEDIENTE_ID', expedienteId);
			
			$.ajax({
				url: url,
				method: 'GET',
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(response) 
				{
					console.log('cargarMensajesWhatsApp', response);
					renderizarMensajes(response);
				},
				error: function(xhr, status, error) {
					console.error('Error al cargar mensajes:', error);
					$('#whatsappMessagesContent').html(
						'<div class="alert alert-warning alert-dismissible fade show" role="alert">' +
						'<strong>No hay mensajes</strong> o ocurrió un error al cargar la conversación.' +
						'<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
						'<span aria-hidden="true">&times;</span></button></div>'
					);
					$('#whatsappInputArea').hide();
				}
			});
		}
		
		function renderizarMensajes(messages) {
			if (!messages || messages.length === 0) {
				$('#whatsappMessagesContent').html(
					'<div class="alert alert-info alert-dismissible fade show" role="alert">' +
					'<strong>Sin mensajes</strong> - No hay conversaciones de WhatsApp para este expediente.' +
					'<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
					'<span aria-hidden="true">&times;</span></button></div>'
				);
				numeroMensajesActual = 0;
				
				// Verificar si es técnico/comercial asignado para permitir iniciar conversación
				if (usuarioLogueado.role === 'ROLE_TECNICO' || usuarioLogueado.role === 'ROLE_COMERCIAL') {
					$.ajax({
						url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteActual,
						method: 'GET',
						async: false,
						headers: {
							'X-Requested-With': 'XMLHttpRequest'
						},
						success: function(expedienteData) {
							var idUsuario = parseInt(usuarioLogueado.id);
							var idTecnico = expedienteData.id_tecnico ? parseInt(expedienteData.id_tecnico) : null;
							var idComercial = expedienteData.id_comercial ? parseInt(expedienteData.id_comercial) : null;
							
							if (idTecnico === idUsuario || idComercial === idUsuario) {
								console.log('✓ Técnico/Comercial asignado - Mostrando área de envío para iniciar conversación');
								$('#whatsappInputArea').show();
								return;
							}
							$('#whatsappInputArea').hide();
						},
						error: function(xhr, status, error) {
							console.error('Error al verificar técnico/comercial:', error);
							$('#whatsappInputArea').hide();
						}
					});
				} else {
					$('#whatsappInputArea').hide();
				}
				return;
			}
			
			var html = '<div class="whatsapp-messages-container">';
			
			// Filtrar mensajes según el rol del usuario
			var mensajesFiltrados = messages;
			if (usuarioLogueado.role !== 'ROLE_ADMIN' && usuarioLogueado.phone) {
				mensajesFiltrados = messages.filter(function(msg) {
					return msg.phone_number === usuarioLogueado.phone;
				});
			}
			
			if (mensajesFiltrados.length === 0) {
				$('#whatsappMessagesContent').html(
					'<div class="alert alert-warning alert-dismissible fade show" role="alert">' +
					'<strong>Sin acceso</strong> - No tienes mensajes en esta conversación.' +
					'<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
					'<span aria-hidden="true">&times;</span></button></div>'
				);
				$('#whatsappInputArea').hide();
				numeroMensajesActual = 0;
				return;
			}
			
			// Guardar el número de mensajes anterior
			var numeroMensajesAnterior = numeroMensajesActual;
			numeroMensajesActual = mensajesFiltrados.length;
			
			// Si hay un mensaje pendiente y el número de mensajes aumentó, habilitar el botón
			if (mensajeEnviadoAstPendiente && numeroMensajesActual > numeroMensajesAnterior) {
				console.log('✓ Mensaje encontrado en la base de datos. Botón habilitado.');
				console.log('Mensajes anteriores:', numeroMensajesAnterior, 'Mensajes actuales:', numeroMensajesActual);
				mensajeEnviadoAstPendiente = false;
				
				// Eliminar la alerta de mensaje enviado
				$('.alert-success').fadeOut(400, function() {
					$(this).remove();
				});
				
				$('#enviarMensajeWhatsapp').prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Enviar');
			}
			
			$.each(mensajesFiltrados, function(index, msg) {
				var roleClass = msg.role || 'user';
				var roleLabel = msg.role_label || msg.role || 'Usuario';
				var timestamp = msg.timestamp ? new Date(msg.timestamp).toLocaleString() : '';
				
				html += '<div class="whatsapp-message ' + roleClass + '">';
				html += '<div class="whatsapp-message-role">' + roleLabel + '</div>';
				
				// Procesar el mensaje JSON (puede ser texto o imagen)
				var mensajeProcesado = procesarMensajeJSON(msg.text);
				
				html += '<div>' + mensajeProcesado + '</div>';
				
				if (timestamp) {
					html += '<div class="whatsapp-message-time">' + timestamp + '</div>';
				}
				html += '</div>';
			});
			
			html += '</div>';
			$('#whatsappMessagesContent').html(html);
			
			// Verificar si el usuario tiene permiso para enviar mensajes
			// Solo TECNICO/COMERCIAL del expediente puede enviar
			// ADMIN NUNCA puede enviar, solo ver
			var puedeEnviar = false;
			console.log('=== VERIFICANDO PERMISOS DE ENVÍO ===');
			console.log('Role del usuario:', usuarioLogueado.role);
			console.log('Teléfono del usuario:', usuarioLogueado.phone);
			console.log('Expediente actual:', expedienteActual);
			
			if (usuarioLogueado.role === 'ROLE_ADMIN') {
				console.log('El usuario es ADMIN, NO puede enviar (solo ver)');
				puedeEnviar = false;
			} else if (usuarioLogueado.role === 'ROLE_TECNICO' || usuarioLogueado.role === 'ROLE_COMERCIAL') {
				// Verificar si es el técnico o comercial asignado al expediente
				$.ajax({
					url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteActual,
					method: 'GET',
					async: false,
					headers: {
						'X-Requested-With': 'XMLHttpRequest'
					},
					success: function(expedienteData) {
						var idUsuario = parseInt(usuarioLogueado.id);
						var idTecnico = expedienteData.id_tecnico ? parseInt(expedienteData.id_tecnico) : null;
						var idComercial = expedienteData.id_comercial ? parseInt(expedienteData.id_comercial) : null;
						
						console.log('ID Usuario:', idUsuario, 'Técnico:', idTecnico, 'Comercial:', idComercial);
						
						// Verificar si es técnico o comercial del expediente
						if (idTecnico === idUsuario || idComercial === idUsuario) {
							console.log('✓ El usuario es Técnico/Comercial asignado, puede enviar');
							puedeEnviar = true;
						} else {
							console.log('✗ El usuario NO es Técnico/Comercial asignado, NO puede enviar');
							puedeEnviar = false;
						}
					},
					error: function(xhr, status, error) {
						console.error('Error al verificar técnico/comercial asignado:', error);
						puedeEnviar = false;
					}
				});
			} else {
				console.log('El usuario no tiene rol suficiente');
				puedeEnviar = false;
			}
			
			// Mostrar input de envío solo si puede enviar
			console.log('¿Puede enviar?', puedeEnviar);
			if (puedeEnviar) {
				console.log('Mostrando área de envío');
				$('#whatsappInputArea').show();
			} else {
				console.log('Ocultando área de envío');
				$('#whatsappInputArea').hide();
			}
			
			// Scroll al final (últimos mensajes)
			var container = $('#whatsappMessagesContent').find('.whatsapp-messages-container');
			if (container.length) {
				container.scrollTop(container[0].scrollHeight);
			}
		}
		
		// Función para verificar si el usuario logueado es técnico o comercial del expediente
		function verificarSiEsTecnicoOComercialDelExpediente(expedienteId) {
			// Hacer una consulta AJAX para obtener los datos del expediente
			var esValido = false;
			$.ajax({
				url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteId,
				method: 'GET',
				async: false, // Sincrónico para que retorne el valor correctamente
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(response) {
					console.log('Datos del expediente:', response);
					console.log('Usuario logueado ID:', usuarioLogueado.id, 'Técnico:', response.id_tecnico, 'Comercial:', response.id_comercial);
					
					// Convertir a números para comparación segura
					var idUsuario = parseInt(usuarioLogueado.id);
					var idTecnico = response.id_tecnico ? parseInt(response.id_tecnico) : null;
					var idComercial = response.id_comercial ? parseInt(response.id_comercial) : null;
					
					// Verificar si el usuario logueado es técnico o comercial
					if (idTecnico === idUsuario || idComercial === idUsuario) {
						console.log('Usuario SÍ es técnico o comercial del expediente');
						esValido = true;
					} else {
						console.log('Usuario NO es técnico o comercial del expediente');
						esValido = false;
					}
				},
				error: function(xhr, status, error) {
					console.error('Error al verificar técnico/comercial:', error);
					esValido = false;
				}
			});
			console.log('Resultado final de verificación:', esValido);
			return esValido;
		}
		
		function enviarMensajeWhatsApp() {
			var mensaje = $('#whatsappMessageInput').val().trim();
			
			if (!mensaje) {
				alert('Por favor escribe un mensaje');
				return;
			}
			
			if (!expedienteActual) {
				alert('Error: No hay expediente seleccionado');
				return;
			}
			
			// SIEMPRE validar que el cliente tiene teléfono antes de enviar
			var validacionPasada = false;
			
			$.ajax({
				url: '{{ path('api_get_expediente_datos') }}?id=' + expedienteActual,
				method: 'GET',
				async: false,
				headers: {
					'X-Requested-With': 'XMLHttpRequest'
				},
				success: function(expedienteData) {
					var telefonoCliente = expedienteData.telefono_cliente;
					console.log('Validando cliente - Teléfono cliente:', telefonoCliente);
					
					if (!telefonoCliente || telefonoCliente === 'N/A' || telefonoCliente === '') {
						alert('❌ Error: El cliente no tiene teléfono registrado. No se puede enviar mensajes a este expediente.');
						validacionPasada = false;
					} else {
						validacionPasada = true;
					}
				},
				error: function(xhr, status, error) {
					console.error('Error al validar cliente:', error);
					alert('❌ Error: No se pudo validar los datos del cliente');
					validacionPasada = false;
				}
			});
			
			// Si la validación no pasó, detener el envío
			if (!validacionPasada) {
				console.log('Envío cancelado: Cliente sin teléfono');
				return;
			}
			
			// Preparar datos para enviar
			var datos = {
				id_expediente: expedienteActual,
				phone_number: usuarioLogueado.phone,
				text: mensaje
			};
			
			console.log('Enviando mensaje:', datos);
			
			// Mostrar estado de carga
			$('#enviarMensajeWhatsapp').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Enviando...');
			
			$.ajax({
				url: '{{ path('api_send_whatsapp_message') }}?api_key=123456',
				method: 'POST',
				headers: {
					'X-Requested-With': 'XMLHttpRequest',
					'Content-Type': 'application/json',
					'X-API-KEY': '123456'
				},
				data: JSON.stringify(datos),
				success: function(response) {
					console.log('Mensaje enviado exitosamente:', response);
					
					// Marcar que hay un mensaje pendiente de confirmación
					mensajeEnviadoAstPendiente = true;
					
					// Limpiar input
					$('#whatsappMessageInput').val('');
					
					// Mostrar notificación de éxito
					var alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
						'<strong>¡Mensaje enviado!</strong> Guardando en base de datos...' +
						'<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
						'<span aria-hidden="true">&times;</span></button></div>';
					
					// Inserta la alerta al inicio del modal body
					$('#whatsappMessagesContent').before(alertHtml);
					
					// Recargar los mensajes con reintentos automáticos
					// Primer intento: 2.5 segundos
					setTimeout(function() {
						console.log('Intento 1: Cargando mensajes después de 2.5 segundos');
						cargarMensajesWhatsApp(expedienteActual);
					}, 2500);
					
					// Segundo intento: 10 segundos
					setTimeout(function() {
						console.log('Intento 2: Recargando mensajes después de 10 segundos');
						cargarMensajesWhatsApp(expedienteActual);
					}, 10000);
					
					// Tercer intento: 20 segundos
					setTimeout(function() {
						console.log('Intento 3: Recargando mensajes después de 20 segundos');
						cargarMensajesWhatsApp(expedienteActual);
					}, 20000);
				},
				error: function(xhr, status, error) {
					console.error('Error al enviar mensaje1:', {
						status: xhr.status,
						statusText: xhr.statusText,
						error: error,
						response: xhr.responseJSON
					});
					
					var mensajeError = 'Error al enviar el mensaje2';
					if (xhr.responseJSON && xhr.responseJSON.error) {
						mensajeError = xhr.responseJSON.error;
					}
					
					// Mostrar notificación de error detallada
					var alertHtml = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
						'<strong>Error:</strong> ' + mensajeError +
						'<br><small>Revisa la consola para más detalles</small>' +
						'<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
						'<span aria-hidden="true">&times;</span></button></div>';
					
					$('#whatsappMessagesContent').before(alertHtml);
					
					// Habilitar botón en caso de error
					mensajeEnviadoAstPendiente = false;
					$('#enviarMensajeWhatsapp').prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Enviar');
				},
				complete: function() {
					// Solo restaurar botón si no está pendiente
					if (!mensajeEnviadoAstPendiente) {
						$('#enviarMensajeWhatsapp').prop('disabled', false).html('<i class="fas fa-paper-plane"></i> Enviar');
					}
				}
			});
		}
		
		// Función para procesar mensaje JSON (texto o imagen)
		function procesarMensajeJSON(jsonText) {
			if (!jsonText) return '';
			
			try {
				// Decodificar Unicode escapados primero
				var textoDecodificado = decodeUnicodeEscapes(jsonText);
				
				// Intentar parsear como JSON
				var mensajeObj = JSON.parse(textoDecodificado);
				
				// Si es un objeto con estructura de mensaje
				if (typeof mensajeObj === 'object' && mensajeObj.type) {
					if (mensajeObj.type === 'image') {
						// Procesar imagen
						return procesarImagenJSON(mensajeObj);
					} else if (mensajeObj.type === 'text') {
						// Procesar texto
						return escapeHtml(mensajeObj.content || '');
					}
				}
				
				// Si no tiene estructura reconocida, devolver como texto plano
				return escapeHtml(textoDecodificado);
				
			} catch (e) {
				// Si no es JSON válido, asumir que es texto plano
				console.warn('Error parseando JSON:', e);
				var textoDecodificado = decodeUnicodeEscapes(jsonText);
				return escapeHtml(textoDecodificado);
			}
		}
		
		// Función para procesar imagen desde JSON
		function procesarImagenJSON(mensajeObj) {
			var html = '';
			var mimeType = mensajeObj.mime_type || 'image/jpeg';
			var imageContent = mensajeObj.content || '';
			
			// Mostrar imagen si hay contenido base64
			if (imageContent) {
				var dataUri = 'data:' + mimeType + ';base64,' + imageContent;
				html += '<img src="' + dataUri + '" style="max-width: 100%; max-height: 300px; border-radius: 5px;" alt="Imagen compartida">';
			}
			
			// Mostrar texto descriptivo si existe
			if (mensajeObj.text) {
				html += '<p style="margin-top: 10px;">' + escapeHtml(mensajeObj.text) + '</p>';
			}
			
			// Si no hay contenido, mostrar placeholder
			if (!imageContent && !mensajeObj.text) {
				html += '<p style="color: #999;"><i>Imagen no disponible</i></p>';
			}
			
			return html;
		}
		
		// Función para decodificar caracteres Unicode escapados
		function decodeUnicodeEscapes(str) {
			if (!str) return str;
			try {
				return str.replace(/\\u([0-9a-fA-F]{4})/g, function(match, grp) {
					return String.fromCharCode(parseInt(grp, 16));
				});
			} catch(e) {
				console.error('Error decodificando Unicode:', e);
				return str;
			}
		}
		
		// Función auxiliar para escapar HTML
		function escapeHtml(text) {
			if (!text) return text;
			var map = {
				'&': '&amp;',
				'<': '&lt;',
				'>': '&gt;',
				'"': '&quot;',
				"'": '&#039;'
			};
			return text.replace(/[&<>"']/g, function(m) { return map[m]; });
		}
	</script>
{% endblock %}
{% block body %}
	<div class="card">
		<div class="card-body">
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			<h4 class="card-title">{{ titulo }}</h4>
			
			<!-- Filtros -->
			<div class="card mb-3">
				<!--<div class="card-header">
					<h5 class="mb-0">Filtros de búsqueda</h5>
				</div>-->
                <div class="card-body">					
                    <form method="get" action="{{ path('lista_expedientes_paginacion') }}" id="formFiltros">
                        {# Campo oculto para preservar el límite de registros al filtrar #}
                        <input type="hidden" name="limit" value="{{ limit }}">
                        
                        <div class="row">
                            {# Filtro por número de expediente 
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') %}
                                <div class="col-md-2 mb-3">
                                    <label for="expediente">Nº Expediente</label>
                                    <input type="text" 
                                            class="form-control" 
                                            id="expediente" 
                                            name="expediente" 
                                            value="{{ app.request.get('expediente') }}"
                                            placeholder="Nº expediente">
                                </div>
                            {% endif %}#}

                            {# Filtro por clientes - Solo si no es ROLE_CLIENTE ni ROLE_COLABORADOR #}
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') %}
                                <div class="col-md-2 mb-3">
                                    <label for="clientes">Buscar cliente </label>
                                    <select class="form-control select2" 
                                            id="clientes" 
                                            name="clientes[]" 
                                            multiple="multiple">
                                        {% for cliente in clientes %}
                                            {% set usuario = cliente %}
                                            {% if usuario.apellidos|length is same as(0) %}
                                                {% if usuario.username|length is same as(0) %}
                                                    {% set nombreCompleto = '' %}
                                                {% else %}
                                                    {% set nombreCompleto = usuario.username %}
                                                {% endif %}
                                            {% else %}
                                                {% if usuario.username|length is same as(0) %}
                                                    {% set nombreCompleto = usuario.apellidos %}
                                                {% else %}
                                                    {% set nombreCompleto = usuario.apellidos ~ ', ' ~ usuario.username %}
                                                {% endif %}
                                            {% endif %}
                                            {% if nombreCompleto|length is not same as(0) %}
                                                {% set nombreCompleto = nombreCompleto  %}
                                            {% endif %}
                                            <option value="{{ cliente.idUsuario }}" 
                                                    {% if app.request.get('clientes') and cliente.idUsuario in app.request.get('clientes') %}selected{% endif %}>
                                                {{ nombreCompleto }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                    
                                </div>
                            {% endif %}

                            {# Filtro por colaboradores #}
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') %}
                                <div class="col-md-2 mb-3">
                                    <label for="colaboradores">Buscar usuario colaborador</label>
                                    <select class="form-control select2" 
                                            id="colaboradores" 
                                            name="colaboradores[]" 
                                            multiple="multiple"
                                            data-placeholder="">
                                        {% for colaborador in colaboradores %}
                                            {% set usuario = colaborador %}
                                            {% if usuario.apellidos|length is same as(0) %}
                                                {% if usuario.username|length is same as(0) %}
                                                    {% set nombreCompleto = '' %}
                                                {% else %}
                                                    {% set nombreCompleto = usuario.username %}
                                                {% endif %}
                                            {% else %}
                                                {% if usuario.username|length is same as(0) %}
                                                    {% set nombreCompleto = usuario.apellidos %}
                                                {% else %}
                                                    {% set nombreCompleto = usuario.apellidos ~ ', ' ~ usuario.username %}
                                                {% endif %}
                                            {% endif %}
                                            <option value="{{ colaborador.idUsuario }}"
                                                    {% if app.request.get('colaboradores') and colaborador.idUsuario in app.request.get('colaboradores') %}selected{% endif %}>
                                                {{ nombreCompleto }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endif %}

                            {# Filtro por comerciales - Solo para ADMIN y COMERCIAL y TECNICO #}
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_COMERCIAL') or is_granted('ROLE_TECNICO') %}
                                <div class="col-md-2 mb-3">
                                    <label for="comerciales">Buscar comercial</label>
                                    <select class="form-control select2" 
                                            id="comerciales" 
                                            name="comerciales[]" 
                                            multiple="multiple"
                                            data-placeholder="">
                                        {% for comercial in comerciales %}
                                            <option value="{{ comercial.idUsuario }}"
                                                    {% if app.request.get('comerciales') and comercial.idUsuario in app.request.get('comerciales') %}selected{% endif %}>
                                                {{ comercial.apellidos }}, {{ comercial.nombre }}{% if comercial.username %} ({{ comercial.username }}){% endif %}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                {# Filtro por técnicos #}
                                <div class="col-md-2 mb-3">
                                    <label for="tecnicos">Buscar técnico</label>
                                    <select class="form-control select2" 
                                            id="tecnicos" 
                                            name="tecnicos[]" 
                                            multiple="multiple"
                                            data-placeholder="">
                                        {% for tecnico in tecnicos %}
                                            <option value="{{ tecnico.idUsuario }}"
                                                    {% if app.request.get('tecnicos') and tecnico.idUsuario in app.request.get('tecnicos') %}selected{% endif %}>
                                                {{ tecnico.apellidos }}, {{ tecnico.nombre }}{% if tecnico.username %} ({{ tecnico.username }}){% endif %}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endif %}

                            {# Filtro por inmobiliarias #}
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') %}
                                <div class="col-md-2 mb-3">
                                    <label for="inmobiliarias">Buscar colaborador</label>
                                    <select class="form-control select2" 
                                            id="inmobiliarias" 
                                            name="inmobiliarias[]" 
                                            multiple="multiple"
                                            data-placeholder="">
                                        {% for inmobiliaria in inmobiliarias %}
                                            <option value="{{ inmobiliaria.idInmobiliaria }}"
                                                    {% if app.request.get('inmobiliarias') and inmobiliaria.idInmobiliaria in app.request.get('inmobiliarias') %}selected{% endif %}>
                                                {{ inmobiliaria.nombre }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endif %}

                            {# Filtro por oficinas - Visible para ROLE_JEFE_OFICINA también #}
                            {% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR') or is_granted('ROLE_JEFE_OFICINA') %}
                                <div class="col-md-2 mb-3">
                                    <label for="oficinas">Buscar oficina</label>
                                    <select class="form-control select2" 
                                            id="oficinas" 
                                            name="oficinas[]" 
                                            multiple="multiple"
                                            data-placeholder="">
                                        {% for oficina in oficinas %}
                                            <option value="{{ oficina.idOficina }}"
                                                    {% if (app.request.get('oficinas') and oficina.idOficina in app.request.get('oficinas')) or (not app.request.get('oficinas') and oficinaPreseleccionada is defined and oficinaPreseleccionada == oficina.idOficina) %}selected{% endif %}>
                                                {{ oficina.nombre }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endif %}
							{# Filtro de estado con botones toggle #}
							{% if not is_granted('ROLE_CLIENTE') %}
                                <div class="col-md-4 mb-3">
									<label for="estado">Estado</label>
									<div style="width: 100% !important;">
										<input type="hidden" id="estado-filtro" name="estado" value="{{ app.request.get('estado') }}">
										<button type="button" class="btn btn-sm btn-outline-danger estado-btn" data-estado="0">
											Cancelados
										</button>
										<button type="button" class="btn btn-sm btn-outline-success estado-btn" data-estado="1">
											Activos
										</button>
										<button type="button" class="btn btn-sm btn-outline-primary estado-btn" data-estado="2">
											Firmados
										</button>
									</div>
                                </div>
                            {% endif %}
                        </div>
						
						{% if not is_granted('ROLE_CLIENTE') %}
							{# Botones de acción #}
							<div class="row mt-3">
								<div class="col-12" style="text-align: center;">
									<button type="submit" class="btn btn-primary">
										<i class="fas fa-filter"></i> Filtrar
									</button>
									<a href="{{ path('lista_expedientes_paginacion') }}" class="btn btn-secondary">
										<i class="fas fa-eraser"></i> Limpiar filtros
									</a>
								</div>
							</div>
						{% endif %}
                    </form>
                </div>
			</div>
			
			{% if expedientes is defined and expedientes is iterable and expedientes|length>0 %}
				<!-- Selector de cantidad de registros y búsqueda -->
				<div class="row mb-3 align-items-center">
					<div class="col-auto">
						<label for="limitSelect" class="col-form-label">Mostrar:</label>
					</div>
					<div class="col-auto">
						<select class="form-control" id="limitSelect" onchange="cambiarLimit(this.value)">
							<option value="10" {% if limit == 10 %}selected{% endif %}>10</option>
							<option value="20" {% if limit == 20 %}selected{% endif %}>20</option>
							<option value="50" {% if limit == 50 %}selected{% endif %}>50</option>
							<option value="100" {% if limit == 100 %}selected{% endif %}>100</option>
							<option value="200" {% if limit == 200 %}selected{% endif %}>200</option>
						</select>
					</div>
					<div class="col-auto">
						<span class="col-form-label">registros</span>
					</div>
					
					<div class="col text-right">
						<label for="buscar-tabla" class="col-form-label mr-2">Buscar:</label>
						<input type="search" class="form-control d-inline-block" id="buscar-tabla" placeholder="" style="width: 200px;" value="{{ app.request.get('buscar') }}">
					</div>
					<div class="col-auto">
						<form method="get" id="formOrden" action="{{ path('lista_expedientes_paginacion') }}">
							{# Preservar parámetros GET actuales excepto 'orden' y 'page' #}
							{% for key, val in app.request.query.all %}
								{% if key != 'orden' and key != 'page' %}
									{% if val is iterable %}
										{% for v in val %}
											<input type="hidden" name="{{ key }}[]" value="{{ v }}">
										{% endfor %}
									{% else %}
										<input type="hidden" name="{{ key }}" value="{{ val }}">
									{% endif %}
								{% endif %}
							{% endfor %}
							<label for="ordenSelect" class="sr-only">Ordenar</label>
							<select id="ordenSelect" name="orden" class="form-control" onchange="document.getElementById('formOrden').submit()">
								<option value="fecha_modificacion" {% if app.request.get('orden') == 'fecha_modificacion' or app.request.get('orden') is null %}selected{% endif %}>Fecha modificación (por defecto)</option>
								<option value="fecha_creacion" {% if app.request.get('orden') == 'fecha_creacion' %}selected{% endif %}>Fecha creación</option>
							</select>
						</form>
					</div>
				</div>
				
				<form class="text-truncate" id="formulario-borrar-entidades" method="post">
