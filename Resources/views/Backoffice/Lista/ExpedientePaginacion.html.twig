										<td>{{ camposPersonalizados[expediente.idExpediente]['telefono'] is defined ? camposPersonalizados[expediente.idExpediente]['telefono'] : '' }}</td>
									{% endif %}
									{% if not is_granted('ROLE_CLIENTE') and not is_granted('ROLE_COLABORADOR')  %}
										<td>
											{% set inmuebles_nombres = [] %}
