		tr:hover a {
			color: #FFFFFF;
		}

		tr:hover a.editar {
			color: green;
		}
		tr:hover a.documentos {
			color: blue;
		}
		tr:hover a.notificar, tr:hover a.cancelar {
			color: red;
		}
