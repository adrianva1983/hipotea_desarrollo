{% block body %}
	<div style="display: flex; display: -webkit-box;justify-content: flex-start;margin: 0px 0;border-bottom: 1px dashed #ccc;padding-bottom: 0px;">
		<div class="col-lg mb-4 mb-lg-0">
			<img src="https://areaprivada.hipotea.com/uploads/logo-hipotea-email.png" style="text-align:left;width:80px;">
		</div>
	</div>
	<div style="display: flex; display: -webkit-box;justify-content: flex-start;margin: 10px 0;border-bottom: 1px dashed #ccc;padding-bottom: 10px;" style="max-width:600px;text-align:center;margin: auto 0;">
		<div class="col-lg mb-4 mb-lg-0">
			<div class="col-lg mb-4 mb-lg-0">
				<div class="card h-100">
					<h4 class="card-header bg-success text-light mb-0">
						{% if tipo_calculo is defined and tipo_calculo =='cuota' %}Tu hipoteca
							{% elseif tipo_calculo is defined and tipo_calculo =='importe_maximo'%}El precio máximo
						{% endif %}
					</h4>
					<div class="card-body d-flex flex-column justify-content-center m-auto" style="width:100%;">
						{% if tipo_calculo is defined and tipo_calculo =='cuota' %}
							<div {% if resultado is not defined %} class="d-none" {% else %} class="text-muted centrado-caja texto-resultado" {% endif %} data-contenedor-resultado>
								{% if resultado is defined and importe_fijo > 0 %}
									<style>
										#plazoAmortizacion {
											padding-left: 0 !important;
											padding-right: 0 !important;
										}
										.btn-right {
											float: right;
											margin-top: -40px;
										}
										.result {
											margin-top: 20px;
										}
										.result h2 {
											font-size: 1.1em;
											margin-bottom: 40px;
										}
										.result table {
											width: 100%;
											border-collapse: inherit;
											border: 3px dotted red;
											border-radius: 10px;
											padding: 2px;
										}
										.result th,
										.result td {
											border: 0 solid #ccc;
											padding: 10px;
											text-align: center;
										}
										.result td {
											font-weight: 500;
											font-size: 22px;
										}
										.result th {
											/* background-color: #f4f4f4; */
											font-size: 1.3em;
											color: #e53935;
										}

										.costs {
											margin-top: 10px;
										}
										.costs h2 {
											font-size: 1.3em;
											color: #e53935;
										}
										.costs .row {
											display: flex; display: -webkit-box;
											justify-content: flex-start;
											margin: 10px 0;
											border-bottom: 1px dashed #ccc;
											padding-bottom: 10px;
										}
										.costs .column {
											display: flex; display: -webkit-box;
											align-items: center;
											width: 50%;
										}
										.costs .icon {
											margin-right: 10px;
										}
										.costs .label {
											font-weight: bold;
											font-size: 14px;
										}
										.costs .value {
											margin-left: 5px;
										}
										span.label {
											color: #888;
										}

										img.icono-imagen {
											height: 40px;
											width: 40px;
											object-fit: cover;
										}

										.costs .column70 {
											display: flex; display: -webkit-box;
											align-items: center;
											text-align: right;
											width: 50%;
											flex-direction: row-reverse;
										}

										.costs .column30 {
											display: flex; display: -webkit-box;
											align-items: center;
											width: 50%;
											flex-direction: row-reverse;
										}
										.costs .row2 {
											display: flex; display: -webkit-box;
											justify-content: flex-start;
											margin: 10px 0;
											padding-bottom: 10px;
										}

										.total {
											color: black;
											font-weight: 600;
										}

										.costs2 {
											padding: 15px;
											margin-top: 0;
										}
										@media(max-width: 576px) {
											.result h2,
											.result th,
											.result td {
												font-size: 1em;
											}

											.costs .column {
												width: 100%;
											}

											.costs.cost3 .column {
												width: 50%;
											}

											.costs2 {
												padding: 3px;
											}

											.costs .column70,
											.costs .column30 {
												width: 50%;
											}

											.costs .label {
												font-size: 14px;
												text-align: left;
											}
											.card .card-title {
												font-size: 1.05rem;
											}
										}
										@media print {
											.topbar,
											.left-sidebar,
											footer,
											.caja-externa,
											.row.page-titles,
											#imprimir {
												display: none;
											}

											.page-wrapper {
												margin-left: 0 !important;
												padding-top: 0 !important;
											}
										}
									</style>
									{% if cuota_fija_final and cuota_fija_final > 0 %}
										{# Caja tipos #}
										<div class="result">
											<h2 style="font-size: 17px;">Para un inmueble de
												{% if resultado is defined %}
													{{ valor_inmueble|number_format(0,',','.') }}
												{% endif %}€, con una aportación de
												{{ entrada }}€ y unos gastos totales de
												{{ gastos|number_format(0,',','.') }}€, el importe total de hipoteca será de
												{{ importe_total|number_format(0,',','.') }}€ en un plazo de
												{% if resultado is defined %}
													{{ amortizacion }}
												{% endif %}
												años, actualmente en venta una propiedad por importe de
												{% if resultado is defined %}
													{{ valor_vivienda_actual }}€
												{% endif %}
												con hipoteca de
												{% if resultado is defined %}
													{{ hipoteca_actual }}€
												{% endif %}
												y cuando venda reembolsará
												{% if resultado is defined %}
													{{ aportacion_tras_venta }}€
												{% endif %}
												las cuotas serán de:</h2>
											<table>
												<tr>
													<th></th>
													<th>Tipo Fijo</th>
													<th>Tipo Variable</th>
													<th>Tipo Mixto</th>
												</tr>
												<tr>
													<td style="width:25%;font-size:18px;">
														Mientras Vende
													</td>
													<td style="width:25%">
														{% if resultado is defined %}
															{{ cuota_fija|number_format(0,',','.') }}
														{% endif %}
														<br><span style="color:#888;font-size:10px;line-height:10px;margin-top: 10px;display: block;">(Tipo de interés
															{{ tipo_fijo }}%) *</span>
													</td>
													<td style="width:25%">
														{% if resultado is defined %}
															{{ cuota_variable|number_format(0,',','.') }}
														{% endif %}
														<br><span style="color:#888;font-size:10px;line-height:10px;margin-top: 10px;display: block;">(Primer año
															{{ tipo_variable }}%, posteriormente Euribor + 0.5) *</span>
													</td>
													<td style="width:25%">
														{% if resultado is defined %}
															{{ cuota_mixta|number_format(0,',','.') }}
														{% endif %}
														<br><span style="color:#888;font-size:10px;line-height:10px;margin-top: 10px;display: block;">(Primeros 5 años
															{{ tipo_mixto }}%, posteriormente Euribor +
															{{ tipo_luego_mixto }}) *</span>
													</td>
												</tr>
												<tr>
													<td style="width:25%;font-size:18px;">
														Cuando Venda
													</td>
													<td style="width:25%">
														{% if resultado is defined %}
															{{ cuota_fija_final|number_format(0,',','.') }}
														{% endif %}
														<br><span style="color:#888;font-size:10px;line-height:10px;margin-top: 10px;display: block;">(Tipo de interés
															{{ tipo_fijo }}%) *</span>
													</td>
													<td style="width:25%">
														{% if resultado is defined %}
															{{ cuota_variable_final|number_format(0,',','.') }}
														{% endif %}
														<br><span style="color:#888;font-size:10px;line-height:10px;margin-top: 10px;display: block;">(Primer año
															{{ tipo_variable }}%, posteriormente Euribor + 0.5) *</span>
													</td>
