{% extends '@App/Backoffice/base.html.twig' %}
{% form_theme crear_cliente '@App/Backoffice/bootstrap_4_layout.html.twig' %}
{% block body %}
	<div class="card  1222">
		<div class="card-body">
			<h4 class="card-title">{{ titulo }}</h4>
			{% include '@App/Backoffice/MensajeAlerta.html.twig' %}
			{% if "Este valor ya se ha utilizado." in form_errors(crear_cliente.nif) %}
				<div class="alert alert-danger alert-dismissible fade show" role="alert">
					<span>
						No es posible dar de alta el cliente con este DNI. Por favor contacte con Hipotea para poder gestionarlo.
					</span>
					<button aria-label="Close" class="close" data-dismiss="alert" type="button">
						<span aria-hidden="true">×</span>
					</button>
				</div>
			{% elseif "Este valor ya se ha utilizado." in form_errors(crear_cliente.email.first) %}
				<div class="alert alert-danger alert-dismissible fade show" role="alert">
					<span>
						No es posible dar de alta el cliente con este EMAIL. Por favor contacte con Hipotea para poder gestionarlo.
					</span>
					<button aria-label="Close" class="close" data-dismiss="alert" type="button">
						<span aria-hidden="true">×</span>
					</button>
				</div>
			{% endif %}
			{{ form_start(crear_cliente) }}
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.username) }}
					{{ form_widget(crear_cliente.username) }}
					{{ form_errors(crear_cliente.username) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.apellidos) }}
					{{ form_widget(crear_cliente.apellidos) }}
					{{ form_errors(crear_cliente.apellidos) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.nif) }}
					{{ form_widget(crear_cliente.nif) }}
					{{ form_errors(crear_cliente.nif) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.telefonoMovil) }}
					{{ form_widget(crear_cliente.telefonoMovil) }}
					{{ form_errors(crear_cliente.telefonoMovil) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.email.first) }}
					{{ form_widget(crear_cliente.email.first) }}
					{{ form_errors(crear_cliente.email.first) }}
				</div>
			</div>
			<div class="form-row">
				<div class="form-group col">
					{{ form_label(crear_cliente.email.second) }}
					{{ form_widget(crear_cliente.email.second) }}
					{{ form_errors(crear_cliente.email.second) }}
				</div>
			</div>
			<div class="d-flex">
				<a class="btn btn-success mr-auto waves-effect" href="{{ path('lista_clientes') }}">Volver</a>
				{{ form_label(crear_cliente.submit) }}
				{{ form_widget(crear_cliente.submit,{'attr':{'class':'btn-success'}}) }}
			</div>
			{{ form_end(crear_cliente) }}
		</div>
	</div>
{% endblock %}
