<div class="row page-titles align-items-center">
	<div class="col-md-5">
		{% if titulo is defined %}
			<h4 class="text-themecolor">{{ titulo }}</h4>
		{% endif %}
	</div>
	<div class="col-md-7">
		<div class="d-flex justify-content-md-end align-items-center">
			<ol class="breadcrumb justify-content-md-end">
				{% if app.request.get('_route') is same as('inicio') %}
					<li class="breadcrumb-item active">Inicio</li>
				{% else %}
					<li class="breadcrumb-item">
						<a href="{{ path('inicio') }}">Inicio</a>
					</li>
					{% if migasPan is defined %}
						{% for migaPan in migasPan %}
							<li class="breadcrumb-item">
								<a href="{{ migaPan.url }}">{{ migaPan.vista }}</a>
							</li>
						{% endfor %}
					{% endif %}
					{% if titulo is defined %}
						<li class="breadcrumb-item active">{{ titulo }}</li>
					{% endif %}
				{% endif %}
			</ol>
			{% if crearnuevo is defined %}
				<a class="btn btn-dark m-l-15 text-white" href="{{ crearnuevo }}">
					<i class="fa fa-plus-circle"></i>
					<span> {{ crearnuevo_texto }}</span>
				</a>
			{% endif %}
		</div>
	</div>
</div>