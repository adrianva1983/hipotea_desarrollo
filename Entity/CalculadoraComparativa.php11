						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total'];

					$cuota_ahorro = $cuota_original - $cuota_oferta;


					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro'] = $cuota_original - $cuota_oferta;

					$respuesta['cuota_mensual_original_variable'] = $cuota_original_variable;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro_variable'] = $cuota_original_variable - $cuota_oferta;

					$respuesta['intereses_original'] = $intereses_original_fija + $intereses_original_variable;
					$respuesta['intereses_oferta'] = $intereses_oferta;
					$respuesta['intereses_ahorro'] = $intereses_original_fija + $intereses_original_variable - $intereses_oferta;

					$respuesta['vinculaciones'] = $this->obtenerVinculacionesOferta($oferta);
					$respuesta['primerosAnios'] = 1;
				}
			}elseif($tipoOferta == 'Mixto'){ // Oferta Mixta
				if($tipoHipoteca == 1) { // Tiene una oferta de Fijo
					$primerosAnios = $this->obtenerAniosOferta($oferta);

					// Primero calculamos los datos para el tipo fijo que trae
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo,
