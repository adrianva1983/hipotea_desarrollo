	public function calcularComparativa(EntityManagerInterface $entityManager)
	{
		$destino = $this->getDestino();
		$tipoHipoteca = $this->getTipoHipoteca();
		$importeHipoteca = $this->getImporteHipoteca();
		$oferta = $this->getOferta();
		$tipoOferta = $this->obtenerTipoOferta($oferta);
		$nombreOferta = $this->obtenerNombreOferta($oferta);
		
		// $margen = 0.3;
		$margenOferta = $this->obtenerRevisionOferta($oferta);
		$euribor = 2;
		// $tipo_euribor = $euribor + $margen;
		$tipo_euriborOferta = $euribor + $margenOferta;

		$respuesta = array(
			'cuota_mensual_original' => 0,
			'cuota_mensual_oferta' => 0,
			'cuota_mensual_ahorro' => 0,
			'mensaje' => '',
			'vinculaciones' => '',
			'destino' => $destino,
			'tipo' => $tipoHipoteca,
			'tipoOferta' => $tipoOferta,
			'nombreOferta' => $nombreOferta,
			'plazoAmortizacion' => false,
			'margen' => $margenOferta
		);
		// $datos = json_decode($request->getContent())->datos;


		// Recogemos las varables en función del cálculo
		if($destino == 1){ // Comprar
			if($tipoOferta == 'Fijo'){ // Oferta fijo
				if($tipoHipoteca == 1) { // Viene de Fijo
					$plazoAmortizacion = $this->getPlazoAmortizacion();
					$plazoOferta = $this->getPlazoAmortizacion();
					if($plazoAmortizacion > 30){
						$respuesta['plazoAmortizacion'] = true;
						$plazoOferta = 30;
					}
					$tipoFijo = $this->getTipoFijo();
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipoFijo,
						'plazo' => $plazoAmortizacion
					);
					$resultado_original = $this->calculoSencillo($datos_calculo);
					$cuota_original = $resultado_original['fee'];
					$intereses_original = $resultado_original['interest_discharged_total'];

					$tipo_oferta = $this->obtenerInteresOferta($oferta);
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_oferta,
						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total'];

					$cuota_ahorro = $cuota_original - $cuota_oferta;
					$intereses_ahorro = $intereses_original - $intereses_oferta;

					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro'] = $cuota_ahorro;

					$respuesta['intereses_original'] = $intereses_original;
					$respuesta['intereses_oferta'] = $intereses_oferta;
					$respuesta['intereses_ahorro'] = $intereses_ahorro;

					$respuesta['vinculaciones'] = $this->obtenerVinculacionesOferta($oferta);
				}elseif($tipoHipoteca == 2) { // Viene de Mixta
					$aniosPlazoFijo = $this->getAniosPlazoFijo();
					$plazoTotal = $this->getPlazoTotal();
					$plazoOferta = $this->getPlazoTotal();
					if($plazoTotal > 30){
						$respuesta['plazoAmortizacion'] = true;
						$plazoOferta = 30;
					}
					$tipoMixta = $this->getTipoMixta();
					$revisionMixta = $this->getRevisionMixta();

					// Primero calculamos los datos para los primeros años del tipo mixto que trae
					$this->hipoteca = [];
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipoMixta,
						'plazo' => $plazoTotal
					);
					$resultado_original = $this->calculoSencillo($datos_calculo);
					$cuota_original = $resultado_original['fee'];
					$intereses_original_fija = $resultado_original['interest_discharged_total_deadline'][$aniosPlazoFijo-1];

					// Segundo calculamos los datos para los restantes años del tipo mixto que trae
					$this->hipoteca = [];
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $euribor + $revisionMixta,
						'plazo' => $plazoTotal
					);
					$resultado_original_variable = $this->calculoSencillo($datos_calculo);
					$cuota_original_variable = $resultado_original_variable['fee'];
					$intereses_original_variable = $resultado_original_variable['interest_discharged_total'] - $resultado_original_variable['interest_discharged_total_deadline'][$aniosPlazoFijo-1];

					// Ahora obtenemos los datos para nuestra oferta fija
					$tipo_oferta = $this->obtenerInteresOferta($oferta);
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_oferta,
						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total'];

					$cuota_ahorro = $cuota_original - $cuota_oferta;


					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro'] = $cuota_original - $cuota_oferta;

					$respuesta['cuota_mensual_original_variable'] = $cuota_original_variable;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro_variable'] = $cuota_original_variable - $cuota_oferta;

					$respuesta['intereses_original'] = $intereses_original_fija + $intereses_original_variable;
					$respuesta['intereses_oferta'] = $intereses_oferta;
					$respuesta['intereses_ahorro'] = $intereses_original_fija + $intereses_original_variable - $intereses_oferta;

					$respuesta['vinculaciones'] = $this->obtenerVinculacionesOferta($oferta);
					$respuesta['primerosAnios'] = $aniosPlazoFijo;
				}elseif($tipoHipoteca == 3) { // Viene de Variable
					$plazoAmortizacion = $this->getPlazoAmortizacion();
					$plazoOferta = $this->getPlazoAmortizacion();
					if($plazoAmortizacion > 30){
						$respuesta['plazoAmortizacion'] = true;
						$plazoOferta = 30;
					}
					$tipoVariable = $this->getTipoVariable();
					$revisionVariable = $this->getRevisionVariable();


					// Primero calculamos los datos para el primero años del tipo variable que trae
					$this->hipoteca = [];
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipoVariable,
						'plazo' => $plazoAmortizacion
					);
					$resultado_original = $this->calculoSencillo($datos_calculo);
					$cuota_original = $resultado_original['fee'];
					$intereses_original_fija = $resultado_original['interest_discharged_total_deadline'][0];

					// Segundo calculamos los datos para los restantes años del tipo variable que trae
					$this->hipoteca = [];
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $euribor + $revisionVariable,
						'plazo' => $plazoAmortizacion
					);
					$resultado_original_variable = $this->calculoSencillo($datos_calculo);
					$cuota_original_variable = $resultado_original_variable['fee'];
					$intereses_original_variable = $resultado_original_variable['interest_discharged_total'] - $resultado_original_variable['interest_discharged_total_deadline'][0];

					// Ahora obtenemos los datos para nuestra oferta fija
					$tipo_oferta = $this->obtenerInteresOferta($oferta);
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_oferta,
						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total'];

					$cuota_ahorro = $cuota_original - $cuota_oferta;


					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro'] = $cuota_original - $cuota_oferta;

					$respuesta['cuota_mensual_original_variable'] = $cuota_original_variable;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro_variable'] = $cuota_original_variable - $cuota_oferta;

					$respuesta['intereses_original'] = $intereses_original_fija + $intereses_original_variable;
					$respuesta['intereses_oferta'] = $intereses_oferta;
					$respuesta['intereses_ahorro'] = $intereses_original_fija + $intereses_original_variable - $intereses_oferta;

					$respuesta['vinculaciones'] = $this->obtenerVinculacionesOferta($oferta);
					$respuesta['primerosAnios'] = 1;

				}
			}elseif($tipoOferta == 'Mixto'){ // Quiere una oferta mixta
				if($tipoHipoteca == 1) { // Tiene una oferta de Fijo
					$plazoAmortizacion = $this->getPlazoAmortizacion();
					$plazoOferta = $this->getPlazoAmortizacion();
					if($plazoAmortizacion > 30){
						$respuesta['plazoAmortizacion'] = true;
						$plazoOferta = 30;
					}
					$tipoFijo = $this->getTipoFijo();
					$primerosAnios = $this->obtenerAniosOferta($oferta);

					// Primero calculamos los datos para el tipo fijo que trae
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipoFijo,
						'plazo' => $plazoAmortizacion
					);
					$resultado_original = $this->calculoSencillo($datos_calculo);
					$cuota_original = $resultado_original['fee'];
					$intereses_original = $resultado_original['interest_discharged_total'];

					// Ahora obtenemos los datos para los años de mixta como fija
					$tipo_oferta = $this->obtenerInteresOferta($oferta);
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_oferta,
						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total_deadline'][$primerosAnios-1];

					$cuota_ahorro = $cuota_original - $cuota_oferta;
					// $intereses_ahorro = $intereses_original - $intereses_oferta;

					//  Ahora obtenemos los datos para cuando pasa de fija a variable la mixta
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_euriborOferta,
						'plazo' => $plazoOferta
					);

					$this->hipoteca = [];
					$resultado_oferta_variable = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta_variable = $resultado_oferta_variable['fee'];
					$intereses_oferta_variable = $resultado_oferta_variable['interest_discharged_total'] - $resultado_oferta_variable['interest_discharged_total_deadline'][$primerosAnios-1];
					$intereses_oferta += $intereses_oferta_variable;

					$cuota_ahorro_variable = $cuota_original - $cuota_oferta_variable;
					// $intereses_ahorro = $intereses_original - $intereses_oferta - $intereses_oferta_variable;

					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta'] = $cuota_oferta;
					$respuesta['cuota_mensual_ahorro'] = $cuota_ahorro;

					$respuesta['cuota_mensual_original'] = $cuota_original;
					$respuesta['cuota_mensual_oferta_variable'] = $cuota_oferta_variable;
					$respuesta['cuota_mensual_ahorro_variable'] = $cuota_ahorro_variable;

					$respuesta['intereses_original'] = $intereses_original;
					$respuesta['intereses_oferta'] = $intereses_oferta;
					$respuesta['intereses_ahorro'] = $intereses_original - $intereses_oferta;

					$respuesta['vinculaciones'] = $this->obtenerVinculacionesOferta($oferta);
					$respuesta['primerosAnios'] = $primerosAnios;
				}elseif($tipoHipoteca == 2) { // Mixta
					$primerosAnios = $this->obtenerAniosOferta($oferta);

					$aniosPlazoFijo = $this->getAniosPlazoFijo();
					$plazoTotal = $this->getPlazoTotal();
					$plazoOferta = $this->getPlazoTotal();
					if($plazoTotal > 30){
						$respuesta['plazoAmortizacion'] = true;
						$plazoOferta = 30;
					}
					$tipoMixta = $this->getTipoMixta();
					$revisionMixta = $this->getRevisionMixta();

					// Primero calculamos los datos para los primeros años del tipo mixto que trae
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipoMixta,
						'plazo' => $plazoTotal
					);
					$this->hipoteca = [];
					$resultado_original = $this->calculoSencillo($datos_calculo);
					$cuota_original = $resultado_original['fee'];
					$intereses_original_fija = $resultado_original['interest_discharged_total_deadline'][$aniosPlazoFijo-1];

					// Segundo calculamos los datos para los restantes años del tipo mixto que trae
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $euribor + $revisionMixta,
						'plazo' => $plazoTotal
					);
					$this->hipoteca = [];
					$resultado_original_variable = $this->calculoSencillo($datos_calculo);
					$cuota_original_variable = $resultado_original_variable['fee'];
					$intereses_original_variable = $resultado_original_variable['interest_discharged_total'] - $resultado_original_variable['interest_discharged_total_deadline'][$aniosPlazoFijo-1];


					
					// Ahora obtenemos los datos para los años de mixta como fija
					$tipo_oferta = $this->obtenerInteresOferta($oferta);
					$datos_calculo = array(
						'precio' => $importeHipoteca,
						'intereses' => $tipo_oferta,
						'plazo' => $plazoOferta
					);
					$this->hipoteca = [];
					$resultado_oferta = $this->calculoSencillo($datos_calculo);
					
					$cuota_oferta = $resultado_oferta['fee'];
					$intereses_oferta = $resultado_oferta['interest_discharged_total_deadline'][$primerosAnios-1];

					$cuota_ahorro = $cuota_original - $cuota_oferta;
					// $intereses_ahorro = $intereses_original - $intereses_oferta;

