	private function obtenerTipoOferta($oferta){
		switch ($oferta) {
			case '1':
				return 'Mixto';
				break;
			case '2':
				return 'Mixto';
				break;
			case '3':
				return 'Mixto';
				break;
			case '4':
				return 'Mixto';
				break;
			case '5':
				return 'Mixto';
				break;
			case '6':
				return 'Fijo';
				break;
			case '7':
				return 'Fijo';
				break;
			case '8':
				if($this->getPersoTipoHipoteca() == 1){
					return 'Fijo';
				}elseif($this->getPersoTipoHipoteca() == 2){
					return 'Mixto';
				}else{
					return 'Variable';
				}
				break;
			default:
				return 'Mixto';
				break;
		}
	}

