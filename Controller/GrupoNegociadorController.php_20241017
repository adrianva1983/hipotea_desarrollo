									$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), $logAccion, $expediente));
								}
								// $managerEntidad->flush();
							}
						}
						if(isset($jsonRecibido['colaborador']) && $jsonRecibido['colaborador']){
							$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
								'idUsuario' => $expediente->getIdColaborador()
							));
							if (is_null($usuario)) {
								$respuesta['error'] = true;
							} else {
								// $notificacion = (new NotificacionEntidad())
								// 	->setIdUsuario($usuario)
								// 	->setIdExpediente($expediente)
								// 	->setTitulo($jsonRecibido['titulo'])
								// 	->setTexto($jsonRecibido['texto'])
								// 	->setFecha(new DateTime());
								// $managerEntidad = $doctrine->getManager();
								// $managerEntidad->persist($notificacion);
								
								if($expediente->getIdColaborador()){
									$this->enviarNotificacionPush($expediente, null, $expediente->getIdColaborador(), $jsonRecibido['titulo'], $jsonRecibido['texto']);
								}
								$logAccion = "NOTIFICACIÓN: ".$jsonRecibido['titulo'].' '.$jsonRecibido['texto'];
								if (isset($logAccion) && isset($expediente) && !is_null($expediente)) {
									$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), $logAccion, $expediente));
								}
								// $managerEntidad->flush();
							}
						}
					}
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function calendarioAction()
	{
		$doctrine = $this->getDoctrine();
		$repositorioUsuarios = $doctrine->getRepository(UsuarioEntidad::class);
		if ($this->getUser()->getRoles()[0] === 'ROLE_ADMIN') {
			$usuarios = $repositorioUsuarios->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_ADMIN'))
				->orWhere(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
				->orWhere(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			);
		}
		$clientes = $repositorioUsuarios->matching(Criteria::create()
			->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
			->andWhere(Criteria::expr()->orX(
				Criteria::expr()->gte('fechaCaducidad', new DateTime()),
				Criteria::expr()->isNull('fechaCaducidad')
			))
			->andWhere(Criteria::expr()->eq('estado', true))
		);
		$formulario = array(
			'agregar' => $this->get('form.factory')->createNamed('seguimiento_horario_agregar', SeguimientoHorarioFormulario::class, null, array(
				'clientes' => $clientes
			)),
			'modificar' => $this->get('form.factory')->createNamed('seguimiento_horario_modificar', SeguimientoHorarioFormulario::class, null, array(
				'clientes' => $clientes
			))
		);
		$seguimientoHorario = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findBy(array(
			'idUsuario' => $this->getUser()->getIdUsuario()
		));
		$seguimientoHorarioArray = array();
		foreach ($seguimientoHorario as $clave => $valor) {
			$seguimientoHorarioArray[$clave] = array(
				'_id' => $valor->getIdSeguimientoHorario(),
				'datosCliente' => $valor->getDatosCliente(),
				'start' => $valor->getFechaInicio()->format('Y-m-d H:i:s'),
				'end' => $valor->getFechaFin()->format('Y-m-d H:i:s'),
				'title' => $valor->getTipo(),
				'observaciones' => $valor->getObservaciones(),
				'estado' => $valor->getEstado()
			);
			if (!is_null($valor->getIdCliente())) {
				$seguimientoHorarioArray[$clave]['idCliente'] = $valor->getIdCliente()->getIdUsuario();
			}
			if (!is_null($valor->getIdInmobiliaria())) {
				$seguimientoHorarioArray[$clave]['idInmobiliaria'] = $valor->getIdInmobiliaria()->getIdInmobiliaria();
			}
			switch ($valor->getTipo()) {
				case 'Apertura de cuenta':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-red';
					break;
				case 'Entrega publicidad':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-maroon';
					break;
				case 'Entrevista banco':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-lime';
					break;
				case 'Pago comisión':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-green';
					break;
				case 'Recogida documentación':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-blue';
					break;
				case 'Reunión cliente en oficina':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-navy';
					break;
				case 'Reunión cliente fuera oficina':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-fuchsia';
					break;
				case 'Tasación':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-purple';
					break;
				case 'Visita comercial':
					$seguimientoHorarioArray[$clave]['className'] = 'bg-teal';
					break;
			}
			$intervalo = $valor->getFechaFin()->diff($valor->getFechaInicio());
			if ($intervalo->y === 0 && $intervalo->m === 0 && $intervalo->d === 1 && $intervalo->h === 0 && $intervalo->m === 0 && $intervalo->s === 0) {
				$todoElDia = true;
			} else {
				$todoElDia = false;
			}
			$seguimientoHorarioArray[$clave]['allDay'] = $todoElDia;
		}
		$seguimientoHorarioJSON = json_encode($seguimientoHorarioArray, JSON_UNESCAPED_UNICODE);
		$variablesTwig = array(
			'titulo' => 'Calendario',
			'agregarEventoCalendario' => $formulario['agregar']->createView(),
			'modificarEventoCalendario' => $formulario['modificar']->createView(),
			'seguimientoHorarioJSON' => $seguimientoHorarioJSON
		);
		if (isset($usuarios)) {
			$variablesTwig['usuarios'] = $usuarios;
		}
		return $this->render('@App/Backoffice/Extras/Calendario.html.twig', $variablesTwig);
	}

	public function actualizarCalendarioAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0) {
				$doctrine = $this->getDoctrine();
				$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
				$repositorioInmo = $doctrine->getRepository(InmobiliariaEntidad::class);
				if (isset($jsonRecibido['idUsuario'])) {
					$idUsuario = $jsonRecibido['idUsuario'];
				} else {
					$idUsuario = $this->getUser()->getIdUsuario();
				}
				$usuario = $repositorio->findOneBy(array(
					'idUsuario' => $idUsuario
				));
				if ($usuario) {
					if (isset($jsonRecibido['eliminar']) && $jsonRecibido['eliminar']) {
						$seguimientoHorario = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findOneBy(array(
							'idSeguimientoHorario' => $jsonRecibido['idSeguimientoHorario']
						));
						if (!$seguimientoHorario) {
							$respuesta['error'] = true;
							return $this->json($respuesta);
						}
						$managerEntidad = $doctrine->getManager();
						$managerEntidad->remove($seguimientoHorario);
						$managerEntidad->flush();
						$respuesta['error'] = false;
					} else {
						if (isset($jsonRecibido['idSeguimientoHorario'])) {
							$seguimientoHorario = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findOneBy(array(
								'idSeguimientoHorario' => $jsonRecibido['idSeguimientoHorario']
							));
							if (!$seguimientoHorario) {
								$respuesta['error'] = true;
								return $this->json($respuesta);
							}
						} else {
							$seguimientoHorario = new SeguimientoHorarioEntidad();
						}
						if (is_null($seguimientoHorario->getIdUsuario())) {
							$seguimientoHorario->setIdUsuario($usuario);
						}
						if (isset($jsonRecibido['idCliente'])) {
							if (empty($jsonRecibido['idCliente'])) {
								$seguimientoHorario->setIdCliente(null);
							} else {
								$cliente = $repositorio->findOneBy(array(
									'idUsuario' => trim($jsonRecibido['idCliente'])
								));
								if ($cliente) {
									$seguimientoHorario->setIdCliente($cliente);
								}
							}
						}
						if (isset($jsonRecibido['datosCliente'])) {
							$seguimientoHorario->setDatosCliente(trim($jsonRecibido['datosCliente']));
						}
						if (isset($jsonRecibido['idInmobiliaria'])) {
							if (empty($jsonRecibido['idInmobiliaria'])) {
								$seguimientoHorario->setIdInmobiliaria(null);
							} else {
								$inmobiliaria = $repositorioInmo->findOneBy(array(
									'idInmobiliaria' => trim($jsonRecibido['idInmobiliaria'])
								));
								if ($inmobiliaria) {
									$seguimientoHorario->setIdInmobiliaria($inmobiliaria);
								}
							}
						}
						try {
							if (isset($jsonRecibido['fechaInicio'])) {
								$seguimientoHorario->setFechaInicio(new DateTime($jsonRecibido['fechaInicio']));
							}
							if (isset($jsonRecibido['fechaFin'])) {
								$seguimientoHorario->setFechaFin(new DateTime($jsonRecibido['fechaFin']));
							} else {
								$fecha = new DateTime($jsonRecibido['fechaInicio']);
								$fecha->add(new DateInterval('P1D'));
								$seguimientoHorario->setFechaFin($fecha);
							}
						} catch (Exception $e) {
						}
						if (isset($jsonRecibido['tipo'])) {
							$seguimientoHorario->setTipo(trim($jsonRecibido['tipo']));
						}
						if (isset($jsonRecibido['observaciones'])) {
							$seguimientoHorario->setObservaciones(trim($jsonRecibido['observaciones']));
						}
						if (isset($jsonRecibido['estado'])) {
							$seguimientoHorario->setEstado(trim($jsonRecibido['estado']));
						}
						$managerEntidad = $doctrine->getManager();
						$managerEntidad->persist($seguimientoHorario);
						$managerEntidad->flush();
						$respuesta['error'] = false;
						$respuesta['id'] = $seguimientoHorario->getIdSeguimientoHorario();
					}
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function seleccionarUsuarioCalendarioAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0) {
				$doctrine = $this->getDoctrine();
				$repositorioUsuarios = $doctrine->getRepository(UsuarioEntidad::class);
				$usuario = $repositorioUsuarios->findOneBy(array(
					'idUsuario' => $jsonRecibido['idUsuario']
				));
				if ($usuario) {
					$seguimientoHorario = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findBy(array(
						'idUsuario' => $usuario->getIdUsuario()
					));
					$seguimientoHorarioArray = array();
					foreach ($seguimientoHorario as $clave => $valor) {
						$seguimientoHorarioArray[$clave] = array(
							'_id' => $valor->getIdSeguimientoHorario(),
							'datosCliente' => $valor->getDatosCliente(),
							'start' => $valor->getFechaInicio()->format('Y-m-d H:i:s'),
							'end' => $valor->getFechaFin()->format('Y-m-d H:i:s'),
							'title' => $valor->getTipo(),
							'observaciones' => $valor->getObservaciones(),
							'estado' => $valor->getEstado()
						);
						if (!is_null($valor->getIdCliente())) {
							$seguimientoHorarioArray[$clave]['idCliente'] = $valor->getIdCliente()->getIdUsuario();
						}
						switch ($valor->getTipo()) {
							case 'Apertura de cuenta':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-red';
								break;
							case 'Entrega publicidad':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-maroon';
								break;
							case 'Entrevista banco':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-lime';
								break;
							case 'Pago comisión':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-green';
								break;
							case 'Recogida documentación':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-blue';
								break;
							case 'Reunión cliente en oficina':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-navy';
								break;
							case 'Reunión cliente fuera oficina':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-fuchsia';
								break;
							case 'Tasación':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-purple';
								break;
							case 'Visita comercial':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-teal';
								break;
							case 'Notaría':
								$seguimientoHorarioArray[$clave]['className'] = 'bg-bisque';
								break;
						}
						$intervalo = $valor->getFechaFin()->diff($valor->getFechaInicio());
						if ($intervalo->y === 0 && $intervalo->m === 0 && $intervalo->d === 1 && $intervalo->h === 0 && $intervalo->m === 0 && $intervalo->s === 0) {
							$todoElDia = true;
						} else {
							$todoElDia = false;
						}
						$seguimientoHorarioArray[$clave]['allDay'] = $todoElDia;
					}
					$respuesta['seguimientoHorarioJSON'] = json_encode($seguimientoHorarioArray, JSON_UNESCAPED_UNICODE);
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function crearNotificacionesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$helpers = $this->get("app.helpers");
		$formulario = $this->createForm(NotificacionFormulario::class, null, array(
			'clientes' => $repositorio->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			)
		));
		if ($request->isMethod('POST')) {
			$notificacion = array();
			$managerEntidad = $doctrine->getManager();
			$id_devices = array();
			$contenidoFormulario = $request->request->get($formulario->getName());
			if (isset($contenidoFormulario['idUsuario'])) {
				$usuariosNoEncontrados = array();
				foreach ($contenidoFormulario['idUsuario'] as $idUsuario) {
					$usuario = $repositorio->findOneBy(array(
						'idUsuario' => $idUsuario
					));
					if ($usuario) {
						$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findBy(array(
							'idUsuario' => $usuario
						));
						foreach ($dispositivos as $dispositivo) {
							$id_devices[] = $dispositivo->getIdentificador();
						}
						$notificacion[] = new NotificacionEntidad();
						end($notificacion)->setIdUsuario($usuario);
						/*if (!empty($contenidoFormulario['idExpediente'])) {
							$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
								'idExpediente' => $contenidoFormulario['idExpediente']
							));
							if ($expediente) {
								end($notificacion)->setIdExpediente($expediente);
							} else {
								$this->addFlash('warning', 'No se ha encontrado el expediente con id="' . $contenidoFormulario['idExpediente'] . '".');
								return $this->redirectToRoute('crear_notificaciones');
							}
						}*/
						if (!empty($contenidoFormulario['titulo'])) {
							end($notificacion)->setTitulo($contenidoFormulario['titulo']);
						}
						end($notificacion)->setTexto($contenidoFormulario['texto'])
							->setFecha(new DateTime());
						$managerEntidad->persist(end($notificacion));
					} else {
						$usuariosNoEncontrados[] = $idUsuario;
					}
				}
				if (count($usuariosNoEncontrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($usuariosNoEncontrados, array(
						'No se ha encontrado el usuario con id=',
						'No se han encontrado los usuarios con ids',
						' y '
					)));
				}
			} else {
				$usuarios = $repositorio->matching(Criteria::create()
					->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
					->andWhere(Criteria::expr()->orX(
						Criteria::expr()->gte('fechaCaducidad', new DateTime()),
						Criteria::expr()->isNull('fechaCaducidad')
					))
					->andWhere(Criteria::expr()->eq('estado', true))
				);
				if (count($usuarios) > 0) {
					foreach ($usuarios as $usuario) {
						$notificacion[] = new NotificacionEntidad();
						end($notificacion)->setIdUsuario($usuario);
						/*if (!empty($contenidoFormulario['idExpediente'])) {
							$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
								'idExpediente' => $contenidoFormulario['idExpediente']
							));
							if ($expediente) {
								end($notificacion)->setIdExpediente($expediente);
							} else {
								$this->addFlash('warning', 'No se ha encontrado el expediente con id="' . $contenidoFormulario['idExpediente'] . '".');
								return $this->redirectToRoute('crear_notificaciones');
							}
						}*/
						if (!empty($contenidoFormulario['titulo'])) {
							end($notificacion)->setTitulo($contenidoFormulario['titulo']);
						}
						end($notificacion)->setTexto($contenidoFormulario['texto'])
							->setFecha(new DateTime());
						$managerEntidad->persist(end($notificacion));
					}
				}
			}
			if (count($notificacion) > 0) {
				$managerEntidad->flush();
				// Ahora enviamos la notificacion PUSH
				$mensaje = end($notificacion)->getTexto();
				$titulo = 'Información';
				$destinatario = '';
				$expediente = '';
				$grupo_destinatarios = $id_devices;
				if (count($id_devices) === 1) {
					$destinatario = $id_devices[0];
				}
				if (count($notificacion) == 1) {
					$helpers->sendFCM($mensaje, $titulo, $destinatario, $grupo_destinatarios, $notificacion[0]);
				}else{
					$helpers->sendFCM($mensaje, $titulo, $destinatario, $grupo_destinatarios, null);
				}
				if (count($notificacion) > 1) {
					$this->addFlash('success', 'Las notificaciones se han creado correctamente.');
				} else {
					$this->addFlash('success', 'La notificación se ha creado correctamente.');
				}
				return $this->redirectToRoute('crear_notificaciones');
			}
		}
		return $this->render('@App/Backoffice/Agregar/Notificaciones.html.twig', array(
			'titulo' => 'Crear notificaciones',
			'crear_notificaciones' => $formulario->createView()
		));
	}

	public function notificacionConfigurarEstadoLeidaAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0) {
				$doctrine = $this->getDoctrine();
				$notificacion = $this->getDoctrine()->getRepository(NotificacionEntidad::class)->findOneBy(array(
					'idNotificacion' => $jsonRecibido['id']
				));
				if ($notificacion) {
					$managerEntidad = $doctrine->getManager();
					$notificacion->setEstado($jsonRecibido['estado']);
					if (!is_null($notificacion->getIdExpediente())) {
						$logAccion = 'El usuario ha leído una notificación del expediente.';
						$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
							'idExpediente' => $notificacion->getIdExpediente()
						));
					}
					switch ($jsonRecibido['estado']) {
						case 0:
							$notificacion->setFechaLeida(new DateTime());
							if (isset($logAccion) && isset($expediente) && !is_null($expediente)) {
								$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), $logAccion, $expediente));
							}
							break;
						case 1:
							$notificacion->setFechaLeida(null);
							if (isset($logAccion) && isset($expediente) && !is_null($expediente)) {
								$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
									'idUsuario' => $this->getUser(),
									'fecha' => $notificacion->getFecha(),
									'accion' => $logAccion,
									'idElemento' => $expediente->getIdExpediente()
								));
								if (count($logs) > 0) {
									foreach ($logs as $log) {
										$managerEntidad->remove($log);
									}
								}
							}
							break;
					}
					$managerEntidad->persist($notificacion);
					$managerEntidad->flush();
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function listaNotificacionesAction()
	{
