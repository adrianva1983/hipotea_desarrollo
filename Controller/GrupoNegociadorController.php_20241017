	public function agregarModificarFacturaAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		if (isset($id)) {
			$factura = $doctrine->getRepository(FacturaEntidad::class)->findOneBy(array(
				'idFactura' => $id
			));
			if (!$factura) {
				$this->addFlash('warning', 'La factura con id="' . $id . '" no existe.');
				return $this->redirectToRoute('lista_facturas');
			}
			$serieInicialFactura = $factura->getSerie();
			$fechaInicialFactura = $factura->getFecha();
		} else {
			$factura = new FacturaEntidad();
			$fecha = new DateTime();
			$facturas = $doctrine->getRepository(FacturaEntidad::class)->findBy(array(
				'serie' => $fecha->format('y')
			), array(
				'numero' => 'DESC'
			));
			if ($facturas) {
				$factura->setNumero($facturas[0]->getNumero() + 1);
				$fechaInicialFactura = $facturas[0]->getFecha();
			} else {
				$factura->setNumero(1);
				$fechaInicialFactura = $fecha;
			}
		}
		$formularioFactura = $this->createForm(FacturaFormulario::class, $factura);
		$formularioLineaFactura = $this->createForm(LineaFacturaFormulario::class);
		$formularioFactura->handleRequest($request);
		if ($formularioFactura->isSubmitted() && $formularioFactura->isValid()) {
			if (empty($factura->getFecha())) {
				$fecha = new DateTime();
				$factura->setFecha($fecha);
			} else {
				$fecha = $factura->getFecha();
			}
			if (empty($factura->getSerie())) {
				$factura->setSerie($fecha->format('y'));
			}
			if (!isset($id) || isset($serieInicialFactura) && $serieInicialFactura !== $factura->getSerie()) {
				$facturas = $doctrine->getRepository(FacturaEntidad::class)->findBy(array(
					'serie' => $factura->getSerie()
				), array(
					'numero' => 'DESC'
				));
				if (count($facturas) > 0) {
					$factura->setNumero($facturas[0]->getNumero() + 1);
				} else {
					$factura->setNumero(1);
				}
			}
			if ($fechaInicialFactura > $factura->getFecha()) {
				$factura->setFecha($fechaInicialFactura);
			}
			$lineasFactura = $request->get('linea_factura');
			if (!is_null($lineasFactura)) {
				$managerEntidad = $doctrine->getManager();
				if (isset($id)) {
					$lineasFacturaExistentes = $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
						'idFactura' => $id
					));
					if ($lineasFacturaExistentes) {
						$numeroLineasFacturaExistentes = count($lineasFacturaExistentes);
						$numeroLineasFactura = count($lineasFactura);
						if ($numeroLineasFacturaExistentes > $numeroLineasFactura) {
							for ($i = $numeroLineasFactura - 1; $i < $numeroLineasFacturaExistentes; $i += 1) {
								$managerEntidad->remove($lineasFacturaExistentes[$i]);
							}
						}
					}
				} else {
					$managerEntidad->persist($factura);
					$managerEntidad->flush();
				}
				$facturaBaseImponible = $facturaImpuestos = $facturaRetenciones = 0;
				foreach ($lineasFactura as $indice => $lineaFactura) {
					if (isset($lineasFacturaExistentes) && isset($lineasFacturaExistentes[$indice])) {
						$lineaFacturaObjecto = $lineasFacturaExistentes[$indice];
					} else {
						$lineaFacturaObjecto = (new LineaFacturaEntidad())
							->setIdFactura($factura);
					}
					$lineaFacturaObjecto->setLineaFactura($indice)
						->setConcepto($lineaFactura['concepto']);
					if (empty($lineaFactura['unidades'])) {
						$lineaFacturaObjecto->setUnidades(1);
					} else {
						$lineaFacturaObjecto->setUnidades($lineaFactura['unidades']);
					}
					if (empty($lineaFactura['importe'])) {
						$lineaFacturaObjecto->setImporte(0);
					} else {
						$lineaFacturaObjecto->setImporte($lineaFactura['importe']);
					}
					$lineaFacturaObjecto->setTipoIva($lineaFactura['tipoIva']);
					if (empty($lineaFactura['tipoRetencion'])) {
						$lineaFacturaObjecto->setTipoRetencion(0);
					} else {
						$lineaFacturaObjecto->setTipoRetencion($lineaFactura['tipoRetencion']);
					}
					$lineaFacturaObjecto->setTotalBaseImponible($lineaFacturaObjecto->getImporte() * $lineaFacturaObjecto->getUnidades())
						->setImpuestos($lineaFacturaObjecto->getTotalBaseImponible() * $lineaFacturaObjecto->getTipoIva() / 100)
						->setRetencion($lineaFacturaObjecto->getTotalBaseImponible() * $lineaFacturaObjecto->getTipoRetencion() / 100)
						->setTotal($lineaFacturaObjecto->getTotalBaseImponible() + $lineaFacturaObjecto->getImpuestos() - $lineaFacturaObjecto->getRetencion());
					$facturaBaseImponible += $lineaFacturaObjecto->getTotalBaseImponible();
					$facturaImpuestos += $lineaFacturaObjecto->getImpuestos();
					$facturaRetenciones += $lineaFacturaObjecto->getRetencion();
					$managerEntidad->persist($lineaFacturaObjecto);
				}
				$factura->setBaseImponible($facturaBaseImponible)
					->setImpuestos($facturaImpuestos)
					->setRetenciones($facturaRetenciones)
					->setTotal($facturaBaseImponible + $facturaImpuestos - $facturaRetenciones);
				$managerEntidad->persist($factura);
				$managerEntidad->flush();
				$this->addFlash('success', 'La factura se ha creado/modificado correctamente.');
				return $this->redirectToRoute('lista_facturas');
			} else {
				$this->addFlash('warning', 'Debe de existir al menos una línea.');
			}
		}
		return $this->render('@App/Backoffice/AgregarModificar/Factura.html.twig', array(
			'titulo' => 'Crear/Modificar factura',
			'migasPan' => array(
				array(
					'vista' => 'Lista de facturas',
					'url' => $router->generate('lista_facturas')
				)
			),
			'agregar_modificar_factura' => $formularioFactura->createView(),
			'agregar_linea_factura' => $formularioLineaFactura->createView(),
			'lineas_factura' => $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
				'idFactura' => $id
			)),
			'factura' => $factura,
			'fecha_inicial_factura' => $fechaInicialFactura
		));
	}

	public function ObtenerNumeroSerieFacturaAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = null;
			if (json_last_error() === 0 && isset($jsonRecibido['serie'])) {
				$facturas = $this->getDoctrine()->getRepository(FacturaEntidad::class)->findBy(array(
					'serie' => $jsonRecibido['serie']
				), array(
					'numero' => 'DESC'
				));
				if ($facturas) {
					$respuesta = array(
						'numero' => $facturas[0]->getNumero() + 1,
						'fecha' => $facturas[0]->getFecha()->format('d/m/Y')
					);
				} else {
					$fecha = new DateTime();
					$respuesta = array(
						'numero' => 1,
						'fecha' => $fecha->format('d/m/Y')
					);
				}
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function verFacturaAction($id)
	{
		$doctrine = $this->getDoctrine();
		$factura = $doctrine->getRepository(FacturaEntidad::class)->findOneBy(array(
			'idFactura' => $id
		));
		if ($factura) {
			$emisor = $doctrine->getRepository(EmisorFacturaEntidad::class)->findOneBy(array(
				'idEmisorFactura' => $factura->getIdEmisorFactura()
			));
			$cliente = $doctrine->getRepository(ClienteFacturaEntidad::class)->findOneBy(array(
				'idClienteFactura' => $factura->getIdClienteFactura()
			));
			$lineasFactura = $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
				'idFactura' => $factura->getIdFactura()
			), array(
				'lineaFactura' => 'ASC'
			));
			$pdf = $this->get('white_october.tcpdf')->create();
			$pdf->setTitle('Factura ' . $factura->getNumero() . '/' . $factura->getSerie());
			$pdf->setHeaderData($this->get('assets.packages')->getUrl('/custom/factura_cabecera.png'), $pdf->getPageWidth() - $pdf->getMargins()['left'] - $pdf->getMargins()['right']);
			$imagenDimensiones = getimagesize(K_PATH_IMAGES . '/custom/factura_cabecera.png');
			$pdf->setMargins(10, ($pdf->getPageWidth() - $pdf->getMargins()['left'] - $pdf->getMargins()['right']) / ($imagenDimensiones[0] / $imagenDimensiones[1]), 10);
			$pdf->setFont(null, null, 7.5);
			$pdf->setCellPadding(1);
			$pdf->setHtmlVSpace(array(
				'div' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				),
				'hr' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				),
				'p' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				)
			));
			$pdf->AddPage();
			$html = '<style>
								.cabecera {
									border: 1px solid #000
								}
								.fecha {
									text-align: right
								}
								.tabla {
									text-align: center
								}
								.tabla td,
								.tabla th {
									border: 1px solid #000
								}
							</style>
							<table class="cabecera">
								<thead>
									<tr>
										<th>
											<h3>Nº FACTURA: ' . $factura->getNumero() . '/' . $factura->getFecha()->format('Y') . '</h3>
										</th>
										<th class="fecha">FECHA: ' . $factura->getFecha()->format('d/m/Y') . '</th>
									</tr>
								</thead>
							</table>
							<div>
								<div>' . $emisor->getRazonSocial() . '</div>
								<div>' . $emisor->getDireccion() . ' ' . $emisor->getMunicipio() . ', ' . $emisor->getProvincia() . '.</div>
								<div>' . $emisor->getCP() . '-' . $emisor->getProvincia() . '</div>
								<div>CIF: ' . $emisor->getCIF() . '</div>
							</div>
							<hr>
							<div>
								<div>
									<b>CLIENTE:</b>
									<span>' . $cliente->getRazonSocial() . '</span>
								</div>
								<div>
									<b>DNI:</b>
									<span>' . $cliente->getCIF() . '</span>
								</div>
								<div>
									<b>DESCRIPCIÓN:</b>
									<span>' . $factura->getDescripcion() . '</span>
								</div>
							</div>
								<table class="tabla">
									<thead>
										<tr>
											<th>CONCEPTO</th>
											<th>UNIDADES</th>
											<th>PRECIO UNITARIO</th>
											<th>IMPORTE</th>
											<th>TIPO IVA</th>
											<th>IMPUESTOS</th>
											<th>TIPO RETENCIÓN</th>
											<th>RETENCIONES</th>
											<th>TOTAL</th>
										</tr>
									</thead>
									<tbody>';
			foreach ($lineasFactura as $lineaFactura) {
				$html .= '<tr>
										<td>' . $lineaFactura->getConcepto() . '</td>
										<td>' . $lineaFactura->getUnidades() . '</td>
										<td>' . $lineaFactura->getImporte() . ' €</td>
										<td>' . $lineaFactura->getUnidades() * $lineaFactura->getImporte() . ' €</td>
										<td>' . $lineaFactura->getTipoIVA() . ' %</td>
										<td>' . $lineaFactura->getImpuestos() . ' €</td>
										<td>' . $lineaFactura->getTipoRetencion() . ' %</td>
										<td>' . $lineaFactura->getRetencion() . ' €</td>
										<td>' . $lineaFactura->getTotal() . ' €</td>
									</tr>';
			}
			$html .= '</tbody>
							</table>
							<div></div>
							<div>
								<b>TOTAL FACTURA</b>
							</div>
							<table class="tabla">
								<thead>
									<tr>
										<th>IMPORTE</th>
										<th>IMPUESTOS</th>
										<th>RETENCIONES</th>
										<th>TOTAL</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td>' . $factura->getBaseImponible() . ' €</td>
										<td>' . $factura->getImpuestos() . ' €</td>
										<td>' . $factura->getRetenciones() . ' €</td>
										<td>' . $factura->getTotal() . ' €</td>
									</tr>
								</tbody>
							</table>
							<div></div>
							<p>';
			if ($factura->getRetenciones() === 0) {
				$html .= 'La presente factura está exenta de IVA en base al Artículo 20.1 apartado 18º.m de la Ley 37/92 del IVA. ';
			}
			$html .= 'Grupo Negociador ALR no es una entidad de crédito, sino que presta servicios de mediación entre entidades de financiación y particulares o empresas.</p>';
			$pdf->writeHTML($html);
			$pdf->output('Factura_' . $factura->getNumero() . '-' . $factura->getSerie() . '.pdf');
			return null;
		} else {
			$this->addFlash('success', 'No existe la factura con id="' . $id . '".');
			return $this->redirectToRoute('lista_facturas');
		}
	}

	public function enviarFacturaEmailAction(Request $request, RouterInterface $router, Swift_Mailer $mailer)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = null;
			if (json_last_error() === 0) {
				$factura = $this->getDoctrine()->getRepository(FacturaEntidad::class)->findOneBy(array(
					'idFactura' => $jsonRecibido['idFactura']
				));
				if ($factura) {
					$mailerOk = $this->obtenerMailer($mailer, $this->getUser());
					if($this->getUser()->getMailerTransport()!= null && $this->getUser()->getMailerTransport()!= ""){
						$from = array($this->getUser()->getMailerUser() => $this->getUser()->getUsername()." ".$this->getUser()->getApellidos(). ' - Grupo Negociador');
					}else{
						$from = array($this->getParameter('mailer_user') => 'Grupo Negociador');
					}
					$mensaje = (new Swift_Message($jsonRecibido['asunto']))
						->setFrom($from)
						->setTo($jsonRecibido['destinatario'])
						->setBody($jsonRecibido['texto'], 'text/plain')
						->attach(Swift_Attachment::fromPath($router->generate('ver_factura', array(
							'id' => $jsonRecibido['idFactura']
						))))
						;
					if (!$mailerOk->send($mensaje)) {
						$respuesta['error'] = true;
					}
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function calculadoraSencillaAction(Request $request)
	{
		$formulario = $this->createForm('AppBundle\Form\CalculadoraSencilla');
		$formulario->handleRequest($request);
		$variablesTwig = array(
			'titulo' => 'Calculadora Sencilla',
			'calculadora_sencilla' => $formulario->createView(),
		);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$formulario->getData()->calcularHipoteca();
			$variablesTwig['hipoteca'] = $formulario->getData()->getHipoteca()['capital_less_initial_amount'];
			$variablesTwig['pago_mensual'] = $formulario->getData()->getHipoteca()['fee'];
			$variablesTwig['hipoteca_total_con_interes'] = $formulario->getData()->getHipoteca()['capital_less_initial_amount'] + $formulario->getData()->getHipoteca()['interest_discharged_total'];
			$variablesTwig['total_con_anticipo'] = $formulario->getData()->getPrecioTotal() + $formulario->getData()->getHipoteca()['interest_discharged_total'];
			$variablesTwig['resultado'] = null;
		}
		return $this->render('@App/Backoffice/Extras/CalculadoraSencilla.html.twig', $variablesTwig);
	}

	public function calculadoraAvanzadaAction(Request $request)
	{
		$formulario = $this->createForm('AppBundle\Form\CalculadoraAvanzada');
		$formulario->handleRequest($request);
		// dump($request);
		// die();
		$variablesTwig = array(
			'titulo' => 'Calculadora Avanzada',
			'calculadora_avanzada' => $formulario->createView(),
		);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$resultado = $formulario->getData()->calcularAvanzada($doctrine = $this->getDoctrine()->getManager());
			// $respuesta['importe_fijo'] = $resultado_f['importe'];
			// $respuesta['importe_variable'] = $resultado_v['importe'];
			// $respuesta['entrada'] = $aportacion_inicial;
			// $respuesta['gastos'] = $gastos;
			// $respuesta['interes_fijo'] = $interes_fijo_l;
			// $respuesta['interes_variable'] = $interes_variable_l;
			// $respuesta['tipo_calculo'] = $tipo_calculo;
			// $respuesta['cuota_fija'] = $resultado['cuota'];
			// $respuesta['cuota_variable'] = $resultado['cuota'];
			if ($formulario->getData()->getTipo() == 1) {
				$variablesTwig['valor_inmueble'] = $formulario->getData()->getValorInmueble();
				$variablesTwig['importe_fijo'] = $resultado['importe_fijo'];
				$variablesTwig['importe_variable'] = $resultado['importe_variable'];
				$variablesTwig['amortizacion'] = $resultado['amortizacion'];
				$variablesTwig['entrada'] = $resultado['entrada'];
				// $variablesTwig['gastos'] = $resultado['gastos'];
				$variablesTwig['interes_fijo'] = $resultado['con_interes_fijo'];
				$variablesTwig['interes_variable'] = $resultado['con_interes_variable'];
				$variablesTwig['con_entrada_fijo'] = $resultado['con_entrada_fijo'];
				$variablesTwig['con_entrada_variable'] = $resultado['con_entrada_variable'];
				$variablesTwig['tipo_calculo'] = $resultado['tipo_calculo'];
				$variablesTwig['cuota_fija'] = $resultado['cuota_fija'];
				$variablesTwig['cuota_variable'] = $resultado['cuota_variable'];
				$variablesTwig['mensaje'] = $resultado['mensaje'];
				if (array_key_exists('cuota_fija_final',$resultado)) {
					$variablesTwig['cuota_fija_final'] = $resultado['cuota_fija_final'];
				} else {
					$variablesTwig['cuota_fija_final'] = 0;
				}
				if (array_key_exists('cuota_variable_final',$resultado)) {
					$variablesTwig['cuota_variable_final'] = $resultado['cuota_variable_final'];
				} else {
					$variablesTwig['cuota_variable_final'] = 0;
				}
				$variablesTwig['valor_vivienda_actual'] = $formulario->getData()->getValorViviendaActual();
				$variablesTwig['hipoteca_actual'] = $formulario->getData()->getHipotecaActual();
				$variablesTwig['aportacion_tras_venta'] = $formulario->getData()->getAportacionTrasVenta();
			} else {
				if ($resultado['importe_fijo'] > 0) {
					$variablesTwig['valor_inmueble'] = $formulario->getData()->getValorInmueble();
					// $variablesTwig['tipo_calculo'] = $formulario->getData()->getTipo();
					$variablesTwig['importe_fijo'] = $resultado['importe_fijo'];
					// $variablesTwig['importe_variable'] = $resultado['importe_variable'];
					$variablesTwig['amortizacion'] = $resultado['amortizacion'];
					$variablesTwig['entrada'] = $resultado['entrada'];
					$variablesTwig['gastos'] = $resultado['gastos'];
					$variablesTwig['cuota'] = $resultado['cuota'];
					$variablesTwig['mensaje'] = $resultado['mensaje'];
					// $variablesTwig['interes_fijo'] = $resultado['interes_fijo'];
					// $variablesTwig['interes_variable'] = $resultado['interes_variable'];
					$variablesTwig['tipo_calculo'] = $resultado['tipo_calculo'];
					// $variablesTwig['cuota_fija'] = $resultado['cuota_fija'];
					// $variablesTwig['cuota_variable'] = $resultado['cuota_variable'];
				} else {
					$variablesTwig['importe_fijo'] = 0;
					$variablesTwig['mensaje'] = $resultado['mensaje'];
				}
			}
			// $variablesTwig['hipoteca_total_con_interes'] = $resultado['capital_less_initial_amount'] + $resultado['interest_discharged_total'];
			// $variablesTwig['total_con_anticipo'] = $formulario->getData()->getPrecioTotal() + $resultado['interest_discharged_total'];
			$variablesTwig['resultado'] = null;
		}
		return $this->render('@App/Backoffice/Extras/CalculadoraAvanzada.html.twig', $variablesTwig);
	}

