							$enviarNotificacion = false;
							
							if($this->getUser()->getRoles()[0] !== 'ROLE_CLIENTE' && $this->getUser()->getRoles()[0] !== 'ROLE_COLABORADOR'){ // ES un usuario del backoffice y tiene que avisar al cliente y/o colaborador
								if ($campoHitoExpediente->getEnviarAlColaborador() && $expediente->getIdColaborador()) {
									$notificacion = (new NotificacionEntidad())
										->setIdExpediente($expediente)
										->setFecha(new DateTime());
									if($campoHitoExpediente->getParaFirmar()){
										$textoNotificacion = $expediente->getIdCliente()->getUsername().' '.$expediente->getIdCliente()->getApellidos()." tiene que firmar el documento: ".$campoHitoExpediente->getIdCampoHito()->getNombre();
