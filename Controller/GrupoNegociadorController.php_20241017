	public function informePendienteExpedienteAction($id)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if (!$expediente) {
			$this->addFlash('warning', 'No se ha encontrado el expediente con id=' . $id . '.');
			return $this->redirectToRoute('lista_expedientes');
		}
		$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(), array(
			'orden' => 'ASC'
		));
		$salida = array();
		foreach ($fases as $fase) {
			$salida[$fase->getIdFase()]['nombre'] = $fase->getNombre();
			$hitos[$fase->getIdFase()] = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase
			), array(
				'orden' => 'ASC'
			));

			foreach ($hitos[$fase->getIdFase()] as $hito) {
				if($hito->getHitoCondicional()){
					$opcionCondicional = $doctrine->getRepository(OpcionesCampoEntidad::class)->findOneBy(array(
						'idHitoCondicional' => $hito
					));
					if($opcionCondicional){
						$campoHitoExpedienteC = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy(array(
							'idCampoHito' => $opcionCondicional->getIdCampoHito(),
							'idExpediente' => $expediente,
							'idOpcionesCampo' => $opcionCondicional
						));
						if($campoHitoExpedienteC){
							$mostrarCondicional = true;
						}else{
							$mostrarCondicional = false;
						}
						
					}else{
						$mostrarCondicional = false;
					}
				}else{
					$mostrarCondicional = false;
				}
				if(!$hito->getHitoCondicional() || ($hito->getHitoCondicional() && $mostrarCondicional )){
					$hitosExpediente[$fase->getIdFase()] = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
						'idHito' => $hito,
						'idExpediente' => $expediente
					));
					$gruposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
						'idHito' => $hito
					), array(
						'orden' => 'ASC'
					));
					// $camposHito[$hito->getIdHito()] = $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
					// 	'idGrupoCamposHito' => $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
					// 		'idHito' => $hito
					// 	), array(
					// 		'orden' => 'ASC'
					// 	))
					// ), array(
					// 	'orden' => 'ASC'
					// ));
					$indiceAnterior = null;
					foreach ($hitosExpediente[$fase->getIdFase()] as $contador => $hitoExpediente) {
						$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()] = array(
							'indice' => $contador,
							'nombre' => $hito->getNombre()
						);
						foreach($gruposHito as $grupoHito){
							$camposHito[$hito->getIdHito()] = $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
								'idGrupoCamposHito' => $grupoHito
								)
							, array(
								'orden' => 'ASC'
							));
							foreach ($camposHito[$hito->getIdHito()] as $campoHito) {
								if($campoHito->getCampoCondicional()){
									// $opcionCondicional = $doctrine->getRepository(OpcionesCampoEntidad::class)->findOneBy(array(
									// 	'idCampoCondicional' => $campoHito
									// ));
									$opcionesCondicionales = $doctrine->getRepository(OpcionesCampoEntidad::class)->matching(Criteria::create()
										->where(Criteria::expr()->contains('idCampoCondicional', $campoHito->getIdCampoHito() ))
									)->toArray();
									
									if(count($opcionesCondicionales)>0){
										foreach($opcionesCondicionales as $opcionCondicional){
											$campoHitoExpedienteC = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy(array(
												'idExpediente' => $expediente,
												'idOpcionesCampo' => $opcionCondicional
											));
											if($campoHitoExpedienteC){
												$mostrarCampoCondicional = true;
												break;
											}else{
												$mostrarCampoCondicional = false;
											}
										}
									}else{
										$mostrarCampoCondicional = false;
									}
								}else{
									$mostrarCampoCondicional = true;
								}


								$campoHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy(array(
									'idCampoHito' => $campoHito,
									'idHitoExpediente' => $hitoExpediente,
									'idExpediente' => $expediente
								));
								if ($campoHitoExpediente && $mostrarCampoCondicional) {
									$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()] = array(
										'nombre' => $campoHito->getNombre(),
										'tipo' => $campoHito->getTipo(),
										'grupo' => $campoHito->getIdGrupoCamposHito()->getNombre()
									);
									if ($campoHito->getTipo() === 1 || $campoHito->getTipo() === 5 || $campoHito->getTipo() === 6) {
										if (is_null($campoHitoExpediente->getValor())) {
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = '';
										} else {
											unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
										}
									} elseif ($campoHito->getTipo() === 2 || $campoHito->getTipo() === 3) {
										if (is_null($campoHitoExpediente->getIdOpcionesCampo()) || is_null($campoHitoExpediente->getIdOpcionesCampo()->getValor())) {
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = '';
										} else {
											unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
										}
									} elseif ($campoHito->getTipo() === 4) {
										if (!$campoHitoExpediente->getObligatorio() && !$campoHitoExpediente->getSolicitarAlColaborador()) {
											unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
										} else {
											if ($campoHitoExpediente->getParaFirmar() && $campoHitoExpediente->getFirmado()){
												unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
											}elseif( !$campoHitoExpediente->getParaFirmar() && !is_null($campoHitoExpediente->getValor()) && !is_null($doctrine->getRepository(FicheroCampoEntidad::class)->findOneBy(array(
												'idCampoHito' => $campoHito,
												'idCampoHitoExpediente' => $campoHitoExpediente,
												'idExpediente' => $expediente
											)))) {
												unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
											} else {
												$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()] = array_merge($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()], array(
													'obligatorio' => $campoHitoExpediente->getObligatorio(),
													'solicitar_al_colaborador' => $campoHitoExpediente->getSolicitarAlColaborador(),
													'avisar_colaborador' => $campoHitoExpediente->getAvisarColaborador(),
													'para_firmar' => $campoHitoExpediente->getParaFirmar(),
													'firmado' => $campoHitoExpediente->getFirmado(),
												));
												if (!is_null($campoHitoExpediente->getValor())) {
													$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['nombreFichero'] = $campoHitoExpediente->getValor();
												}
												$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['subido'] = !is_null($doctrine->getRepository(FicheroCampoEntidad::class)->findOneBy(array(
													'idCampoHito' => $campoHito,
													'idCampoHitoExpediente' => $campoHitoExpediente,
													'idExpediente' => $expediente
												)));
												$campoHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
													'idCampoHito' => $campoHito,
													'idHitoExpediente' => $hitoExpediente,
													'idExpediente' => $expediente
												), array(
													'idEntidadColaboradora' => 'ASC',
													'idAgenteColaborador' => 'ASC'
												));
												$entidadColaboradoraAnterior = null;
												foreach ($campoHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
													$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['entidadesColaboradoras'][$campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getIdEntidadColaboradora()]['nombre'] = $campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getNombre();
													$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['entidadesColaboradoras'][$campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getIdEntidadColaboradora()]['agentesColaboradores'][$campoHitoExpedienteColaborador->getIdAgenteColaborador()->getIdAgenteColaborador()]['nombre'] = (new UsuariosNombreCompleto())->obtener($campoHitoExpedienteColaborador->getIdAgenteColaborador());
												}
											}
										}
									} elseif ($campoHito->getTipo() === 7 || $campoHito->getTipo() === 8 || $campoHito->getTipo() === 9) {
										if (is_null($campoHitoExpediente->getIdAgenteColaborador())) {
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = '';
										} else {
											unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
										}
									} elseif ($campoHito->getTipo() === 10) {
										unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
									} else {
										$this->addFlash('warning', 'El campo hito con id="' . $campoHito->getIdCampoHito() . '" es de un tipo no valido.');
										return $this->redirectToRoute('lista_expedientes');
									}
									if (count($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito']) <= 0) {
										unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito']);
									}
								}
							}
							if (count($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]) <= 2) {
								unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]);
							}
						}
					}
				}
				if (count($salida[$fase->getIdFase()]['hitos']) <= 0) {
					unset($salida[$fase->getIdFase()]['hitos']);
				}
			}
			if (count($salida[$fase->getIdFase()]) <= 1) {
				unset($salida[$fase->getIdFase()]);
			}
		}

		$vivienda = $expediente->getVivienda();
		$colaborador = (new UsuariosNombreCompleto())->obtener($expediente->getIdColaborador());
		$cliente = (new UsuariosNombreCompleto())->obtener($expediente->getIdCliente());
		$comercial = (new UsuariosNombreCompleto())->obtener($expediente->getIdComercial());
		$tecnico = (new UsuariosNombreCompleto())->obtener($expediente->getIdTecnico());

		//  SALIDA EN HTML para pruebas, recordar cambiar en el twig la base
		// return $this->render('@App/Backoffice/Informes/InformePendienteExpediente.html.twig', array(
		// 		'salida' => $salida,
		// 		'vivienda' => $vivienda,
		// 		'colaborador' => $colaborador,
		// 		'cliente' => $cliente,
		// 		'comercial' => $comercial,
		// 		'tecnico' => $tecnico,
		// 		'num_expediente' => $id));

		
		//  Generar descarga de PDF
		// return new PdfResponse($this->get('knp_snappy.pdf')->getOutputFromHtml(
		// 	$this->renderView('@App/Backoffice/Informes/InformePendienteExpediente.html.twig', array(
		// 		'salida' => $salida,
		// 		'vivienda' => $vivienda,
		// 		'colaborador' => $colaborador,
		// 		'cliente' => $cliente,
		// 		'comercial' => $comercial,
		// 		'tecnico' => $tecnico,
		// 		'num_expediente' => $id
		// 	))),
		// 	// $contenido,
		// 	'expediente_n_' . $expediente->getIdExpediente() . '.pdf',
		// 	[],
		// 	true
		// );
		
		// Genera pdf en el navegador
		header('Content-Type: application/pdf');
		echo $this->get('knp_snappy.pdf')->getOutputFromHtml(
			$this->renderView('@App/Backoffice/Informes/InformePendienteExpediente.html.twig', array(
				'salida' => $salida,
				'vivienda' => $vivienda,
				'colaborador' => $colaborador,
				'cliente' => $cliente,
				'comercial' => $comercial,
				'tecnico' => $tecnico,
				'num_expediente' => $id
			)));

		return;

		// Formato antiguo
		$pdf = $this->get('white_october.tcpdf')->create();
		$pdf->setTitle('Informe de campos pendientes del expediente nº ' . $expediente->getIdExpediente());
		$pdf->setHeaderData($this->get('assets.packages')->getUrl('/custom/logo-negro_gruponegociador.png'), $pdf->getPageWidth() * 2 / 5 - $pdf->getMargins()['left'] - $pdf->getMargins()['right'], '', '', array(0, 0, 0), array(255, 255, 255));
		$pdf->setHeaderMargin(10);
		$imagenDimensiones = getimagesize(K_PATH_IMAGES . '/custom/logo-negro_gruponegociador.png');
		$pdf->setMargins(10, ($pdf->getPageWidth() * 2 / 5 - $pdf->getMargins()['left'] - $pdf->getMargins()['right']) / ($imagenDimensiones[0] / $imagenDimensiones[1]) + 15, 10);
		$pdf->setFont(null, null, 7.5);
		$pdf->setCellPadding(1);
		$pdf->setHtmlVSpace(array(
			'div' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'br' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'h1' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'h2' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'h3' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'li' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'p' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			),
			'ul' => array(
				0 => array(
					'h' => 0,
					'n' => 0
				),
				1 => array(
					'h' => 0,
					'n' => 0
				)
			)
		));
		$pdf->AddPage();
		$html = '<h1>Informe de campos pendientes del expediente nº ' . $expediente->getIdExpediente() . '</h1><table align="center" cellspacing="0" cellpadding="2" border="1"><tr style="background-color:#ef6c00;color:#ffffff"><th>Vivienda</th><th>Colaborador</th><th>Cliente</th><th>Comercial</th><th>Técnico</th></tr><tr><td>' . $expediente->getVivienda() . '</td><td>' . (new UsuariosNombreCompleto())->obtener($expediente->getIdColaborador()) . '</td><td>' . (new UsuariosNombreCompleto())->obtener($expediente->getIdCliente()) . '</td><td>' . (new UsuariosNombreCompleto())->obtener($expediente->getIdComercial()) . '</td><td>' . (new UsuariosNombreCompleto())->obtener($expediente->getIdTecnico()) . '</td></tr></table>';
		if (count($salida) > 0) {
			foreach ($salida as $fase) {
				$html .= '<h2><b>' . strtoupper($fase['nombre']) . '</b></h2>';
				$contador = 0;
				$numeroColumnas = 2;
				$html .= '<table cellspacing="0" cellpadding="2">';
				foreach ($fase['hitos'] as $hito) {
					if ($contador === 0) {
						$html .= '<tr>';
					}
					$html .= '<td>';
					if ($hito['indice'] === 0) {
						$html .= '<h3 bgcolor="#ef6c00" style="color:#f8f9fa;font-weight:500;line-height:1"><i>' . strtoupper($hito['nombre']) . '</i></h3>';
					} else {
						$html .= '<h3 bgcolor="#ef6c00" style="color:#f8f9fa;font-weight:500;line-height:1"><i>' . strtoupper($hito['nombre']) . ' (' . ($hito['indice'] + 1) . ')</i></h3>';
					}
					foreach ($hito['camposHito'] as $campoHito) {
						if ($campoHito['tipo'] === 4) {
							$html .= '<div><b>' . $campoHito['nombre'] . '</b></div>';
							if (!isset($campoHito['nombreFichero'])) {
								$campoHito['nombreFichero'] = 'Sin nombre';
							}
							$html .= '<div>Nombre: ' . $campoHito['nombreFichero'] . '.</div>';
							if ($campoHito['subido']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Subido: ' . $siNo . '.</div>';
							if ($campoHito['obligatorio']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Solicitar al cliente: ' . $siNo . '.</div>';
							if ($campoHito['solicitar_al_colaborador']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Solicitar al colaborador: ' . $siNo . '.</div>';
							if ($campoHito['avisar_colaborador']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Avisar al colaborador: ' . $siNo . '.</div>';
							if ($campoHito['para_firmar']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Para firmar: ' . $siNo . '.</div>';
							if ($campoHito['firmado']) {
								$siNo = 'Si';
							} else {
								$siNo = 'No';
							}
							$html .= '<div>Firmado: ' . $siNo . '.</div>';
							if (isset($campoHito['entidadesColaboradoras']) && count($campoHito['entidadesColaboradoras']) > 0) {
								$html .= '<div>Agentes Colaboradores:</div>';
								$html .= '<ul>';
								foreach ($campoHito['entidadesColaboradoras'] as $entidadColaboradora) {
									$html .= '<li>' . $entidadColaboradora['nombre'] . '<ul>';
									foreach ($entidadColaboradora['agentesColaboradores'] as $agenteColaborador) {
										$html .= '<li>' . $agenteColaborador['nombre'] . '</li>';
									}
									$html .= '</ul></li>';
								}
								$html .= '</ul>';
							}
						} else {
							$html .= '<p><b>' . $campoHito['nombre'] . '</b> ' . $campoHito['valor'] . '</p>';
						}
					}
					$html .= '</td>';
					if ($contador > $numeroColumnas - 2) {
						$contador = 0;
						$html .= '</tr>';
					} else {
						$contador += 1;
					}
				}
				if ($contador > 0) {
					$html .= '</tr>';
				}
				$html .= '</table>';
			}
			$pdf->writeHTML($html);
		} else {
			$pdf->writeHTML($html . '<div></div><div style="background-color:#fff3cd;border:thin solid #ffeeba;color:#846404;font-size:9px">El expediente no tiene campos vacios.</div>');
		}
		$pdf->output('Informe_campos_pendientes_expediente_n_' . $expediente->getIdExpediente() . '.pdf');
		return null;
	}

	private function borrarExpedientes($managerEntidad, $expediente)
	{
		$doctrine = $this->getDoctrine();
		$repositorios = array(
			'hitoExpediente' => $doctrine->getRepository(HitoExpedienteEntidad::class),
			'campoHitoExpediente' => $doctrine->getRepository(CampoHitoExpedienteEntidad::class),
			'grupoHitoExpediente' => $doctrine->getRepository(GrupoHitoExpedienteEntidad::class),
			'seguimientoExpediente' => $doctrine->getRepository(SeguimientoExpedienteEntidad::class),
			'campoHitoExpedienteColaboradores' => $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class),
			'ficheroCampo' => $doctrine->getRepository(FicheroCampoEntidad::class),
			'notificaciones' => $doctrine->getRepository(NotificacionEntidad::class),
			'logs' => $doctrine->getRepository(LogEntidad::class)
		);
		$hitosExpediente = $repositorios['hitoExpediente']->findBy(array(
			'idExpediente' => $expediente
		));
		$gruposHitoExpediente = $repositorios['grupoHitoExpediente']->findBy(array(
			'idHitoExpediente' => $hitosExpediente
		));
		$seguimientosExpediente = $repositorios['seguimientoExpediente']->findBy(array(
			'idExpediente' => $expediente
		));
		$camposHitoExpediente = $repositorios['campoHitoExpediente']->findBy(array(
			'idExpediente' => $expediente
		));
		$camposHitoExpedienteColaboradores = $repositorios['campoHitoExpedienteColaboradores']->findBy(array(
			'idExpediente' => $expediente
		));
		$ficherosCampo = $repositorios['ficheroCampo']->findBy(array(
			'idExpediente' => $expediente
		));
		$imagenesFicheroCampo = $doctrine->getRepository(ImagenFicheroEntidad::class)->findBy(array(
			'idFicheroCampo' => $ficherosCampo
		));
		$notificaciones = $repositorios['notificaciones']->findBy(array(
			'idExpediente' => $expediente
		));
		$logs = $repositorios['logs']->matching(Criteria::create()
			->where(Criteria::expr()->contains('accion', ' expediente.'))
			->andWhere(Criteria::expr()->eq('idElemento', $expediente->getIdExpediente()))
		)->toArray();
		foreach ($ficherosCampo as $ficheroCampo) {
			if (!is_null($ficheroCampo->getNombreFichero())) {
				if (count($repositorios['ficheroCampo']->findBy(array(
						'nombreFichero' => $ficheroCampo->getNombreFichero()
					))) === 1) {
					$filesystem = new Filesystem();
					try {
						$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $ficheroCampo->getNombreFichero());
					} catch (IOExceptionInterface $e) {
						$this->addFlash('danger', 'Error al borrar el archivo del campo hito "' . $ficheroCampo->getIdCampoHito() . '" del expediente con id="' . $expediente->getIdExpediente() . '".');
						return false;
					}
				}
			}
			foreach($imagenesFicheroCampo as $imagenFicheroCampo){
				$managerEntidad->remove($imagenFicheroCampo);
			}
			$managerEntidad->remove($ficheroCampo);
		}
		foreach ($seguimientosExpediente as $seguimientoExpediente) {
			$managerEntidad->remove($seguimientoExpediente);
		}
		foreach ($gruposHitoExpediente as $grupoHitoExpediente) {
			$managerEntidad->remove($grupoHitoExpediente);
		}
		foreach ($camposHitoExpedienteColaboradores as $campoHitoExpedienteColaboradores) {
			$managerEntidad->remove($campoHitoExpedienteColaboradores);
		}
		
		foreach ($camposHitoExpediente as $campoHitoExpediente) {
			$managerEntidad->remove($campoHitoExpediente);
		}
		foreach ($hitosExpediente as $hitoExpediente) {
			$managerEntidad->remove($hitoExpediente);
		}
		foreach ($notificaciones as $notificacion) {
			$managerEntidad->remove($notificacion);
		}
		foreach ($logs as $log) {
			$managerEntidad->remove($log);
		}
		return true;
	}

	private function borrarCamposExpedientes($campoExpediente)
	{
		$doctrine = $this->getDoctrine();
		$repositorios = array(
			'hitoExpediente' => $doctrine->getRepository(HitoExpedienteEntidad::class),
			'campoHitoExpediente' => $doctrine->getRepository(CampoHitoExpedienteEntidad::class),
			'campoHitoExpedienteColaboradores' => $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class),
			'ficheroCampo' => $doctrine->getRepository(FicheroCampoEntidad::class),
		);
		$managerEntidad = $doctrine->getManager();
		$hitosExpediente = $repositorios['hitoExpediente']->findBy(array(
			'idHitoExpediente' => $campoExpediente
		));
		$camposHitoExpediente = $repositorios['campoHitoExpediente']->findBy(array(
			'idCampoHitoExpediente' => $campoExpediente
		));
		if (count($camposHitoExpediente) > 0) {
			foreach ($camposHitoExpediente as $campoHitoExpediente) {
				$camposHitoExpedienteColaboradores = $repositorios['campoHitoExpedienteColaboradores']->findBy(array(
					'idCampoHito' => $campoHitoExpediente->getIdCampoHito()
				));
				$ficherosCampo = $repositorios['ficheroCampo']->findBy(array(
					'idCampoHitoExpediente' => $campoHitoExpediente
				));
				$imagenesFicheroCampo = $doctrine->getRepository(ImagenFicheroEntidad::class)->findBy(array(
					'idFicheroCampo' => $ficherosCampo
				));
				foreach ($ficherosCampo as $ficheroCampo) {
					if (!is_null($ficheroCampo->getNombreFichero())) {
						if (count($repositorios['ficheroCampo']->findBy(array(
								'nombreFichero' => $ficheroCampo->getNombreFichero()
							))) === 1) {
							$filesystem = new Filesystem();
							try {
								$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $ficheroCampo->getNombreFichero());
							} catch (IOExceptionInterface $e) {
								$this->addFlash('danger', 'Error al borrar el archivo del campo hito "' . $ficheroCampo->getIdCampoHito() . '" del expediente con id="' . $ficheroCampo->getIdExpediente() . '".');
								return false;
							}
						}
					}
					foreach($imagenesFicheroCampo as $imagenFicheroCampo){
						$managerEntidad->remove($imagenFicheroCampo);
					}
					$managerEntidad->remove($ficheroCampo);
				}
				foreach ($camposHitoExpedienteColaboradores as $campoHitoExpedienteColaboradores) {
					$managerEntidad->remove($campoHitoExpedienteColaboradores);
				}
				$managerEntidad->remove($campoHitoExpediente);
			}
		}
		foreach ($hitosExpediente as $hitoExpediente) {
			$managerEntidad->remove($hitoExpediente);
		}
		return true;
	}

	private function listaTabla($parametros)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository($parametros['entidad']);
		if (isset($parametros['requestGet'])) {
			$entradasSeleccionadas = $parametros['requestGet'];
			if (!is_null($entradasSeleccionadas)) {
				$managerEntidad = $doctrine->getManager();
				try {
					$elementosBorrados = $elementosNoBorrados = array();
					foreach ($entradasSeleccionadas as $entrada) {
						$entidad = $repositorio->find($entrada);
						if ($entidad) {
							$managerEntidad->remove($entidad);
							$elementosBorrados[] = $entrada;
							//$this->registrarActividadConEntidad('Borrar', $managerEntidad, $entidad);
						} else {
							$elementosNoBorrados[] = $entrada;
						}
						$managerEntidad->flush();
						if (count($elementosBorrados) > 0) {
							$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
								$parametros['elementosBorrados'][0],
								$parametros['elementosBorrados'][1],
								' y '
							)));
						}
						if (count($elementosNoBorrados) > 0) {
							$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
								$parametros['elementosNoBorrados'][0],
								$parametros['elementosNoBorrados'][1],
								' y '
							)));
						}
					}
				} catch (ForeignKeyConstraintViolationException $e) {
					$this->addFlash('danger', "No se puede eliminar porque existe información referente a este elemento en otras partes de la aplicación.");
				}
			}
		} else {
			//$this->registrarActividadSinEntidad('Leer ' . $parametros['tabla']);
		}
		if (isset($parametros['nombreCampo'])) {
			return $this->render($parametros['renderizar'], array(
				'titulo' => $parametros['tituloPagina'],
				$parametros['nombreRepositorio'] => $repositorio->findBy(array(
					$parametros['nombreCampo'] => $parametros['valorCampo']
				))
			));
		} else {
			return $this->render($parametros['renderizar'], array(
				'titulo' => $parametros['tituloPagina'],
				$parametros['nombreRepositorio'] => $repositorio->findAll()
			));
		}
	}

	private
	function formularioEntidad($parametros)
	{
		$doctrine = $this->getDoctrine();
		if (isset($parametros['id'])) {
			$elemento = $doctrine->getRepository($parametros['entidad'])->findOneBy(array(
				$parametros['idEntidad'] => $parametros['id']
			));
			if (!$elemento) {
				$this->addFlash('warning', $parametros['elementoNoExiste']);
				return $this->redirectToRoute($parametros['ruta']);
			}
			$formulario = $this->createForm($parametros['formulario'], $elemento, $parametros['formularioOpciones']);
		} else {
			$formulario = $this->createForm($parametros['formulario'], null, $parametros['formularioOpciones']);
		}
		$formulario->handleRequest($parametros['request']);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$managerEntidad = $doctrine->getManager();
			$managerEntidad->persist($formulario->getData());
			$managerEntidad->flush();
			$this->addFlash('success', $parametros['formularioMensaje']);
			return $this->redirectToRoute($parametros['ruta']);
		}
		return $this->render($parametros['renderizar'], array(
			'titulo' => $parametros['titulo'],
			'migasPan' => $parametros['migasPan'],
			$parametros['formularioNombre'] => $formulario->createView()
		));
	}

	private
	function formularioUsuario($parametros)
	{
		$doctrine = $this->getDoctrine();
		$old_mail_pass ="";
		$ficheroSubido = "";
		$ficheroSubidoRuta = "";
		$nombreFicheroMostrar = "";

		if (isset($parametros['id'])) {
			if (isset($parametros['cliente'])) {
				$usuario = $doctrine->getRepository($parametros['entidad'])->findOneBy(array(
					$parametros['idEntidad'] => $parametros['id'],
					'role' => 'ROLE_CLIENTE'
				));
			} else {
				$usuario = $doctrine->getRepository($parametros['entidad'])->findOneBy(array(
					$parametros['idEntidad'] => $parametros['id']
				));
			}
			if (!$usuario) {
				$this->addFlash('warning', $parametros['elementoNoExiste']);
				return $this->redirectToRoute($parametros['ruta']);
			}else{
				$old_mail_pass = $usuario->getMailerPassword();
				$filesystem = new Filesystem();
				if (!is_null($usuario->getFirmaCorreo()) && $filesystem->exists($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $usuario->getFirmaCorreo())) {
					$router = $parametros['router'];
					$ficheroSubido = str_replace($this->get('kernel')->getProjectDir() . '/web', '', $this->getParameter('files_directory') . '/' . $usuario->getFirmaCorreo());
					$ficheroSubidoRuta = $router->generate('descargar_fichero_documento', array(
						'id' => $usuario->getIdUsuario()
					));
					$nombreFicheroMostrar = "Firma Correo";
				}
			}
			$formulario = $this->createForm($parametros['formularioModificar'], $usuario);
		} else {
			$usuario = new UsuarioEntidad();
			$formulario = $this->createForm($parametros['formularioAgregar'], $usuario);
		}
		$formulario->handleRequest($parametros['request']);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			if (!is_null($usuario->getPlainPassword())) {
				$usuario->setPassword($parametros['passwordEncoder']->encodePassword($usuario, $usuario->getPlainPassword()));
			}
			if(is_null($usuario->getMailerPassword())){
				$usuario->setMailerPassword($old_mail_pass);
			}

			if (!is_null($usuario->getFirmaCorreo())) {
				$filesystem = new Filesystem();
				try {
					$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $usuario->getFirmaCorreo());
				} catch (IOExceptionInterface $e) {
					$this->addFlash('danger', 'Error al borrar el archivo antiguo.');
					return $this->redirectToRoute($parametros['ruta']);
				}
				$nombreFichero = md5(uniqid()) . '.' . $usuario->getFirmaCorreo()->guessExtension();
				try {
					$usuario->getFirmaCorreo()->move($this->getParameter('files_directory'), $nombreFichero);
				} catch (FileException $e) {
					$this->addFlash('danger', 'Error al guardar el archivo en el servidor.');
					return $this->redirectToRoute($parametros['ruta']);
				}
				$usuario->setFirmaCorreo($nombreFichero);
			}

			$managerEntidad = $doctrine->getManager();
			$managerEntidad->persist($usuario);
			$managerEntidad->flush();
			$this->addFlash('success', $parametros['formularioMensaje']);
			return $this->redirectToRoute($parametros['ruta']);
		}
		$titulo = $usuario->getApellidos().','.$usuario->getUsername();
		($titulo == ',')?$titulo = "Nuevo Usuario":$titulo;
		$formatosPermitidos = $this->getParameter('image_formats');
		if (in_array('jpeg', $formatosPermitidos)) {
			array_push($formatosPermitidos, 'jpg');
		}
		return $this->render($parametros['renderizar'], array(
			// 'titulo' => $parametros['titulo'],
			'titulo' => $titulo,
			'migasPan' => $parametros['migasPan'],
			'extensiones_permitidas' => implode(' ', $formatosPermitidos),
			'max_file_size' => $this->redondearBytesAUnidad($this->convertirABytes(ini_get('upload_max_filesize'))),
			'fichero_subido' => $ficheroSubido,
			'nombres_fichero_mostrar' => $nombreFicheroMostrar,
			'fichero_subido_ruta' => $ficheroSubidoRuta,
			$parametros['formularioNombre'] => $formulario->createView()
		));
	}

	private
	function formularioFaseHitoCampoOpcion($parametros)
	{
		$doctrine = $this->getDoctrine();
		if (isset($parametros['entidadPrevia'])) {
			$repositorioPrevio = $doctrine->getRepository($parametros['entidadPrevia']);
			$elementoPrevio = $repositorioPrevio->findOneBy(array(
				$parametros['idNombrePrevio'] => $parametros['idPrevia']
			));
			if (!$elementoPrevio) {
				$this->addFlash('warning', $parametros['mensajeNoEncontradoPrevio']);
				return $this->redirectToRoute($parametros['ruta']);
			} elseif ($parametros['entidadPrevia'] === 'AppBundle\Entity\CampoHito' && $elementoPrevio->getTipo() !== 2 && $elementoPrevio->getTipo() !== 3) {
				$this->addFlash('warning', $parametros['mensajeTipoNoValido']);
				return $this->redirectToRoute($parametros['ruta']);
			}
		}
		$repositorioActual = $doctrine->getRepository($parametros['entidad']);
		if (isset($parametros['obtenerIdObjeto'])) {
			$obtenerIdObjeto = $parametros['obtenerIdObjeto'];
		}
		if (isset($parametros['id'])) {
			if (isset($parametros['idNombrePrevio'])) {
				$elementoActual = $repositorioActual->findOneBy(array(
					$parametros['idNombrePrevio'] => $parametros['idPrevia'],
					$parametros['idNombre'] => $parametros['id']
				));
			} else {
				$elementoActual = $repositorioActual->findOneBy(array(
					$parametros['idNombre'] => $parametros['id']
				));
			}
			if (!$elementoActual) {
				$this->addFlash('warning', $parametros['mensajeNoEncontrado']);
				return $this->redirectToRoute($parametros['ruta']);
			}
			$tipo = $parametros['formularioModificar'];
			$posicionInicial = $elementoActual->getOrden();
			if (isset($elementoPrevio) && isset($obtenerIdObjeto)) {
				$numeroElementos = count($repositorioActual->findBy(array(
					$parametros['idNombrePrevio'] => $elementoPrevio->$obtenerIdObjeto()
				)));
			} else {
				$numeroElementos = count($repositorioActual->findAll());
			}
			if ($parametros['entidad'] === 'AppBundle\Entity\CampoHito') {
				$tipoPrevio = $elementoActual->getTipo();
			}
		} else {
			if (isset($elementoPrevio) && isset($obtenerIdObjeto)) {
				$numeroElementos = count($repositorioActual->findBy(array(
					$parametros['idNombrePrevio'] => $elementoPrevio->$obtenerIdObjeto()
				)));
				if ($parametros['entidadPrevia'] === 'AppBundle\Entity\CampoHito' && ($elementoPrevio->getTipo() === 2) && $numeroElementos > 1) {
					$this->addFlash('warning', $parametros['mensajeBooleanoSolo2Opciones']);
					return $this->redirectToRoute($parametros['ruta']);
				}
			} else {
				$numeroElementos = count($repositorioActual->findAll());
			}
			$tipo = $parametros['formulario'];
			$elementoActual = null;
			$numeroElementos += 1;
			$posicionInicial = $numeroElementos;
		}
		$nombresDesplegable = array();
		for ($i = 0; $i < $numeroElementos; $i += 1) {
			$valorDesplegable = $i + 1;
			$nombresDesplegable[$valorDesplegable . 'º'] = $valorDesplegable;
		}
		$opcionesFormulario = array();
		if (isset($parametros['idNombrePrevio'])) {
			$opcionesFormulario[$parametros['idNombrePrevio']] = $parametros['idPrevia'];
		}
		$opcionesFormulario[$parametros['formularioOpciones'][0]] = $nombresDesplegable;
		$opcionesFormulario[$parametros['formularioOpciones'][1]] = $numeroElementos;
		if ($parametros['entidad'] === 'AppBundle\Entity\OpcionesCampo' && isset($repositorioPrevio) && isset($elementoPrevio)) {
			$fase = $elementoPrevio->getIdGrupoCamposHito()->getIdHito();
			$opcionesFormulario['hitos'] = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase->getIdFase(),
				'hitoCondicional' => true
			));
			$opcionesFormulario['campos_hito'] = $repositorioPrevio->findBy(array(
				'idGrupoCamposHito' => $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
					'idHito' => $doctrine->getRepository(HitoEntidad::class)->findBy(array(
						'idFase' => $doctrine->getRepository(FaseEntidad::class)->findOneBy(array(
							'idFase' => $fase->getIdFase()
						))
					))
				)),
				'campoCondicional' => true
			));
		}
		$formulario = $this->createForm($tipo, $elementoActual, $opcionesFormulario);
		$formulario->handleRequest($parametros['request']);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			if ($formulario->has('final') && $formulario->get('final')->getData()) {
				if (isset($parametros['id'])) {
					$elementos = $repositorioActual->matching(Criteria::create()->where(Criteria::expr()->gt('orden', $posicionInicial)));
					foreach ($elementos as $elemento) {
						$elemento->setOrden($elemento->getOrden() - 1)
							->setFinal(false);
					}
				} else {
					$elementos = $repositorioActual->findBy(array(
						'final' => true
					));
					foreach ($elementos as $elemento) {
						$elemento->setFinal(false);
					}
				}
			} else {
				if ($posicionInicial < $formulario->get('orden')->getData()) {
					for ($i = $formulario->get('orden')->getData(); $i > $posicionInicial; $i -= 1) {
						if (isset($parametros['idNombrePrevio'])) {
							$elemento = $repositorioActual->findOneBy(array(
								$parametros['idNombrePrevio'] => $formulario->get($parametros['idNombrePrevio'])->getData(),
								'orden' => $i
							));
						} else {
							$elemento = $repositorioActual->findOneBy(array(
								'orden' => $i
							));
						}
						if ($elemento) {
							$elemento->setOrden($elemento->getOrden() - 1);
						}
					}
				} else {
					for ($i = $formulario->get('orden')->getData(); $i < $posicionInicial; $i += 1) {
						if (isset($parametros['idNombrePrevio'])) {
							$elemento = $repositorioActual->findOneBy(array(
								$parametros['idNombrePrevio'] => $formulario->get($parametros['idNombrePrevio'])->getData(),
								'orden' => $i
							));
						} else {
							$elemento = $repositorioActual->findOneBy(array(
								'orden' => $i
							));
						}
						if ($elemento) {
							$elemento->setOrden($elemento->getOrden() + 1);
						}
					}
				}
				if (isset($elemento) && method_exists($elemento, 'setFinal') && $i === $numeroElementos) {
					$elemento = $repositorioActual->findOneBy(array(
						'orden' => ($i - 1)
					));
					$elemento->setFinal(true);
				}
			}
			if (isset($tipoPrevio)) {
				if ($tipoPrevio !== $formulario->get('tipo')->getData()) {
					switch ($tipoPrevio) {
						case 2:
							if ($formulario->get('tipo')->getData() !== 3) {
								$elementosDescendientes = $doctrine->getRepository(OpcionesCampoEntidad::class)->findBy(array(
									'idCampoHito' => $elementoActual->getIdCampoHito()
								));
								if ($elementosDescendientes) {
									$this->addFlash('warning', $parametros['mensajeNoSePuedeCambiarTipoCampoHitoConOpciones']);
									return $this->redirectToRoute($parametros['ruta']);
								}
							}
							break;
						case 3:
							if ($formulario->get('tipo')->getData() === 2) {
								$elementosDescendientes = $doctrine->getRepository(OpcionesCampoEntidad::class)->findBy(array(
									'idCampoHito' => $elementoActual->getIdCampoHito()
								));
								if ($elementosDescendientes && count($elementosDescendientes) > 2) {
									$this->addFlash('warning', $parametros['mensajeBooleanoSolo2Opciones']);
									return $this->redirectToRoute($parametros['ruta']);
								}
							} else {
								$elementosDescendientes = $doctrine->getRepository(OpcionesCampoEntidad::class)->findBy(array(
									'idCampoHito' => $elementoActual->getIdCampoHito()
								));
								if ($elementosDescendientes) {
									$this->addFlash('warning', $parametros['mensajeNoSePuedeCambiarTipoCampoHitoConOpciones']);
									return $this->redirectToRoute($parametros['ruta']);
								}
							}
							break;
					}
				}
			}
			$managerEntidad = $doctrine->getManager();
			$managerEntidad->persist($formulario->getData());
			/*$salir = false;
