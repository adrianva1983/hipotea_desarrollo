	public function agregarModificarExpedienteAction(Request $request, RouterInterface $router, $id, Swift_Mailer $mailer)
	{
		if(strpos($request->getPathInfo(),'ClienteColaborador/Formulario/Expediente/Documentos')){
			$irADocumentos = true;
		}else{
			$irADocumentos = false;
		}

		$doctrine = $this->getDoctrine();
		$managerEntidad = $doctrine->getManager();
		if (isset($id)) {
			$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
				'idExpediente' => $id
			));
			if (!$expediente) {
				$this->addFlash('warning', 'El expediente con id="' . $id . '" no existe.');
				return $this->redirectToRoute('lista_expedientes');
			}else{
				$fasePrevia = $expediente->getIdFaseActual();
			}
		} else {
			$primeraFase = $doctrine->getRepository(FaseEntidad::class)->findOneBy(array(
				'orden' => 1
			));
			if ($primeraFase) {
				$expediente = (new ExpedienteEntidad())
					->setIdFaseActual($primeraFase);
				$fasePrevia = $primeraFase;
			} else {
				$this->addFlash('warning', 'No hay fases.');
				return $this->redirectToRoute('lista_expedientes');
			}
		}
		switch ($this->getUser()->getRoles()[0]) {
			case 'ROLE_ADMIN':
				$formularioExpedienteOpciones = array(
					'esAdmin' => true,
					'colaboradores' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'comerciales' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'tecnicos' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)
				);
				break;
			case 'ROLE_COLABORADOR':
				if(!isset($id)){
					$expediente->setIdColaborador($this->getUser());
					$expediente->setIdComercial($this->getUser()->getIdInmobiliaria()->getIdComercial());
				}
				// $formularioExpedienteOpciones['idClienteRequerido'] = true;
				if ($expediente->getIdColaborador() !== $this->getUser()) {
					$this->addFlash('danger', 'El expediente con id="' . $id . '" es de otro colaborador.');
					return $this->redirectToRoute('lista_expedientes');
				}
				break;
			case 'ROLE_COMERCIAL':
				if(!isset($id)){
					$expediente->setIdComercial($this->getUser());
				}
				$formularioExpedienteOpciones = array(
					'esAdmin' => true,
					'colaboradores' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'comerciales' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'tecnicos' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)
				);
				break;
			case 'ROLE_TECNICO':
				if(!isset($id)){
					$expediente->setIdTecnico($this->getUser());
				}
				$formularioExpedienteOpciones = array(
					'esAdmin' => true,
					'colaboradores' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'comerciales' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'tecnicos' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)
				);
				break;
			case 'ROLE_CLIENTE':
				if ($expediente->getIdCliente() !== $this->getUser()) {
					$this->addFlash('danger', 'No tiene acceso al expediente con id="' . $id . '".');
					return $this->redirectToRoute('lista_expedientes');
				}
				break;
			default:
				// $this->addFlash('warning', 'Usuario con rol no válido.');
				// return $this->redirectToRoute('lista_expedientes');
		}

		if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
			$formularioExpedienteOpciones['clientes'] = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->eq('idInmobiliaria', $this->getUser()->getIdInmobiliaria()))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			);
		}elseif ($this->getUser()->getRole() === 'ROLE_CLIENTE') {
			$formularioExpedienteOpciones['clientes'] = $doctrine->getRepository(UsuarioEntidad::class)->findBy(array(
				'idUsuario' => $this->getUser(),
				'role' => 'ROLE_CLIENTE'
			));
		} else {
			$formularioExpedienteOpciones['clientes'] = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			);
		}
		$formularioExpedienteOpciones['nuevo'] = !isset($id);
