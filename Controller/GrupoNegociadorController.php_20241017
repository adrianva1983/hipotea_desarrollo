	public function ordenarFasesHitosCamposOpcionesAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$elementos = json_decode($request->getContent(), true);
			$mensaje = null;
			if (json_last_error() === 0 && isset($elementos[0]) && isset($elementos[0]['id'])) {
				$valido = true;
				$numeroElementos = array(
					count($elementos)
				);
				$elemento = array();
				$doctrine = $this->getDoctrine();
				$repositorio = array(
					$doctrine->getRepository(FaseEntidad::class),
					$doctrine->getRepository(HitoEntidad::class),
					$doctrine->getRepository(GrupoCamposHitoEntidad::class),
					$doctrine->getRepository(CampoHitoEntidad::class),
					$doctrine->getRepository(OpcionesCampoEntidad::class)
				);
				$repositorioExpedientes = array(
					$doctrine->getRepository(ExpedienteEntidad::class),
					$doctrine->getRepository(HitoExpedienteEntidad::class),
					$doctrine->getRepository(CampoHitoExpedienteEntidad::class)
				);
				$ids = array(
					'idFase',
					'idHito',
					'idGrupoCamposHito',
					'idCampoHito',
					'idOpcionesCampo'
				);
				$posicion = array();
				$managerEntidad = $doctrine->getManager();
				$elementoHijo = array();
				for ($i = 0; $valido && $i < $numeroElementos[0]; $i += 1) {
					$elemento[0] = $repositorio[0]->findOneBy(array(
						$ids[0] => $elementos[$i]['id']
					));
					if ($elemento[0]) {
						$posicion[0] = $i + 1;
						if ($elemento[0]->getOrden() !== $posicion[0]) {
							$elemento[0]->setOrden($posicion[0]);
							if ($posicion[0] === $numeroElementos[0] && !$elemento[0]->getFinal()) {
								$elemento[0]->setFinal(true);
							} elseif ($elemento[0]->getFinal()) {
								$elemento[0]->setFinal(false);
							}
							$managerEntidad->persist($elemento[0]);
							/*$expedientes = $repositorioExpedientes[0]->findAll();
							$fases = $repositorio[0]->findAll();
							foreach ($expedientes as $expediente) {
								foreach ($fases as $fase) {
									if ($fase->getOrden() < $expediente->getIdFaseActual()->getOrden()) {
										$hitos = $repositorio[1]->findBy(array(
											$ids[0] => $fase
										));
										$numeroHitos = count($hitos);
										if ($numeroHitos > 0) {
											$hitosExpediente = $repositorioExpedientes[1]->findBy(array(
												$ids[1] => $hitos,
												'idExpediente' => $expediente
											));
											if ($numeroHitos !== count($hitosExpediente)) {
												$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida contiene hitos sin asignar a ningún expediente.';
												$valido = false;
												break 2;
											}
											$hitosExpedienteSinCompletar = $repositorioExpedientes[1]->findBy(array(
												$ids[1] => $hitos,
												'idExpediente' => $expediente,
												'estado' => 0
											));
											if (count($hitosExpedienteSinCompletar) > 0) {
												$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida contiene hitos pendientes.';
												$valido = false;
												break 2;
											}
										} else {
											$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida no contiene ningún hito.';
											$valido = false;
											break 2;
										}
									}
								}
							}*/
						}
						if (isset($elementos[$i]['children'])) {
							$elementoHijo[0] = $elementos[$i]['children'];
							$numeroElementos[1] = count($elementoHijo[0]);
							for ($j = 0; $valido && $j < $numeroElementos[1]; $j += 1) {
								$elemento[1] = $repositorio[1]->findOneBy(array(
									$ids[1] => $elementoHijo[0][$j]['id']
								));
								if ($elemento[1]) {
									if ($elemento[1]->getIdFase() !== $elemento[0]->getIdFase()) {
										/*$hitosExpediente = $repositorioExpedientes[1]->findBy(array(
											$ids[1] => $elemento[1],
											'estado' => 0
										));
										foreach ($hitosExpediente as $hitoExpediente) {
											if ($hitoExpediente && $hitoExpediente->getIdExpediente()->getIdFaseActual()->getOrden() > $elemento[0]->getOrden()) {
												$valido = false;
												$mensaje = 'No se puede cambiar el hito seleccionado a la fase seleccionada debido a que hay algún expediente en una fase superior, y el hito esta pendiente.';
												break;
											}
										}*/
										if ($valido) {
											$elemento[1]->setIdFase($elemento[0]);
											$managerEntidad->persist($elemento[1]);
										}
									}
									if ($valido) {
										$posicion[1] = $j + 1;
										if ($elemento[1]->getOrden() !== $posicion[1]) {
											$elemento[1]->setOrden($posicion[1]);
											$managerEntidad->persist($elemento[1]);
										}
									}
									if (isset($elementoHijo[0][$j]['children'])) {
										$elementoHijo[1] = $elementoHijo[0][$j]['children'];
										$numeroElementos[2] = count($elementoHijo[1]);
										for ($k = 0; $valido && $k < $numeroElementos[2]; $k += 1) {
											$elemento[2] = $repositorio[2]->findOneBy(array(
												$ids[2] => $elementoHijo[1][$k]['id']
											));
											if ($elemento[2]) {
												if ($elemento[2]->getIdHito() !== $elemento[1]->getIdHito()) {
													$elemento[2]->setIdHito($elemento[1]);
													$managerEntidad->persist($elemento[2]);
												}
												$posicion[2] = $k + 1;
												if ($elemento[2]->getOrden() !== $posicion[2]) {
													$elemento[2]->setOrden($posicion[2]);
													$managerEntidad->persist($elemento[2]);
												}
												if (isset($elementoHijo[1][$k]['children'])) {
													$elementoHijo[2] = $elementoHijo[1][$k]['children'];
													$numeroElementos[3] = count($elementoHijo[2]);
													for ($l = 0; $valido && $l < $numeroElementos[3]; $l += 1) {
														$elemento[3] = $repositorio[3]->findOneBy(array(
															$ids[3] => $elementoHijo[2][$l]['id']
														));
														if ($elemento[3]) {
															if ($elemento[3]->getIdGrupoCamposHito() !== $elemento[2]->getIdGrupoCamposHito()) {
																$elemento[3]->setIdGrupoCamposHito($elemento[2]);
																$managerEntidad->persist($elemento[3]);
															}
															$posicion[3] = $l + 1;
															if ($elemento[3]->getOrden() !== $posicion[3]) {
																$elemento[3]->setOrden($posicion[3]);
																$managerEntidad->persist($elemento[3]);
															}
															if (isset($elementoHijo[2][$l]['children'])) {
																$elementoHijo[3] = $elementoHijo[2][$l]['children'];
																$numeroElementos[4] = count($elementoHijo[3]);
																for ($m = 0; $valido && $m < $numeroElementos[4]; $m += 1) {
																	$elemento[4] = $repositorio[4]->findOneBy(array(
																		$ids[4] => $elementoHijo[3][$m]['id']
																	));
																	if ($elemento[4]) {
																		$elementoValorAnterior = $repositorio[3]->findOneBy(array(
																			$ids[3] => $elemento[4]->getIdCampoHito()
																		));
																		if ($elemento[3]->getTipo() !== $elementoValorAnterior->getTipo()) {
																			$valido = false;
																			$mensaje = 'No se puede mover una opcion a un campo de diferente tipo.';
																		} elseif ($elemento[3]->getTipo() === 2 && $numeroElementos[4] > 2) {
																			$valido = false;
																			$mensaje = 'Un campo de tipo verdadero/falso solamente puede contener 2 opciones.';
																		} else {
																			if ($elemento[4]->getIdCampoHito()->getIdCampoHito() !== $elemento[3]->getIdCampoHito()) {
																				if ($elemento[3]->getTipo() === 2 || $elemento[3]->getTipo() === 3) {
																					$campoHitoExpediente = $repositorioExpedientes[3]->findOneBy(array(
																						$ids[4] => $elemento[4]->getIdOpcionesCampo()
																					));
																				}
																				if (isset($campoHitoExpediente) && $campoHitoExpediente) {
																					$valido = false;
																					$mensaje = 'No se puede cambiar la opción de un campo a otro, ya que dicha opción esta seleccionada en algún expediente.';
																				}
																				$elemento[4]->setIdCampoHito($elemento[3]);
																				$managerEntidad->persist($elemento[4]);
																			}
																			$posicion[4] = $m + 1;
																			if ($elemento[4]->getOrden() !== $posicion[4]) {
																				$elemento[4]->setOrden($posicion[4]);
																				$managerEntidad->persist($elemento[4]);
																			}
																		}
																	} else {
																		$valido = false;
																		$mensaje = 'El campo "opciones campo" con id="' . $elementoHijo[3][$m]['id'] . '" no existe.';
																	}
																}
															}
														} else {
															$valido = false;
															$mensaje = 'El grupo de campos hito con id="' . $elementoHijo[2][$l]['id'] . '" no existe.';
														}
													}
												}
											} else {
												$valido = false;
												$mensaje = 'El campo hito con id="' . $elementoHijo[1][$k]['id'] . '" no existe.';
											}
										}
									}
								} else {
									$valido = false;
									$mensaje = 'El hito con id="' . $elementoHijo[0][$j]['id'] . '" no existe.';
								}
							}
						}
					} else {
						$valido = false;
						$mensaje = 'La fase con id="' . $elementos[$i]['id'] . '" no existe.';
					}
				}
				if ($valido) {
					$managerEntidad->flush();
					return $this->json(array(
						'error' => false
					));
				}
			}
			return $this->json(array(
				'error' => true,
				'mensaje' => $mensaje
			));
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	
	public function refrescarUsuariosColaboradorAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$respuesta = array();
			$respuesta['error'] = 0;
			$idInmobiliaria = $request->get('inmobiliaria');
			$nombreUsuario = $request->get('usuario');
			if ($nombreUsuario == null){
				$nombreUsuario = "";
			}

			$mensaje = null;
			if (json_last_error() === 0 && $idInmobiliaria) {

				$doctrine = $this->getDoctrine();

				$inmobiliaria = $doctrine->getRepository(InmobiliariaEntidad::class)->findOneBy(array(
					'idInmobiliaria' => $idInmobiliaria
				));
				if($inmobiliaria){
					if($nombreUsuario != ""){
						$colaboradores = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('idInmobiliaria', $inmobiliaria))
						->andWhere(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
						// ->andWhere(Criteria::expr()->eq('nombre', $nombreUsuario))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->contains('nombre', $nombreUsuario),
							Criteria::expr()->contains('apellidos', $nombreUsuario)
						))
						// ->addOrderBy('apellidos', 'ASC')
						// ->addOrderBy('nombre', 'ASC')
					)->toArray();
					}else{
						$colaboradores = $doctrine->getRepository(UsuarioEntidad::class)->findBy(array(
							'idInmobiliaria' => $inmobiliaria,
							'role' => 'ROLE_COLABORADOR'
						), array(
							'apellidos' => 'ASC',
							'nombre' => 'ASC'
						));
					}
					// 
					$datos = array();
					foreach ($colaboradores as $colaborador) {
						$campo = array(
							// 'id' => $medicamento->getIdMedicamento(),
							'id' => $colaborador->getIdUsuario(),
							'text' => $colaborador->getApellidos().','.$colaborador->getUsername()
						);
						$datos[]= $campo;									
					}
					$respuesta['datos'] = $datos;
				}else{
					$respuesta['error'] = 1;
				}
			}
			return new JsonResponse($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function listaClientesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$entradasSeleccionadas = $request->get('cliente');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idUsuario' => $entrada
				));
				if ($entidad) {
					$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$documentos = $doctrine->getRepository(DocumentoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$expedientes = $doctrine->getRepository(ExpedienteEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$noticias = $doctrine->getRepository(NoticiaUsuarioEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$notificaciones = $doctrine->getRepository(NotificacionEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$seguimientosHorarios = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					if (count($documentos) === 0 && count($expedientes) === 0 && count($noticias) === 0 && count($notificaciones) === 0 && count($seguimientosHorarios) === 0) {
						foreach($dispositivos as $dispositivo){
							$managerEntidad->remove($dispositivo);
						}
						foreach($logs as $log){
							$managerEntidad->remove($log);
						}
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrado el cliente con id=',
					'Han sido borrados los clientes con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha podido borrar el cliente con id=',
					'No se han podido borrar los clientes con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado el cliente con id=',
					'No se han encontrado los clientes con ids',
					' y '
				)));
			}
		}
		if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
			$clientes = $repositorio->findBy(array(
				'role' => 'ROLE_CLIENTE',
				'idInmobiliaria' => $this->getUser()->getIdInmobiliaria()
			));
		} else {
			$clientes = $repositorio->findBy(array(
				'role' => 'ROLE_CLIENTE'
			));
		}
		return $this->render('@App/Backoffice/Lista/Cliente.html.twig', array(
			'titulo' => 'Lista de clientes',
			'clientes' => $clientes
		));
	}

	public function agregarModificarClienteAction(Request $request, RouterInterface $router, UserPasswordEncoderInterface $passwordEncoder, $id)
	{
		return $this->formularioUsuario(array(
