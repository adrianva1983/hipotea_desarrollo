								$ficherosCampoAReemplazar[$indice - 1]->setNombreFichero($ficheroCampoAReemplazar->getNombreFichero());
								$ficheroCampoAReemplazar->setNombreFichero($aux);
								$managerEntidad->persist($ficherosCampoAReemplazar[$indice - 1]);
