	}

	public function listaExpedientesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio['expedientes'] = $doctrine->getRepository(ExpedienteEntidad::class);
		$repositorio['usuarios'] = $doctrine->getRepository(UsuarioEntidad::class);
		$repositorio['camposHitoExpediente'] = $doctrine->getRepository(CampoHitoExpedienteEntidad::class);
		$repositorio['camposHito'] = $doctrine->getRepository(CampoHitoEntidad::class);
		if ($this->getUser()->getRoles()[0] !== 'ROLE_CLIENTE') {
			$entradasSeleccionadas = $request->get('expediente');
			if (!is_null($entradasSeleccionadas)) {
				$managerEntidad = $doctrine->getManager();
				$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
				foreach ($entradasSeleccionadas as $entrada) {
					$entidad = $repositorio['expedientes']->find($entrada);
					if ($entidad) {
						if ($this->borrarExpedientes($managerEntidad, $entidad)) {
							$managerEntidad->remove($entidad);
							$elementosBorrados[] = $entrada;
						} else {
							$elementosNoBorrados[] = $entrada;
						}
					} else {
						$elementosNoEncontrados[] = $entrada;
					}
				}
				$managerEntidad->flush();
				if (count($elementosBorrados) > 0) {
					$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
						'Ha sido borrado el expediente con id=',
						'Han sido borrados los expedientes con ids',
						' y '
					)));
				}
				if (count($elementosNoBorrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
						'No se ha podido borrar el expediente con id=',
						'No se han podido borrar los expedientes con ids',
						' y '
					)));
				}
				if (count($elementosNoEncontrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
						'No se ha encontrado el expediente con id=',
						'No se han encontrado los expedientes con ids',
						' y '
					)));
				}
			}
		}
		switch ($this->getUser()->getRoles()[0]) {
			case 'ROLE_COLABORADOR':
				$expedientes = $repositorio['expedientes']->findBy(array(
					'idColaborador' => $repositorio['usuarios']->matching(Criteria::create()
						->where(Criteria::expr()->eq('idInmobiliaria', $this->getUser()->getIdInmobiliaria()))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)->toArray(),
					'estado' => 1
				));
				break;
			case 'ROLE_CLIENTE':
				$expedientes = $repositorio['expedientes']->matching(Criteria::create()
					->where(Criteria::expr()->eq('idCliente', $this->getUser()))
					->andWhere(Criteria::expr()->gt('estado', 0))
				);
				break;
			default:
				$expedientes = $repositorio['expedientes']->findAll();
		}
		$formularioNotificacionExpediente = $this->createForm(NotificacionExpediente::class);
		// Ahora recuperamos los campos email, telefono de los formularios web
		$camposPersonalizados = [];
		$campoHitoEmail = $repositorio['camposHito']->matching(Criteria::create()
			->where(Criteria::expr()->eq('idCampoHito', 407))
		);
		$campoHitoTelefono = $repositorio['camposHito']->matching(Criteria::create()
			->where(Criteria::expr()->eq('idCampoHito', 408))
		);
		$i = 0;
		foreach ($expedientes as $expediente) {
			$campoExpedienteEmail = $repositorio['camposHitoExpediente']->matching(Criteria::create()
				->where(Criteria::expr()->eq('idExpediente', $expediente))
				->andWhere(Criteria::expr()->eq('idCampoHito', $campoHitoEmail[0]))
			);
			$campoExpedienteTelefono = $repositorio['camposHitoExpediente']->matching(Criteria::create()
				->where(Criteria::expr()->eq('idExpediente', $expediente))
				->andWhere(Criteria::expr()->eq('idCampoHito', $campoHitoTelefono[0]))
			);
			$camposPersonalizados[$expediente->getIdExpediente()] = [
				"email" => ($campoExpedienteEmail[0]==null?"":($campoExpedienteEmail[0])->getValor()),
				"telefono" => ($campoExpedienteTelefono[0]==null?"":($campoExpedienteTelefono[0])->getValor())
			];
		}
		
		return $this->render('@App/Backoffice/Lista/Expediente.html.twig', array(
			'titulo' => 'Lista de expedientes',
			'expedientes' => $expedientes,
			'camposPersonalizados' => $camposPersonalizados,
			'sinAsignar' => false,
			'clientes' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_CLIENTE'
			)),
			'colaboradores' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_COLABORADOR'
			)),
			'comerciales' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_COMERCIAL'
			)),
			'tecnicos' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_TECNICO'
			)),
			'formularioNotificacionExpediente' => $formularioNotificacionExpediente->createView()
		));
	}

