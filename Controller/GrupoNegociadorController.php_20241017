												->setParameter('idTecnico', $tecnico);
										}

										$expedientes = $exp->groupBy('col.idInmobiliaria')
											->getQuery()
											->getResult();

										foreach($expedientes as $expediente){
											$columnas[]= $expediente['nombre'];
											$valores[]= $expediente['num'];
										}
									// }
									$respuesta['columnas'] = $columnas;
									$respuesta['valores'] = $valores;

								}else{
									$exp = $doctrine->getRepository(ExpedienteEntidad::class)->createQueryBuilder('ex')
									->select(['inm.nombre as nombre','count(ex) as num'])
									->innerJoin('AppBundle:Usuario', 'col', 'WITH' , 'col.idUsuario = ex.idColaborador')
									->innerJoin('AppBundle:Inmobiliaria', 'inm', 'WITH' , 'inm.idInmobiliaria = col.idInmobiliaria')
									->where('ex.estado = :estado')
									->andWhere('ex.fechaCreacion >= :desde')
									->andWhere('ex.fechaCreacion <= :hasta')
									->setParameter('estado', 1)
									->setParameter('desde', $fechaInicio)
									->setParameter('hasta', $fechaFin);
									
									if(count($comercial)>0){
										$exp->andWhere('ex.idComercial IN (:idComercial)')
											->setParameter('idComercial', $comercial);
									}

									if(count($tecnico)>0){
										$exp->andWhere('ex.idTecnico IN (:idTecnico)')
											->setParameter('idTecnico', $tecnico);
									}

									$expedientes = $exp->groupBy('inm.idInmobiliaria')
										->getQuery()
										->getResult();

									foreach($expedientes as $expediente){
										$columnas[]= $expediente['nombre'];
										$valores[]= $expediente['num'];
									}
									$respuesta['columnas'] = $columnas;
									$respuesta['valores'] = $valores;
								}
								break;
						}
						break;
					case "5": // Porcentaje de Transformación		
						$columnas = array();
						$valores = array();

						$exp = $doctrine->getRepository(ExpedienteEntidad::class)->createQueryBuilder('ex')
							->select(['ex.estado as nombre','count(ex) as num'])
							->where('ex.estado IN (0,2)')
							->andWhere('ex.fechaCreacion >= :desde')
							->andWhere('ex.fechaCreacion <= :hasta')
							->setParameter('desde', $fechaInicio)
							->setParameter('hasta', $fechaFin);

						if(count($comercial)>0){
							$exp->andWhere('ex.idComercial IN (:idComercial)')
								->setParameter('idComercial', $comercial);
						}

						if(count($tecnico)>0){
							$exp->andWhere('ex.idTecnico IN (:idTecnico)')
								->setParameter('idTecnico', $tecnico);
						}

						if(count($inmobiliaria)>0){
							$exp->innerJoin('AppBundle:Usuario', 'col', 'WITH' , 'col.idInmobiliaria IN (:inmobiliaria)')
								->setParameter('inmobiliaria', $inmobiliaria)
								->andWhere('ex.idColaborador = col.idUsuario');
						}

						if(count($entidadColaboradora)>0){
							$exp->innerJoin('AppBundle:CampoHitoExpediente', 'campo', 'WITH' , 'campo.idExpediente = ex.idExpediente')
								->innerJoin('AppBundle:AgenteColaborador', 'a', 'WITH' , 'a.idAgenteColaborador = campo.idAgenteColaborador')
								->innerJoin('AppBundle:EntidadColaboradora', 'ent', 'WITH' , 'ent.idEntidadColaboradora = a.idEntidadColaboradora')
								->andWhere('ent.idEntidadColaboradora IN (:entidades)')
								->setParameter('entidades', $entidadColaboradora);
						}

						$expedientes = $exp->groupBy('ex.estado')
							->getQuery()
							->getResult();

						$total = 0;
						foreach($expedientes as $expediente){
							if($expediente['nombre']=="0"){
								$estado = "Cancelado";
							}else{
								$estado = "Firmado";
							}
							$columnas[]= $estado;
							$valores[]= $expediente['num'];
							$total += $expediente['num'];
						}

						if($agrupar == 'porcentaje'){
							for($i=0;$i<count($valores);$i++){
								$porcentaje = round($valores[$i]*100/$total,2);
								$valores[$i] = $porcentaje;
							}
						}
						$respuesta['columnas'] = $columnas;
						$respuesta['valores'] = $valores;

						break;
					case "6": // Calendario		
						switch($agrupar){
							case "tecnicos-comerciales":
								$columnas = array();
								$valores = array();

								$vis = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->createQueryBuilder('cal')
									->select(['CONCAT(u.nombre, \' \',u.apellidos) as nombre','count(cal) as num'])
									->innerJoin('AppBundle:Usuario', 'u', 'WITH' , 'cal.idUsuario = u.idUsuario')
									->where('cal.estado IN (2)')
									->andWhere('cal.fechaInicio >= :desde')
									->andWhere('cal.fechaInicio <= :hasta')
									->setParameter('desde', $fechaInicio)
									->setParameter('hasta', $fechaFin);

								if(count($tecnicosComerciales)>0){
									$vis->andWhere('cal.idUsuario IN (:tecnicosComerciales)')
										->setParameter('tecnicosComerciales', $tecnicosComerciales);
								}

								if(count($inmobiliaria)>0){
									$vis->andWhere('cal.idInmobiliaria IN (:inmobiliaria)')
										->setParameter('inmobiliaria', $inmobiliaria);
								}

								$visitas = $vis->groupBy('cal.idUsuario')
									->getQuery()
									->getResult();

								foreach($visitas as $visita){
									$columnas[]= $visita['nombre'];
									$valores[]= $visita['num'];
								}

								
								$respuesta['columnas'] = $columnas;
								$respuesta['valores'] = $valores;
								break;
							case "inmobiliarias":
								$columnas = array();
								$valores = array();

								$vis = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->createQueryBuilder('cal')
									->select(['i.nombre as nombre','count(cal) as num'])
									->innerJoin('AppBundle:Inmobiliaria', 'i', 'WITH' , 'cal.idInmobiliaria = i.idInmobiliaria')
									->where('cal.estado IN (2)')
									->andWhere('cal.fechaInicio >= :desde')
									->andWhere('cal.fechaInicio <= :hasta')
									->setParameter('desde', $fechaInicio)
									->setParameter('hasta', $fechaFin);

								if(count($tecnicosComerciales)>0){
									$vis->andWhere('cal.idUsuario IN (:tecnicosComerciales)')
										->setParameter('tecnicosComerciales', $tecnicosComerciales);
								}

								if(count($inmobiliaria)>0){
									$vis->andWhere('cal.idInmobiliaria IN (:inmobiliaria)')
										->setParameter('inmobiliaria', $inmobiliaria);
								}

								$visitas = $vis->groupBy('cal.idInmobiliaria')
									->getQuery()
									->getResult();

								foreach($visitas as $visita){
									$columnas[]= $visita['nombre'];
									$valores[]= $visita['num'];
								}

								
								$respuesta['columnas'] = $columnas;
								$respuesta['valores'] = $valores;
								break;
						break;
						}

						// AHORA EL LISTADO DE VISITAS
						$vis = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->createQueryBuilder('cal')
							->select(['CONCAT(u.nombre, \' \',u.apellidos) as nombre','i.nombre as inmobiliaria','CONCAT(cli.nombre, \' \',cli.apellidos) as cliente','cal.tipo','cal.datosCliente','cal.observaciones','cal.fechaInicio','cal.fechaFin'])
							->leftJoin('AppBundle:Usuario', 'cli', 'WITH' , 'cal.idCliente = cli.idUsuario')
							->where('cal.estado IN (2)')
							->andWhere('cal.fechaInicio >= :desde')
							->andWhere('cal.fechaInicio <= :hasta')
							->setParameter('desde', $fechaInicio)
							->setParameter('hasta', $fechaFin);

						if($agrupar == "tecnicos-comerciales"){
							$vis->innerJoin('AppBundle:Usuario', 'u', 'WITH' , 'cal.idUsuario = u.idUsuario')
								->leftJoin('AppBundle:Inmobiliaria', 'i', 'WITH' , 'cal.idInmobiliaria = i.idInmobiliaria');
						}else{
							$vis->leftJoin('AppBundle:Usuario', 'u', 'WITH' , 'cal.idUsuario = u.idUsuario')
								->innerJoin('AppBundle:Inmobiliaria', 'i', 'WITH' , 'cal.idInmobiliaria = i.idInmobiliaria');
						}

						if(count($tecnicosComerciales)>0){
							$vis->andWhere('cal.idUsuario IN (:tecnicosComerciales)')
								->setParameter('tecnicosComerciales', $tecnicosComerciales);
						}

						if(count($inmobiliaria)>0){
							$vis->andWhere('cal.idInmobiliaria IN (:inmobiliaria)')
								->setParameter('inmobiliaria', $inmobiliaria);
						}

						$visitas = $vis->orderBy('cal.fechaInicio','DESC')->getQuery()
							->getResult();

						$arrayVisitas = array();
						foreach($visitas as $visita){
							$fechaInicio = $visita['fechaInicio'];
							$fechaInicio = $fechaInicio->format('d/m/Y');
							$fechaFin = $visita['fechaFin'];
							$fechaFin = $fechaFin->format('d/m/Y');
							array_push($arrayVisitas,[
								$visita['nombre'],
								$visita['inmobiliaria'],
								$visita['cliente'],
								$visita['tipo'],
								$visita['datosCliente'],
								$visita['observaciones'],
								$fechaInicio,
								$fechaFin
							]);
						}

						$respuesta['visitas'] = $arrayVisitas;
					}
				
			}
			return new JsonResponse($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}
}
