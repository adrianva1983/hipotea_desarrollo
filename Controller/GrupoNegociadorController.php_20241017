	public function agregarModificarInmobiliariaAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$elementos = $repositorio->matching(Criteria::create()
			->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
			->andWhere(Criteria::expr()->orX(
				Criteria::expr()->gte('fechaCaducidad', new DateTime()),
				Criteria::expr()->isNull('fechaCaducidad')
			))
			->andWhere(Criteria::expr()->eq('estado', true))
		);
		if ($elementos->count() === 0) {
			$this->addFlash('warning', 'No hay comerciales activos.');
			return $this->redirectToRoute('lista_inmobiliarias');
		}

		$titulo = 'Agregar/Modificar inmobiliaria';
		if($id){
			$repositorio = $doctrine->getRepository(InmobiliariaEntidad::class);
			$inmobiliaria = $repositorio->findOneBy(array(
				'idInmobiliaria' => $id
			));

			if($inmobiliaria){
				$titulo = $inmobiliaria->getNombre();
			}
		}

		return $this->formularioEntidad(array(
			'id' => $id,
			'entidad' => InmobiliariaEntidad::class,
			'idEntidad' => 'idInmobiliaria',
			'elementoNoExiste' => 'El colaborador con id="' . $id . '" no existe.',
			'ruta' => 'lista_inmobiliarias',
			'formulario' => InmobiliariaFormulario::class,
			'formularioOpciones' => array(
				'comerciales' => $elementos
			),
			'request' => $request,
			'formularioMensaje' => 'El colaborador ha sido añadido/modificado correctamente.',
			'renderizar' => '@App/Backoffice/AgregarModificar/Inmobiliaria.html.twig',
			'titulo' => $titulo,
			'migasPan' => array(
				array(
					'vista' => 'Lista de colaboradores',
					'url' => $router->generate('lista_inmobiliarias')
				)
			),
			'formularioNombre' => 'agregarModificarInmobiliaria'
		));
	}

	public function listaUsuariosAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$entradasSeleccionadas = $request->get('usuario');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idUsuario' => $entrada
				));
				if ($entidad) {
					$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$documentos = $doctrine->getRepository(DocumentoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$expedientes = $doctrine->getRepository(ExpedienteEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('idCliente', $entidad))
						->orWhere(Criteria::expr()->eq('idColaborador', $entidad))
						->orWhere(Criteria::expr()->eq('idComercial', $entidad))
						->orWhere(Criteria::expr()->eq('idTecnico', $entidad))
					);
					$inmobiliarias = $doctrine->getRepository(InmobiliariaEntidad::class)->findBy(array(
						'idComercial' => $entidad
					));
					$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$noticias = $doctrine->getRepository(NoticiaEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$notificaciones = $doctrine->getRepository(NotificacionEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$seguimientosHorarios = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('idUsuario', $entidad))
						->orWhere(Criteria::expr()->eq('idCliente', $entidad))
					);
					if (count($dispositivos) === 0 && count($documentos) === 0 && count($expedientes) === 0 && count($inmobiliarias) === 0 && count($logs) === 0 && count($noticias) === 0 && count($notificaciones) === 0 && count($seguimientosHorarios) === 0) {
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrado el usuario con id=',
					'Han sido borrados los usuarios con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha podido borrar el usuario con id=',
					'No se han podido borrar los usuario con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado el usuario con id=',
					'No se han encontrado los usuarios con ids',
					' y '
				)));
			}
		}
		$roles = array('ROLE_ADMIN','ROLE_COMERCIAL','ROLE_TECNICO');
		return $this->render('@App/Backoffice/Lista/Usuario.html.twig', array(
			'titulo' => 'Lista de usuarios',
			'usuarios' => $repositorio->findBy(
				array(
					'role' => $roles
				)
			)
		));
	}

