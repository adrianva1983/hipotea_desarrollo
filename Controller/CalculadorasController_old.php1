						$variablesTwig['intereses_ahorro'] = $resultado['intereses_ahorro'];

						$variablesTwig['primerosAnios'] = $resultado['primerosAnios'];
						$variablesTwig['vinculaciones'] = $resultado['vinculaciones'];
					}elseif($tipoHipoteca == 2) { // Mixta
