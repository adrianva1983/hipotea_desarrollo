	public function listaFasesHitosCamposOpcionesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		if (!is_null($request->get('borrar-entidades'))) {
			$entradas = array(
				$request->get('borrar-opciones-campo'),
				$request->get('borrar-campo-hito'),
				$request->get('borrar-grupo-campos-hito'),
				$request->get('borrar-hito'),
				$request->get('borrar-fase')
			);
			$numeroEntradas = count($entradas);
			$repositorios = array(
				OpcionesCampoEntidad::class,
				CampoHitoEntidad::class,
				GrupoCamposHitoEntidad::class,
				HitoEntidad::class,
				FaseEntidad::class
			);
			$ids = array(
				'idOpcionesCampo',
				'idCampoHito',
				'idGrupoCamposHito',
				'idHito',
				'idFase'
			);
			$managerEntidad = $doctrine->getManager();
			$obtenerIdPrevia = array(
				'getIdCampoHito',
				'getIdGrupoCamposHito',
				'getIdHito',
				'getIdFase'
			);
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			for ($i = 0; $i < $numeroEntradas; $i += 1) {
				if (!is_null($entradas[$i])) {
					$repositorio = $doctrine->getRepository($repositorios[$i]);
					foreach ($entradas[$i] as $entrada) {
						$entidad = $repositorio->findOneBy(array(
							$ids[$i] => $entrada
						));
						if ($entidad) {
							$continuar = true;
							if ($i < 4) {
								switch ($i) {
									case 0:
										$entidadExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findBy(array(
											'idOpcionesCampo' => $entidad
										));
										break;
									case 1:
										$entidadExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findBy(array(
											'idCampoHito' => $entidad
										));
										break;
									case 3:
										$entidadExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
											'idHito' => $entidad
										));
										break;
								}
								if (isset($entidadExpediente) && count($entidadExpediente) > 0) {
									if (!$this->borrarCamposExpedientes($entidadExpediente)) {
										$continuar = false;
										$elementosNoBorrados[$i][] = $entrada;
									}
								}
							}
							if ($continuar) {
								if ($i !== 0) {
									$repositorioHijo = $doctrine->getRepository($repositorios[$i - 1]);
									$elementoMetadatos = $managerEntidad->getMetadataFactory()->getMetadataFor(get_class($entidad));
									$idArray = $elementoMetadatos->getIdentifierValues($entidad);
									$elementoHijo = $repositorioHijo->findOneBy(array(
										key($idArray) => $idArray[key($idArray)]
									));
									if ($elementoHijo) {
										$elementosNoBorrados[$i][] = $entrada;
									}
								}
								if ($i === 0 || empty($elementoHijo)) {
									if ($i < $numeroEntradas - 1) {
										$elementosSiguientes = $repositorio->matching(Criteria::create()
											->where(Criteria::expr()->eq($ids[$i + 1], $entidad->{$obtenerIdPrevia[$i]}()))
											->andWhere(Criteria::expr()->gt('orden', $entidad->getOrden()))
										);
									} else {
										$elementosSiguientes = $repositorio->matching(Criteria::create()->where(Criteria::expr()->gt('orden', $entidad->getOrden())));
									}
									if (count($elementosSiguientes) > 0) {
										foreach ($elementosSiguientes as $elementoSiguiente) {
											$elementoSiguiente->setOrden($elementoSiguiente->getOrden() - 1);
										}
									} elseif (method_exists($entidad, 'getFinal')) {
										$elementoAnterior = $repositorio->findOneBy(array(
											'orden' => $entidad->getOrden() - 1
										));
										if ($elementoAnterior) {
											$elementoAnterior->setFinal(true);
										}
									}
									$managerEntidad->remove($entidad);
									$elementosBorrados[$i][] = $entrada;
								}
								$managerEntidad->flush();
							}
						} else {
							$elementosNoEncontrados[$i][] = $entrada;
						}
					}
				}
			}
			foreach ($elementosBorrados as $clave => $valor) {
				$this->crearMensajeBorrarFasesHitosCamposOpciones($clave, $valor, array(
					'tipo' => 'success',
					'opcion' => 'Ha sido borrada la opcion con id=',
					'opciones' => 'Han sido borradas las opciones con ids',
					'campo' => 'Ha sido borrado el campo hito con id=',
					'campos' => 'Han sido borrados los campos hito con ids',
					'grupo' => 'Ha sido borrado el grupo de campos hito con id=',
					'grupos' => 'Han sido borrados los grupos de campos hito con ids',
					'hito' => 'Ha sido borrado el hito con id=',
					'hitos' => 'Han sido borrados los hitos con ids',
					'fase' => 'Ha sido borrada la fase con id=',
					'fases' => 'Han sido borradas las fases con ids'
				));
			}
			foreach ($elementosNoBorrados as $clave => $valor) {
				$this->crearMensajeBorrarFasesHitosCamposOpciones($clave, $valor, array(
					'tipo' => 'warning',
					'opcion' => 'No se ha podido borrar la opcion con id=',
					'opciones' => 'No se han podido borrar las opciones con ids',
					'campo' => 'No se ha podido borrar el campo hito con id=',
					'campos' => 'No se han podido borrar los campos hito con ids',
					'grupo' => 'No se ha podido borrar el grupo de campos hito con id=',
					'grupos' => 'No se han podido borrar los grupos de campos hito con ids',
					'hito' => 'No se ha podido borrar el hito con id=',
					'hitos' => 'No se han podido borrar los hitos con ids',
					'fase' => 'No se ha podido borrar la fase con id=',
					'fases' => 'No se han podido borrar las fases con ids'
				));
			}
			foreach ($elementosNoEncontrados as $clave => $valor) {
				$this->crearMensajeBorrarFasesHitosCamposOpciones($clave, $valor, array(
					'tipo' => 'danger',
					'opcion' => 'No se ha encontrado la opcion con id=',
					'opciones' => 'No se han encontrado las opciones con ids',
					'campo' => 'No se ha encontrado el campo hito con id=',
					'campos' => 'No se han encontrado los campos hito con ids',
					'grupo' => 'No se ha encontrado el grupo de campos hito con id=',
					'grupos' => 'No se han encontrado los grupos de campos hito con ids',
					'hito' => 'No se ha encontrado el hito con id=',
					'hitos' => 'No se han encontrado los hitos con ids',
					'fase' => 'No se ha encontrado la fase con id=',
					'fases' => 'No se han encontrado las fases con ids'
				));
			}
		}
		$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(), array(
			'orden' => 'ASC'
		));
		$hitos = array();
		$gruposCamposHito = array();
		$camposHito = array();
		$opcionesCampo = array();
		foreach ($fases as $fase) {
			$hitos[$fase->getIdFase()] = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase->getIdFase()
			), array(
				'orden' => 'ASC'
			));
			foreach ($hitos[$fase->getIdFase()] as $hito) {
				$gruposCamposHito[$hito->getIdHito()] = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
					'idHito' => $hito->getIdHito()
				), array(
					'orden' => 'ASC'
				));
				foreach ($gruposCamposHito[$hito->getIdHito()] as $grupoCamposHito) {
					$camposHito[$grupoCamposHito->getIdGrupoCamposHito()] = $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
						'idGrupoCamposHito' => $grupoCamposHito->getIdGrupoCamposHito()
					), array(
						'orden' => 'ASC'
					));
					foreach ($camposHito[$grupoCamposHito->getIdGrupoCamposHito()] as $campoHito) {
						$opcionesCampo[$campoHito->getIdCampoHito()] = $doctrine->getRepository(OpcionesCampoEntidad::class)->findBy(array(
							'idCampoHito' => $campoHito->getIdCampoHito()
						), array(
							'orden' => 'ASC'
						));
					}
				}
			}
		}
		return $this->render('@App/Backoffice/Lista/FasesHitosCamposOpciones.html.twig', array(
			'titulo' => 'Lista de fases, hitos, campos y opciones',
			'fases' => $fases,
			'hitos' => $hitos,
			'grupos_campos_hito' => $gruposCamposHito,
			'campos_hito' => $camposHito,
			'opciones_campo' => $opcionesCampo
		));
	}

	public function agregarModificarFaseAction(Request $request, RouterInterface $router, $id)
	{
		if (!isset($id)) {
			$expedientes = $this->getDoctrine()->getRepository(ExpedienteEntidad::class)->findBy(array(
				'estado' => 2
			));
			if (count($expedientes) > 0) {
				$this->addFlash('warning', 'No se puede añadir una fase debido a que hay al menos un expediente finalizado.');
				return $this->redirectToRoute('lista_fases_hitos_campos_opciones');
			}
		}
		return $this->formularioFaseHitoCampoOpcion(array(
			'ruta' => 'lista_fases_hitos_campos_opciones',
			'entidad' => FaseEntidad::class,
			'idNombre' => 'idFase',
			'id' => $id,
