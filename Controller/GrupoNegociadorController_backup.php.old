	public function crearNotificacionesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$helpers = $this->get("app.helpers");
		$formulario = $this->createForm(NotificacionFormulario::class, null, array(
			'clientes' => $repositorio->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			)
		));
		if ($request->isMethod('POST')) {
			$notificacion = array();
			$managerEntidad = $doctrine->getManager();
			$id_devices = array();
			$contenidoFormulario = $request->request->get($formulario->getName());
			if (isset($contenidoFormulario['idUsuario'])) {
				$usuariosNoEncontrados = array();
				foreach ($contenidoFormulario['idUsuario'] as $idUsuario) {
					$usuario = $repositorio->findOneBy(array(
						'idUsuario' => $idUsuario
					));
					if ($usuario) {
						$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findAll(array(
							'idUsuario' => $usuario
						));
						foreach ($dispositivos as $dispositivo) {
							$id_devices[] = $dispositivo->getIdentificador();
						}
						$notificacion[] = new NotificacionEntidad();
						end($notificacion)->setIdUsuario($usuario);
						/*if (!empty($contenidoFormulario['idExpediente'])) {
							$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
								'idExpediente' => $contenidoFormulario['idExpediente']
							));
							if ($expediente) {
								end($notificacion)->setIdExpediente($expediente);
							} else {
								$this->addFlash('warning', 'No se ha encontrado el expediente con id="' . $contenidoFormulario['idExpediente'] . '".');
								return $this->redirectToRoute('crear_notificaciones');
							}
						}*/
						if (!empty($contenidoFormulario['titulo'])) {
							end($notificacion)->setTitulo($contenidoFormulario['titulo']);
						}
						end($notificacion)->setTexto($contenidoFormulario['texto'])
							->setFecha(new DateTime());
						$managerEntidad->persist(end($notificacion));
					} else {
						$usuariosNoEncontrados[] = $idUsuario;
					}
				}
				if (count($usuariosNoEncontrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($usuariosNoEncontrados, array(
						'No se ha encontrado el usuario con id=',
						'No se han encontrado los usuarios con ids',
						' y '
					)));
				}
			} else {
				$usuarios = $repositorio->matching(Criteria::create()
					->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
					->andWhere(Criteria::expr()->orX(
						Criteria::expr()->gte('fechaCaducidad', new DateTime()),
						Criteria::expr()->isNull('fechaCaducidad')
					))
					->andWhere(Criteria::expr()->eq('estado', true))
				);
				if (count($usuarios) > 0) {
					foreach ($usuarios as $usuario) {
						$notificacion[] = new NotificacionEntidad();
						end($notificacion)->setIdUsuario($usuario);
						/*if (!empty($contenidoFormulario['idExpediente'])) {
							$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
								'idExpediente' => $contenidoFormulario['idExpediente']
							));
							if ($expediente) {
								end($notificacion)->setIdExpediente($expediente);
							} else {
								$this->addFlash('warning', 'No se ha encontrado el expediente con id="' . $contenidoFormulario['idExpediente'] . '".');
								return $this->redirectToRoute('crear_notificaciones');
							}
						}*/
						if (!empty($contenidoFormulario['titulo'])) {
							end($notificacion)->setTitulo($contenidoFormulario['titulo']);
						}
						end($notificacion)->setTexto($contenidoFormulario['texto'])
							->setFecha(new DateTime());
						$managerEntidad->persist(end($notificacion));
					}
				}
			}
			if (count($notificacion) > 0) {
				$managerEntidad->flush();
				// Ahora enviamos la notificacion PUSH
				$mensaje = end($notificacion)->getTexto();
				$titulo = 'Información';
				$destinatario = '';
				$expediente = '';
				$grupo_destinatarios = $id_devices;
				if (count($id_devices) === 1) {
					$destinatario = $id_devices[0];
				}
				$helpers->sendFCM($mensaje, $titulo, $destinatario, $grupo_destinatarios, $expediente);
				if (count($notificacion) > 1) {
					$this->addFlash('success', 'Las notificaciones se han creado correctamente.');
				} else {
					$this->addFlash('success', 'La notificación se ha creado correctamente.');
				}
				return $this->redirectToRoute('crear_notificaciones');
			}
		}
		return $this->render('@App/Backoffice/Agregar/Notificaciones.html.twig', array(
			'titulo' => 'Crear notificaciones',
			'crear_notificaciones' => $formulario->createView()
		));
	}

	public function notificacionConfigurarEstadoLeidaAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0) {
				$doctrine = $this->getDoctrine();
				$notificacion = $this->getDoctrine()->getRepository(NotificacionEntidad::class)->findOneBy(array(
					'idNotificacion' => $jsonRecibido['id']
				));
				if ($notificacion) {
					$managerEntidad = $doctrine->getManager();
					$notificacion->setEstado($jsonRecibido['estado']);
					if (!is_null($notificacion->getIdExpediente())) {
						$logAccion = 'El usuario ha leído una notificación del expediente.';
						$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
							'idExpediente' => $notificacion->getIdExpediente()
						));
					}
					switch ($jsonRecibido['estado']) {
						case 0:
							$notificacion->setFechaLeida(new DateTime());
							if (isset($logAccion) && isset($expediente) && !is_null($expediente)) {
								$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), $logAccion, $expediente));
							}
							break;
						case 1:
							$notificacion->setFechaLeida(null);
							if (isset($logAccion) && isset($expediente) && !is_null($expediente)) {
								$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
									'idUsuario' => $this->getUser(),
									'fecha' => $notificacion->getFecha(),
									'accion' => $logAccion,
									'idElemento' => $expediente->getIdExpediente()
								));
								if (count($logs) > 0) {
									foreach ($logs as $log) {
										$managerEntidad->remove($log);
									}
								}
							}
							break;
					}
					$managerEntidad->persist($notificacion);
					$managerEntidad->flush();
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function listaNotificacionesAction()
	{
		return $this->render('@App/Backoffice/Lista/Notificaciones.html.twig', array(
			'titulo' => 'Notificaciones',
			'lista_notificaciones' => $this->getDoctrine()->getRepository(NotificacionEntidad::class)->findBy(array(
