	public function agregarModificarGrupoCamposHitoAction(Request $request, RouterInterface $router, $idHito, $idGrupoCamposHito)
	{
		if (!isset($idGrupoCamposHito)) {
			$doctrine = $this->getDoctrine();
			$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
				'idHito' => $idHito,
				'estado' => 1
			));
			if (count($hitosExpediente) > 0) {
				$this->addFlash('warning', 'No se puede añadir un grupo de campos a este hito debido a que dicho hito esta completado en al menus un expediente.');
				return $this->redirectToRoute('lista_fases_hitos_campos_opciones');
			}
		}
		return $this->formularioFaseHitoCampoOpcion(array(
			'entidadPrevia' => HitoEntidad::class,
			'idNombrePrevio' => 'idHito',
			'idPrevia' => $idHito,
			'mensajeNoEncontradoPrevio' => 'El hito con id="' . $idHito . '" no existe.',
			'ruta' => 'lista_fases_hitos_campos_opciones',
			'entidad' => GrupoCamposHitoEntidad::class,
			'idNombre' => 'idGrupoCamposHito',
			'id' => $idGrupoCamposHito,
			'mensajeNoEncontrado' => 'El hito con id="' . $idHito . '" no tiene un grupo de campos hito con id="' . $idGrupoCamposHito . '".',
			'formularioModificar' => GrupoCamposHitoModificarFormulario::class,
			'obtenerIdObjeto' => 'getIdHito',
			'formulario' => GrupoCamposHitoFormulario::class,
			'formularioOpciones' => array(
				'grupo_campos_hito_array',
				'numero_grupos_campo_hito'
			),
			'request' => $request,
			'mensajeCorrecto' => 'El grupo de campos hito ha sido añadido/modificado correctamente',
			'renderizarPlantilla' => '@App/Backoffice/AgregarModificar/GrupoCamposHito.html.twig',
			'tituloPagina' => 'Agregar/Modificar grupo campos hito',
			'migasPan' => array(
				array(
					'vista' => 'Lista de fases, hitos, campos y opciones',
					'url' => $router->generate('lista_fases_hitos_campos_opciones')
				)
			),
			'formularioNombre' => 'agregarModificarGrupoCamposHito'
		));
	}

	public function agregarModificarCampoHitoAction(Request $request, RouterInterface $router, $idGrupoCamposHito, $idCampoHito)
	{
		if (!isset($idCampoHito)) {
			$doctrine = $this->getDoctrine();
			$grupoCamposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findOneBy(array(
				'idGrupoCamposHito' => $idGrupoCamposHito
			));
			$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
				'idHito' => $grupoCamposHito->getIdHito(),
				'estado' => 1
			));
			if (count($hitosExpediente) > 0) {
				$this->addFlash('warning', 'No se puede añadir un campo a este hito debido a que dicho hito esta completado en al menos un expediente.');
				return $this->redirectToRoute('lista_fases_hitos_campos_opciones');
			}
		}
		return $this->formularioFaseHitoCampoOpcion(array(
			'entidadPrevia' => GrupoCamposHitoEntidad::class,
			'idNombrePrevio' => 'idGrupoCamposHito',
			'idPrevia' => $idGrupoCamposHito,
			'mensajeNoEncontradoPrevio' => 'El grupo de campos hito con id="' . $idGrupoCamposHito . '" no existe.',
