				'estado' => array(
					'0',
					'1'
				)
			), array(
				'fecha' => 'DESC'
			))
		));
	}

	public function listaNoticiasAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio['noticias'] = $doctrine->getRepository(NoticiaEntidad::class);
		if (isset($request)) {
			$entradasSeleccionadas = $request->get('noticia');
			if (!is_null($entradasSeleccionadas)) {
				$repositorio['noticiaUsuarios'] = $doctrine->getRepository(NoticiaUsuarioEntidad::class);
				$managerEntidad = $doctrine->getManager();
				$elementosBorrados = $elementosNoBorrados = array();
				foreach ($entradasSeleccionadas as $entrada) {
					$entidad = $repositorio['noticias']->find($entrada);
					if ($entidad) {
						if (is_null($entidad->getImagen())) {
							$entidadHijaArray = $repositorio['noticiaUsuarios']->findBy(array(
								'idNoticia' => $entidad
							));
							foreach ($entidadHijaArray as $entidadHija) {
								$managerEntidad->remove($entidadHija);
							}
							$managerEntidad->remove($entidad);
							$elementosBorrados[] = $entrada;
						} else {
							$filesystem = new Filesystem();
							try {
								$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $entidad->getImagen());
								$entidadHijaArray = $repositorio['noticiaUsuarios']->findBy(array(
									'idNoticia' => $entidad
								));
								foreach ($entidadHijaArray as $entidadHija) {
									$managerEntidad->remove($entidadHija);
								}
								$managerEntidad->remove($entidad);
								$elementosBorrados[] = $entrada;
							} catch (IOExceptionInterface $e) {
								$this->addFlash('error', 'Error al borrar el archivo de la noticia con id="' . $entidad->getIdDocumento() . '".');
								$elementosNoBorrados[] = $entrada;
							}
						}
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				}
				$managerEntidad->flush();
				if (count($elementosBorrados) > 0) {
					$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
						'Ha sido borrada la noticia con id=',
						'Han sido borradas las noticias con ids',
						' y '
					)));
				}
				if (count($elementosNoBorrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
						'No se ha encontrado la noticia con id=',
						'No se han encontrado las noticias con ids',
						' y '
					)));
				}
			}
		}
		return $this->render('@App/Backoffice/Lista/Noticia.html.twig', array(
			'titulo' => 'Lista de noticias',
			'noticias' => $repositorio['noticias']->findAll()
		));
	}

	public function agregarModificarNoticiaAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		if (isset($id)) {
			$noticia = $doctrine->getRepository(NoticiaEntidad::class)->findOneBy(array(
				'idNoticia' => $id
			));
			if (!$noticia) {
				$this->addFlash('warning', 'La noticia con id="' . $id . '" no existe.');
				return $this->redirectToRoute('lista_noticias');
			}
			$filesystem = new Filesystem();
			if (!is_null($noticia->getImagen()) && $filesystem->exists($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $noticia->getImagen())) {
				$ficheroSubido = str_replace($this->get('kernel')->getProjectDir() . '/web', '', $this->getParameter('files_directory') . '/' . $noticia->getImagen());
				$ficheroSubidoRuta = $router->generate('descargar_fichero_documento', array(
					'id' => $noticia->getIdNoticia()
				));
				$nombreFicheroMostrar = $noticia->getTitulo();
			}
		} else {
			$noticia = new NoticiaEntidad();
		}
		$formularioNoticia = $this->createForm(NoticiaFormulario::class, $noticia);
		$noticiaUsuarios = $doctrine->getRepository(NoticiaUsuarioEntidad::class)->findBy(array(
			'idNoticia' => $id
		));
		if (count($noticiaUsuarios) === 0) {
			$noticiaUsuarios[0] = (new NoticiaUsuarioEntidad())->setIdNoticia($noticia);
		}
		$usuarios = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
			->andWhere(Criteria::expr()->orX(
				Criteria::expr()->gte('fechaCaducidad', new DateTime()),
				Criteria::expr()->isNull('fechaCaducidad')
			))
			->andWhere(Criteria::expr()->eq('estado', true))
		)->toArray();
		$usuariosSeleccionadosArrayObjetos = $doctrine->getRepository(NoticiaUsuarioEntidad::class)->findBy(array(
			'idUsuario' => $usuarios
		));
		$usuariosSeleccionados = $roles = $tags = array();
		foreach ($usuariosSeleccionadosArrayObjetos as $usuarioSeleccionadoObjecto) {
			$usuariosSeleccionados[] = $usuarioSeleccionadoObjecto->getIdUsuario();
		}
		$rolesArray = $doctrine->getRepository(UsuarioEntidad::class)->createQueryBuilder('a')
			->select('a.role')
			->distinct()
			->getQuery()
			->getResult();
		if (count($rolesArray) > 0) {
			foreach ($rolesArray as $rol) {
				if (isset($rol['role'])) {
					switch ($rol['role']) {
						case 'ROLE_ADMIN':
							$roles['Administradores'] = 1;
							break;
						case 'ROLE_COLABORADOR':
							$roles['Colaboradores'] = 2;
							break;
						case 'ROLE_COMERCIAL':
							$roles['Comerciales'] = 3;
							break;
						case 'ROLE_TECNICO':
							$roles['Tecnicos'] = 4;
							break;
						default:
							$roles['Clientes'] = 5;
					}
				}
			}
		}
		$tagsArray = $doctrine->getRepository(UsuarioEntidad::class)->createQueryBuilder('a')
			->select('a.tag')
			->distinct()
			->getQuery()
			->getResult();
		if (count($tagsArray) > 0) {
			foreach ($tagsArray as $tag) {
				if (isset($tag['tag']) && !is_null($tag['tag'])) {
					$tags[$tag['tag']] = $tag['tag'];
				}
			}
		}
		$formularioNoticiaUsuario = $this->createForm(NoticiaUsuarioFormulario::class, $noticiaUsuarios[0], array(
			'usuarios' => $usuarios,
			'usuariosSeleccionados' => $usuariosSeleccionados,
			'roles' => $roles,
			'tags' => $tags
		));
		$formularioNoticia->handleRequest($request);
		if ($formularioNoticia->isSubmitted() && $formularioNoticia->isValid()) {
			$formularioNoticiaUsuario->submit($request->request->get($formularioNoticiaUsuario->getName()));
			if ($formularioNoticiaUsuario->isValid()) {
				$usuariosRecibidos = $request->get('noticia_usuario');
				$contador = 0;
				if (count($usuariosRecibidos) > 0) {
					foreach ($usuariosRecibidos as $tipo => $usuariosMismoTipo) {
						if (in_array($tipo, array(
							'idUsuario'
						))) {
							foreach ($usuariosMismoTipo as $idUsuario) {
								$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
									'idUsuario' => $idUsuario
								));
								if ($usuario) {
									if (isset($noticiaUsuarios[$contador])) {
										$noticiaUsuarios[$contador]->setIdUsuario($usuario);
									} else {
										$noticiaUsuarios[] = (new NoticiaUsuarioEntidad())
											->setIdNoticia($noticia)
											->setIdUsuario($usuario);
									}
									$contador += 1;
								}
							}
						}
					}
				}
				if (!is_null($noticia->getFichero())) {
					$filesystem = new Filesystem();
					try {
						$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $noticia->getImagen());
					} catch (IOExceptionInterface $e) {
						$this->addFlash('error', 'Error al borrar el archivo antiguo.');
						return $this->redirectToRoute('agregar_modificar_noticia');
					}
					$nombreFichero = md5(uniqid()) . '.' . $noticia->getFichero()->guessExtension();
					try {
						$noticia->getFichero()->move($this->getParameter('files_directory'), $nombreFichero);
					} catch (FileException $e) {
						$this->addFlash('error', 'Error al guardar el archivo en el servidor.');
						return $this->redirectToRoute('agregar_modificar_noticia');
					}
					$noticia->setImagen($nombreFichero);
				}
				$managerEntidad = $doctrine->getManager();
				$managerEntidad->persist($noticia);
				foreach ($noticiaUsuarios as $indice => $noticiaUsuario) {
					if ($indice < $contador) {
						$managerEntidad->persist($noticiaUsuario);
					} else {
						$managerEntidad->remove($noticiaUsuario);
					}
				}
				$managerEntidad->flush();
				$this->addFlash('success', 'La noticia ha sido añadida/modificada correctamente.');
				return $this->redirectToRoute('lista_noticias');
			}
		}
		$formatosPermitidos = $this->getParameter('image_formats');
		if (in_array('jpeg', $formatosPermitidos)) {
			array_push($formatosPermitidos, 'jpg');
		}
		$variablesTwig = array(
			'titulo' => 'Agregar/Modificar noticia',
			'migasPan' => array(
				array(
					'vista' => 'Lista de noticiass',
					'url' => $router->generate('lista_noticias')
				)
			),
			'agregar_modificar_noticia' => $formularioNoticia->createView(),
			'agregar_modificar_noticia_usuario' => $formularioNoticiaUsuario->createView(),
			'extensiones_permitidas' => implode(' ', $formatosPermitidos),
			'max_file_size' => $this->redondearBytesAUnidad($this->convertirABytes(ini_get('upload_max_filesize')))
		);
		if (isset($ficheroSubido)) {
			$variablesTwig['fichero_subido'] = $ficheroSubido;
		}
		if (isset($nombreFicheroMostrar)) {
			$variablesTwig['nombres_fichero_mostrar'] = $nombreFicheroMostrar;
		}
		if (isset($ficheroSubidoRuta)) {
			$variablesTwig['fichero_subido_ruta'] = $ficheroSubidoRuta;
		}
		return $this->render('@App/Backoffice/AgregarModificar/Noticia.html.twig', $variablesTwig);
	}

	public function borrarFicheroNoticiaAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0 && isset($jsonRecibido['fichero'])) {
				$nombreFicheroArray = explode('/', $jsonRecibido['fichero']);
				$nombreFichero = end($nombreFicheroArray);
				$doctrine = $this->getDoctrine();
				$documento = $doctrine->getRepository(NoticiaEntidad::class)->findOneBy(array(
					'imagen' => $nombreFichero
				));
				if ($documento) {
					$filesystem = new Filesystem();
					try {
						if ($filesystem->exists($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $documento->getImagen())) {
							$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $documento->getImagen());
						}
						$documento->setImagen(null);
						$managerEntidad = $doctrine->getManager();
						$managerEntidad->persist($documento);
						$managerEntidad->flush();
						$respuesta['error'] = false;
					} catch (IOExceptionInterface $e) {
						$respuesta['error'] = true;
					}
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

