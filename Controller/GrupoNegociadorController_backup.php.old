									$diferencia = $numeroGruposHitoExpedienteDuplicados - $numeroGruposHitoExpedienteDuplicadosArray[$hitoExpediente->getIdHitoExpediente()][$grupoHito->getIdGrupoCamposHito()];
									for ($i = 0; $i < $diferencia; $i += 1) {
