	public function activarCuentaAction($token)
	{
		$doctrine = $this->getDoctrine();
		$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
			'tokenActivacion' => $token
		));
		if ($usuario) {
			$managerEntidad = $doctrine->getManager();
			if ($usuario->getTokenFecha()->add(new DateInterval('P1D')) > new DateTime()) {
				$usuario->setEstado(true)
					->setTokenActivacion(null)
					->setTokenFecha(null);
				$managerEntidad->persist($usuario);
				$managerEntidad->flush();

				// Ahora creamos un expediente para el nuevo cliente
				$repositorios = array(
					'Fases' => $doctrine->getRepository('AppBundle:Fase'),
					'Usuarios' => $doctrine->getRepository('AppBundle:Usuario')
				);
				$fase = $repositorios['Fases']->findOneBy(array(
						'tipo' => 0
					)
				);

				$vivienda = "NUEVA VIVIENDA";
				
				$expediente = (new ExpedienteEntidad())
					->setEstado(1)
					->setIdCliente($usuario)
					// ->setIdColaborador($colaborador)
					// ->setIdComercial($colaborador->getIdInmobiliaria()->getIdComercial())
					->setIdFaseActual($fase)
					->setVivienda($vivienda)
					->setFechaCreacion(new DateTime());
				$managerEntidad = $doctrine->getManager();
				$managerEntidad->persist($expediente);
				// $this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($usuario, 'Creación del expediente', $expediente));
				$managerEntidad->flush();
				// Enviar notificación NO PUSH al admin y al comercial


				// Ahora creamos los hitos campos etc del expediente para que en la app se puedan ver los formularios
				$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(), array(
					'orden' => 'ASC'
				));
				
				$admin = $repositorios['Usuarios']->findOneBy(array(
						'role' => 'ROLE_ADMIN'
					)
				);
				$notificacion = (new NotificacionEntidad)
					->setIdExpediente($expediente)
					->setEstado(1)
					->setFecha(new DateTime())
					->setIdUsuario($admin)
					->setTitulo('Nuevo expediente creado')
					->setTexto('El cliente ' . $usuario->getUsername() . ' ' . $usuario->getApellidos() . ' ha creado un nuevo expediente al registrarse en la aplicación');
				$managerEntidad->persist($notificacion);
				$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($usuario, 'Se ha enviado una notificacion a ' . (new UsuariosNombreCompleto())->obtener($notificacion->getIdUsuario()), $expediente));
				$managerEntidad->flush();

				$this->addFlash('success', 'Su cuenta se ha activado correctamente.');
				return $this->redirectToRoute('iniciar_sesion');
			} else {
				$managerEntidad->remove($usuario);
				$managerEntidad->flush();
				$this->addFlash('warning', 'El token de activación ha expirado, por favor, registrese de nuevo.');
				return $this->redirectToRoute('registrar_cuenta');
			}
		} else {
			$this->addFlash('warning', 'El token no ha sido encontrado.');
			return $this->redirectToRoute('registrar_cuenta');
		}
	}

	public function reestablecerCuentaAction(Request $request, UserPasswordEncoderInterface $passwordEncoder, $token)
	{
		$doctrine = $this->getDoctrine();
		$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
			'tokenActivacion' => $token
		));
		if ($usuario) {
			if ($usuario->getTokenFecha()->add(new DateInterval('P1D')) > new DateTime()) {
				$formulario = $this->createForm(RecuperarUsuarioFormulario::class, $usuario);
				$formulario->handleRequest($request);
				if ($formulario->isSubmitted() && $formulario->isValid()) {
					$usuario->setPassword($passwordEncoder->encodePassword($usuario, $usuario->getPlainPassword()))
						->setTokenActivacion(null)
						->setTokenFecha(null);
					$managerEntidad = $doctrine->getManager();
					$managerEntidad->persist($usuario);
					$managerEntidad->flush();
					$this->addFlash('success', 'Su contraseña acaba de ser cambiada correctamente.');
					return $this->redirectToRoute('iniciar_sesion');
				}
			} else {
				$usuario->setTokenActivacion(null)
					->setTokenFecha(null);
				$managerEntidad = $doctrine->getManager();
				$managerEntidad->persist($usuario);
				$managerEntidad->flush();
				$this->addFlash('warning', 'El token de recuperación ha expirado.');
				return $this->redirectToRoute('iniciar_sesion');
			}
		} else {
			$this->addFlash('warning', 'El token no ha sido encontrado.');
			return $this->redirectToRoute('iniciar_sesion');
		}
		return $this->render('@App/Backoffice/RecuperarCuenta.html.twig', array(
			'titulo' => 'Recuperar cuenta',
			'recuperar_usuario' => $formulario->createView()
		));
	}

	public function indexAction()
	{
		if ($this->getUser()->getRoles()[0] === 'ROLE_CLIENTE') {
			return $this->redirectToRoute('lista_expedientes');
		} else {
			return $this->redirectToRoute('lista_expedientes');
		}
	}

	public function iniciarSesionAction(AuthenticationUtils $authenticationUtils)
	{
		if ($this->container->get('security.authorization_checker')->isGranted('IS_AUTHENTICATED_REMEMBERED')) {
			return $this->redirectToRoute('inicio');
		} else {
			return $this->render('@App/Backoffice/InicioSesion.html.twig', array(
				'titulo' => 'Acceder',
				'last_username' => $authenticationUtils->getLastUsername(),
				'error' => $authenticationUtils->getLastAuthenticationError()
			));
		}
	}

	public function recuperarCuentaAction(Request $request, Swift_Mailer $mailer)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = array();
			if (json_last_error() === 0 && isset($jsonRecibido['email'])) {
				$doctrine = $this->getDoctrine();
				$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
					'email' => $jsonRecibido['email']
				));
				if ($usuario) {
					try {
						$usuario->setTokenActivacion(bin2hex(random_bytes(60)));
					} catch (Exception $e) {
						$respuesta['error'] = true;
						$respuesta['mensaje'] = 'Error al crear el token.';
					}
					$usuario->setTokenFecha(new DateTime());
					$managerEntidad = $doctrine->getManager();
					$managerEntidad->persist($usuario);
					$managerEntidad->flush();
					$mensaje = (new Swift_Message('Recuperar contraseña'))
						->setFrom($this->getParameter('mailer_user'))
						->setTo($jsonRecibido['email'])
						->setBody($this->renderView('@App/Backoffice/Correo/ReestablecerCuenta.html.twig', array(
							'urlgenerada' => $this->generateUrl('reestablecer_cuenta', array(
								'token' => $usuario->getTokenActivacion()
							), UrlGeneratorInterface::ABSOLUTE_URL)
						)), 'text/html');
					if ($mailer->send($mensaje)) {
						$respuesta['error'] = false;
						$respuesta['mensaje'] = 'Se ha enviado a su correo un enlace para reestablecer su contraseña.';
					} else {
						$respuesta['error'] = true;
						$respuesta['mensaje'] = 'Error al enviar el E-Mail.';
					}
				} else {
					$respuesta['error'] = true;
					$respuesta['mensaje'] = 'No se ha encontrado ningún usuario con dicho E-Mail.';
				}
			} else {
				$respuesta['error'] = true;
				$respuesta['mensaje'] = 'Error en el JSON enviado.';
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function registrarCuentaAction(Request $request, UserPasswordEncoderInterface $passwordEncoder, Swift_Mailer $mailer)
	{
		if ($this->container->get('security.authorization_checker')->isGranted('IS_AUTHENTICATED_REMEMBERED')) {
			return $this->redirectToRoute('inicio');
		} else {
			$doctrine = $this->getDoctrine();
			$usuario = new UsuarioEntidad();
			$formulario = $this->createForm(RegistrarUsuarioFormulario::class, $usuario);
			$formulario->handleRequest($request);
			if ($formulario->isSubmitted() && $formulario->isValid()) {
				if ($usuario->getPoliticaPrivacidad() && $usuario->getContratoFipre()) {
					$usuario->setPassword($passwordEncoder->encodePassword($usuario, $usuario->getPlainPassword()))
						->setRole('ROLE_CLIENTE')
						->setEstado(false);
					try {
						$usuario->setTokenActivacion(bin2hex(random_bytes(60)));
					} catch (Exception $e) {
					}
					$usuario->setTokenFecha(new DateTime());
					$mensaje = (new Swift_Message('Grupo Negociador - Activar cuenta'))
						->setFrom($this->getParameter('mailer_user'))
						->setTo($usuario->getEmail())
						->setBody($this->renderView('@App/Backoffice/Correo/ActivarCuenta.html.twig', array(
							'urlgenerada' => $this->generateUrl('activar_cuenta', array(
								'token' => $usuario->getTokenActivacion()
							), UrlGeneratorInterface::ABSOLUTE_URL)
						)), 'text/html');
					if ($mailer->send($mensaje)) {
						$managerEntidad = $doctrine->getManager();
						$managerEntidad->persist($usuario);
						$managerEntidad->flush();
						$this->addFlash('info', 'Se ha enviado un E-Mail con el enlace para la activación.');
					} else {
						$this->addFlash('danger', 'Error al enviar el E-Mail con el enlace para la activación.');
					}
				} else {
					$this->addFlash('warning', 'No has aceptado las condiciones.');
				}
			}
			return $this->render('@App/Backoffice/Registrarse.html.twig', array(
				'titulo' => 'Regístrate',
				'formulario_usuario' => $formulario->createView()
			));
		}
	}

	public function listaAgenteColaboradorAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(AgenteColaboradorEntidad::class);
		$entradasSeleccionadas = $request->get('agente-colaborador');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idAgenteColaborador' => $entrada
				));
				if ($entidad) {
					$camposHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
						'idAgenteColaborador' => $entidad
					));
					if (count($camposHitoExpediente) === 0) {
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrado el agente colaborador con id=',
					'Han sido borrados los agentes colaboradores con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha encontrado el agente colaborador con id=',
					'No se han podido borrar las entidades colaboradoras con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado la entidad colaboradora con id=',
					'No se han encontrado los agentes colaboradores con ids',
					' y '
				)));
			}
		}
		return $this->render('@App/Backoffice/Lista/AgenteColaborador.html.twig', array(
			'titulo' => 'Lista de agentes colaboradores',
			'agentes_colaboradores' => $repositorio->findAll()
		));
	}

	public function agregarModificarAgenteColaboradorAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(EntidadColaboradoraEntidad::class);
		$elementos = $repositorio->matching(Criteria::create()
			->where(Criteria::expr()->eq('estado', true))
		);
		if ($elementos->count() === 0) {
			$this->addFlash('warning', 'No hay comerciales activos.');
			return $this->redirectToRoute('lista_inmobiliarias');
		}
		return $this->formularioEntidad(array(
			'id' => $id,
			'entidad' => AgenteColaboradorEntidad::class,
			'idEntidad' => 'idAgenteColaborador',
			'elementoNoExiste' => 'El agente colaborador con id="' . $id . '" no existe.',
			'ruta' => 'lista_agentes_colaboradores',
			'formulario' => AgenteColaboradorFormulario::class,
			'formularioOpciones' => array(
				'entidades_colaboradoras' => $elementos
			),
			'request' => $request,
			'formularioMensaje' => 'El agente colaborador ha sido añadido/modificado correctamente.',
			'renderizar' => '@App/Backoffice/AgregarModificar/AgenteColaborador.html.twig',
			'titulo' => 'Agregar/Modificar agente colaborador',
			'migasPan' => array(
				array(
					'vista' => 'Lista de agentes colaboradores',
					'url' => $router->generate('lista_agentes_colaboradores')
				)
			),
			'formularioNombre' => 'agregarModificarAgenteColaborador'
		));
	}

	public function listaEntidadColaboradoraAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(EntidadColaboradoraEntidad::class);
		$entradasSeleccionadas = $request->get('entidad-colaboradora');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idEntidadColaboradora' => $entrada
				));
				if ($entidad) {
					$agentesColaboradores = $doctrine->getRepository(AgenteColaboradorEntidad::class)->findBy(array(
						'idEntidadColaboradora' => $entidad
					));
					$camposHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
						'idEntidadColaboradora' => $entidad
					));
					if (count($agentesColaboradores) === 0 && count($camposHitoExpediente) === 0) {
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrada la entidad colaboradora con id=',
					'Han sido borradas las entidades colaboradoras con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha podido borrar la entidad colaboradora con id=',
					'No se han podido borrar las entidades colaboradoras con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado la entidad colaboradora con id=',
					'No se han encontrado las entidades colaboradoras con ids',
					' y '
				)));
			}
		}
		return $this->render('@App/Backoffice/Lista/EntidadColaboradora.html.twig', array(
			'titulo' => 'Lista de entidades colaboradoras',
			'entidades_colaboradoras' => $repositorio->findAll()
		));
	}

	public function agregarModificarEntidadColaboradoraAction(Request $request, RouterInterface $router, $id)
	{
		return $this->formularioEntidad(array(
			'id' => $id,
			'entidad' => EntidadColaboradoraEntidad::class,
