							if (isset($numeroGruposHitoExpedienteDuplicadosArray[$hitoExpediente->getIdHitoExpediente()][$grupoHito->getIdGrupoCamposHito()])) {
								if ($numeroGruposHitoExpedienteDuplicados < $numeroGruposHitoExpedienteDuplicadosArray[$hitoExpediente->getIdHitoExpediente()][$grupoHito->getIdGrupoCamposHito()]) { // Hay nuevos grupos que crear
									$diferencia = $numeroGruposHitoExpedienteDuplicadosArray[$hitoExpediente->getIdHitoExpediente()][$grupoHito->getIdGrupoCamposHito()] - $numeroHitosExpedienteDuplicados;
									for ($i = 0; $i < $diferencia; $i += 1) {
										$gruposHitosExpediente[] = (new GrupoHitoExpedienteEntidad())
