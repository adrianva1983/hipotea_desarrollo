	public function agregarModificarFacturaAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		if (isset($id)) {
			$factura = $doctrine->getRepository(FacturaEntidad::class)->findOneBy(array(
				'idFactura' => $id
			));
			if (!$factura) {
				$this->addFlash('warning', 'La factura con id="' . $id . '" no existe.');
				return $this->redirectToRoute('lista_facturas');
			}
			$serieInicialFactura = $factura->getSerie();
			$fechaInicialFactura = $factura->getFecha();
		} else {
			$factura = new FacturaEntidad();
			$fecha = new DateTime();
			$facturas = $doctrine->getRepository(FacturaEntidad::class)->findBy(array(
				'serie' => $fecha->format('y')
			), array(
				'numero' => 'DESC'
			));
			if ($facturas) {
				$factura->setNumero($facturas[0]->getNumero() + 1);
				$fechaInicialFactura = $facturas[0]->getFecha();
			} else {
				$factura->setNumero(1);
				$fechaInicialFactura = $fecha;
			}
		}
		$formularioFactura = $this->createForm(FacturaFormulario::class, $factura);
		$formularioLineaFactura = $this->createForm(LineaFacturaFormulario::class);
		$formularioFactura->handleRequest($request);
		if ($formularioFactura->isSubmitted() && $formularioFactura->isValid()) {
			if (empty($factura->getFecha())) {
				$fecha = new DateTime();
				$factura->setFecha($fecha);
			} else {
				$fecha = $factura->getFecha();
			}
			if (empty($factura->getSerie())) {
				$factura->setSerie($fecha->format('y'));
			}
			if (!isset($id) || isset($serieInicialFactura) && $serieInicialFactura !== $factura->getSerie()) {
				$facturas = $doctrine->getRepository(FacturaEntidad::class)->findBy(array(
					'serie' => $factura->getSerie()
				), array(
					'numero' => 'DESC'
				));
				if (count($facturas) > 0) {
					$factura->setNumero($facturas[0]->getNumero() + 1);
				} else {
					$factura->setNumero(1);
				}
			}
			if ($fechaInicialFactura > $factura->getFecha()) {
				$factura->setFecha($fechaInicialFactura);
			}
			$lineasFactura = $request->get('linea_factura');
			if (!is_null($lineasFactura)) {
				$managerEntidad = $doctrine->getManager();
				if (isset($id)) {
					$lineasFacturaExistentes = $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
						'idFactura' => $id
					));
					if ($lineasFacturaExistentes) {
						$numeroLineasFacturaExistentes = count($lineasFacturaExistentes);
						$numeroLineasFactura = count($lineasFactura);
						if ($numeroLineasFacturaExistentes > $numeroLineasFactura) {
							for ($i = $numeroLineasFactura - 1; $i < $numeroLineasFacturaExistentes; $i += 1) {
								$managerEntidad->remove($lineasFacturaExistentes[$i]);
							}
						}
					}
				} else {
					$managerEntidad->persist($factura);
					$managerEntidad->flush();
				}
				$facturaBaseImponible = $facturaImpuestos = $facturaRetenciones = 0;
				foreach ($lineasFactura as $indice => $lineaFactura) {
					if (isset($lineasFacturaExistentes) && isset($lineasFacturaExistentes[$indice])) {
						$lineaFacturaObjecto = $lineasFacturaExistentes[$indice];
					} else {
						$lineaFacturaObjecto = (new LineaFacturaEntidad())
							->setIdFactura($factura);
					}
					$lineaFacturaObjecto->setLineaFactura($indice)
						->setConcepto($lineaFactura['concepto']);
					if (empty($lineaFactura['unidades'])) {
						$lineaFacturaObjecto->setUnidades(1);
					} else {
						$lineaFacturaObjecto->setUnidades($lineaFactura['unidades']);
					}
					if (empty($lineaFactura['importe'])) {
						$lineaFacturaObjecto->setImporte(0);
					} else {
						$lineaFacturaObjecto->setImporte($lineaFactura['importe']);
					}
					$lineaFacturaObjecto->setTipoIva($lineaFactura['tipoIva']);
					if (empty($lineaFactura['tipoRetencion'])) {
						$lineaFacturaObjecto->setTipoRetencion(0);
					} else {
						$lineaFacturaObjecto->setTipoRetencion($lineaFactura['tipoRetencion']);
					}
					$lineaFacturaObjecto->setTotalBaseImponible($lineaFacturaObjecto->getImporte() * $lineaFacturaObjecto->getUnidades())
						->setImpuestos($lineaFacturaObjecto->getTotalBaseImponible() * $lineaFacturaObjecto->getTipoIva() / 100)
						->setRetencion($lineaFacturaObjecto->getTotalBaseImponible() * $lineaFacturaObjecto->getTipoRetencion() / 100)
						->setTotal($lineaFacturaObjecto->getTotalBaseImponible() + $lineaFacturaObjecto->getImpuestos() - $lineaFacturaObjecto->getRetencion());
					$facturaBaseImponible += $lineaFacturaObjecto->getTotalBaseImponible();
					$facturaImpuestos += $lineaFacturaObjecto->getImpuestos();
					$facturaRetenciones += $lineaFacturaObjecto->getRetencion();
					$managerEntidad->persist($lineaFacturaObjecto);
				}
				$factura->setBaseImponible($facturaBaseImponible)
					->setImpuestos($facturaImpuestos)
					->setRetenciones($facturaRetenciones)
					->setTotal($facturaBaseImponible + $facturaImpuestos - $facturaRetenciones);
				$managerEntidad->persist($factura);
				$managerEntidad->flush();
				$this->addFlash('success', 'La factura se ha creado/modificado correctamente.');
				return $this->redirectToRoute('lista_facturas');
			} else {
				$this->addFlash('warning', 'Debe de existir al menos una línea.');
			}
		}
		return $this->render('@App/Backoffice/AgregarModificar/Factura.html.twig', array(
			'titulo' => 'Crear/Modificar factura',
			'migasPan' => array(
				array(
					'vista' => 'Lista de facturas',
					'url' => $router->generate('lista_facturas')
				)
			),
			'agregar_modificar_factura' => $formularioFactura->createView(),
			'agregar_linea_factura' => $formularioLineaFactura->createView(),
			'lineas_factura' => $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
				'idFactura' => $id
			)),
			'factura' => $factura,
			'fecha_inicial_factura' => $fechaInicialFactura
		));
	}

	public function ObtenerNumeroSerieFacturaAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = null;
			if (json_last_error() === 0 && isset($jsonRecibido['serie'])) {
				$facturas = $this->getDoctrine()->getRepository(FacturaEntidad::class)->findBy(array(
					'serie' => $jsonRecibido['serie']
				), array(
					'numero' => 'DESC'
				));
				if ($facturas) {
					$respuesta = array(
						'numero' => $facturas[0]->getNumero() + 1,
						'fecha' => $facturas[0]->getFecha()->format('d/m/Y')
					);
				} else {
					$fecha = new DateTime();
					$respuesta = array(
						'numero' => 1,
						'fecha' => $fecha->format('d/m/Y')
					);
				}
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function verFacturaAction($id)
	{
		$doctrine = $this->getDoctrine();
		$factura = $doctrine->getRepository(FacturaEntidad::class)->findOneBy(array(
			'idFactura' => $id
		));
		if ($factura) {
			$emisor = $doctrine->getRepository(EmisorFacturaEntidad::class)->findOneBy(array(
				'idEmisorFactura' => $factura->getIdEmisorFactura()
			));
			$cliente = $doctrine->getRepository(ClienteFacturaEntidad::class)->findOneBy(array(
				'idClienteFactura' => $factura->getIdClienteFactura()
			));
			$lineasFactura = $doctrine->getRepository(LineaFacturaEntidad::class)->findBy(array(
				'idFactura' => $factura->getIdFactura()
			), array(
				'lineaFactura' => 'ASC'
			));
			$pdf = $this->get('white_october.tcpdf')->create();
			$pdf->setTitle('Factura ' . $factura->getNumero() . '/' . $factura->getSerie());
			$pdf->setHeaderData($this->get('assets.packages')->getUrl('/custom/factura_cabecera.png'), $pdf->getPageWidth() - $pdf->getMargins()['left'] - $pdf->getMargins()['right']);
			$imagenDimensiones = getimagesize(K_PATH_IMAGES . '/custom/factura_cabecera.png');
			$pdf->setMargins(10, ($pdf->getPageWidth() - $pdf->getMargins()['left'] - $pdf->getMargins()['right']) / ($imagenDimensiones[0] / $imagenDimensiones[1]), 10);
			$pdf->setFont(null, null, 7.5);
			$pdf->setCellPadding(1);
			$pdf->setHtmlVSpace(array(
				'div' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				),
				'hr' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				),
				'p' => array(
					0 => array(
						'h' => 0,
						'n' => 0
					),
					1 => array(
						'h' => 0,
						'n' => 0
					)
				)
			));
			$pdf->AddPage();
			$html = '<style>
								.cabecera {
									border: 1px solid #000
								}
								.fecha {
									text-align: right
								}
								.tabla {
									text-align: center
								}
								.tabla td,
								.tabla th {
									border: 1px solid #000
								}
							</style>
							<table class="cabecera">
								<thead>
									<tr>
										<th>
											<h3>Nº FACTURA: ' . $factura->getNumero() . '/' . $factura->getFecha()->format('Y') . '</h3>
										</th>
										<th class="fecha">FECHA: ' . $factura->getFecha()->format('d/m/Y') . '</th>
									</tr>
								</thead>
							</table>
							<div>
								<div>' . $emisor->getRazonSocial() . '</div>
								<div>' . $emisor->getDireccion() . ' ' . $emisor->getMunicipio() . ', ' . $emisor->getProvincia() . '.</div>
								<div>' . $emisor->getCP() . '-' . $emisor->getProvincia() . '</div>
								<div>CIF: ' . $emisor->getCIF() . '</div>
							</div>
							<hr>
							<div>
								<div>
									<b>CLIENTE:</b>
									<span>' . $cliente->getRazonSocial() . '</span>
								</div>
								<div>
									<b>DNI:</b>
									<span>' . $cliente->getCIF() . '</span>
								</div>
								<div>
									<b>DESCRIPCIÓN:</b>
									<span>' . $factura->getDescripcion() . '</span>
								</div>
							</div>
								<table class="tabla">
									<thead>
										<tr>
											<th>CONCEPTO</th>
											<th>UNIDADES</th>
											<th>PRECIO UNITARIO</th>
											<th>IMPORTE</th>
											<th>TIPO IVA</th>
											<th>IMPUESTOS</th>
											<th>TIPO RETENCIÓN</th>
											<th>RETENCIONES</th>
											<th>TOTAL</th>
										</tr>
									</thead>
									<tbody>';
			foreach ($lineasFactura as $lineaFactura) {
				$html .= '<tr>
										<td>' . $lineaFactura->getConcepto() . '</td>
										<td>' . $lineaFactura->getUnidades() . '</td>
										<td>' . $lineaFactura->getImporte() . ' €</td>
										<td>' . $lineaFactura->getUnidades() * $lineaFactura->getImporte() . ' €</td>
										<td>' . $lineaFactura->getTipoIVA() . ' %</td>
										<td>' . $lineaFactura->getImpuestos() . ' €</td>
										<td>' . $lineaFactura->getTipoRetencion() . ' %</td>
										<td>' . $lineaFactura->getRetencion() . ' €</td>
										<td>' . $lineaFactura->getTotal() . ' €</td>
									</tr>';
			}
			$html .= '</tbody>
							</table>
							<div></div>
							<div>
								<b>TOTAL FACTURA</b>
							</div>
							<table class="tabla">
								<thead>
									<tr>
										<th>IMPORTE</th>
										<th>IMPUESTOS</th>
										<th>RETENCIONES</th>
										<th>TOTAL</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td>' . $factura->getBaseImponible() . ' €</td>
										<td>' . $factura->getImpuestos() . ' €</td>
										<td>' . $factura->getRetenciones() . ' €</td>
										<td>' . $factura->getTotal() . ' €</td>
									</tr>
								</tbody>
							</table>
							<div></div>
							<p>';
			if ($factura->getRetenciones() === 0) {
				$html .= 'La presente factura está exenta de IVA en base al Artículo 20.1 apartado 18º.m de la Ley 37/92 del IVA. ';
			}
			$html .= 'Grupo Negociador ALR no es una entidad de crédito, sino que presta servicios de mediación entre entidades de financiación y particulares o empresas.</p>';
			$pdf->writeHTML($html);
			$pdf->output('Factura_' . $factura->getNumero() . '-' . $factura->getSerie() . '.pdf');
			return null;
		} else {
			$this->addFlash('success', 'No existe la factura con id="' . $id . '".');
			return $this->redirectToRoute('lista_facturas');
		}
	}

	public function enviarFacturaEmailAction(Request $request, RouterInterface $router, Swift_Mailer $mailer)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = null;
			if (json_last_error() === 0) {
				$factura = $this->getDoctrine()->getRepository(FacturaEntidad::class)->findOneBy(array(
					'idFactura' => $jsonRecibido['idFactura']
				));
				if ($factura) {
					$mensaje = (new Swift_Message($jsonRecibido['asunto']))
						->setFrom($this->getParameter('mailer_user'))
						->setTo($jsonRecibido['destinatario'])
						->setBody($jsonRecibido['texto'], 'text/plain')
						->attach(Swift_Attachment::fromPath($router->generate('ver_factura', array(
							'id' => $jsonRecibido['idFactura']
						))));
					if (!$mailer->send($mensaje)) {
						$respuesta['error'] = true;
					}
				} else {
					$respuesta['error'] = true;
				}
			} else {
				$respuesta['error'] = true;
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function calculadoraSencillaAction(Request $request)
	{
		$formulario = $this->createForm('AppBundle\Form\CalculadoraSencilla');
		$formulario->handleRequest($request);
		$variablesTwig = array(
			'titulo' => 'Calculadora Sencilla',
			'calculadora_sencilla' => $formulario->createView(),
		);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$formulario->getData()->calcularHipoteca();
			$variablesTwig['hipoteca'] = $formulario->getData()->getHipoteca()['capital_less_initial_amount'];
			$variablesTwig['pago_mensual'] = $formulario->getData()->getHipoteca()['fee'];
			$variablesTwig['hipoteca_total_con_interes'] = $formulario->getData()->getHipoteca()['capital_less_initial_amount'] + $formulario->getData()->getHipoteca()['interest_discharged_total'];
			$variablesTwig['total_con_anticipo'] = $formulario->getData()->getPrecioTotal() + $formulario->getData()->getHipoteca()['interest_discharged_total'];
			$variablesTwig['resultado'] = null;
		}
		return $this->render('@App/Backoffice/Extras/CalculadoraSencilla.html.twig', $variablesTwig);
	}

	public function calculadoraAvanzadaAction(Request $request)
	{
		$formulario = $this->createForm('AppBundle\Form\CalculadoraAvanzada');
		$formulario->handleRequest($request);
		// dump($request);
		// die();
		$variablesTwig = array(
			'titulo' => 'Calculadora Avanzada',
			'calculadora_avanzada' => $formulario->createView(),
		);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$resultado = $formulario->getData()->calcularAvanzada();
			// $respuesta['importe_fijo'] = $resultado_f['importe'];
			// $respuesta['importe_variable'] = $resultado_v['importe'];
			// $respuesta['entrada'] = $aportacion_inicial;
			// $respuesta['gastos'] = $gastos;
			// $respuesta['interes_fijo'] = $interes_fijo_l;
			// $respuesta['interes_variable'] = $interes_variable_l;
			// $respuesta['tipo_calculo'] = $tipo_calculo;
			// $respuesta['cuota_fija'] = $resultado['cuota'];
			// $respuesta['cuota_variable'] = $resultado['cuota'];
			if ($formulario->getData()->getTipo() == 1) {
				$variablesTwig['valor_inmueble'] = $formulario->getData()->getValorInmueble();
				$variablesTwig['importe_fijo'] = $resultado['importe_fijo'];
				$variablesTwig['importe_variable'] = $resultado['importe_variable'];
				$variablesTwig['amortizacion'] = $resultado['amortizacion'];
				$variablesTwig['entrada'] = $resultado['entrada'];
				// $variablesTwig['gastos'] = $resultado['gastos'];
				$variablesTwig['interes_fijo'] = $resultado['con_interes_fijo'];
				$variablesTwig['interes_variable'] = $resultado['con_interes_variable'];
				$variablesTwig['con_entrada_fijo'] = $resultado['con_entrada_fijo'];
				$variablesTwig['con_entrada_variable'] = $resultado['con_entrada_variable'];
				$variablesTwig['tipo_calculo'] = $resultado['tipo_calculo'];
				$variablesTwig['cuota_fija'] = $resultado['cuota_fija'];
				$variablesTwig['cuota_variable'] = $resultado['cuota_variable'];
				$variablesTwig['mensaje'] = $resultado['mensaje'];
				if (array_key_exists('cuota_fija_final',$resultado)) {
					$variablesTwig['cuota_fija_final'] = $resultado['cuota_fija_final'];
				} else {
					$variablesTwig['cuota_fija_final'] = 0;
				}
				if (array_key_exists('cuota_variable_final',$resultado)) {
					$variablesTwig['cuota_variable_final'] = $resultado['cuota_variable_final'];
				} else {
					$variablesTwig['cuota_variable_final'] = 0;
				}
				$variablesTwig['valor_vivienda_actual'] = $formulario->getData()->getValorViviendaActual();
				$variablesTwig['hipoteca_actual'] = $formulario->getData()->getHipotecaActual();
				$variablesTwig['aportacion_tras_venta'] = $formulario->getData()->getAportacionTrasVenta();
			} else {
				if ($resultado['importe_fijo'] > 0) {
					$variablesTwig['valor_inmueble'] = $formulario->getData()->getValorInmueble();
					// $variablesTwig['tipo_calculo'] = $formulario->getData()->getTipo();
					$variablesTwig['importe_fijo'] = $resultado['importe_fijo'];
					// $variablesTwig['importe_variable'] = $resultado['importe_variable'];
					$variablesTwig['amortizacion'] = $resultado['amortizacion'];
					$variablesTwig['entrada'] = $resultado['entrada'];
					$variablesTwig['gastos'] = $resultado['gastos'];
					$variablesTwig['cuota'] = $resultado['cuota'];
					$variablesTwig['mensaje'] = $resultado['mensaje'];
					// $variablesTwig['interes_fijo'] = $resultado['interes_fijo'];
					// $variablesTwig['interes_variable'] = $resultado['interes_variable'];
					$variablesTwig['tipo_calculo'] = $resultado['tipo_calculo'];
					// $variablesTwig['cuota_fija'] = $resultado['cuota_fija'];
					// $variablesTwig['cuota_variable'] = $resultado['cuota_variable'];
				} else {
					$variablesTwig['importe_fijo'] = 0;
					$variablesTwig['mensaje'] = $resultado['mensaje'];
				}
			}
			// $variablesTwig['hipoteca_total_con_interes'] = $resultado['capital_less_initial_amount'] + $resultado['interest_discharged_total'];
			// $variablesTwig['total_con_anticipo'] = $formulario->getData()->getPrecioTotal() + $resultado['interest_discharged_total'];
			$variablesTwig['resultado'] = null;
		}
		return $this->render('@App/Backoffice/Extras/CalculadoraAvanzada.html.twig', $variablesTwig);
	}

	public function expedienteEmailAction(Request $request, RouterInterface $router, Swift_Mailer $mailer, $id)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if (!$expediente) {
			$this->addFlash('warning', 'No se ha encontrado el expediente con id=' . $id . '.');
			return $this->redirectToRoute('lista_expedientes');
		}
		$variablesTwig = array(
			'titulo' => 'Enviar documentos del expediente nº ' . $id . ' por E-Mail',
			'migasPan' => array(
				array(
					'vista' => 'Lista de expedientes',
					'url' => $router->generate('lista_expedientes')
				)
			)
		);
		$fase = $doctrine->getRepository(FaseEntidad::class)->findOneBy(array(
			'tipo' => 0
		));
		$variablesTwig['fase'] = $fase;
		$formulariosCamposHito = array();
		if (!is_null($fase)) {
			$hitos = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase
			), array(
				'orden' => 'ASC'
			));
			$variablesTwig['hitos'] = $hitos;
			foreach ($hitos as $hito) {
				$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
					'idHito' => $hito,
					'idExpediente' => $expediente
				));
				foreach ($hitosExpediente as $hitoExpediente) {
					$gruposCamposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
						'idHito' => $hito
					), array(
						'orden' => 'ASC'
					));
					foreach ($gruposCamposHito as $grupoCamposHito) {
						$formulariosCamposHito[$hitoExpediente->getIdHitoExpediente()][$grupoCamposHito->getIdGrupoCamposHito()] = $this->get('form.factory')->createNamed('', ExpedienteEmailCheckboxes::class, null, array(
							'campos_hito' => $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
								'idGrupoCamposHito' => $grupoCamposHito
							), array(
								'orden' => 'ASC'
							))
						));
						$variablesTwig['formularios_campos_hito'][$hitoExpediente->getIdHitoExpediente()][$grupoCamposHito->getIdGrupoCamposHito()] = $formulariosCamposHito[$hitoExpediente->getIdHitoExpediente()][$grupoCamposHito->getIdGrupoCamposHito()]->createView();
					}
					$variablesTwig['grupos_campos_hito'][$hito->getIdHito()] = $gruposCamposHito;
				}
				$variablesTwig['hitos_expediente'][$hito->getIdHito()] = $hitosExpediente;
			}
		}
		$ficherosCampo = $doctrine->getRepository(FicheroCampoEntidad::class)->findBy(array(
			'idExpediente' => $expediente
		));
		$ficheroCampoArray = array();
		foreach ($ficherosCampo as $ficheroCampo) {
			$ficheroCampoArray[] = $ficheroCampo->getIdCampoHitoExpediente();
		}
		$entidades = array(
			'agentes_colaboradores' => $doctrine->getRepository(AgenteColaboradorEntidad::class)->findAll(),
			'entidades_colaboradoras' => $doctrine->getRepository(EntidadColaboradoraEntidad::class)->findBy(array(
				'estado' => 1
			)),
			'documentos' => $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->in('idCampoHitoExpediente', $ficheroCampoArray))
				->andWhere(Criteria::expr()->neq('valor', null))
			)
		);
		$valoresAnteriores = array();
		$valoresRepetidos = array();
		$documentos = $entidades['documentos']->toArray();
		foreach ($documentos as $documento) {
			if (empty($valoresAnteriores)) {
				$valoresAnteriores[] = $documento->getValor();
			} else {
				if (in_array($documento->getValor(), $valoresAnteriores)) {
					$valoresRepetidos[] = $documento->getValor();
					$documento->setValor($documento->getValor() . ' (' . array_count_values($valoresRepetidos)[$documento->getValor()] . ')');
				} else {
					$valoresAnteriores[] = $documento->getValor();
				}
			}
		}
		$entidades['documentos'] = $documentos;
		$expedienteEmail = new ExpedienteEmailEntidad();
		$formulario = $this->createForm(ExpedienteEmailFormulario::class, $expedienteEmail, $entidades);
		$formulario->handleRequest($request);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			$camposHitoMarcados = $request->get('campoHito');
			$contenido = '';
			if (!is_null($camposHitoMarcados)) {
				$salida = array();
				foreach ($camposHitoMarcados as $campoHitoMarcadoArray) {
					foreach ($campoHitoMarcadoArray as $clave => $valor) {
						$campoHito = $doctrine->getRepository(CampoHitoEntidad::class)->findOneBy(array(
							'idCampoHito' => $valor
						));
						if (!is_null($campoHito) && !is_null($campoHito->getNombre())) {
							$campoHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy(array(
								'idCampoHito' => $campoHito,
								'idHitoExpediente' => $clave,
								'idExpediente' => $expediente
							));
							if (!is_null($campoHitoExpediente)) {
								if (is_null($campoHitoExpediente->getIdOpcionesCampo())) {
									if (!is_null($campoHitoExpediente->getIdAgenteColaborador())) {
										if (is_null($campoHitoExpediente->getIdAgenteColaborador()->getIdEntidadColaboradora())) {
											if (is_null($campoHitoExpediente->getValor())) {
												$valor = null;
											} else {
												$valor = $campoHitoExpediente->getValor();
											}
										} elseif (is_null($campoHitoExpediente->getIdAgenteColaborador()->getIdEntidadColaboradora()->getNombre())) {
											$valor = null;
										} else {
											$valor = $campoHitoExpediente->getIdAgenteColaborador()->getIdEntidadColaboradora()->getNombre();
										}
									}else{
										$valor = $campoHitoExpediente->getValor();
									}
								} elseif (is_null($campoHitoExpediente->getIdOpcionesCampo()->getValor())) {
									$valor = null;
								} else {
									$valor = $campoHitoExpediente->getIdOpcionesCampo()->getValor();
								}
								if (!is_null($valor) && $valor != "") {
									$salida[$clave]['nombre'] = $campoHito->getIdGrupoCamposHito()->getIdHito()->getNombre();
									$salida[$clave]['grupo'] = $campoHito->getIdGrupoCamposHito()->getNombre();
									$salida[$clave][] = array(
										'nombre' => $campoHito->getNombre(),
										'valor' => $valor
									);
								}
							}
						}
					}
				}
				$contador = 2;
				foreach ($salida as $hito) {
					if (!isset($hitoAnterior) || $hitoAnterior !== $hito['nombre']) {
						$contenido .= '<h2 bgcolor="#ef6c00" style="color:#f8f9fa;font-weight:500;line-height:1"><i>' . $hito['nombre'] . '</i></h2>';
						$hitoAnterior = $hito['nombre'];
						$contador = 2;
					} else {
						$contenido .= '<h2 bgcolor="#ef6c00" style="color:#f8f9fa;font-weight:500;line-height:1"><i>' . $hito['nombre'] . ' (' . $contador . ')</i></h2>';
						$contador += 1;
					}
					foreach ($hito as $campoHito) {
						if (is_array($campoHito)) {
							$contenido .= '<div><b>' . $campoHito['nombre'] . '</b>: ' . $campoHito['valor'] . '</div>';
						}
					}
				}
			}
			// $pdf = $this->get('white_october.tcpdf')->create();
			// $pdf->setTitle('Expediente nº ' . $expediente->getIdExpediente());
			// $pdf->setHeaderData($this->get('assets.packages')->getUrl('/custom/logo-negro_gruponegociador.png'), $pdf->getPageWidth() * 2 / 5 - $pdf->getMargins()['left'] - $pdf->getMargins()['right'], '', '', array(0, 0, 0), array(255, 255, 255));
			// $pdf->setHeaderMargin(10);
			// $imagenDimensiones = getimagesize(K_PATH_IMAGES . '/custom/logo-negro_gruponegociador.png');
			// $pdf->setMargins(10, ($pdf->getPageWidth() * 2 / 5 - $pdf->getMargins()['left'] - $pdf->getMargins()['right']) / ($imagenDimensiones[0] / $imagenDimensiones[1]) + 15, 10);
			// $pdf->setFont(null, null, 7.5);
			// $pdf->setCellPadding(1);
			// $pdf->setHtmlVSpace(array(
			// 	'div' => array(
			// 		0 => array(
			// 			'h' => 0,
			// 			'n' => 1
			// 		),
			// 		1 => array(
			// 			'h' => 0,
			// 			'n' => 0
			// 		)
			// 	),
			// 	'h2' => array(
			// 		0 => array(
			// 			'h' => 1,
			// 			'n' => 2
			// 		),
			// 		1 => array(
			// 			'h' => 0,
			// 			'n' => 0
			// 		)
			// 	)
			// ));
			// $pdf->AddPage();
			// $html = $contenido;
			// $pdf->writeHTML($html);




			// NUEVA LIBRERIA
			// $snappy = new Pdf('/usr/local/bin/wkhtmltopdf');
			// $twig;

			// $html=$this->render('@App/Backoffice/InicioSesion.html.twig', array(
			// 	'titulo' => 'Acceder',
			// 	'last_username' => '',
			// 	'error' => ''
			// ));
			// // $pdfContents=$pdf->getOutputFromHtml($html);
	
			// $snappy->generateFromHtml($html,
			// $this->getParameter('files_directory') . DIRECTORY_SEPARATOR . 'documento.pdf');


			// $this->get('knp_snappy.pdf')->generate('https://www.weeduu.es', $this->getParameter('files_directory') . DIRECTORY_SEPARATOR . 'documento.pdf');

			// $pdf->output('expediente_n_' . $expediente->getIdExpediente() . '.pdf');

			// ENVIO COMENTADO
			$mensaje = (new Swift_Message($expedienteEmail->getAsunto()))
				->setFrom($this->getParameter('mailer_user'))
				->setTo($expedienteEmail->getIdAgenteColaborador()->getEmail())
				->setBody($expedienteEmail->getMensaje(), 'text/html');
			foreach ($expedienteEmail->getDocumentos() as $campoHitoExpediente) {
				$documento = $doctrine->getRepository(FicheroCampoEntidad::class)->findOneBy(array(
					'idCampoHito' => $campoHitoExpediente->getIdCampoHito(),
					'idExpediente' => $expediente
				));
				$mensaje->attach(Swift_Attachment::fromPath($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $documento->getNombreFichero()));
			}

			$this->get('knp_snappy.pdf')->generateFromHtml(
				$this->renderView('@App/Backoffice/Informes/InformeEmail.html.twig', array(
					'salida' => $salida
				)),
				// $contenido,
				$this->getParameter('files_directory') . DIRECTORY_SEPARATOR . 'expediente_n_' . $expediente->getIdExpediente() . '.pdf',
				[],
				true
			);

			// return $this->render('@App/Backoffice/Informes/InformeEmail.html.twig', array(
			// 	'salida' => $salida));
			$mensaje->attach(Swift_Attachment::fromPath($this->getParameter('files_directory') . DIRECTORY_SEPARATOR .'expediente_n_' . $expediente->getIdExpediente() . '.pdf'));
			//if (true) {
			if ($mailer->send($mensaje)) {
				$this->addFlash('success', 'El mensaje se ha enviado correctamente.');
				return $this->redirectToRoute('lista_expedientes');
			} else {
				$this->addFlash('warning', 'Error al enviar el mensaje.');
			}
		}
		$variablesTwig['expediente_email'] = $formulario->createView();
		$variablesTwig['cliente'] = $expediente->getIdCliente();
		return $this->render('@App/Backoffice/Extras/ExpedienteEmail.html.twig', $variablesTwig);
	}

	public function obtenerAgentesColaboradoresAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$jsonRecibido = json_decode($request->getContent(), true);
			$respuesta = null;
			if (json_last_error() === 0) {
				$agentesColaboradores = $this->getDoctrine()->getRepository(AgenteColaboradorEntidad::class)->findBy(array(
					'idEntidadColaboradora' => $jsonRecibido['idEntidadColaboradora']
				));
				if ($agentesColaboradores) {
					$agentesColaboradoresArray = array();
					foreach ($agentesColaboradores as $agenteColaborador) {
						$agentesColaboradoresArray[] = array(
							'id' => $agenteColaborador->getIdAgenteColaborador(),
							'nombre' => $agenteColaborador->getNombre(),
							'apellidos' => $agenteColaborador->getApellidos()
						);
					}
					$respuesta = json_encode($agentesColaboradoresArray, JSON_UNESCAPED_UNICODE);
				}
			}
			return $this->json($respuesta);
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	
	public function actualizarSeguimientoExpedienteAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$elementos = json_decode($request->getContent(), true);
			$mensaje = null;
			
			if (json_last_error() === 0 && isset($elementos[0])) {
				$doctrine = $this->getDoctrine();
				$managerEntidad = $doctrine->getManager();
				$repositorio_seguimientos = $doctrine->getRepository(SeguimientoExpedienteEntidad::class);
				$repositorio_expedientes = $doctrine->getRepository(ExpedienteEntidad::class);
				$repositorio_conceptos = $doctrine->getRepository(ConceptoSeguimientoExpedienteEntidad::class);

				foreach( $elementos as $fila){
					$expediente = $repositorio_expedientes->findOneBy(array(
						'idExpediente' => $fila['idExpediente']
					));
					$concepto = $repositorio_conceptos->findOneBy(array(
						'idConceptoSeguimientoExpediente' => $fila['concepto']
					));
					$seguimiento = $repositorio_seguimientos->findOneBy(array(
						'idExpediente' => $expediente,
						'idConceptoSeguimientoExpediente' => $concepto
					));

					if($seguimiento){
						if($fila['fecha']){
							$seguimiento->setFecha(\DateTime::createFromFormat("d/m/Y",trim($fila['fecha'])));
						}
						$seguimiento->setComentario($fila['comentario']);
						$seguimiento->setCliente($fila['cliente']);
						$seguimiento->setColaborador($fila['colaborador']);
						$managerEntidad->persist($seguimiento);
						$managerEntidad->flush();
					}else{
						$seguimiento = new SeguimientoExpedienteEntidad();
						$seguimiento->setIdExpediente($expediente);
						$seguimiento->setIdConceptoSeguimientoExpediente($concepto);
						if($fila['fecha']){
							$seguimiento->setFecha(\DateTime::createFromFormat("d/m/Y",trim($fila['fecha'])));
						}
						$seguimiento->setComentario($fila['comentario']);
						$seguimiento->setCliente($fila['cliente']);
						$seguimiento->setColaborador($fila['colaborador']);
						$managerEntidad->persist($seguimiento);
						$managerEntidad->flush();
					}
				}

				
				return $this->json(array(
					'error' => false
				));
			}else{
				return $this->json(array(
					'error' => true
				));
			}
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function colaboradorAgregarClienteAction(Request $request, RouterInterface $router, Swift_Mailer $mailer)
	{
		$doctrine = $this->getDoctrine();
		$usuario = new UsuarioEntidad();
		$formulario = $this->createForm(CrearCliente::class, $usuario);
		$formulario->handleRequest($request);
		if ($formulario->isSubmitted() && $formulario->isValid()) {
			try {
				$usuario->setTokenActivacion(bin2hex(random_bytes(60)));
			} catch (Exception $e) {
			}
			$usuario->setRole('ROLE_CLIENTE')
				->setIdInmobiliaria($this->getUser()->getIdInmobiliaria())
				->setEstado(false)
				->setTokenFecha(new DateTime());
			$mensaje = (new Swift_Message('Grupo Negociador - Activar cuenta'))
				->setFrom($this->getParameter('mailer_user'))
				->setTo($usuario->getEmail())
				->setBody($this->renderView('@App/Backoffice/Correo/ActivarCuenta.html.twig', array(
					'urlgenerada' => $this->generateUrl('activar_cliente_creado_colaborador', array(
						'token' => $usuario->getTokenActivacion()
					), UrlGeneratorInterface::ABSOLUTE_URL)
				)), 'text/html');
			if ($mailer->send($mensaje)) {
				$managerEntidad = $doctrine->getManager();
				$managerEntidad->persist($usuario);
				$managerEntidad->flush();
				$this->addFlash('success', 'El cliente se ha creado correctamente, se le ha enviado un mensaje por E-Mail para que active su cuenta.');
				return $this->redirectToRoute('lista_clientes');
			} else {
				$this->addFlash('danger', 'Error al enviar el E-Mail al cliente.');
			}
		}
		return $this->render('@App/Backoffice/Agregar/ColaboradorCliente.twig', array(
			'titulo' => 'Crear cliente',
			'migasPan' => array(
				array(
					'vista' => 'Lista de clientes',
					'url' => $router->generate('lista_clientes')
				)
			),
			'crear_cliente' => $formulario->createView()
		));
	}

	public function activarCuentaCreadaColaboradorAction(Request $request, UserPasswordEncoderInterface $passwordEncoder, $token)
	{
		$doctrine = $this->getDoctrine();
		$usuario = $doctrine->getRepository(UsuarioEntidad::class)->findOneBy(array(
			'tokenActivacion' => $token
		));
		if ($usuario) {
			$managerEntidad = $doctrine->getManager();
			if ($usuario->getTokenFecha()->add(new DateInterval('P1D')) > new DateTime()) {
				$formulario = $this->createForm(CompletarDatosCliente::class, $usuario);
				$formulario->handleRequest($request);
				if ($formulario->isSubmitted() && $formulario->isValid()) {
					if ($formulario->getData()->getPoliticaPrivacidad() && $formulario->getData()->getContratoFipre()) {
						$usuario->setPassword($passwordEncoder->encodePassword($usuario, $usuario->getPlainPassword()))
							->setEstado(true)
							->setTokenActivacion(null)
							->setTokenFecha(null);
						$managerEntidad->persist($usuario);
						$managerEntidad->flush();
						$this->addFlash('success', 'Su cuenta se ha activado correctamente.');
						return $this->redirectToRoute('iniciar_sesion');
					} else {
						$this->addFlash('warning', 'No has aceptado las condiciones.');
					}
				}
			} else {
				$managerEntidad->remove($usuario);
				$managerEntidad->flush();
				$this->addFlash('warning', 'El token de activación ha expirado, por favor, solicite a su colaborador que vuelva a crear su cuenta.');
				return $this->redirectToRoute('registrar_cuenta');
			}
		} else {
			$this->addFlash('warning', 'El token no ha sido encontrado.');
			return $this->redirectToRoute('registrar_cuenta');
		}
		return $this->render('@App/Backoffice/Agregar/ColaboradorClienteCompletar.twig', array(
			'titulo' => 'Completar registro',
			'completar_datos_cliente' => $formulario->createView()
		));
	}

	public function estadisticasAction()
	{
		$doctrine = $this->getDoctrine();
		$usuarios = array(
			'clientes' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->orWhere(Criteria::expr()->eq('role', null))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			),
			'colaboradores' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			),
			'comerciales' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			),
			'tecnicos' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			)
		);
		$formulario = $this->createForm(Estadisticas::class, null, $usuarios);
		$serializador = new Serializer(array(
			new ObjectNormalizer()
		), array(
			new JsonEncoder()
		));
		return $this->render('@App/Backoffice/Extras/Estadisticas.html.twig', array(
			'titulo' => 'Estadísticas',
			'formulario' => $formulario->createView(),
			'usuarios' => json_encode($serializador->normalize($usuarios, null), JSON_UNESCAPED_UNICODE),
			'fases' => json_encode($serializador->normalize($doctrine->getRepository(FaseEntidad::class)->findAll(), null), JSON_UNESCAPED_UNICODE),
			'expedientes' => json_encode($serializador->normalize($doctrine->getRepository(ExpedienteEntidad::class)->findAll(), null), JSON_UNESCAPED_UNICODE)
		));
	}

	public function obtenerRegistroExpedienteAction(RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if (!$expediente) {
			$this->addFlash('warning', 'No se ha encontrado el expediente con id=' . $id . '.');
			return $this->redirectToRoute('lista_expedientes');
		}
		$logs = $doctrine->getRepository(LogEntidad::class)->matching(Criteria::create()
			->where(Criteria::expr()->contains('accion', ' expediente.'))
			->andWhere(Criteria::expr()->eq('idElemento', $expediente->getIdExpediente()))
		)->toArray();
		foreach ($logs as $log) {
			$log->setAccion(str_replace(' expediente.', '', $log->getAccion()));
		}
		return $this->render('@App/Backoffice/Extras/RegistroExpediente.html.twig', array(
			'titulo' => 'Registro de movimientos del expediente nº ' . $id . '.',
			'migasPan' => array(
				array(
					'vista' => 'Lista de expedientes',
					'url' => $router->generate('lista_expedientes')
				)
			),
			'logs' => $logs
		));
	}

	public function duplicarExpedienteAction($id)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if ($expediente) {
			$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
				'idExpediente' => $expediente
			));
			$managerEntidad = $doctrine->getManager();
			$copiaExpediente = clone $expediente;
			$managerEntidad->persist($copiaExpediente);
			$managerEntidad->flush();
			foreach ($hitosExpediente as $hitoExpediente) {
				$copiaHitoExpediente = (clone $hitoExpediente)
					->setIdExpediente($copiaExpediente);
				$managerEntidad->persist($copiaHitoExpediente);
				$managerEntidad->flush();
				$camposHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findBy(array(
					'idHitoExpediente' => $hitoExpediente,
					'idExpediente' => $expediente
				));
				foreach ($camposHitoExpediente as $campoHitoExpediente) {
					$copiaCampoHitoExpediente = (clone $campoHitoExpediente)
						->setIdHitoExpediente($copiaHitoExpediente)
						->setIdExpediente($copiaExpediente);
					$managerEntidad->persist($copiaCampoHitoExpediente);
					$managerEntidad->flush();
					$ficherosCampo = $doctrine->getRepository(FicheroCampoEntidad::class)->findBy(array(
						'idCampoHitoExpediente' => $campoHitoExpediente,
						'idExpediente' => $expediente
					));
					foreach ($ficherosCampo as $ficheroCampo) {
						$copiaFicheroCampo = (clone $ficheroCampo)
							->setIdCampoHitoExpediente($copiaCampoHitoExpediente)
							->setIdExpediente($copiaExpediente);
						$managerEntidad->persist($copiaFicheroCampo);
						$managerEntidad->flush();
					}
				}
				$camposHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
					'idHitoExpediente' => $hitoExpediente,
					'idExpediente' => $expediente
				));
				foreach ($camposHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
					$copiaCampoHitoExpedienteColaborador = (clone $campoHitoExpedienteColaborador)
						->setIdHitoExpediente($copiaHitoExpediente)
						->setIdExpediente($copiaExpediente);
					$managerEntidad->persist($copiaCampoHitoExpedienteColaborador);
					$managerEntidad->flush();
				}
			}
			$this->addFlash('success', 'El expediente ha sido copiado correctamente.');
		} else {
			$this->addFlash('warning', 'No se ha encontrado el expediente con id=' . $id . '.');
		}
		return $this->redirectToRoute('lista_expedientes');
	}

	public function informeExpedienteAction($id)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if (!$expediente) {
			$this->addFlash('warning', 'No se ha encontrado el expediente con id=' . $id . '.');
			return $this->redirectToRoute('lista_expedientes');
		}
		$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(), array(
			'orden' => 'ASC'
		));
		$salida = array();
		foreach ($fases as $fase) {
			$salida[$fase->getIdFase()]['nombre'] = $fase->getNombre();
			$hitos[$fase->getIdFase()] = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase
			), array(
				'orden' => 'ASC'
			));
			foreach ($hitos[$fase->getIdFase()] as $hito) {
				$hitosExpediente[$fase->getIdFase()] = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
					'idHito' => $hito,
					'idExpediente' => $expediente
				));
				$camposHito[$hito->getIdHito()] = $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
					'idGrupoCamposHito' => $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
						'idHito' => $hito
					), array(
						'orden' => 'ASC'
					))
				), array(
					'orden' => 'ASC'
				));
				$indiceAnterior = null;
				foreach ($hitosExpediente[$fase->getIdFase()] as $contador => $hitoExpediente) {
					$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()] = array(
						'indice' => $contador,
						'nombre' => $hito->getNombre(),
						// 'grupo' => 'Grupo',
					);
					foreach ($camposHito[$hito->getIdHito()] as $campoHito) {
						// $salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['grupo'] = $campoHito->getIdGrupoCamposHito()->getNombre();
						$campoHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy(array(
							'idCampoHito' => $campoHito,
							'idHitoExpediente' => $hitoExpediente,
							'idExpediente' => $expediente
						));
						if ($campoHitoExpediente) {
							$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()] = array(
								'nombre' => $campoHito->getNombre(),
								'tipo' => $campoHito->getTipo(),
								'grupo' => $campoHito->getIdGrupoCamposHito()->getNombre()
							);
							if ($campoHito->getTipo() === 1 || $campoHito->getTipo() === 5 || $campoHito->getTipo() === 6) {
								if (is_null($campoHitoExpediente->getValor())) {
									unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
								} else {
									$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = $campoHitoExpediente->getValor();
								}
							} elseif ($campoHito->getTipo() === 2 || $campoHito->getTipo() === 3) {
								if (is_null($campoHitoExpediente->getIdOpcionesCampo()) || is_null($campoHitoExpediente->getIdOpcionesCampo()->getValor())) {
									unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
								} else {
									$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = $campoHitoExpediente->getIdOpcionesCampo()->getValor();
								}
							} elseif ($campoHito->getTipo() === 4) {
								if ($campoHitoExpediente->getObligatorio() || $campoHitoExpediente->getSolicitarAlColaborador()) {
									if (($campoHitoExpediente->getParaFirmar() && $campoHitoExpediente->getFirmado()) || !$campoHitoExpediente->getParaFirmar()) {
										$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()] = array_merge($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()], array(
											'obligatorio' => $campoHitoExpediente->getObligatorio(),
											'solicitar_al_colaborador' => $campoHitoExpediente->getSolicitarAlColaborador(),
											'avisar_colaborador' => $campoHitoExpediente->getAvisarColaborador(),
											'para_firmar' => $campoHitoExpediente->getParaFirmar(),
											'firmado' => $campoHitoExpediente->getFirmado(),
										));
										if (!is_null($campoHitoExpediente->getValor())) {
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['nombreFichero'] = $campoHitoExpediente->getValor();
										}
										$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['subido'] = !is_null($doctrine->getRepository(FicheroCampoEntidad::class)->findOneBy(array(
											'idCampoHito' => $campoHito,
											'idCampoHitoExpediente' => $campoHitoExpediente,
											'idExpediente' => $expediente
										)));
										$campoHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
											'idCampoHito' => $campoHito,
											'idHitoExpediente' => $hitoExpediente,
											'idExpediente' => $expediente
										), array(
											'idEntidadColaboradora' => 'ASC',
											'idAgenteColaborador' => 'ASC'
										));
										$entidadColaboradoraAnterior = null;
										foreach ($campoHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['entidadesColaboradoras'][$campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getIdEntidadColaboradora()]['nombre'] = $campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getNombre();
											$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['entidadesColaboradoras'][$campoHitoExpedienteColaborador->getIdEntidadColaboradora()->getIdEntidadColaboradora()]['agentesColaboradores'][$campoHitoExpedienteColaborador->getIdAgenteColaborador()->getIdAgenteColaborador()]['nombre'] = (new UsuariosNombreCompleto())->obtener($campoHitoExpedienteColaborador->getIdAgenteColaborador());
										}
									} else {
										unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
									}
								} else {
									unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
								}
							} elseif ($campoHito->getTipo() === 7 || $campoHito->getTipo() === 8 || $campoHito->getTipo() === 9) {
								if (is_null($campoHitoExpediente->getIdAgenteColaborador())) {
									unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]);
								} else {
									$salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito'][$campoHitoExpediente->getIdCampoHitoExpediente()]['valor'] = $campoHitoExpediente->getIdAgenteColaborador()->getIdEntidadColaboradora()->getNombre() . ' - ' . $campoHitoExpediente->getIdAgenteColaborador()->getNombre() . ' ' . $campoHitoExpediente->getIdAgenteColaborador()->getApellidos();
								}
							} elseif ($campoHito->getTipoo() === 10) {
							} else {
								$this->addFlash('warning', 'El campo hito con id="' . $campoHito->getIdCampoHito() . '" es de un tipo no valido.');
								return $this->redirectToRoute('lista_expedientes');
							}
							if (count($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito']) <= 0) {
								unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]['camposHito']);
							}
						}
					}
					if (count($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]) <= 2) {
						unset($salida[$fase->getIdFase()]['hitos'][$hitoExpediente->getIdHitoExpediente()]);
					}
				}
				if (count($salida[$fase->getIdFase()]['hitos']) <= 0) {
					unset($salida[$fase->getIdFase()]['hitos']);
				}
			}
			if (count($salida[$fase->getIdFase()]) <= 1) {
				unset($salida[$fase->getIdFase()]);
			}
		}

		//  NUEVO INFORME
