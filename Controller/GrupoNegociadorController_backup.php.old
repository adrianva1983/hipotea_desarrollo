	public function ordenarFasesHitosCamposOpcionesAction(Request $request)
	{
		if ($request->isXmlHttpRequest()) {
			$elementos = json_decode($request->getContent(), true);
			$mensaje = null;
			if (json_last_error() === 0 && isset($elementos[0]) && isset($elementos[0]['id'])) {
				$valido = true;
				$numeroElementos = array(
					count($elementos)
				);
				$elemento = array();
				$doctrine = $this->getDoctrine();
				$repositorio = array(
					$doctrine->getRepository(FaseEntidad::class),
					$doctrine->getRepository(HitoEntidad::class),
					$doctrine->getRepository(GrupoCamposHitoEntidad::class),
					$doctrine->getRepository(CampoHitoEntidad::class),
					$doctrine->getRepository(OpcionesCampoEntidad::class)
				);
				$repositorioExpedientes = array(
					$doctrine->getRepository(ExpedienteEntidad::class),
					$doctrine->getRepository(HitoExpedienteEntidad::class),
					$doctrine->getRepository(CampoHitoExpedienteEntidad::class)
				);
				$ids = array(
					'idFase',
					'idHito',
					'idGrupoCamposHito',
					'idCampoHito',
					'idOpcionesCampo'
				);
				$posicion = array();
				$managerEntidad = $doctrine->getManager();
				$elementoHijo = array();
				for ($i = 0; $valido && $i < $numeroElementos[0]; $i += 1) {
					$elemento[0] = $repositorio[0]->findOneBy(array(
						$ids[0] => $elementos[$i]['id']
					));
					if ($elemento[0]) {
						$posicion[0] = $i + 1;
						if ($elemento[0]->getOrden() !== $posicion[0]) {
							$elemento[0]->setOrden($posicion[0]);
							if ($posicion[0] === $numeroElementos[0] && !$elemento[0]->getFinal()) {
								$elemento[0]->setFinal(true);
							} elseif ($elemento[0]->getFinal()) {
								$elemento[0]->setFinal(false);
							}
							$managerEntidad->persist($elemento[0]);
							/*$expedientes = $repositorioExpedientes[0]->findAll();
							$fases = $repositorio[0]->findAll();
							foreach ($expedientes as $expediente) {
								foreach ($fases as $fase) {
									if ($fase->getOrden() < $expediente->getIdFaseActual()->getOrden()) {
										$hitos = $repositorio[1]->findBy(array(
											$ids[0] => $fase
										));
										$numeroHitos = count($hitos);
										if ($numeroHitos > 0) {
											$hitosExpediente = $repositorioExpedientes[1]->findBy(array(
												$ids[1] => $hitos,
												'idExpediente' => $expediente
											));
											if ($numeroHitos !== count($hitosExpediente)) {
												$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida contiene hitos sin asignar a ningún expediente.';
												$valido = false;
												break 2;
											}
											$hitosExpedienteSinCompletar = $repositorioExpedientes[1]->findBy(array(
												$ids[1] => $hitos,
												'idExpediente' => $expediente,
												'estado' => 0
											));
											if (count($hitosExpedienteSinCompletar) > 0) {
												$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida contiene hitos pendientes.';
												$valido = false;
												break 2;
											}
										} else {
											$mensaje = 'No se puede cambiar la fase a esta posición debido a que hay algún expediente en una fase superior y a que la fase movida no contiene ningún hito.';
											$valido = false;
											break 2;
										}
									}
								}
							}*/
						}
						if (isset($elementos[$i]['children'])) {
							$elementoHijo[0] = $elementos[$i]['children'];
							$numeroElementos[1] = count($elementoHijo[0]);
							for ($j = 0; $valido && $j < $numeroElementos[1]; $j += 1) {
								$elemento[1] = $repositorio[1]->findOneBy(array(
									$ids[1] => $elementoHijo[0][$j]['id']
								));
								if ($elemento[1]) {
									if ($elemento[1]->getIdFase() !== $elemento[0]->getIdFase()) {
										/*$hitosExpediente = $repositorioExpedientes[1]->findBy(array(
											$ids[1] => $elemento[1],
											'estado' => 0
										));
										foreach ($hitosExpediente as $hitoExpediente) {
											if ($hitoExpediente && $hitoExpediente->getIdExpediente()->getIdFaseActual()->getOrden() > $elemento[0]->getOrden()) {
												$valido = false;
												$mensaje = 'No se puede cambiar el hito seleccionado a la fase seleccionada debido a que hay algún expediente en una fase superior, y el hito esta pendiente.';
												break;
											}
										}*/
										if ($valido) {
											$elemento[1]->setIdFase($elemento[0]);
											$managerEntidad->persist($elemento[1]);
										}
									}
									if ($valido) {
										$posicion[1] = $j + 1;
										if ($elemento[1]->getOrden() !== $posicion[1]) {
											$elemento[1]->setOrden($posicion[1]);
											$managerEntidad->persist($elemento[1]);
										}
									}
									if (isset($elementoHijo[0][$j]['children'])) {
										$elementoHijo[1] = $elementoHijo[0][$j]['children'];
										$numeroElementos[2] = count($elementoHijo[1]);
										for ($k = 0; $valido && $k < $numeroElementos[2]; $k += 1) {
											$elemento[2] = $repositorio[2]->findOneBy(array(
												$ids[2] => $elementoHijo[1][$k]['id']
											));
											if ($elemento[2]) {
												if ($elemento[2]->getIdHito() !== $elemento[1]->getIdHito()) {
													$elemento[2]->setIdHito($elemento[1]);
													$managerEntidad->persist($elemento[2]);
												}
												$posicion[2] = $k + 1;
												if ($elemento[2]->getOrden() !== $posicion[2]) {
													$elemento[2]->setOrden($posicion[2]);
													$managerEntidad->persist($elemento[2]);
												}
												if (isset($elementoHijo[1][$k]['children'])) {
													$elementoHijo[2] = $elementoHijo[1][$k]['children'];
													$numeroElementos[3] = count($elementoHijo[2]);
													for ($l = 0; $valido && $l < $numeroElementos[3]; $l += 1) {
														$elemento[3] = $repositorio[3]->findOneBy(array(
															$ids[3] => $elementoHijo[2][$l]['id']
														));
														if ($elemento[3]) {
															if ($elemento[3]->getIdGrupoCamposHito() !== $elemento[2]->getIdGrupoCamposHito()) {
																$elemento[3]->setIdGrupoCamposHito($elemento[2]);
																$managerEntidad->persist($elemento[3]);
															}
															$posicion[3] = $l + 1;
															if ($elemento[3]->getOrden() !== $posicion[3]) {
																$elemento[3]->setOrden($posicion[3]);
																$managerEntidad->persist($elemento[3]);
															}
															if (isset($elementoHijo[2][$l]['children'])) {
																$elementoHijo[3] = $elementoHijo[2][$l]['children'];
																$numeroElementos[4] = count($elementoHijo[3]);
																for ($m = 0; $valido && $m < $numeroElementos[4]; $m += 1) {
																	$elemento[4] = $repositorio[4]->findOneBy(array(
																		$ids[4] => $elementoHijo[3][$m]['id']
																	));
																	if ($elemento[4]) {
																		$elementoValorAnterior = $repositorio[3]->findOneBy(array(
																			$ids[3] => $elemento[4]->getIdCampoHito()
																		));
																		if ($elemento[3]->getTipo() !== $elementoValorAnterior->getTipo()) {
																			$valido = false;
																			$mensaje = 'No se puede mover una opcion a un campo de diferente tipo.';
																		} elseif ($elemento[3]->getTipo() === 2 && $numeroElementos[4] > 2) {
																			$valido = false;
																			$mensaje = 'Un campo de tipo verdadero/falso solamente puede contener 2 opciones.';
																		} else {
																			if ($elemento[4]->getIdCampoHito()->getIdCampoHito() !== $elemento[3]->getIdCampoHito()) {
																				if ($elemento[3]->getTipo() === 2 || $elemento[3]->getTipo() === 3) {
																					$campoHitoExpediente = $repositorioExpedientes[3]->findOneBy(array(
																						$ids[4] => $elemento[4]->getIdOpcionesCampo()
																					));
																				}
																				if (isset($campoHitoExpediente) && $campoHitoExpediente) {
																					$valido = false;
																					$mensaje = 'No se puede cambiar la opción de un campo a otro, ya que dicha opción esta seleccionada en algún expediente.';
																				}
																				$elemento[4]->setIdCampoHito($elemento[3]);
																				$managerEntidad->persist($elemento[4]);
																			}
																			$posicion[4] = $m + 1;
																			if ($elemento[4]->getOrden() !== $posicion[4]) {
																				$elemento[4]->setOrden($posicion[4]);
																				$managerEntidad->persist($elemento[4]);
																			}
																		}
																	} else {
																		$valido = false;
																		$mensaje = 'El campo "opciones campo" con id="' . $elementoHijo[3][$m]['id'] . '" no existe.';
																	}
																}
															}
														} else {
															$valido = false;
															$mensaje = 'El grupo de campos hito con id="' . $elementoHijo[2][$l]['id'] . '" no existe.';
														}
													}
												}
											} else {
												$valido = false;
												$mensaje = 'El campo hito con id="' . $elementoHijo[1][$k]['id'] . '" no existe.';
											}
										}
									}
								} else {
									$valido = false;
									$mensaje = 'El hito con id="' . $elementoHijo[0][$j]['id'] . '" no existe.';
								}
							}
						}
					} else {
						$valido = false;
						$mensaje = 'La fase con id="' . $elementos[$i]['id'] . '" no existe.';
					}
				}
				if ($valido) {
					$managerEntidad->flush();
					return $this->json(array(
						'error' => false
					));
				}
			}
			return $this->json(array(
				'error' => true,
				'mensaje' => $mensaje
			));
		} else {
			throw new AccessDeniedHttpException();
		}
	}

	public function listaClientesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$entradasSeleccionadas = $request->get('cliente');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idUsuario' => $entrada
				));
				if ($entidad) {
					$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$documentos = $doctrine->getRepository(DocumentoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$expedientes = $doctrine->getRepository(ExpedienteEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$noticias = $doctrine->getRepository(NoticiaUsuarioEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$notificaciones = $doctrine->getRepository(NotificacionEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$seguimientosHorarios = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					if (count($dispositivos) === 0 && count($documentos) === 0 && count($expedientes) === 0 && count($logs) === 0 && count($noticias) === 0 && count($notificaciones) === 0 && count($seguimientosHorarios) === 0) {
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrado el cliente con id=',
					'Han sido borrados los clientes con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha podido borrar el cliente con id=',
					'No se han podido borrar los clientes con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado el cliente con id=',
					'No se han encontrado los clientes con ids',
					' y '
				)));
			}
		}
		if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
			$clientes = $repositorio->findBy(array(
				'role' => 'ROLE_CLIENTE',
				'idInmobiliaria' => $this->getUser()->getIdInmobiliaria()
			));
		} else {
			$clientes = $repositorio->findBy(array(
				'role' => 'ROLE_CLIENTE'
			));
		}
		return $this->render('@App/Backoffice/Lista/Cliente.html.twig', array(
			'titulo' => 'Lista de clientes',
			'clientes' => $clientes
		));
	}

	public function agregarModificarClienteAction(Request $request, RouterInterface $router, UserPasswordEncoderInterface $passwordEncoder, $id)
	{
		return $this->formularioUsuario(array(
			'id' => $id,
			'cliente' => true,
			'entidad' => UsuarioEntidad::class,
			'idEntidad' => 'idUsuario',
			'elementoNoExiste' => 'El cliente con id="' . $id . '" no existe.',
			'ruta' => 'lista_clientes',
			'formularioAgregar' => UsuarioClienteFormulario::class,
			'formularioModificar' => UsuarioClienteModificarFormulario::class,
			'request' => $request,
			'passwordEncoder' => $passwordEncoder,
			'formularioMensaje' => 'El cliente ha sido añadido/modificado correctamente.',
			'renderizar' => '@App/Backoffice/AgregarModificar/Usuario.html.twig',
			'titulo' => 'Agregar/Modificar cliente',
			'migasPan' => array(
				array(
					'vista' => 'Lista de clientes',
					'url' => $router->generate('lista_clientes')
				)
			),
			'formularioNombre' => 'agregarModificarUsuario'
		));
	}

	public function listaExpedientesAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio['expedientes'] = $doctrine->getRepository(ExpedienteEntidad::class);
		$repositorio['usuarios'] = $doctrine->getRepository(UsuarioEntidad::class);
		if ($this->getUser()->getRoles()[0] !== 'ROLE_CLIENTE') {
			$entradasSeleccionadas = $request->get('expediente');
			if (!is_null($entradasSeleccionadas)) {
				$managerEntidad = $doctrine->getManager();
				$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
				foreach ($entradasSeleccionadas as $entrada) {
					$entidad = $repositorio['expedientes']->find($entrada);
					if ($entidad) {
						if ($this->borrarExpedientes($managerEntidad, $entidad)) {
							$managerEntidad->remove($entidad);
							$elementosBorrados[] = $entrada;
						} else {
							$elementosNoBorrados[] = $entrada;
						}
					} else {
						$elementosNoEncontrados[] = $entrada;
					}
				}
				$managerEntidad->flush();
				if (count($elementosBorrados) > 0) {
					$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
						'Ha sido borrado el expediente con id=',
						'Han sido borrados los expedientes con ids',
						' y '
					)));
				}
				if (count($elementosNoBorrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
						'No se ha podido borrar el expediente con id=',
						'No se han podido borrar los expedientes con ids',
						' y '
					)));
				}
				if (count($elementosNoEncontrados) > 0) {
					$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
						'No se ha encontrado el expediente con id=',
						'No se han encontrado los expedientes con ids',
						' y '
					)));
				}
			}
		}
		switch ($this->getUser()->getRoles()[0]) {
			case 'ROLE_COLABORADOR':
				$expedientes = $repositorio['expedientes']->findBy(array(
					'idColaborador' => $repositorio['usuarios']->matching(Criteria::create()
						->where(Criteria::expr()->eq('idInmobiliaria', $this->getUser()->getIdInmobiliaria()))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)->toArray()
				));
				break;
			case 'ROLE_CLIENTE':
				$expedientes = $repositorio['expedientes']->matching(Criteria::create()
					->where(Criteria::expr()->eq('idCliente', $this->getUser()))
					->andWhere(Criteria::expr()->gt('estado', 0))
				);
				break;
			default:
				$expedientes = $repositorio['expedientes']->findAll();
		}
		$formularioNotificacionExpediente = $this->createForm(NotificacionExpediente::class);
		return $this->render('@App/Backoffice/Lista/Expediente.html.twig', array(
			'titulo' => 'Lista de expedientes',
			'expedientes' => $expedientes,
			'clientes' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_CLIENTE'
			)),
			'colaboradores' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_COLABORADOR'
			)),
			'comerciales' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_COMERCIAL'
			)),
			'tecnicos' => $repositorio['usuarios']->findBy(array(
				'role' => 'ROLE_TECNICO'
			)),
			'formularioNotificacionExpediente' => $formularioNotificacionExpediente->createView()
		));
	}

	public function listaDocumentosExpedienteAction(Request $request, RouterInterface $router, $id, $paraFirmar)
	{
		$doctrine = $this->getDoctrine();
		$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
			'idExpediente' => $id
		));
		if (!$expediente) {
			$this->addFlash('warning', 'El expediente con id="' . $id . '" no existe.');
			return $this->redirectToRoute('lista_expedientes');
		} else {
			$formatosPermitidos = array_merge($this->getParameter('document_formats'), $this->getParameter('image_formats'));
			if (in_array('jpeg', $formatosPermitidos)) {
				array_push($formatosPermitidos, 'jpg');
			}
			$variablesTwig = array(
				'migasPan' => array(
					array(
						'vista' => 'Lista de expedientes',
						'url' => $router->generate('lista_expedientes')
					)
				),
				'max_file_size' => $this->redondearBytesAUnidad($this->convertirABytes(ini_get('upload_max_filesize'))),
				'extensiones_permitidas' => implode(' ', $formatosPermitidos)
			);
			if (is_null($expediente->getIdCliente())) {
				$variablesTwig['titulo'] = 'Lista de documentos del expediente nº' . $id . '.';
			} else {
				$variablesTwig['titulo'] = 'Lista de documentos del expediente nº' . $id . ' del cliente ' . (new UsuariosNombreCompleto())->obtener($expediente->getIdCliente()) . '.';
			}
			$formulariosValidos = true;
			$formulariosCampoHitoExpediente = $formulariosCampoHitoExpedienteColaboradores = $formulariosFicheroCampo = $nombresFichero = $documentos = $gruposCamposHito = array();
			$entidadesColaboradoras = $doctrine->getRepository(EntidadColaboradoraEntidad::class)->findBy(array(
				'estado' => true
			));
			$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(
				'tipo' => 1
			));
			foreach ($fases as $fase) {
				$hitos = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
					'idFase' => $fase
				), array(
					'orden' => 'ASC'
				));
				foreach ($hitos as $hito) {
					$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
						'idHito' => $hito,
						'idExpediente' => $expediente
					));
					$contador = 0;
					foreach ($hitosExpediente as $indice => $hitoExpediente) {
						if (!isset($gruposCamposHito[$hito->getIdHito()])) {
							$gruposCamposHito[$hito->getIdHito()] = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
								'idHito' => $hito
							), array(
								'orden' => 'ASC'
							));
							$variablesTwig['grupos_campos_hito'][$hito->getIdHito()] = $gruposCamposHito[$hito->getIdHito()];
						}
						foreach ($gruposCamposHito[$hito->getIdHito()] as $grupoCamposHito) {
							$camposHito = $doctrine->getRepository(CampoHitoEntidad::class)->findBy(array(
								'idGrupoCamposHito' => $grupoCamposHito
							), array(
								'orden' => 'ASC'
							));
							foreach ($camposHito as $campoHito) {
								if ($campoHito->getTipo() === 4) {
									$campoHitoABuscar = array(
										'idCampoHito' => $campoHito,
										'idHitoExpediente' => $hitoExpediente,
										'idExpediente' => $expediente
									);
									if ($this->getUser()->getRole() === 'ROLE_CLIENTE' || $this->getUser()->getRole() === 'ROLE_COLABORADOR' || $this->getUser()->getRole() === null) {
										if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
											$campoHitoABuscar = array_merge($campoHitoABuscar, array('solicitarAlColaborador' => true));
										} else {
											$campoHitoABuscar = array_merge($campoHitoABuscar, array('obligatorio' => true));
										}
										if (!is_null($paraFirmar) && $paraFirmar === 'ParaFirmar') {
											$campoHitoABuscar = array_merge($campoHitoABuscar, array('paraFirmar' => true));
										} else {
											$campoHitoABuscar = array_merge($campoHitoABuscar, array('paraFirmar' => false));
										}
									}
									$campoHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findOneBy($campoHitoABuscar);
									if ($campoHitoExpediente) {
										$formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()][] = $this->get('form.factory')->createNamed('campo_hito_expediente_' . $campoHito->getIdCampoHito() . '_' . $indice, CampoHitoExpedienteFicheroFormulario::class, $campoHitoExpediente);
										if ($request->isMethod('POST')) {
											if (!end($formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()])->isSubmitted()) {
												end($formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()])->submit($request->request->get(end($formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()])->getName()));
												if (!end($formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()])->isValid() && $formulariosValidos) {
													$formulariosValidos = false;
												}
											}
										}
										$variablesTwig['agregar_modificar_campo_hito_expediente'][$campoHito->getIdCampoHito()][] = end($formulariosCampoHitoExpediente[$campoHito->getIdCampoHito()])->createView();
										$campoHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
											'idCampoHito' => $campoHito,
											'idHitoExpediente' => $hitoExpediente,
											'idExpediente' => $expediente
										));
										$entidadesColaboradorasSeleccionadas = $agentesColaboradoresSeleccionados = array();
										if (count($campoHitoExpedienteColaboradores) === 0) {
											$campoHitoExpedienteColaboradores[0] = (new CampoHitoExpedienteColaboradoresEntidad())
												->setIdCampoHito($campoHito)
												->setIdHitoExpediente($hitoExpediente)
												->setIdExpediente($expediente);
										} else {
											foreach ($campoHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
												$entidadesColaboradorasSeleccionadas[] = $campoHitoExpedienteColaborador->getIdEntidadColaboradora();
												$agentesColaboradoresSeleccionados[] = $campoHitoExpedienteColaborador->getIdAgenteColaborador();
											}
										}
										$formulariosCampoHitoExpedienteColaboradores[$campoHito->getIdCampoHito()][] = $this->get('form.factory')->createNamed('campo_hito_expediente_colaboradores_' . $campoHito->getIdCampoHito() . '_' . $indice, CampoHitoExpedienteColaboradoresFormulario::class, $campoHitoExpedienteColaboradores[0], array(
											'entidades_colaboradoras' => $entidadesColaboradoras,
											'entidades_colaboradoras_seleccionadas' => $entidadesColaboradorasSeleccionadas,
											'agentes_colaboradores_seleccionados' => $agentesColaboradoresSeleccionados
										));
										if ($request->isMethod('POST')) {
											end($formulariosCampoHitoExpedienteColaboradores[$campoHito->getIdCampoHito()])->handleRequest($request);
											if (!end($formulariosCampoHitoExpedienteColaboradores[$campoHito->getIdCampoHito()])->isValid() && $formulariosValidos) {
												$formulariosValidos = false;
											}
										}
										$variablesTwig['agregar_modificar_campo_hito_expediente_colaboradores'][$campoHito->getIdCampoHito()][] = end($formulariosCampoHitoExpedienteColaboradores[$campoHito->getIdCampoHito()])->createView();
										$ficheroCampo = $doctrine->getRepository(FicheroCampoEntidad::class)->findOneBy(array(
											'idCampoHito' => $campoHito->getIdCampoHito(),
											'idCampoHitoExpediente' => $campoHitoExpediente,
											'idExpediente' => $expediente
										));
										if ($ficheroCampo) {
											$rutaFichero = $this->getParameter('files_directory') . '/' . $ficheroCampo->getNombreFichero();
											$rutaFichero = str_replace($this->get('kernel')->getProjectDir() . '/web', '', $rutaFichero);
											$variablesTwig['fichero_subido'][$campoHito->getIdCampoHito()][$contador] = $rutaFichero;
											$nombresFichero[] = $campoHitoExpediente->getValor();
											$variablesTwig['fichero_subido_ruta'][$campoHito->getIdCampoHito()][$contador] = $router->generate('descargar_fichero_expediente', array(
												'id' => $ficheroCampo->getIdFicheroCampo()
											));
										} else {
											$ficheroCampo = (new FicheroCampoEntidad())
												->setIdCampoHito($campoHito)
												->setIdCampoHitoExpediente($campoHitoExpediente)
												->setIdExpediente($expediente);
											$nombresFichero[] = null;
										}
										$contador += 1;
										$formulariosFicheroCampo[$campoHito->getIdCampoHito()][] = $this->get('form.factory')->createNamed('fichero_campo_' . $campoHito->getIdCampoHito() . '_' . $indice, FicheroCampoFormulario::class, $ficheroCampo);
										if ($request->isMethod('POST')) {
											end($formulariosFicheroCampo[$campoHito->getIdCampoHito()])->handleRequest($request);
											if (!end($formulariosFicheroCampo[$campoHito->getIdCampoHito()])->isValid()) {
												$formulariosValidos = false;
											}
										}
										$variablesTwig['agregar_modificar_fichero_campo'][$campoHito->getIdCampoHito()][] = end($formulariosFicheroCampo[$campoHito->getIdCampoHito()])->createView();
										if ($campoHitoExpediente->getParaFirmar()) {
											$variablesTwig['extensiones_permitidas_col_cl'][] = 'pdf';
										} else {
											if (!isset($formatosPermitidos)) {
												$formatosPermitidos = array_merge($this->getParameter('document_formats'), $this->getParameter('image_formats'));
												if (in_array('jpeg', $formatosPermitidos)) {
													array_push($formatosPermitidos, 'jpg');
												}
											}
											$variablesTwig['extensiones_permitidas_col_cl'][] = implode(' ', $formatosPermitidos);
										}
										$documentos[$campoHito->getIdCampoHito()][] = $campoHitoExpediente;
									}
								}
							}
						}
					}
				}
			}
			if (count($documentos) > 0) {
				$variablesTwig['documentos'] = $documentos;
			}
			if (count($nombresFichero) > 0) {
				$variablesTwig['nombres_fichero'] = json_encode($nombresFichero, JSON_UNESCAPED_UNICODE);
			}
			if ($request->isMethod('POST') && $formulariosValidos) {
				$managerEntidad = $doctrine->getManager();
				$existeRegistroActividadConEntidadFaseDatos = false;
				foreach ($formulariosCampoHitoExpediente as $formularioCampoHitoExpedienteArray) {
					foreach ($formularioCampoHitoExpedienteArray as $formularioCampoHitoExpediente) {
						$campoHitoExpediente = $formularioCampoHitoExpediente->getData();
						if (!$this->comprobarSiLasEntidadesSonIguales($managerEntidad, $campoHitoExpediente)) {
							$campoHitoExpediente->setFechaModificacion(new DateTime());
							$managerEntidad->persist($campoHitoExpediente);
							if ($campoHitoExpediente->getIdCampoHito()->getIdGrupoCamposHito()->getIdHito()->getIdFase()->getTipo() === 0) {
								if (!$existeRegistroActividadConEntidadFaseDatos) {
									$existeRegistroActividadConEntidadFaseDatos = true;
									$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Entrada del expediente', $expediente));
								}
							} else {
								$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Modificación del campo hito "' . $campoHitoExpediente->getIdCampoHito() . '"', $expediente));
							}
						}
					}
				}
				foreach ($formulariosCampoHitoExpedienteColaboradores as $formularioCampoHitoExpedienteColaboradoresArray) {
					foreach ($formularioCampoHitoExpedienteColaboradoresArray as $indice => $formularioCampoHitoExpedienteColaboradores) {
						$campoHitoExpedienteColaboradoresDatos = $formularioCampoHitoExpedienteColaboradores->getData();
						$campoHitoExpedienteColaboradoresEntrada = $request->get('campo_hito_expediente_colaboradores_' . $campoHitoExpedienteColaboradoresDatos->getIdCampoHito()->getIdCampoHito() . '_' . $indice);
						$campoHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
							'idCampoHito' => $campoHitoExpedienteColaboradoresDatos->getIdCampoHito(),
							'idHitoExpediente' => $campoHitoExpedienteColaboradoresDatos->getIdHitoExpediente(),
							'idExpediente' => $expediente
						));
						$numeroCampoHitoExpedienteColaboradores = count($campoHitoExpedienteColaboradores);
						$camposHitoExpedienteColaboradoresModificados = false;
						if (isset($campoHitoExpedienteColaboradoresEntrada['idAgenteColaborador'])) {
							$numeroCampoHitoExpedienteColaboradoresEntrada = count($campoHitoExpedienteColaboradoresEntrada['idAgenteColaborador']);
							if ($numeroCampoHitoExpedienteColaboradoresEntrada > 0) {
								if ($numeroCampoHitoExpedienteColaboradoresEntrada !== $numeroCampoHitoExpedienteColaboradores) {
									if ($numeroCampoHitoExpedienteColaboradoresEntrada > $numeroCampoHitoExpedienteColaboradores) {
										for ($i = $numeroCampoHitoExpedienteColaboradores; $i < $numeroCampoHitoExpedienteColaboradoresEntrada; $i += 1) {
											$campoHitoExpedienteColaboradores[$i] = new CampoHitoExpedienteColaboradoresEntidad();
										}
									} elseif ($numeroCampoHitoExpedienteColaboradoresEntrada < $numeroCampoHitoExpedienteColaboradores) {
										$diferencia = $numeroCampoHitoExpedienteColaboradores - $numeroCampoHitoExpedienteColaboradoresEntrada;
										for ($i = 0; $i < $diferencia; $i += 1) {
											$managerEntidad->remove(end($campoHitoExpedienteColaboradores));
											$numeroCampoHitoExpedienteColaboradores -= 1;
											unset($campoHitoExpedienteColaboradores[$numeroCampoHitoExpedienteColaboradores]);
											if (!$camposHitoExpedienteColaboradoresModificados) {
												$camposHitoExpedienteColaboradoresModificados = true;
											}
										}
									}
								}
								foreach ($campoHitoExpedienteColaboradoresEntrada['idAgenteColaborador'] as $indice2 => $idAgenteColaborador) {
									$agenteColaborador = $doctrine->getRepository(AgenteColaboradorEntidad::class)->findOneBy(array(
										'idAgenteColaborador' => $idAgenteColaborador
									));
									if (!is_null($agenteColaborador)) {
										$campoHitoExpedienteColaboradores[$indice2]->setIdCampoHito($campoHitoExpedienteColaboradoresDatos->getIdCampoHito())
											->setIdHitoExpediente($campoHitoExpedienteColaboradoresDatos->getIdHitoExpediente())
											->setIdExpediente($campoHitoExpedienteColaboradoresDatos->getIdExpediente())
											->setIdEntidadColaboradora($agenteColaborador->getIdEntidadColaboradora())
											->setIdAgenteColaborador($agenteColaborador);
									}
								}
								foreach ($campoHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
									if (!$this->comprobarSiLasEntidadesSonIguales($managerEntidad, $campoHitoExpedienteColaborador)) {
										$managerEntidad->persist($campoHitoExpedienteColaborador);
										if (!$camposHitoExpedienteColaboradoresModificados) {
											$camposHitoExpedienteColaboradoresModificados = true;
										}
									}
								}
							}
						} elseif ($numeroCampoHitoExpedienteColaboradores > 0) {
							foreach ($campoHitoExpedienteColaboradores as $campoHitoExpedienteColaborador) {
								$managerEntidad->remove($campoHitoExpedienteColaborador);
							}
							$camposHitoExpedienteColaboradoresModificados = true;
						}
						if ($camposHitoExpedienteColaboradoresModificados) {
							$managerEntidad->flush();
							if ($campoHitoExpedienteColaboradoresDatos->getIdCampoHito()->getIdGrupoCamposHito()->getIdHito()->getIdFase()->getTipo() === 0) {
								if (!$existeRegistroActividadConEntidadFaseDatos) {
									$existeRegistroActividadConEntidadFaseDatos = true;
									$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Entrada del expediente', $expediente));
								}
							} else {
								$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Modificación de los agentes colaboradores seleccionados del campo hito ' . $campoHitoExpedienteColaboradoresDatos->getIdCampoHito(), $expediente));
							}
						}
					}
				}
				$camposHitoExpediente = $doctrine->getRepository(CampoHitoExpedienteEntidad::class)->findBy(array(
					'idExpediente' => $expediente,
					'avisarColaborador' => true
				));
				foreach ($camposHitoExpediente as $campoHitoExpediente) {
					$campoHitoExpedienteColaboradores = $doctrine->getRepository(CampoHitoExpedienteColaboradoresEntidad::class)->findBy(array(
						'idCampoHito' => $campoHitoExpediente->getIdCampoHito(),
						'idHitoExpediente' => $campoHitoExpediente->getIdHitoExpediente(),
						'idExpediente' => $expediente
					));
					if (count($campoHitoExpedienteColaboradores) === 0) {
						$campoHitoExpediente->setAvisarColaborador(false);
						$managerEntidad->persist($campoHitoExpediente);
					}
				}
				foreach ($formulariosFicheroCampo as $formularioFicheroCampoArray) {
					foreach ($formularioFicheroCampoArray as $formularioFicheroCampo) {
						$ficheroCampo = $formularioFicheroCampo->getData();
						$campoHito = $ficheroCampo->getIdCampoHito();
						$campoHitoExpediente = $ficheroCampo->getIdCampoHitoExpediente();
						if (!is_null($ficheroCampo->getFichero())) {
							if ($ficheroCampo->getFichero()->guessExtension() === 'pdf') {
								if ($this->buscarCadenaEnFichero($ficheroCampo->getFichero(), 'adbe.pkcs7.detached')) {
									$campoHitoExpediente->setFirmado(true);
								} else {
									$campoHitoExpediente->setFirmado(false);
								}
							} else {
								if ($campoHitoExpediente->getParaFirmar()) {
									$this->addFlash('warning', 'Has marcado el ' . $campoHito . ' para firmar y has subido un archivo que no es un pdf.');
									return $this->render('@App/Backoffice/Lista/DocumentosExpediente.html.twig', $variablesTwig);
								} elseif ($campoHitoExpediente->getFirmado()) {
									$campoHitoExpediente->setFirmado(false);
								}
							}
							if (!is_null($ficheroCampo->getNombreFichero())) {
								$filesystem = new Filesystem();
								try {
									$filesystem->remove($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $ficheroCampo->getNombreFichero());
								} catch (IOExceptionInterface $e) {
									$this->addFlash('error', 'Error al borrar el archivo antiguo.');
									return $this->render('@App/Backoffice/Lista/DocumentosExpediente.html.twig', $variablesTwig);
								}
							}
							$nombreFichero = md5(uniqid()) . '.' . $ficheroCampo->getFichero()->guessExtension();
							try {
								$ficheroCampo->getFichero()->move($this->getParameter('files_directory'), $nombreFichero);
							} catch (FileException $e) {
								$this->addFlash('error', 'Error al guardar el archivo en el servidor.');
								return $this->render('@App/Backoffice/Lista/DocumentosExpediente.html.twig', $variablesTwig);
							}
							$ficheroCampo->setNombreFichero($nombreFichero);
							$managerEntidad->persist($ficheroCampo);
							if ($campoHito->getIdGrupoCamposHito()->getIdHito()->getIdFase()->getTipo() === 0) {
								if (!$existeRegistroActividadConEntidadFaseDatos) {
									$existeRegistroActividadConEntidadFaseDatos = true;
									$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Entrada del expediente', $expediente));
								}
							} else {
								$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Subido fichero al campo hito "' . $campoHito . '".', $expediente));
							}
							if (!is_null($expediente->getIdCliente()) && !is_null($expediente->getIdColaborador()) && (!is_null($campoHitoExpediente->getEnviarAlCliente() || !is_null($campoHitoExpediente->getEnviarAlColaborador())))) {
								$enviarNotificacion = false;
								$notificacion = (new NotificacionEntidad())
									->setIdExpediente($expediente)
									->setFecha(new DateTime());
								if ($this->getUser()->getRoles()[0] === 'ROLE_CLIENTE' OR $this->getUser()->getRoles()[0] === '') {
									if ($campoHitoExpediente->getEnviarAlColaborador()) {
										$enviarNotificacion = true;
										$notificacion->setIdUsuario($expediente->getIdColaborador())
											->setTexto('El cliente ' . (new UsuariosNombreCompleto())->obtener($expediente->getIdCliente()) . ' acaba de subir un documento al campo hito "' . $campoHito . '" del hito "' . $campoHito->getIdGrupoCamposHito()->getIdHito() . '" del expediente nº ' . $expediente->getIdExpediente() . '.');
									}
								} elseif ($campoHitoExpediente->getEnviarAlCliente()) {
									$enviarNotificacion = true;
									$notificacion->setIdUsuario($expediente->getIdCliente())
										->setTexto('El colaborador ' . (new UsuariosNombreCompleto())->obtener($expediente->getIdColaborador()) . ' acaba de subir un documento al campo hito "' . $campoHito . '" del hito "' . $campoHito->getIdGrupoCamposHito()->getIdHito() . '" del expediente nº ' . $expediente->getIdExpediente() . '.');
								}
								if ($enviarNotificacion) {
									$managerEntidad->persist($notificacion);
									if ($campoHito->getIdGrupoCamposHito()->getIdHito()->getIdFase()->getTipo() === 0) {
										if (!$existeRegistroActividadConEntidadFaseDatos) {
											$existeRegistroActividadConEntidadFaseDatos = true;
											$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Entrada del expediente', $expediente));
										}
									} else {
										$this->get('event_dispatcher')->dispatch('log.registrarActividadConEntidad', new RegistrarActividad($this->getUser(), 'Se ha enviado una notificacion a ' . (new UsuariosNombreCompleto())->obtener($expediente->getIdCliente()), $expediente));
									}
								}
							}
						} elseif (isset($managerEntidad->getUnitOfWork()->getOriginalEntityData($campoHitoExpediente)['paraFirmar']) && !$managerEntidad->getUnitOfWork()->getOriginalEntityData($campoHitoExpediente)['paraFirmar'] && $campoHitoExpediente->getParaFirmar() && !is_null($ficheroCampo->getNombreFichero())) {
							$archivo = new File($this->getParameter('files_directory') . DIRECTORY_SEPARATOR . $ficheroCampo->getNombreFichero());
							if ($archivo->guessExtension() !== 'pdf') {
								$this->addFlash('warning', 'Has marcado el ' . $campoHito . ' para firmar y el archivo ya subido no es un pdf.');
								return $this->render('@App/Backoffice/Lista/DocumentosExpediente.html.twig', $variablesTwig);
							}
						}
					}
				}
				$managerEntidad->flush();
				$this->addFlash('success', 'El expediente ha sido modificado correctamente.');
				return $this->redirectToRoute('lista_expedientes');
			}
			return $this->render('@App/Backoffice/Lista/DocumentosExpediente.html.twig', $variablesTwig);
		}
	}

	public function agregarModificarExpedienteAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		$managerEntidad = $doctrine->getManager();
		if (isset($id)) {
			$expediente = $doctrine->getRepository(ExpedienteEntidad::class)->findOneBy(array(
				'idExpediente' => $id
			));
			if (!$expediente) {
				$this->addFlash('warning', 'El expediente con id="' . $id . '" no existe.');
				return $this->redirectToRoute('lista_expedientes');
			}
		} else {
			$primeraFase = $doctrine->getRepository(FaseEntidad::class)->findOneBy(array(
				'orden' => 1
			));
			if ($primeraFase) {
				$expediente = (new ExpedienteEntidad())
					->setIdFaseActual($primeraFase);
			} else {
				$this->addFlash('warning', 'No hay fases.');
				return $this->redirectToRoute('lista_expedientes');
			}
		}
		switch ($this->getUser()->getRoles()[0]) {
			case 'ROLE_ADMIN':
				$formularioExpedienteOpciones = array(
					'esAdmin' => true,
					'colaboradores' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COLABORADOR'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'comerciales' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_COMERCIAL'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					),
					'tecnicos' => $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
						->where(Criteria::expr()->eq('role', 'ROLE_TECNICO'))
						->andWhere(Criteria::expr()->orX(
							Criteria::expr()->gte('fechaCaducidad', new DateTime()),
							Criteria::expr()->isNull('fechaCaducidad')
						))
						->andWhere(Criteria::expr()->eq('estado', true))
					)
				);
				break;
			case 'ROLE_COLABORADOR':
				$expediente->setIdColaborador($this->getUser());
				$formularioExpedienteOpciones['idClienteRequerido'] = true;
				break;
			case 'ROLE_COMERCIAL':
				$expediente->setIdComercial($this->getUser());
				break;
			case 'ROLE_TECNICO':
				$expediente->setIdTecnico($this->getUser());
				break;
			default:
				$this->addFlash('warning', 'Usuario con rol no válido.');
				return $this->redirectToRoute('lista_expedientes');
		}
		if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
			$formularioExpedienteOpciones['clientes'] = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->eq('idInmobiliaria', $this->getUser()->getIdInmobiliaria()))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			);
		} else {
			$formularioExpedienteOpciones['clientes'] = $doctrine->getRepository(UsuarioEntidad::class)->matching(Criteria::create()
				->where(Criteria::expr()->eq('role', 'ROLE_CLIENTE'))
				->andWhere(Criteria::expr()->orX(
					Criteria::expr()->gte('fechaCaducidad', new DateTime()),
					Criteria::expr()->isNull('fechaCaducidad')
				))
				->andWhere(Criteria::expr()->eq('estado', true))
			);
		}
		$formularioExpedienteOpciones['nuevo'] = !isset($id);
		$formulariosValidos = true;
		$fases = $doctrine->getRepository(FaseEntidad::class)->findBy(array(), array(
			'orden' => 'ASC'
		));
		$formularioExpedienteOpciones['fases'] = $fases;
		$formularioExpediente = $this->createForm(ExpedienteFormulario::class, $expediente, $formularioExpedienteOpciones);
		$formularioExpediente->handleRequest($request);

		$arraySeguimientosFase = array();
		$arrayFases = array();

		$fasesSeguimientos = $doctrine->getRepository(ConceptoSeguimientoExpedienteEntidad::class)->findBy(array(),
			array(
				'orden' => 'ASC'
			));
		$fase_actual = "";
		foreach($fasesSeguimientos as $fase){
			if($fase->getFase() != $fase_actual){
				$arrayFases[]= $fase->getFase();
			}
			$fase_actual = $fase->getFase();
		}
		foreach($arrayFases as $fase){
			$arrayFormularioSeguimientoExpediente = array();
			$conceptosFase = $doctrine->getRepository(ConceptoSeguimientoExpedienteEntidad::class)->findBy(array(
				'fase' => $fase
			));
			$seguimientos = $doctrine->getRepository(SeguimientoExpedienteEntidad::class)->findBy(array(
				'idExpediente' => $expediente,
				'idConceptoSeguimientoExpediente' => $conceptosFase
			));
			
			
			if($expediente->getIdExpediente() > 0 && count($seguimientos)==0){
				$conceptos = $doctrine->getRepository(ConceptoSeguimientoExpedienteEntidad::class)->findBy(array(
					'idConceptoSeguimientoExpediente' => $conceptosFase
				),
				array(
					'orden' => 'ASC'
				));
				
				foreach($conceptos as $concepto){
					$seguimiento = (new SeguimientoExpedienteEntidad())
						->setIdExpediente($expediente)
						->setIdConceptoSeguimientoExpediente($concepto);
					$managerEntidad->persist($seguimiento);
					$managerEntidad->flush();
					$formularioSeguimientoExpediente = $this->createForm(FormularioSeguimientoExpediente::class, $seguimiento);
					$arrayFormularioSeguimientoExpediente[] = $formularioSeguimientoExpediente->createView();
				}
				
			}else{
				foreach ($seguimientos as $seguimiento){
					$formularioSeguimientoExpediente = $this->createForm(FormularioSeguimientoExpediente::class, $seguimiento);
					$arrayFormularioSeguimientoExpediente[] = $formularioSeguimientoExpediente->createView();		
				}
			}
			$arraySeguimientosFase[$fase] = $arrayFormularioSeguimientoExpediente;
		}
		

		if ($formularioExpediente->isSubmitted() && !$formularioExpediente->isValid()) {
			$formulariosValidos = false;
		}
		$faseActual = $expediente->getIdFaseActual();
		$variablesTwig = array(
			'titulo' => 'Agregar/modificar expediente',
			'migasPan' => array(
				array(
					'vista' => 'Lista de expedientes',
					'url' => $router->generate('lista_expedientes')
				)
			),
			'agregarModificarExpediente' => $formularioExpediente->createView(),
			'arraySeguimientosFase' => $arraySeguimientosFase,
			'idExpediente' => $id,
			'fases' => $fases,
			'faseActual' => $faseActual
		);
		if (isset($id) && $expediente->getVivienda()) {
			$variablesTwig['titulo'] = $expediente->getVivienda();
		}
		$formulariosHitoExpediente = $formulariosCampoHitoExpediente = $formulariosCampoHitoExpedienteColaboradores = $formulariosFicheroCampo = $formulariosHitoExpedienteModelo = $formulariosCampoHitoExpedienteModelo = $formulariosCampoHitoExpedienteColaboradoresModelo = $formulariosFicheroCampoModelo = $nombresFichero = $gruposCamposHito = $gruposHitoExpediente= $camposHito = $hitosExpedienteABorrar = $gruposHitosExpediente = array();
		$numeroHitosExpedienteDuplicadosArray = $request->get('numero-hitos-expediente-duplicados');
		// echo "Hitos Duplicados: <br>";
		// dump($numeroHitosExpedienteDuplicadosArray);
		$numeroGruposHitoExpedienteDuplicadosArray = $request->get('numero-grupos-hito-expediente-duplicados');
		$entidadesColaboradoras = $doctrine->getRepository(EntidadColaboradoraEntidad::class)->findBy(array(
			'estado' => true
		), array(
			'nombre' => 'ASC'
		));
		foreach ($fases as $fase) {
			$hitos[$fase->getIdFase()] = $doctrine->getRepository(HitoEntidad::class)->findBy(array(
				'idFase' => $fase
			), array(
				'orden' => 'ASC'
			));
			$variablesTwig['hitos'] = $hitos;
			foreach ($hitos[$fase->getIdFase()] as $hito) {
				$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
					'idHito' => $hito,
					'idExpediente' => $expediente
				));
				// if($hito->getIdHito() == 30){
				// 	dump($hitosExpediente);
				// 	die();
				// }
				$numeroHitosExpediente = count($hitosExpediente);
				if ($numeroHitosExpediente === 0) {
					$hitosExpediente[0] = (new HitoExpedienteEntidad())
						->setIdHito($hito)
						->setIdExpediente($expediente)
						->setFechaModificacion(new DateTime())
						->setEstado(0);
					if (isset($numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()])) {
						for ($i = 0; $i < $numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()]; $i += 1) {
							$hitosExpediente[] = (new HitoExpedienteEntidad())
								->setIdHito($hito)
								->setIdExpediente($expediente)
								->setFechaModificacion(new DateTime())
								->setEstado(0);
						}
					}
					foreach ($hitosExpediente as $hitoExpediente){
						$gruposHitoExpediente = $doctrine->getRepository(GrupoHitoExpedienteEntidad::class)->findBy(array(
							'idHitoExpediente' => $hitoExpediente
						));
						$numeroGruposHitoExpediente = count($gruposHitoExpediente);
						if ($numeroGruposHitoExpediente === 0) {
							$gruposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
								'idHito' => $hito
							));
							foreach ($gruposHito as $grupoHito){
								$gruposHitoExpediente[0] = (new GrupoHitoExpedienteEntidad())
									->setIdHitoExpediente($hitoExpediente)
									->setIdGrupoCamposHito($grupoHito);
								if (isset($numeroGruposHitoExpedienteDuplicadosArray[$hito->getIdHito()][$grupoHito->getIdGrupoCamposHito()])) {
									for ($i = 0; $i < $numeroGruposHitoExpedienteDuplicadosArray[$hito->getIdHito()][$grupoHito->getIdGrupoCamposHito()]; $i += 1) {
										$gruposHitoExpediente[] = (new GrupoHitoExpedienteEntidad())
											->setIdHitoExpediente($hitoExpediente)
											->setIdGrupoCamposHito($grupoHito);
									}
								}
							}
						}
					}
				} else {
					$numeroHitosExpedienteDuplicados = $numeroHitosExpediente - 1;
					// $numeroHitosExpedienteDuplicados = 0;

					$variablesTwig['numero_hitos_expediente_duplicados'][$hito->getIdHito()] = $numeroHitosExpedienteDuplicados;
					// if($hito->getIdHito() == 30){
					// 	if(isset($numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()])){
					// 		dump($numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()]);
					// 	}else{
					// 		echo "NO";
					// 	}
					// 	die();
					// }
					if (isset($numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()])) {
						if ($numeroHitosExpedienteDuplicados < $numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()]) { // Hay nuevos hitos que crear
							$diferencia = $numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()] - $numeroHitosExpedienteDuplicados;
							// echo "Diferencia: ".$diferencia."<br>";
							
							for ($i = 0; $i < $diferencia; $i += 1) {
								$hitoExpediente = (new HitoExpedienteEntidad())
									->setIdHito($hito)
									->setIdExpediente($expediente)
									->setFechaModificacion(new DateTime())
									->setEstado(0);
								$managerEntidad->persist($hitoExpediente);
								$hitosExpediente[] = $hitoExpediente;
									// dump($hitosExpediente);
									// die();
								$gruposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
									'idHito' => $hito
								));
								foreach ($gruposHito as $grupoHito){
									$grupoHitoExpediente = (new GrupoHitoExpedienteEntidad())
										->setIdHitoExpediente($hitoExpediente)
										->setIdGrupoCamposHito($grupoHito);
									$managerEntidad->persist($grupoHitoExpediente);
									$gruposHitoExpediente[] = $grupoHitoExpediente;
									if (isset($numeroGruposHitoExpedienteDuplicadosArray[$hito->getIdHito()][$grupoHito->getIdGrupoCamposHito()])) {
										for ($i = 0; $i < $numeroGruposHitoExpedienteDuplicadosArray[$hito->getIdHito()][$grupoHito->getIdGrupoCamposHito()]; $i += 1) {
											$grupoHitoExpediente = (new GrupoHitoExpedienteEntidad())
												->setIdHitoExpediente($hitoExpediente)
												->setIdGrupoCamposHito($grupoHito);
											$managerEntidad->persist($grupoHitoExpediente);
											$gruposHitoExpediente[] = $grupoHitoExpediente;
										}
									}
								}
								// dump($gruposHitoExpediente);
								// 	die();
								foreach ($gruposHito as $grupoHito){
									
									
									$numeroGruposHitoExpedienteDuplicados = $numeroGruposHitoExpediente - 1;
									$variablesTwig['numero_grupos_hitos_expediente_duplicados'][$grupoHito->getIdGrupoCamposHito()] = $numeroGruposHitoExpedienteDuplicados;
								}
							}
							// dump($gruposHitoExpediente);
							// die();
							// for ($i = 0; $i < count($gruposHitoExpediente); $i += 1) {
							// 	$managerEntidad->persist($gruposHitoExpediente[$i]);
							// }
							// for ($i = 0; $i < count($hitosExpediente); $i += 1) {
							// 	$managerEntidad->persist($hitosExpediente[$i]);
							// }
						} elseif ($numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()] < $numeroHitosExpedienteDuplicados) { // Hay que borrar hitos
							$diferencia = $numeroHitosExpedienteDuplicados - $numeroHitosExpedienteDuplicadosArray[$hito->getIdHito()];
							for ($i = 0; $i < $diferencia; $i += 1) {
								$hitosExpedienteABorrar[] = $hitosExpediente[count($hitosExpediente) - 1];
								unset($hitosExpediente[count($hitosExpediente) - 1]);
							}
						}else{
							// No hay mas ni menos hitos, entonces para los que habia revisamos los grupos por si ha cambiado el numero
							$hitosExpediente = $doctrine->getRepository(HitoExpedienteEntidad::class)->findBy(array(
								'idHito' => $hito,
								'idExpediente' => $expediente
							));
							$gruposHito = $doctrine->getRepository(GrupoCamposHitoEntidad::class)->findBy(array(
								'idHito' => $hito
							));
							foreach ($hitosExpediente as $hitoExpediente){
								foreach ($gruposHito as $grupoHito){
									$gruposHitoExpediente = $doctrine->getRepository(GrupoHitoExpedienteEntidad::class)->findBy(array(
										'idHitoExpediente' => $hitoExpediente,
										'idGrupoCamposHito' => $grupoHito
									));
									$numeroGruposHitoExpediente = count($gruposHitoExpediente);
									$numeroGruposHitoExpedienteDuplicados = $numeroGruposHitoExpediente - 1;
									$variablesTwig['numero_grupos_hito_expediente_duplicados'][$hitoExpediente->getIdHitoExpediente()][$grupoHito->getIdGrupoCamposHito()] = $numeroGruposHitoExpedienteDuplicados;
								}
							}
						}
					} elseif ($request->isMethod('POST') && $numeroHitosExpedienteDuplicados > 0) {
						for ($i = 0; $i < $numeroHitosExpedienteDuplicados; $i += 1) {
							$hitosExpedienteABorrar[] = $hitosExpediente[count($hitosExpediente) - 1];
							unset($hitosExpediente[count($hitosExpediente) - 1]);
						}
