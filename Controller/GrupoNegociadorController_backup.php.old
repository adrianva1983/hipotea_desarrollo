			'formularioModificar' => FaseModificarFormulario::class,
			'formulario' => FaseFormulario::class,
			'formularioOpciones' => array(
				'fases_array',
				'numero_fases'
			),
			'request' => $request,
			'mensajeCorrecto' => 'La fase ha sido añadida/modificada correctamente',
			'renderizarPlantilla' => '@App/Backoffice/AgregarModificar/Fase.html.twig',
			'tituloPagina' => 'Agregar/Modificar fase',
			'migasPan' => array(
				array(
					'vista' => 'Lista de fases, hitos, campos y opciones',
					'url' => $router->generate('lista_fases_hitos_campos_opciones')
				)
			),
			'formularioNombre' => 'agregarModificarFase'
		));
	}

