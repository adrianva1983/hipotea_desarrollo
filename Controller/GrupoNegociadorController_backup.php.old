	}

	private
	function crearMensajeBorrarFasesHitosCamposOpciones($clave, $valor, $parametros)
	{
		switch ($clave) {
			case 0:
				$this->addFlash($parametros['tipo'], $this->crearMensaje($valor, array(
					$parametros['opcion'],
					$parametros['opciones'],
					' y '
				)));
				break;
			case 1:
				$this->addFlash($parametros['tipo'], $this->crearMensaje($valor, array(
					$parametros['campo'],
					$parametros['campos'],
					' y '
				)));
				break;
			case 2:
				$this->addFlash($parametros['tipo'], $this->crearMensaje($valor, array(
					$parametros['grupo'],
					$parametros['grupos'],
					' y '
				)));
				break;
			case 3:
				$this->addFlash($parametros['tipo'], $this->crearMensaje($valor, array(
					$parametros['hito'],
					$parametros['hitos'],
					' y '
				)));
				break;
			case 4:
				$this->addFlash($parametros['tipo'], $this->crearMensaje($valor, array(
					$parametros['fase'],
					$parametros['fases'],
					' y '
				)));
				break;
		}
	}

	private
	function crearMensaje($elementos, $cadenas)
	{
		$mensaje = null;
		$longitud = count($elementos);
		if ($longitud > 0) {
			if ($longitud === 1) {
				$mensaje = $cadenas[0] . '"' . $elementos[0] . '"';
			} else {
				$mensaje = $cadenas[1];
				for ($i = 0; $i < $longitud; $i += 1) {
					if ($i === 0) {
						$mensaje .= ' "' . $elementos[$i] . '"';
					} elseif ($i < ($longitud - 1)) {
						$mensaje .= ', "' . $elementos[$i] . '"';
					} else {
						$mensaje .= $cadenas[2] . '"' . $elementos[$i] . '"';
					}
				}
			}
		}
		return $mensaje;
	}

	private
	function convertirABytes($size)
	{
		if (is_numeric($size)) {
			$valor = $size;
		} else {
			$unidad = substr($size, -1);
			$valor = substr($size, 0, -1);
			switch (strtoupper($unidad)) {
				case 'Y':
					$valor *= 1208925819614629174706176;
					break;
				case 'Z':
					$valor *= 1180591620717411303424;
					break;
				case 'E':
					$valor *= 1152921504606846976;
					break;
				case 'P':
					$valor *= 1125899906842624;
					break;
				case 'T':
					$valor *= 1099511627776;
					break;
				case 'G':
					$valor *= 1073741824;
					break;
				case 'M':
					$valor *= 1048576;
					break;
				case 'K':
					$valor *= 1024;
					break;
				default:
					$valor = null;
			}
		}
		return $valor;
	}

	private
	function redondearBytesAUnidad($size)
	{
		if (is_numeric($size)) {
			$valor = $size;
			$unidades = array(
				'K',
				'M',
				'G',
				'T',
				'P',
				'E',
				'Z',
				'Y'
			);
			$numUnidades = count($unidades);
			for ($i = 0; $valor % 1024 === 0 && $i < $numUnidades; $i += 1) {
				$valor /= 1024;
			}
			if ($i === 0) {
				return $valor / 1024 . $unidades[$i];
			} else {
				return $valor . $unidades[$i - 1];
			}
		}
		return null;
	}

	private
	function buscarCadenaEnFichero($fichero, $cadena)
	{
		$ficheroAbierto = fopen($fichero, 'r');
		$valido = false;
		while (($bufer = fgets($ficheroAbierto)) !== false) {
			if (strpos($bufer, $cadena) !== false) {
				$valido = true;
				break;
			}
		}
		fclose($ficheroAbierto);
		return $valido;
	}

	private
	function comprobarSiLasEntidadesSonIguales($managerEntidad, $entidadModificada)
	{
		$entidadOriginalArray = $managerEntidad->getUnitOfWork()->getOriginalEntityData($entidadModificada);
		$entidadModificadaArray = $this->convertirObjetoAArrayAsociativo($entidadModificada);
		if (count($entidadOriginalArray) > 0) {
			$iguales = true;
			foreach ($entidadModificadaArray as $clave => $valor) {
				if ($entidadModificadaArray[$clave] !== $entidadOriginalArray[$clave]) {
					$iguales = false;
					break;
				}
			}
		} else {
			$iguales = null;
		}
		return $iguales;
	}

	private
	function convertirObjetoAArrayAsociativo($objeto)
	{
		$array = array();
		try {
			$reflectionClass = new ReflectionClass(get_class($objeto));
			foreach ($reflectionClass->getProperties() as $propiedad) {
				$propiedad->setAccessible(true);
				$array[$propiedad->getName()] = $propiedad->getValue($objeto);
				$propiedad->setAccessible(false);
			}
		} catch (ReflectionException $e) {
		}
		return $array;
	}

	public function listaUsuariosInmobiliariaAction(Request $request)
	{
		$doctrine = $this->getDoctrine();
		$repositorio = $doctrine->getRepository(UsuarioEntidad::class);
		$entradasSeleccionadas = $request->get('cliente');
		if (!is_null($entradasSeleccionadas)) {
			$managerEntidad = $doctrine->getManager();
			$elementosBorrados = $elementosNoBorrados = $elementosNoEncontrados = array();
			foreach ($entradasSeleccionadas as $entrada) {
				$entidad = $repositorio->findOneBy(array(
					'idUsuario' => $entrada
				));
				if ($entidad) {
					$dispositivos = $doctrine->getRepository(DispositivoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$documentos = $doctrine->getRepository(DocumentoEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$expedientes = $doctrine->getRepository(ExpedienteEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					$logs = $doctrine->getRepository(LogEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$noticias = $doctrine->getRepository(NoticiaUsuarioEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$notificaciones = $doctrine->getRepository(NotificacionEntidad::class)->findBy(array(
						'idUsuario' => $entidad
					));
					$seguimientosHorarios = $doctrine->getRepository(SeguimientoHorarioEntidad::class)->findBy(array(
						'idCliente' => $entidad
					));
					if (count($dispositivos) === 0 && count($documentos) === 0 && count($expedientes) === 0 && count($logs) === 0 && count($noticias) === 0 && count($notificaciones) === 0 && count($seguimientosHorarios) === 0) {
						$managerEntidad->remove($entidad);
						$elementosBorrados[] = $entrada;
					} else {
						$elementosNoBorrados[] = $entrada;
					}
				} else {
					$elementosNoEncontrados[] = $entrada;
				}
			}
			$managerEntidad->flush();
			if (count($elementosBorrados) > 0) {
				$this->addFlash('success', $this->crearMensaje($elementosBorrados, array(
					'Ha sido borrado el usuario de inmobiliaria con id=',
					'Han sido borrados los usuarios de inmobiliaria con ids',
					' y '
				)));
			}
			if (count($elementosNoBorrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoBorrados, array(
					'No se ha podido borrar el usuario de inmobiliaria con id=',
					'No se han podido borrar los usuarios de inmobiliaria con ids',
					' y '
				)));
			}
			if (count($elementosNoEncontrados) > 0) {
				$this->addFlash('warning', $this->crearMensaje($elementosNoEncontrados, array(
					'No se ha encontrado el usuario de inmobiliaria con id=',
					'No se han encontrado los usuarios de inmobiliaria con ids',
					' y '
				)));
			}
		}
		
		$usuarios = $repositorio->findBy(array(
			'role' => 'ROLE_COLABORADOR'
		));
		
		return $this->render('@App/Backoffice/Lista/UsuariosInmobiliaria.html.twig', array(
			'titulo' => 'Lista de Usuarios de Inmobiliaria',
			'usuarios' => $usuarios
		));
	}

	
	public function seguimientoExpedienteAction(Request $request, RouterInterface $router, $id)
	{
		$doctrine = $this->getDoctrine();
		$repositorio_expedientes = $doctrine->getRepository(ExpedienteEntidad::class);
		$repositorio_seguimientos = $doctrine->getRepository(SeguimientoExpedienteEntidad::class);
		
		if ($this->getUser()->getRole() === 'ROLE_CLIENTE') {
			$expediente = $repositorio_expedientes->findOneBy(array(
				'idExpediente' => $id,
				'idCliente' => $this->getUser()
			));
		}else if ($this->getUser()->getRole() === 'ROLE_COLABORADOR') {
			$expediente = $repositorio_expedientes->findOneBy(array(
				'idExpediente' => $id,
				'idColaborador' => $this->getUser()
			));
		}

		$arrayFases = array();

		$fasesSeguimientos = $doctrine->getRepository(ConceptoSeguimientoExpedienteEntidad::class)->findBy(array(),
			array(
				'orden' => 'ASC'
			));
		$fase_actual = "";
		foreach($fasesSeguimientos as $fase){
			if($fase->getFase() != $fase_actual){
				$arrayFases[]= $fase->getFase();
			}
			$fase_actual = $fase->getFase();
		}

		$seguimientos = $repositorio_seguimientos->findBy(array(
			'idExpediente' => $expediente
		));
		
		if (count($seguimientos) === 0) {
			$this->addFlash('warning', 'No hay Datos de seguimiento para el expediente.');
			return $this->redirectToRoute('lista_expedientes');
		}
		return $this->render('@App/Backoffice/Extras/SeguimientoExpediente.html.twig', array(
			'titulo' => 'Seguimiento '.$expediente->getVivienda(),
			'seguimientos' => $seguimientos,
			'fases' => $arrayFases
		));
	}
}
